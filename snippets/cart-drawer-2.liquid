        }

        .cart-ab-2 .progress-bar {
            width: 0%;
            height: 10px;
            display: block;
            background: #E9B88B;
            border-radius: 15px;
            transition: all 1s ease;
        }

        .cart-ab-2 .cart-price-slider {
            margin: -0px -15px 0 -15px;
            padding: 6px 15px 10px 15px;
          background:#F0E8D3;
        }
    .cart-ab-2 .min-cart-body{
      background:#F6F1E5;
    }
        .cart-ab-2 .cart-price-slider.gradient-bg {
            /* background-image: linear-gradient(to top, #EAE6FF, #F2F5FF) !important; */
            background-color: #F0E8D3;
        }

        .cart-ab-2 .cart-top-bar {
            margin: 0px -15px 0px -15px;
            font-size: 15px;
            padding: 12px !important;
        }

        .cart-ab-2 .cart-product-details input.qty {
            border-left: 1px solid #ccc;
            border-right: 1px solid #ccc;
        }

        .cart-ab-2 .cart-products-wrapper .cart-product {
            background: #F6F1E5;
            margin-left: -15px;
            margin-right: -15px;
        }
      .cart-ab-2 .cart-products-wrapper .cart-product .p-price h3{
        font-size:14px;
        color:#212121;
        font-weight:bold;
      }
  .cart-ab-2 .cart-products-wrapper .cart-product .p-price h3 del{
     font-size:12px;
        color:#212121;
        font-weight:400;
  }
      .cart-ab-2 .min-cart-wrapper{
        height: 100%;
        overflow-x: hidden;
        display: flex;
        flex-direction: column;
        -webkit-box-pack: justify;
        justify-content: space-between;
        -webkit-box-align: center;
        align-items: center;
      }
      .cart-ab-2 .min-cart-header{
        width:100%;
      }
      .cart-ab-2 .min-cart-footer{
        position:relative;
        padding-bottom:20px;
        width:100%;
      }
      .cart-ab-2 .min-cart-body{
        width: 100%;
        height: 100%;
        -webkit-box-flex: 1;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        -webkit-box-pack: justify;
        overflow-x: hidden;
        padding-top:70px !important;
      }
      .cart-price-slider{
        position: fixed;
      top: 53px;
      z-index: 1;
      right: 0;
      right: 15px;
      width: 400px;
      max-width: 100%;
      }
      .min-cart-footer .checkout-btn{
        width:370px;
      }
      @media (max-width:560px) {
        .cart-ab-2 .min-cart-footer{
        position:relative;
        padding-bottom:20px;
      }
