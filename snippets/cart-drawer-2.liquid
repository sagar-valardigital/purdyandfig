        background:#212121;
      }
      .cart-ab-2 .qty-wrapper .qty{
        color:#212121;
        font-weight:400;
      }
        .cart-ab-2 .empty-cart-block .product-img img {
            max-width: 100%
        }

       .cart-ab-2 .empty-cart-wrapper {
            display: flex;
            align-items: center
        }

        .cart-ab-2 .empty-cart-wrapper .empty-cart-products {
            width: 100%;
        }

        .cart-ab-2 .free-limit-check {
            text-align: center;
        }

        .cart-ab-2 .free-limit-check span {
            display: inline-block;
            width: 22px;
        }

        .cart-ab-2 .free-limit-check span svg {
            width: 100%;
            fill: #ccc;
        }

        .cart-ab-2 .free-limit-check.checked span svg {
