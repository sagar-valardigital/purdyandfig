        .pf-min-cart.cart-2 .min-cart-header:not(.cart-header-2),
        .pf-min-cart:not(.cart-2) .min-cart-footer.cart-footer-2,
        .pf-min-cart:not(.cart-2) .min-cart-header.cart-header-2,
        .pf-min-cart:not(.cart-2) .cart-top-bar {
            display: none;
        }

        .cart-ab-2 .empty-cart-block .min-cart-body {
            height: calc(100vh - 230px);
        }
    .cart-ab-2 .qty-wrapper{
      border-radius:0;
      border:1px solid #ccc;
    }
      .cart-ab-2 .min-cart-body{
        height:calc(100vh - 171px);
      }
      @media(max-width:768px){
        .cart-ab-2 .min-cart-body{
        height:calc(100vh - 184px);
      }
      }
      .cart-ab-2 .qty-wrapper .qty-minus,.cart-ab-2 .qty-wrapper .qty-plus,.cart-ab-2 .qty-wrapper{
        height:32px;
      }
     .cart-ab-2 .qty-wrapper .qty{
