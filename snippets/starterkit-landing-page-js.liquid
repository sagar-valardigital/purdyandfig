<script type="text/javascript">

document.addEventListener('DOMContentLoaded', function() {
  var buyNowButtons = document.querySelectorAll('.checkout-starterkit-btn');

  buyNowButtons.forEach(function(buyNowButton, index) {
    buyNowButton.addEventListener('click', function() {
    // Add 'loading' class or any other indication that the process has started
    buyNowButton.classList.add('loading');

    // Initialize an array to hold the items to add to the cart
    var items = [];

    var section_id = buyNowButton.dataset.sectionId;

    // Get the main product details from the button dataset
    var mainProduct = {
      id: parseInt(buyNowButton.dataset.productId),
      quantity: parseInt(buyNowButton.dataset.quantity),
      selling_plan: parseInt(buyNowButton.dataset.sellingPlan)
    };
      var mainProductTwo = {
      id: parseInt(buyNowButton.dataset.productTwoId),
      quantity: parseInt(buyNowButton.dataset.quantity),
      selling_plan: parseInt(buyNowButton.dataset.sellingPlanTwo)
    };

    // Add the main product to the items array
    items.push(mainProduct,mainProductTwo);

    // Find all checkboxes with the class 'upsell_checkbox'
    var upsellCheckboxes = document.querySelectorAll('#'+section_id+' '+'.upsell_checkbox');

    // Loop through the checkboxes and add checked items to the items array
    upsellCheckboxes.forEach(function(checkbox) {
      if (checkbox.checked) {
        items.push({
          id: parseInt(checkbox.dataset.productId),
          quantity: parseInt(checkbox.dataset.quantity)
        });
      }
    });

    // Prepare the data object with the items array
    var data = { items: items };

    // Make the call to Shopify's add.js with the data object
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
      // Handle success
      console.log('Items added to cart:', data);
      // Remove the 'loading' class
      buyNowButton.classList.remove('loading');
      // Redirect to the checkout page
      var discountCode = 'FREESPA5';
      var checkoutURL = '/discount/'+encodeURIComponent(discountCode)+'?redirect=%2Fcheckout';
      window.location.href = checkoutURL;
     
    })
    .catch((error) => {
      // Handle errors here
      console.error('Error adding items to cart:', error);
      // Remove the 'loading' class
      buyNowButton.classList.remove('loading');
    });
  });
  })
});  

</script>