{% assign product = all_products[pHandle] %}
{% assign variant = product.selected_or_first_available_variant %}
{% liquid
  if product.selected_selling_plan
    assign selected_selling_plan = product.selected_selling_plan
  else
    assign selected_selling_plan = variant.selling_plan_allocations.first.selling_plan
  endif
%}
{% if product.available %}
  <div class="upsell-product-wrapper upsell-2">
    <div class="upsell-product">
      <div class="upsell-product-section">
        <div class="up-product-img">
          <img class="w-100" src="{{all_products[pHandle].featured_image | product_img_url}}" alt="">
        </div>

        <div class="up-add-cart-option">
          <div class="up-top">
            <div class="up-title">
              {{ settings['cart--upsell-product'].title }}
              <h4 class="theme-text font-lausanne fw-600">{{ all_products[pHandle].title }}</h4>
              {% if all_products[pHandle].variants.first.metafields.metadata.includes %}
                <p class="theme-text font-lausanne d-none fw-200 mb-1">
                  Include: {{ all_products[pHandle].variants.first.metafields.metadata.includes }}
                </p>
              {% endif %}

              <div class="up-price">
                {% if variant.selling_plan_allocations.first.selling_plan %}
                  <span class="upsell-price theme-text font-lausanne fw-400" style="font-size:12px;">
                    {{- variant.selling_plan_allocations[0].price_adjustments[0].price | money -}}
                  </span>
                   <span style="font-size:12px; padding-left: 5px;">
                    <small><del class="font-lausanne">{{- variant.selling_plan_allocations[0].compare_at_price | money -}}</del></small>
                   </span>
                {% else %}
                  <span class="upsell-price theme-text font-lausanne fw-400" style="font-size:12px;">{{ variant.price | money }}</span>
                  <span style="font-size:12px; padding-left: 5px;">
                     <small><del class="font-lausanne">{{ variant.compare_at_price | money }}</del></small>
                   </span>
                {% endif %}
              </div>
            </div>

            <form
              @submit.prevent="console.log('submitted')"
              x-ref="product_form_{{ product.id }}"
              enctype="multipart/form-data"
              accept-charset="UTF-8"
              id="product_form_{{product.id}}"
              class="shopify-product-form"
              data-product-id="{{product.id}}"
              action="/cart/add"
            >
              <input
                type="hidden"
                name="id"
                value="{{ variant.id }}"
                data-plan-id="{{variant.selling_plan_allocations.first.selling_plan.id}}"
                data-include="{{variant.metafields.metadata.includes}}"
                data-subprice="{{ sub_discount_price | money }}"
                data-price="{{variant.price |  money}}"
              >
              <input type="hidden" name="selling_plan" value="{{selected_selling_plan.id}}">
              <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
              {% if product.available %}
                <button
                  class="btn green-btn theme-btn btn-loader"
                  
                  x-on:click="Purdy.AddToCart($refs.product_form_{{ product.id }}, false, '{{ product.title | replace:'"',''}}', $event)"
                >
                  Add
                </button>
              {% else %}
                <button class="btn theme-btn green-btn disabled" >
                  Out of Stock
                </button>
              {% endif %}
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <style>
      .upsell-2 .upsell-product{
        padding:5px;
        background:#fff;
        margin-bottom:5px;
      }
      .upsell-product-wrapper{margin:10px 0;}
    .upsell-2  .upsell-product{background:#FCFAF6;border-radius:1px;box-shadow:none;}
      .upsell-2 .up-title p{font-size:12px;}
      .upsell-2 .up-top{display:grid; flex-wrap:wrap; justify-content:space-between; grid-template-columns:calc(100% - 80px) 70px; height:100%; }
    .upsell-2  .up-top .up-title{width:calc(100% - 5px);}
      .upsell-2 .up-top .up-title h4{font-size:14px; font-weight:600;}
      .upsell-2 .up-top .up-price{width:55px;display:flex;justify-content:space-between;}
      .upsell-2 .up-top .up-price .remove-product{position:static;}
      .upsell-2 .upsell-product-section{display:flex;justify-content:space-between;flex-wrap:wrap;}
      .upsell-2 .upsell-product-section .up-product-img{width:95px;}
      .upsell-2 .upsell-product-section .up-add-cart-option{width:calc(100% - 100px);}
      .upsell-2 .upsell-product-section .up-add-cart-option label{padding:8px;border:1px solid #555;border-radius:4px;margin-bottom:10px;width:100%;display:block;}
      .upsell-2 .upsell-product-section .up-add-cart-option button.btn{font-size:13px;}
      .upsell-2 .upsell-product-section .btn{padding:10px;margin-top:0px;}
      .upsell-2 .okendo-cart-review .okeReviews[data-oke-container].oke-sr .oke-sr-count{
        font-size:14px;
      }
    .upsell-2 .up-top form{
      align-self:center;
    }
  </style>
{% endif %}
