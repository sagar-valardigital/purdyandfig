    margin-right:-15px;
    width:calc(100% + 30px)
  }
  
  .christmas-cart .cart-product-details {padding-right:0;
  }
</style>

{% assign current_total = cart.total_price | money_without_currency %}
{% assign free_shipping_total = settings.free_shipping_amount | minus: current_total %}
{% assign free_product_total = settings.free_product_amount | minus: current_total %}
{% assign free_shipping_progress = current_total | divided_by: settings.free_shipping_amount | times: 100 %}
{% assign free_shipping_progress = free_shipping_progress | divided_by: 1 %}
{% assign free_product_progress = current_total | divided_by: settings.free_product_amount | times: 100 %}

{% if free_shipping_progress > 100 %}
  {% assign free_shipping_progress = 100 %}
{% endif %}



<div
  data-cart-init="{{ free_shipping_progress }}"
  class="pf-min-cart cart-ab-2 open cart-2 {% if template.suffix == "pf-225-christmas" %}christmas-cart{% endif %}" 
  x-ref="cart_content"
  x-data="
    {
       showCartDrawer: false,
       loading: false,
       toggleCartShow() {
         if (this.showCartDrawer) {
           document.body.classList.add('cart-show');
         } else {
           document.body.classList.remove('cart-show');
         }
       },
       updateCart(){
           // send fetch reqeust to update cart
           fetch(window.Shopify.routes.root+'?view=cart-7')
           .then(response => response.text())
           .then(cartData => {
               $refs.cart_content.innerHTML = cartData;

               // This code is use to parse json object. for cart count
               var el = document.createElement('div');
               el.innerHTML = cartData;
               //var cartCount = JSON.parse(el.querySelector('[data-options]').innerHTML).item_count;
               $dispatch('cart-count-updated', cartData);
               this.loading = false;

           })
       },
       async removeBundle(boxIndex) {
        fetch('/cart.js')
        .then((response) => response.json())
        .then(async (response) => {
          let updates = {};
    
          for(const item of response.items) {
            if(item.properties.hasOwnProperty('_dynamicBoxIndex') && item.properties['_dynamicBoxIndex'] == boxIndex) {
              updates[item.key] = 0;
            }
          }
    
          fetch('/cart/update.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              updates,
            })
          })
          .then((response) => response.json())
          .then((data) => {
            Purdy.CartCountUpdate();
            window.dispatchEvent(new Event('cart-updated'));
          })
          .catch((error) => {
            console.error('Error:', error);
          });
        })
      }
    }
  "
  x-show="showCartDrawer"
  @cart-updated.window="updateCart;"
  @toggle-cart.window="showCartDrawer = !showCartDrawer;toggleCartShow()"
  x-cloak
>
  <span class="cart-overlay" x-on:click="showCartDrawer = false;  $dispatch('cart-close'); toggleCartShow();"></span>

  <div class="min-cart-wrapper position-relative">
    <div class="min-cart-header cart-header-2">
      <div class="d-flex align-items-center position-relative">
        <div class="cart-heading">
          <h2 class="heading-3-5  m-0 text-center font-lausanne fw-400">Cart</h2>
        </div>
        <div class="cart-arrow" x-on:click="showCartDrawer = false; $dispatch('cart-close');  toggleCartShow();">
                  <img
                    width="16px"
                    height="16px"
                    src="{{'close-line-icon.svg' | asset_url}}"
                    alt=""
                  >  
        </div>
      </div>
    </div>
    <div class="min-cart-body pt-0">
      {% if settings.cartAnnouncementShow %}
        <div class="p-2 theme-text text-center font-lausanne fw-200 cart-top-bar">
          <small>
            {{- settings.cartAnnouncement }}
            <a
              href="{{ settings.cartAnnouncementLink }}"
              class="theme-text font-lausanne fw-400"
              ><u>Shop Now</u></a
            ></small
          >
        </div>
      {% endif %}

      <div
        class="cart-price-slider theme-text  {% if free_shipping_total > 0 %} {% else %} gradient-bg {% endif %}"
      >
        {% if cart.items == 0 %}
          <div class="d-flex justify-content-center">
            <div
              class="free-delivery-limit free-limit-check  {% if free_shipping_total <= 0 %} checked {%  endif %}"
            >
              <b class="font-lausanne fw-400">Free Shipping</b>
            </div>
          </div>
        {% endif %}
        {% if free_shipping_total > 0 %}
          <p style="font-size:16px;text-align:center;margin-top:10px;margin-bottom:8px;">
            <b class="font-lausanne fw-400">Add {{ free_shipping_total | times: 100 | money }} to unlock free shipping!</b>
          </p>
          <div class="free-limit-progress-bar">
            <span
              class="progress-bar"
              style="width:{{ free_shipping_progress }}%"
            ></span>
          </div>

        {% else %}
          <p style="font-size:16px;text-align:center;margin-top:10px;margin-bottom:8px;">
            <b class="font-lausanne fw-400">{{ settings.freeShippingOption }} </b>
          </p>
          <div class="free-limit-progress-bar"><span class="progress-bar" style="width:100%"></span></div>
        {% endif %}
      </div>

      <div class="cart-products-wrapper">
        
        {% if cart.item_count == 0 %}
          <div class="py-2 mt-3">
            <h2 class="m-0 heading-3 text-center theme-text font-lausanne fw-400" style="color:#161718; font-size:14px;">
              Your cart is empty
            </h2>
            <p class="theme-text text-center font-lausanne fw-200 mt-1" style="color:#161718; font-size:12px;">Add your favourite items to your cart</p>
          </div>
          <div class="mt-1 empty-cart-wrapper">
            <div class="empty-cart-products">
              {%- for product in settings.upsellcollChristmas.products -%}
                {% if product.available %}
                  {% render 'christmas-cart-product-variant',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    lazy_load: lazy_load
                  %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% for item in cart.items %}
          <div class="cart-product">
            <div>
            <div class="d-flex flex-wrap">
              {% if item.image %}
                <div class="cart-product-image">
                  {{
                    item.image
                    | image_url: width: 400
                    | image_tag: loading: 'lazy', class: 'img-responsive
                            w-100'
                  }}
                </div>
              {% endif %}

              <div class="cart-product-details font-lausanne fw-400 theme-text">
                <div class="">
                  <h4 class="p-category m-0 font-lausanne fw-600">
                    {% if item.product.metafields.custom.bundle_breakdown %}
                      {% assign excluded_handles = "orange-clove-refill-pack,frankincense-myrrh-counter-clean-refill-copy,mini-black-friday-bundle-copy,bathroom-bliss-bundle-kit" | split: "," %}
                      {% if excluded_handles contains item.product.handle %}
                        {% assign is_excluded = true %}
                      {% else %}
                        {% assign is_excluded = false %}
                      {% endif %}
                      
                      {% unless is_excluded %}
                        <span class="bundle_product-qty">{{ item.quantity }}</span> x
                      {% endunless %}
                    {% endif %}
                      {{ item.product.title }}</h4>
                  {% if item.product.variants.size > 1 %}
                  <h4 class="cart-v-title normal-text font-lausanne fw-200 mt-1 mb-0">{{ item.variant.title }}</h4>
                  {% endif %}
                  {% if item.product.type != blank %}
                  <h3 class="p-title font-lausanne fw-400 my-1">{{ item.product.type }}</h3>
                  {% endif %}
                </div>
                <small class="subscription-details">
                  {{ item.selling_plan_allocation.selling_plan.name }}
                </small>

              {% assign isBoxItem = false %}
              {% assign boxIndex = nil %}
               {% for property in item.properties %}
                  {% if property.first contains '_dynamicBoxIndex' %}
                    {% assign isBoxItem = true %}
                    {% assign boxIndex = property.last | plus: 0 %}
                  {% endif %}

                  {% unless property.first contains '_' %}
                    <div class="line-item-property" >
                      <small class="property-name">{{ property.first }}:</small>
                      <small class="property-value">{{ property.last }}</small>
                    </div>
                  {% endunless %}
                {% endfor %}
                
                
                <div
                  class="d-flex align-items-center justify-content-between my-2"
                  x-data="{ qty: {{ item.quantity }}}"
                  {% if item.price <= 0 %}style="justify-content: flex-end;"{% endif %}
                >
                  {% if item.price > 0 %}
                  <div class="qty-wrapper">
                    <button
                      {% if isBoxItem %} disabled {% endif %}
                      class="qty-minus"
                      @click.debounce="loading = true; Purdy.updateQuantityWithDiscount({{ forloop.index }}, --qty);"
                    ></button>
                    <input class="qty font-lausanne fw-400" type="text" value="1" x-model="qty">
                    <button
                      {% if isBoxItem %} disabled {% endif %}
                      class="qty-plus"
                      @click.debounce="loading = true; Purdy.updateQuantityWithDiscount({{ forloop.index }}, ++qty)"
                    ></button>
                  </div>
                  {% endif %}
                  <div class="p-price">
                    <h3 class="m-0 font-lausanne fw-400">
                      {{ item.price | money }}
                      {% if item.variant.compare_at_price > item.price %}
                        <small
                          ><del class="font-lausanne">{{ item.variant.compare_at_price | money }}</del></small
                        >
                      {% endif %}
                    </h3>
                  </div>
                </div>

               {% if item.selling_plan_allocation.price > 0 and item.selling_plan_allocation.selling_plan.price_adjustments[0].value > 0 %}
                {% assign value_discount = item.product.price | minus:item.selling_plan_allocation.selling_plan.price_adjustments[0].value %}
                {% assign value_discount_comp = value_discount | plus: 0 %}
                {% assign value_discount_comp = value_discount_comp | times: item.quantity %}
              
                {% if value_discount_comp > 0 %}
                  <div class="cart_subscription d-none text-sm">
                    <span class="cart_subscription--discount font-semibold text-green-700">
                      You saved
                      {% if item.selling_plan_allocation.selling_plan.price_adjustments[0].value_type == 'percentage' %}
                        {{ item.selling_plan_allocation.selling_plan.price_adjustments[0].value }}%
                      {% else %}
                        {{ value_discount_comp | money }}
                      {% endif %}
                    </span>
                  </div>
                {% endif %}
              {% endif %}
                <div
                  class="remove-product"
                  title="remove {{ item.product.title }}"
                  @click="loading = true; {% if isBoxItem %}removeBundle({{ boxIndex }}){% else %}Purdy.updateQuantity({{ forloop.index }}, 0){% endif %}"
                >
                  <i class="fa-regular fa-trash"></i>
                </div>
              </div>
            </div>
          
              {% if item.product.metafields.custom.bundle_breakdown %}
                {% assign excluded_handles = "orange-clove-refill-pack,frankincense-myrrh-counter-clean-refill-copy,mini-black-friday-bundle-copy,bathroom-bliss-bundle-kit" | split: "," %}
                      {% if excluded_handles contains item.product.handle %}
                        {% assign is_excluded = true %}
                      {% else %}
                        {% assign is_excluded = false %}
                      {% endif %}
                      
                      {% unless is_excluded %}
                        <div>
                  <!-- Loop through the products in the bundle_breakdown metafield -->
                  {% for bundle_item in item.product.metafields.custom.bundle_breakdown.value %}
              
                      <div class="cart_product-bundle">
                        <div class="cart_product-img">
                          <img src="{{ bundle_item.featured_image | img_url: '120x120', crop: 'center'  }}" alt="{{ bundle_item.title }}" width="32" height="32" class="img-responsive h-auto">
                        </div>
                      <div>
                      <div class="cart_product_b-title font-lausanne fw-600"><span class="bundle_product-qty">{{ item.quantity }}<span> x {{ bundle_item.title }}</div>
                      {% assign total_price = bundle_item.price | times: item.quantity %}
                        <div class="cart_product_b-price">FREE <del>{{ localization.country.currency.symbol }}{{ total_price | money_without_currency}}</del></div>
                      </div>
                    </div>

                  {% endfor %}
                </div>
                      {% endunless %}
                
              {% endif %}
          
                        
          </div>
            
          </div>
        {% endfor %}
<div class="cart-upsell-wrapper">
        {% if settings['cart--show-mini'] %}
          {% assign upsell_product_string = '' %}
          {% for product in settings.upsellcollChristmas.products %}
            {% if product.handle == 'seasonal-refill-booster-pack-autumn-1' %}
              {% assign p_handle = 'seasonal-refill-booster-pack-autumn' %}
            {% else %}
              {% assign p_handle = product.handle %}
            {%  endif %}
            {% if forloop.last %}
              {% assign upsell_product_string = upsell_product_string | append: p_handle %}
            {% else %}
              {% assign upsell_product_string = upsell_product_string | append: p_handle | append: ', ' %}
            {% endif %}
          {% endfor %}

          {% assign upsell_product_array = upsell_product_string | split: ', ' %}

          {% for product in settings.upsellcollChristmas.products %}
            {% if forloop.last %}
              {% assign last_product = product.handle %}
            {% endif %}
          {% endfor %}
          {% for item in cart.items %}
            {% if upsell_product_array contains item.product.handle %}
              {% if item.product.handle == last_product %}
                {% assign item_handle = item.product.handle %}
              {% else %}
                {% assign item_handle = item.product.handle | append: ', ' %}
              {% endif %}
              {% assign upsell_product_string = upsell_product_string | remove: item_handle %}
            {% endif %}
          {% endfor %}

          {% assign upsell_products = upsell_product_string | split: ', ' %}
          {% if cart.item_count > 0 %}
           {% for uproduct in upsell_products %}
              {% if forloop.index == 1 %}
                <div class="text-center">
                  
                  <h3
                    class="heaidng-3 font-lausanne fw-200 py-2 theme-text"
                    style="color:#212121; font-size:14px; font-weight:200; margin-top:10px"
                  >
                      Add extra member-price offers
                  
                  </h3>
                </div>
              {% endif %}

              {% if upsell_products == blank %}
              {% else %}
                <div class="cart--upsell show {{ upsell_product_string }}">
                  {% render 'upsell-christmas-product-variant', pHandle: uproduct %}
                </div>
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endif %}
  </div>
      </div>
    </div>

    <div class="min-cart-footer cart-footer-2">
      <form action="/checkout/" name="checkout_form">
        {%- assign discounts = '' -%}

{%- for item in cart.items -%}
  {%- case item.product.handle -%}
    {%- when 'bathroom-bliss-starter-kit' -%}
      {%- assign discounts = discounts | append: 'BATHROOMBLISS225CX,' -%}
    {%- when 'bathroom-bliss-bundle-kit' -%}
      {%- assign discounts = discounts | append: 'BATHROOMBLISS225CX,' -%}
    {%- when 'mini-black-friday-bundle-copy' -%}
      {%- assign discounts = discounts | append: 'MINIBUNDLE242CX,' -%}
    {%- when 'orange-clove-refill-pack' -%}
      {%- assign discounts = discounts | append: 'ORANGECLOVEREF242CX,' -%}
    {%- when 'frankincense-myrrh-counter-clean-refill-copy' -%}
      {%- assign discounts = discounts | append: 'FMREF242CX,' -%}
    {%- when 'christmas-scent-bundle' -%}
      {%- if item.quantity == 1 -%}
        {%- assign discounts = discounts | append: 'CHRISTMASBUNDLE242,' -%}
      {%- elsif item.quantity == 2 -%}
        {%- assign discounts = discounts | append: 'CHRISTMASBUNDLE242x2,' -%}
      {%- elsif item.quantity >= 3 -%}
        {%- assign discounts = discounts | append: 'CHRISTMASBUNDLE242x3,' -%}
      {%- endif -%}
  {%- endcase -%}
{%- endfor -%}

{%- if discounts != '' -%}
  {%- assign discounts = discounts | split: ',' | uniq | join: ',' -%}
{%- endif -%}

 <input autocomplete="off"  type="hidden" name="discount" value="{{ discounts }}">
        <div class="">
          <div class="d-flex justify-content-between font-lausanne fw-400 theme-text mb-1" >
            <div style="color:#161718;">
              Subtotal ({{ cart.item_count }}
                {{ cart.item_count | pluralize: 'item', 'items' }})
            </div>
            <div style="color:#161718;">
              {{ cart.total_price | money }}
            </div>
          </div>
          <div class="w-100">
            <button
              type="submit"
              class="btn font-lausanne fw-400 checkout-btn green-btn theme-btn btn-loader"
              style="padding: 14px 20px;"
            >
              CHECKOUT
            </button>
          </div>
          {% if settings.freeshipping -%}
            <p class="theme-text mt-1 mb-0 text-center">Free Delivery on UK orders</p>
          {%- endif %}
        </div>
      </form>
    </div>
  </div>
</div>
