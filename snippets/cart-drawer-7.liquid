      cursor: not-allowed;
    }

  .p-category{
  font-size:14px;
  line-height:1.5;
  color:#212121;
  font-weight:600;
}
  .subscription-details{
    color:#212121;
    font-size:12px;
  }
  .qty-wrapper .qty{background:#F6F1E5}
  
  .christmas-cart .cart-product{
    padding-bottom:0;
  }
  .christmas-cart .cart-product:last-child{
    padding-bototm:15px;
  }
  .christmas-cart .cart-upsell-wrapper{
    background-color:#EDE3CA;
    padding:2px 15px 15px 15px;
    margin-top:15px;
