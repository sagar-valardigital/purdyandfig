{% assign current_total = cart.total_price | money_without_currency %}
{% assign free_shipping_total = settings.free_shipping_amount | minus: current_total %}
{% assign free_product_total = settings.free_product_amount | minus: current_total %}
{% assign free_shipping_progress = current_total | divided_by: settings.free_shipping_amount | times: 100 %}
{% assign free_shipping_progress = free_shipping_progress | divided_by: 1 %}
{% assign free_product_progress = current_total | divided_by: settings.free_product_amount | times: 100 %}

{% if free_shipping_progress > 100 %}
  {% assign free_shipping_progress = 100 %}
{% endif %}

<span class="cart-overlay" x-on:click="setTimeout(() => { showCartDrawer = false; $dispatch('cart-close'); }, 400); animateDrawer(true);"></span>

<div class="min-cart-wrapper position-relative no-animation" data-shipping-progress="{{ free_shipping_progress }}">
  <div class="min-cart-header cart-header-2">
    <div class="d-flex align-items-center">
      <div class="cart-heading">
        <h2 class="heading-3-5 m-0 value-bold">Cart</h2>
      </div>
      <div class="cart-arrow" x-on:click="setTimeout(() => { showCartDrawer = false; $dispatch('cart-close'); }, 400); animateDrawer(true);">
        <img width="24px" height="24px" src="{{'close.svg' | asset_url}}" alt="">
      </div>
    </div>
  </div>
  <div class="min-cart-body pt-0">
    {% if settings.cartAnnouncementShow %}
      <div class="p-2 theme-text text-center cart-top-bar">
        <small>
          {{- settings.cartAnnouncement }}
          <a href="{{ settings.cartAnnouncementLink }}" class="theme-text" ><u>Shop Now</u></a></small>
      </div>
    {% endif %}

    <div class="cart-products-wrapper" style="{% if cart.item_count == 0 %}padding-left: 0; padding-right: 0;{% endif %}">
      {% if cart.item_count == 0 %}
        <div class="py-2">
          <h2 class="m-0 heading-3 text-center theme-text value-bold" style="color: #161718; font-size: 18px;">
            Your cart is empty
          </h2>
          <p class="text-center value-sans" style="color: #161718;">Add your favourite items to your cart</p>
        </div>

        <div class="mt-1 empty-cart-wrapper">
          <div class="empty-cart-products">
            {%- for product in settings.emptycoll.products -%}
              {% if product.available %}
                {% render 'cart-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  lazy_load: lazy_load
                %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {% assign total_savings_subscription = 0 %}
      
      {% for item in cart.items %}
        <div class="cart-product">
          <div class="d-flex flex-wrap">
            {% if item.image %}
              <div class="cart-product-image d-flex">
                {{ item.image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'img-responsive w-100' }}
              </div>
            {% endif %}

            <div class="cart-product-details value-sans theme-text">
              <div class="">
                <h4 class="p-category m-0 value-bold">{{ item.title }}</h4>
                <h3 class="p-title my-1 value-sans">{{ item.product.type }}</h3>
              </div>
              
              <small class="subscription-details">
                {% if item.variant.metafields.metadata.includes -%}
                  Includes: {{ item.variant.metafields.metadata.includes -}}
                  <br>
                {% endif %}
                {{ item.selling_plan_allocation.selling_plan.name }}
              </small>
              
              {% assign isBoxItem = false %}
              {% assign boxIndex = nil %}

              {% for property in item.properties %}
                {% if property.first contains '_dynamicBoxIndex' %}
                  {% assign isBoxItem = true %}
                  {% assign boxIndex = property.last | plus: 0 %}
                {% endif %}

                {% unless property.first contains '_' %}
                  <div class="line-item-property" >
                    <small class="property-name">{{ property.first }}:</small>
                    <small class="property-value">{{ property.last }}</small>
                  </div>
                {% endunless %}
              {% endfor %}
      
              <div class="remove-product" title="remove {{ item.product.title }}" @click="loading = true; {% if isBoxItem %}removeBundle({{ boxIndex }}){% else %}Purdy.updateQuantity({{ forloop.index }}, 0){% endif %}">
                <img src="{{'trash.svg' | asset_url}}" width="24px" height="24px" alt="">
              </div>
            </div>
          </div>
        
          <div class="d-flex align-items-center justify-content-between my-2" x-data="{ qty: {{ item.quantity }}}" {% if item.price <= 0 %}style="justify-content: flex-end;"{% endif %}>
            {% if item.price > 0 %}
            <div class="qty-wrapper">
              <button {% if isBoxItem %} disabled {% endif %} class="qty-minus" @click.debounce="loading = true; Purdy.updateQuantity({{ forloop.index }}, --qty);"></button>
              <input class="qty" type="text" value="1" x-model="qty">
              <button {% if isBoxItem %} disabled {% endif %} class="qty-plus" @click.debounce="loading = true; Purdy.updateQuantity({{ forloop.index }}, ++qty)"></button>
            </div>
            {% endif %}
            <div class="p-price">
              <h3 class="m-0">
                {% if item.product.compare_at_price > item.price %}
                  <small><del>{{ item.product.compare_at_price | money }}</del></small>
                {% endif %}
                {{ item.price | money }}
              </h3>
            </div>
          </div>

          {% if item.selling_plan_allocation.price > 0 and item.selling_plan_allocation.selling_plan.price_adjustments[0].value > 0 %}
            {% assign value_discount = item.product.price | minus:item.selling_plan_allocation.selling_plan.price_adjustments[0].value %}
            {% assign value_discount_comp = value_discount | plus: 0 %}
            {% assign value_discount_comp = value_discount_comp | times: item.quantity %}
          
            {% if value_discount_comp > 0 %}
              <div class="cart_subscription text-sm">
                <span class="cart_subscription--discount value-sans text-green-700">
                  You saved
                  {% if item.selling_plan_allocation.selling_plan.price_adjustments[0].value_type == 'percentage' %}
                    {% assign total_savings_subscription = total_savings_subscription | plus: (item.price | times: item.quantity) %}
                    {{ item.selling_plan_allocation.selling_plan.price_adjustments[0].value }}%
                  {% else %}
                    {{ value_discount_comp | money }}
                  {% endif %}
                </span>
              </div>
            {% endif %}
          {% endif %}
        </div>
      {% endfor %}
    </div>
    {% if settings['cart--show-mini'] %}
      {% assign upsell_product_string = '' %}
      {% for product in settings.upsellcoll.products %}
        {% if forloop.last %}
          {% assign upsell_product_string = upsell_product_string | append: product.handle %}
        {% else %}
          {% assign upsell_product_string = upsell_product_string | append: product.handle | append: ', ' %}
        {% endif %}
      {% endfor %}

      {% assign upsell_product_array = upsell_product_string | split: ', ' %}

      {% for product in settings.upsellcoll.products %}
        {% if forloop.last %}
          {% assign last_product = product.handle %}
        {% endif %}
      {% endfor %}

      {% for item in cart.items %}
        {% if upsell_product_array contains item.product.handle %}
          {% if item.product.handle == last_product %}
            {% assign item_handle = item.product.handle %}
          {% else %}
            {% assign item_handle = item.product.handle | append: ', ' %}
          {% endif %}
          {% assign upsell_product_string = upsell_product_string | remove: item_handle %}
        {% endif %}
      {% endfor %}

      {% assign upsell_products = upsell_product_string | split: ', ' %}
      {% if cart.item_count > 0 %}
        {% for uproduct in upsell_products %}
          {% if forloop.index == 1 %}
            <div class="text-center">
              <h3 class="heaidng-3 py-2 value-sans" style="color:#000000; font-size: 14px; font-weight:800; margin-top: 16px">
                {{ settings['cart--upsell-product-heading'] }}
              </h3>
            </div>
          {% endif %}

          <div class="cart--upsell show {{ upsell_product_string }}">
            {% render 'upsell-product-2', pHandle: uproduct %}
          </div>
        {% endfor %}
      {% endif %}
    {% endif %}
  </div>

  <div class="min-cart-footer cart-footer-2">
    <div class="cart-price-slider theme-text">
      {% if cart.items == 0 %}
        <div class="d-flex justify-content-center">
          <div class="free-delivery-limit free-limit-check  {% if free_shipping_total <= 0 %} checked {%  endif %}">
            <b>Free Shipping</b>
          </div>
        </div>
      {% endif %}
      
      {% if free_shipping_total > 0 %}
        <p class="value-sans" style="color: #434448; font-size: 12px; text-align: center; margin-bottom: 0px; font-weight: 700; line-height: 18px;">
          <b>Add {{ free_shipping_total | times: 100 | money }} to unlock FREE SHIPPING!</b>
        </p>
        <div class="free-limit-progress-bar"><span class="progress-bar"></span></div>
      {% else %}
        <p class="value-sans" style="color: #434448; font-size: 12px; text-align: center; margin-bottom: 0px; font-weight: 700; line-height: 18px;">
          <b>{{ settings.freeShippingOption }}</b>
        </p>
        <div class="free-limit-progress-bar"><span class="progress-bar" style="width:100%"></span></div>
      {% endif %}
    </div>
    
    <form action="/checkout/" name="checkout_form">
      <div class="">
        {% if total_savings_subscription > 0 %}
          <div class="subsaving d-flex justify-content-between value-bold" style="color: #3350B4;">
            <b>Subscribe & Save 50%</b>
            <b>-{{ total_savings_subscription | money }}</b>
          </div>
        {% endif %}
        <div class="subtotal d-flex justify-content-between value-bold" style="color:#000000;">
          <div>
            <b>Subtotal ({{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }})</b>
          </div>
          <div>
            <b>{{ cart.total_price | money }}</b>
          </div>
        </div>
        <div class="w-100">
          <button type="submit" class="btn d-flex checkout-btn value-sans btn-loader">
            <span class="d-flex">
              <span style="padding-right: 12px;">Checkout securely</span>
              <img src="{{'lock.svg' | asset_url}}" class="my-auto" width="24px" height="24px" alt="">
            </span>
          </button>
        </div>
        {% if settings.freeshipping -%}
          <p class="value-sans mt-1 mb-0 text-center" style="color: #000000;">Free Delivery on UK orders</p>
        {%- endif %}
      </div>
    </form>
  </div>
</div>