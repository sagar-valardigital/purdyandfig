<style>
  .coll-product-title {
    font-size: 18px !important;
    margin: 0 !important;
    color: #212121 !important;
    height: auto !important;
    line-height: 27px;
  }

  .colletion-product .product-detail .product-price {
    font-size: 16px;
    line-height: 25.6px;
  }
</style>

<div class="colletion-product position-relative" x-data="{ qty:1 }">
  {% assign product = card_product %}
  <form @submit.prevent="console.log('submitted')" x-ref="product_form_{{card_product.id}}" enctype="multipart/form-data" accept-charset="UTF-8" id="product_form_{{card_product.id}}" class="shopify-product-form" data-product-id="{{card_product.id}}" action="/cart/add">
    <div class="product-varient-selection d-none">
      {% assign s_variant = card_product.selected_or_first_available_variant %}
      <input type="hidden" name="id" value="{{s_variant.id}}">
      <input type="checkbox" name="purchase_type" value="subscription" checked>
    </div>
    <div class="selling_plan_wrapper d-none">
      {% liquid
        if product.selected_selling_plan
          assign selected_selling_plan = product.selected_selling_plan
        else
          assign selected_selling_plan = s_variant.selling_plan_allocations.first.selling_plan
        endif
      %}
      <input type="hidden" name="selling_plan" value="{{selected_selling_plan.id}}">
    </div>
    <input type="hidden" name="quantity" value="1">
  </form>

  <div class="product-img position-relative">
    <a href="{% if card_product.metafields.custom.redirect_link %}
        {{ card_product.metafields.custom.redirect_link  }}
      {% else %}
      {{ card_product.url }}
        {% endif %}">
      <div class="coll-tag-wrap">
        {% for tag in card_product.tags %}
          {% if tag contains 'tag' %}
            {% assign stag = tag | split : ':' %}
            <span class="collection-tag {{ stag[1] | handleize }}">{{ stag[1] }}</span>
          {% endif %}
        {% endfor %}
      </div>
      <img
        src="{{ card_product.featured_media | image_url: width: 280, height: 400 }}"
        alt="{{ card_product.featured_media.alt | escape }}"
        class="img-responsive w-100"
        {% unless lazy_load == false %}loading="lazy"{% endunless %}
      >
    </a>
    <!--{% assign sub_discount_price = s_variant.selling_plan_allocations[0].price_adjustments[0].price %}
    {% if card_product.metafields.custom.product_custom_price != blank %}
      <a href="{{ card_product.url }}" class="colletion-add">Shop Now <span>| {{ card_product.metafields.custom.product_custom_price | money }}</span></a>
    {% else %}
      <a href="{{ card_product.url }}" class="colletion-add">Shop Now <span>| {% if sub_discount_price %} {{sub_discount_price | money }} {%else%}{{ card_product.price | money }} {%endif%}</span></a>
    {% endif %}
    {% if card_product.available %}
      <button x-on:click="Purdy.AddToCart($refs.product_form_{{ card_product.id }})" class="colletion-add collection-add-ab font-pier">Add <span>
        <svg xmlns="http://www.w3.org/2000/svg" version="1.1" xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:svgjs="http://svgjs.com/svgjs" width="512" height="512" x="0" y="0" viewBox="0 0 512 512" style="enable-background:new 0 0 512 512" xml:space="preserve" class="">
          <g>
            <path d="M256 0C114.836 0 0 114.836 0 256s114.836 256 256 256 256-114.836 256-256S397.164 0 256 0zm112 277.332h-90.668V368c0 11.777-9.555 21.332-21.332 21.332s-21.332-9.555-21.332-21.332v-90.668H144c-11.777 0-21.332-9.555-21.332-21.332s9.555-21.332 21.332-21.332h90.668V144c0-11.777 9.555-21.332 21.332-21.332s21.332 9.555 21.332 21.332v90.668H368c11.777 0 21.332 9.555 21.332 21.332s-9.555 21.332-21.332 21.332zm0 0" fill="#3d5065" data-original="#000000" class=""></path>
          </g>
        </svg>
      </span></button>
    {% else %}
      <button class="colletion-add collection-add-ab font-pier">Out of Stock <span>
        <svg xmlns="http://www.w3.org/2000/svg" version="1.1" xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:svgjs="http://svgjs.com/svgjs" width="512" height="512" x="0" y="0" viewBox="0 0 512 512" style="enable-background:new 0 0 512 512" xml:space="preserve" class="">
          <g>
            <path d="M256 0C114.836 0 0 114.836 0 256s114.836 256 256 256 256-114.836 256-256S397.164 0 256 0zm112 277.332h-90.668V368c0 11.777-9.555 21.332-21.332 21.332s-21.332-9.555-21.332-21.332v-90.668H144c-11.777 0-21.332-9.555-21.332-21.332s9.555-21.332 21.332-21.332h90.668V144c0-11.777 9.555-21.332 21.332-21.332s21.332 9.555 21.332 21.332v90.668H368c11.777 0 21.332 9.555 21.332 21.332s-9.555 21.332-21.332 21.332zm0 0" fill="#3d5065" data-original="#000000" class=""></path>
          </g>
        </svg>
      </span></button>
    {% endif %}-->
  </div>

 <a href="{% if card_product.metafields.custom.redirect_link %}
        {{ card_product.metafields.custom.redirect_link  }}
      {% else %}
      {{ card_product.url }}
        {% endif %}">
  <div class="product-detail">
    <span class="heading-4 coll-product-title fw-400">{{ card_product.title | escape }}</span>
    <div class="product-footer">
      {% render 'okendo-reviews-product-rating-summary', product: card_product %}
      <div class="d-flex justify-content-between theme-text align-items-center">
        {% if card_product.metafields.custom.product_custom_price != blank %}
          <p class="product-price fw-200 m-0 {{ card_product.title | handle }}">{{ card_product.metafields.custom.product_custom_price | money }}
             {% if card_product.metafields.custom.product_custom_compare_price != blank or card_product.metafields.custom.product_custom_compare_price > card_product.metafields.custom.product_custom_price %}
              <del>{{ card_product.metafields.custom.product_custom_compare_price | money }}</del>
             {% endif %}
            </p>
        {% else %}
          <p class="product-price fw-200 m-0 {{ card_product.title | handle }}">
            {% if sub_discount_price %}
              {{ sub_discount_price | money }}
              {% if card_product.compare_at_price > sub_discount_price %}
                <del>{{ card_product.compare_at_price | money }}</del>
              {% endif %}
            {% else %}
              {{ card_product.price | money }}
              {% if card_product.compare_at_price > card_product.price %}
                <del>{{ card_product.compare_at_price | money }}</del>
              {% endif %}
            {% endif %}
          </p>
        {% endif %}
      </div>
    </div>
  </div>
</a>
</div>