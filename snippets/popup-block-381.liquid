<!-- popup code -->
<div class="popup-card-wrapper-381">
  <div class="popup-close-button-wrapper-381">
    <div class="popup-close-button-381">&times;</div>
  </div>

  <div class="popup-card-content-381">
    <div class="popup-product-info-381">
      <div class="popup-img-381">
        <img src="https://placehold.co/110x110" class="toast-image-381" width="110" height="110">
      </div>
      <div class="popup-product-texts-381">
        <div class="popup-product-title-381"></div>
        <div class="popup-product-desc-381"></div>
      </div>
    </div>

    <div class="popup-pack-includes-381">
      <div class="popup-pack-includes-title-381"></div>

      <div class="popup-pack-item-381">
        <div class="popup-pack-item-icon-381"></div>
        <div class="popup-pack-item-text-381"></div>
      </div>
    </div>

    <div class="popup-purchase-section-381">
      <div class="bind-these-two">
        <div class="popup-radio-icon-381"></div>
        <div class="popup-purchase-label-381">One-time purchase</div>
      </div>
      <div class="popup-purchase-price-381">
        <div class="popup-price-381"></div>
        <div class="popup-cross-price-381"></div>
      </div>
    </div>

    <form
      name="shopify-product-form"
      autocomplete="off"
      @submit.prevent="console.log('submitted')"
      x-ref="product_toast_form"
      enctype="multipart/form-data"
      accept-charset="UTF-8"
      id="product_toast_form"
      class="shopify-product-form link-to-variant show toast-form-381"
      data-product-id=""
      action="/cart/add"
      x-data="{qty: 1}"
    >
      <input
        autocomplete="off"
        type="hidden"
        name="id"
        class="input_variant_id_"
        value="{{ block.settings.variant_id }}"
      >
      <input autocomplete="off" type="hidden" name="quantity" value="1">
      {% if block.settings.isSub %}
        <input
          autocomplete="off"
          type="checkbox"
          name="purchase_type"
          value="subscription"
          checked
          class="d-none gp--buyoption-input purc_type"
        >
      {% else %}
        <input
          autocomplete="off"
          type="checkbox"
          name="purchase_type"
          value="payg"
          checked
          class="d-none gp--buyoption-input purc_type"
        >
      {% endif %}
      <input
        autocomplete="off"
        class="input_selling_plan_"
        type="hidden"
        name="selling_plan"
        value="{{ block.settings.sealing_plan}}"
      >
      <input
        autocomplete="off"
        type="hidden"
        class="disc"
        name="discount"
        value="{{ block.settings.discount }}"
      >
      <button
        x-on:click="Purdy.AddToCartWithDiscount($refs.product_toast_form, false, false, $event)"
        class="btn btn-christmas-btn btn-loader cta-381 toast-btn-381"
      >
        ADD TO CART
      </button>
    </form>
  </div>
  <div class="popup-toast-uni-inr-381 box-inr" x-data="{qty: 1}" style="display: flex;">
    <div class="popup-toast-left-uni-inr-381">
      <div class="popup-toast-icon-uni-inr-381">&check;</div>
      <div class="popup-toast-text-uni-inr-381">Item has been added.</div>
    </div>
    <div class="popup-toast-link-uni-inr-381" @click="$dispatch('toggle-cart')">View cart</div>
  </div>
</div>

<script>
  const currencySymbol = '{{- localization.country.currency.symbol -}}';

  function firepopupblock(element) {
    const parentcontainer = element.parentElement.parentElement;

    let popupctasame = '';
    if(parentcontainer.querySelector('.popup-cta-same')) {
      popupctasame = parentcontainer.querySelector('.popup-cta-same').innerHTML;
    }
    
    const toastTitle = parentcontainer.querySelector('.popup-title').innerHTML;
    const toastSummary = parentcontainer.querySelector('.popup-summary').innerHTML;
    const toastImage = parentcontainer.querySelector('.image-main-381').src;

    const toastProductID = parentcontainer.querySelector('form').getAttribute('data-product-id');
    const toastVariantID = parentcontainer.querySelector('.input_variant_id_').value;
    const toastPurchaseType = parentcontainer.querySelector('.purc_type').value;
    const toastSellingPlan = parentcontainer.querySelector('.input_selling_plan_').value;
    const toastDisacount = parentcontainer.querySelector('.disc').value;

    const toastbulletpoints1 = parentcontainer.querySelector('.bulletpoints1').innerHTML;
    const toastbulletpoints2 = parentcontainer.querySelector('.bulletpoints2').innerHTML;
    const toastbulletpoints3 = parentcontainer.querySelector('.bulletpoints3').innerHTML;
    const toastbulletpoints4 = parentcontainer.querySelector('.bulletpoints4').innerHTML;
    const toastbulletpoints5 = parentcontainer.querySelector('.bulletpoints5').innerHTML;
    const toastbulletpoints6 = parentcontainer.querySelector('.bulletpoints6').innerHTML;
    const toastbulletpoints7 = parentcontainer.querySelector('.bulletpoints7').innerHTML;
    const toastbulletpoints8 = parentcontainer.querySelector('.bulletpoints8').innerHTML;
    const toastSub = parentcontainer.querySelector('.toast-sub').getAttribute('data-pop-sub');
    const packincludeslbel = parentcontainer.querySelector('.pop-bullet-heading').innerHTML;

    let toastBulletPointHTML = '';
    if(toastbulletpoints1 || toastbulletpoints2 || toastbulletpoints3 || toastbulletpoints4  || toastbulletpoints5 || toastbulletpoints6 || toastbulletpoints7 || toastbulletpoints8) {
      toastBulletPointHTML = '<div class="popup-pack-includes-title-381">' + packincludeslbel + '</div>';
    }

    if(toastbulletpoints1) {
      toastBulletPointHTML += `<div class="popup-pack-item-381">
        <div class="popup-pack-item-icon-381">&check;</div>
        <div class="popup-pack-item-text-381">${toastbulletpoints1}</div>
      </div>`;
    }
    if(toastbulletpoints2) {
      toastBulletPointHTML += `<div class="popup-pack-item-381">
        <div class="popup-pack-item-icon-381">&check;</div>
        <div class="popup-pack-item-text-381">${toastbulletpoints2}</div>
      </div>`;
    }
    if(toastbulletpoints3) {
      toastBulletPointHTML += `<div class="popup-pack-item-381">
        <div class="popup-pack-item-icon-381">&check;</div>
        <div class="popup-pack-item-text-381">${toastbulletpoints3}</div>
      </div>`;
    }
    if(toastbulletpoints4) {
      toastBulletPointHTML += `<div class="popup-pack-item-381">
        <div class="popup-pack-item-icon-381">&check;</div>
        <div class="popup-pack-item-text-381">${toastbulletpoints4}</div>
      </div>`;
    }
    if(toastbulletpoints5) {
      toastBulletPointHTML += `<div class="popup-pack-item-381">
        <div class="popup-pack-item-icon-381">&check;</div>
        <div class="popup-pack-item-text-381">${toastbulletpoints5}</div>
      </div>`;
    }
    if(toastbulletpoints6) {
      toastBulletPointHTML += `<div class="popup-pack-item-381">
        <div class="popup-pack-item-icon-381">&check;</div>
        <div class="popup-pack-item-text-381">${toastbulletpoints6}</div>
      </div>`;
    }
    if(toastbulletpoints7) {
      toastBulletPointHTML += `<div class="popup-pack-item-381">
        <div class="popup-pack-item-icon-381">&check;</div>
        <div class="popup-pack-item-text-381">${toastbulletpoints7}</div>
      </div>`;
    }
    if(toastbulletpoints8) {
      toastBulletPointHTML += `<div class="popup-pack-item-381">
        <div class="popup-pack-item-icon-381">&check;</div>
        <div class="popup-pack-item-text-381">${toastbulletpoints8}</div>
      </div>`;
    }

    const toastPrice = parentcontainer.querySelector('.btn-main-381').getAttribute('data-price');
    const toastCrossPrice = parentcontainer.querySelector('.btn-main-381').getAttribute('data-cross-price');
    const toastItemType = parentcontainer.querySelector('.btn-main-381').getAttribute('data-item-type');
    const toastBTNLabel = parentcontainer.querySelector('.btn-main-381').innerHTML;

    const toastBTN = document.querySelector('.toast-btn-381');
    
    let out_of_stock = 'false';
    if(parentcontainer.querySelector('.out-of-stock')) {
      out_of_stock = parentcontainer.querySelector('.out-of-stock').innerText;
    }

    if(out_of_stock == 'false') {
      toastBTN.removeAttribute('disabled', 'disabled');
      toastBTN.style.opacity = '1';
      toastBTN.setAttribute('data-add-to-cart', parentcontainer.querySelector('.btn-main-381').getAttribute('data-add-to-cart'));
      toastBTN.setAttribute('data-page-url', parentcontainer.querySelector('.btn-main-381').getAttribute('data-page-url'));
      toastBTN.setAttribute('data-target-url', parentcontainer.querySelector('.btn-main-381').getAttribute('data-target-url'));
      toastBTN.setAttribute('data-index', parentcontainer.querySelector('.btn-main-381').getAttribute('data-index'));
      toastBTN.setAttribute('data-funnel-stage', parentcontainer.querySelector('.btn-main-381').getAttribute('data-funnel-stage'));
      toastBTN.setAttribute('data-module', parentcontainer.querySelector('.btn-main-381').getAttribute('data-module'));
      toastBTN.setAttribute('data-event-label', parentcontainer.querySelector('.btn-main-381').getAttribute('data-event-label'));
      toastBTN.setAttribute('data-event-value', parentcontainer.querySelector('.btn-main-381').getAttribute('data-event-value'));
      toastBTN.setAttribute('data-item-id', parentcontainer.querySelector('.btn-main-381').getAttribute('data-item-id'));
      toastBTN.setAttribute('data-option-index', parentcontainer.querySelector('.btn-main-381').getAttribute('data-option-index'));
      toastBTN.setAttribute('data-item-name', parentcontainer.querySelector('.btn-main-381').getAttribute('data-item-name'));
      toastBTN.setAttribute('data-quantity', parentcontainer.querySelector('.btn-main-381').getAttribute('data-quantity'));
      toastBTN.setAttribute('data-price', toastPrice);
      toastBTN.setAttribute('data-cross-price', toastCrossPrice);
      toastBTN.setAttribute('data-item-type', toastItemType);

      // toastBTNHTML = `<span class="tst-btn-txt-381">ADD TO CART | </span>
      //                 <del class="tst-btn-del-price-381">${toastCrossPrice}</del>
      //                 <span class="tst-btn-price-381">${toastPrice}</span>`;

      const ptnbtnText = parentcontainer.querySelector('.btn-main-381').innerText;
      if(toastItemType == 'subscription') {
        if(popupctasame != 'true') {
          toastBTNHTML = `<span class="tst-btn-txt-381">ADD 90-DAY PLAN</span>`;
        } else {
          toastBTNHTML = `<span class="tst-btn-txt-381">${ptnbtnText}</span>`;
        }
      } else {
        toastBTNHTML = `<span class="tst-btn-txt-381">${ptnbtnText}</span>`;
      }
    } else {
      toastBTN.setAttribute('disabled', 'disabled');
      toastBTN.style.opacity = '0.6';
      toastBTNHTML = `<span class="tst-btn-txt-381">OUT OF STOCK</span>`;
    }
    toastBTN.innerHTML = toastBTNHTML;

    document.querySelector('.toast-image-381').src = toastImage;
    document.querySelector('.popup-product-title-381').innerHTML = toastTitle;
    document.querySelector('.popup-product-desc-381').innerHTML = toastSummary;
    document.querySelector('.popup-pack-includes-381').innerHTML = toastBulletPointHTML;
    document.querySelector('.popup-price-381').innerHTML = toastPrice;
    
    document.querySelector('.popup-cross-price-381').innerHTML = '';
    if(toastCrossPrice !== currencySymbol) {
      document.querySelector('.popup-cross-price-381').innerHTML = toastCrossPrice;
    }
    
    if(toastItemType == 'subscription') {
      document.querySelector('.popup-purchase-label-381').innerHTML = '90-day plan';
    } else {
      document.querySelector('.popup-purchase-label-381').innerHTML = 'One-time purchase';
    }
    
    const toastForm = document.querySelector('.toast-form-381');
    toastForm.setAttribute('data-product-id', toastProductID);
    toastForm.querySelector('.input_variant_id_').value = toastVariantID;
    toastForm.querySelector('.purc_type').value = toastPurchaseType;
    toastForm.querySelector('.input_selling_plan_').value = toastSellingPlan;
    toastForm.querySelector('.disc').value = toastDisacount;

    document.body.classList.add('bodyoverlay');
    console.log(document.body.classList);
    document.querySelector('.popup-card-wrapper-381').classList.add('easein-open');
  };
  
  document.addEventListener("DOMContentLoaded", function () {
    const imageonly = document.querySelectorAll('.reskin-product-block img');
    const alltitles = document.querySelectorAll('.title-main-381');
    const citrusimage = document.querySelectorAll('.citrus-image');
    const citrustitle = document.querySelectorAll('.citrus-product-title');
    
    const closebtnicon = document.querySelector('.popup-close-button-381');
    closebtnicon.addEventListener('click', function(event) {
      document.body.classList.remove('bodyoverlay');
      event.target.parentElement.parentElement.classList.remove('easein-open');
    });

    const container = document.querySelector('.popup-card-wrapper-381');
    document.addEventListener('click', (event) => {
      const clickedInsideContainer = container.contains(event.target);
      const clickedTrigger = [...imageonly].some(trigger => trigger.contains(event.target));
      const clickedTriggerTitle = [...alltitles].some(trigger => trigger.contains(event.target));
      const clickedCitrusTitle = [...citrusimage].some(trigger => trigger.contains(event.target));
      const clickedCitrusImage = [...citrustitle].some(trigger => trigger.contains(event.target));
    
      if (!clickedInsideContainer && !clickedTrigger && !clickedTriggerTitle && !clickedCitrusTitle && !clickedCitrusImage) {
        console.log('removing');
        document.body.classList.remove('bodyoverlay');
        container.classList.remove('easein-open');
      }
    });

    window.addEventListener('product:added', function(event) {
      const isinnertoast = document.querySelector('.popup-card-wrapper-381').classList;

      if(!isinnertoast.contains('easein-open')) {
        // document.body.classList.add('bodyoverlay');
        document.querySelector('.box-out').classList.add('toast-easein-open');
  
        setTimeout(function() {
          // document.body.classList.remove('bodyoverlay');
          document.querySelector('.box-out').classList.remove('toast-easein-open');
        }, 4000);
      } else {
        document.querySelector('.box-inr').classList.add('easein-inr-open');

        setTimeout(function() {
          document.querySelector('.box-inr').classList.remove('easein-inr-open');
        }, 4000);
      }
    });
  });
</script>
