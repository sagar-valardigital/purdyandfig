    "faq_section_2_FUFBYY": {
      "type": "faq-section-2",
      "blocks": {
        "d5f0750c-d1c1-4e82-bde9-e538cec56d97": {
          "type": "text",
          "settings": {
            "open": true,
            "faq-question": "Are these products an extra subscription?",
            "faq-ans": "<p>No, these are buy-once products with prices just for our members. You won’t be taking out a new subscription unless specifically stated.</p>"
          }
        },
        "text_TA9k4H": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "Why am I getting these offers?",
            "faq-ans": "<p>All our members with active subscriptions get access to member benefits, including limited edition scents and exclusive offers. </p>"
          }
        },
        "3bef21b1-6cdf-4174-a35c-01e4fa513c76": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How long will the offer last?",
            "faq-ans": "<p>This page will be live for the rest of Autumn, but we cannot guarantee how long offers will last, so don’t wait around.</p>"
          }
        },
        "text_NPPtzz": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How can I track my order?",
            "faq-ans": "<p>We aim to send your products within one working day of receiving your order, and for you to receive it within 48 hours of it being dispatched. For orders being shipped to Europe, please allow two to seven working days from dispatch.</p><p>If your order tracking shows it’s been five working days or more since the last tracking scan, please do give us a shout and a member of our Customer Experience team will get back to you as soon as possible.</p>"
          }
        }
      },
