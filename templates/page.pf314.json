    "pf314_expend_blocks_NkgMeP": {
      "type": "pf314-expend-blocks",
      "blocks": {
        "image_MqXHLD": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/Summer_Lawn_8c6e9236-27d5-428c-949f-feab2f878bb4.png",
            "mBlockImage": "shopify://shop_images/Summer_Lawn_Mobile.png",
            "tag": "Free with your next order",
            "heading": "Summer Lawn",
            "details": "A fresh blend featuring citrusy bergamot and cool mint that’s inspired by the leafy scent of freshly cut grass.",
            "expend-label": "blend details",
            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Top notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Bergamot</span>\n            <br>\n            Sweet and citrusy\n        </li>\n        <li class=\"font-lausanne  fw-200\">\n            <span class=\"fw-400\">Leaf alcohol</span>\n            <br>\n            Green and herbaceous\n        </li>\n<li class=\"font-lausanne  fw-200\">\n            <span class=\"fw-400\">Galbanum</span>\n            <br>\n            Leafy and fresh\n        </li>\n<li class=\"font-lausanne  fw-200\">\n            <span class=\"fw-400\">Eau de Cologne mint</span>\n            <br>\n            Citrusy and minty\n        </li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne  fw-200\">\n            <span class=\"fw-400\">Linden blossom</span>\n            <br>\n            Fresh and floral\n        </li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Base notes</h4>\n    <ul>\n        <li class=\"font-lausanne  fw-200\">\n            <span class=\"fw-400\">Copaiba balsam</span>\n            <br>\n            Gentle and woody\n        </li>\n<li class=\"font-lausanne  fw-200\">\n            <span class=\"fw-400\">Coumarin</span>\n            <br>\n            Warm and sweet\n        </li>\n    </ul>\n</div>"
          }
        },
        "image_eA6bUG": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/Geranium_Ylang_Ylang_f69cd2bd-69e3-489b-8fde-e427d38f06af.png",
