    "a2194449-184e-4118-8225-9a59caeea728": {
      "type": "faq-section-reskin",
      "blocks": {
        "d5f0750c-d1c1-4e82-bde9-e538cec56d97": {
          "type": "text",
          "settings": {
            "open": true,
            "faq-question": "Is this an extra subscription?",
            "faq-ans": "<p>No, this is a buy-once offer just for our members. You won’t be taking out a new subscription.</p>"
          }
        },
        "3bef21b1-6cdf-4174-a35c-01e4fa513c76": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "Why am I getting this offer?",
            "faq-ans": "<p>All our members with active subscriptions get access to member benefits, including limited edition scents and exclusive offers. As a member, concentrate refills are always 15% off.</p>"
          }
        },
        "text_gwXQrP": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How long will this offer last?",
            "faq-ans": "<p>As long as our limited edition seasonal scents last, so we recommend getting your skates on.</p>"
          }
        },
        "3c474819-85aa-4a9a-bcc0-dc1e0f54550d": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How do I manage my subscription?",
            "faq-ans": "<p>You can view, manage or cancel your subscription by logging into your account with the email address you used to place your first Purdy & Figg order. Once you’re in, you’ll be able to tweak your subscription however you like. You can change what’s in your order, adjust your delivery and billing date, or pause deliveries completely for a bit.</p>"
          }
        },
        "b3da5911-c83c-46b6-b545-797e91781fff": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How can I track my order?",
            "faq-ans": "<p>We aim to send your products within one working day of receiving your order, and for you to receive it within 48 hours of it being dispatched. For orders being shipped to Europe, please allow two to seven working days from dispatch. <br/><br/>If your order tracking shows it’s been five working days or more since the last tracking scan, please do give us a shout and a member of our Customer Experience team will get back to you as soon as possible.</p>"
          }
        },
        "29134be3-da11-47cf-a53b-7f88d2bbe596": {
          "type": "text",
          "disabled": true,
          "settings": {
            "open": false,
            "faq-question": "Are your products safe for pets?",
            "faq-ans": "<p>Our products are safe to use around dogs and other domestic pets, but if you’re worried about allergies it’s always best to check with your vet. Birds are particularly sensitive to airborne substances so it’s a good idea to take them out of the room while you clean. It’s also important to note that Ylang Ylang and Citronella are both toxic to dogs if they’re ingested or applied topically, so naturally we wouldn’t recommend that. It probably goes without saying, but please don’t let your pets lick or drink Counter Clean or Bathroom Bliss.</p>"
          }
        }
      },
