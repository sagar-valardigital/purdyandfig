der":["text_drLaq","text_Gj78U","text_fwQ3B","text_TYTfq","text_hFBtG"],"name":"Table US V2"},"two_women_v2_VBWhX":{"type":"two-women-v2","disabled":false,"settings":{"autoplay":false,"video":"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/5c5e343bbf94401b8aa54d7f61e796ac.mp4","poster":"shopify:\/\/shop_images\/Media_c3a7de8b-04c9-4ff8-b5d5-e9562524fc0a.png","addScrollBtn":true,"className":"two-women-wrapper","background":"#fafafa","layout":false,"main_heading":"Two women on a mission","sub_heading":"Two best friends Charlotte Figg and Purdy Rubin got together on a mission to make cleaning products that were safe and they loved using for their home.","image":"shopify:\/\/shop_images\/c0855ba36e497bb2acf6ef7605222d4a.jpg","details":"<span class=\"fw-400\">Backed by science and expertise<\/span><span class=\"fw-200\"> Dr Anna Slastanova PHD and Honorary Research Fellow in Surfactant Chemistry is responsible for the world’s most advanced scent extraction ever achieved in a cleaning product. She created our essential oil blends alongside co-founder Charlotte Figg, who has years of experience working with plants. <\/span>","man_details_1":"We manufacture Purdy &amp; Figg eco-concentrates in England, where we’re subject to stringent health regulations.","man_details_2":"Every Purdy &amp; Figg eco-concentrate is made in a state-of-the-art laboratory. We promise we’ll never cut corners when it comes to your health or safety.","btnLabel":"GET OFFER","scrollto":"starterkit-product","top":"0","header-c2a8280d925359e67986016f336bfaa8":null,"dataTrack":true,"targetUrl":"","index":0,"funnel_stage":"landing_page","dataModule":"manufactured_in_the_uk","dataTitle":"get_offer","eventValue":"shop_anchor","itemId":"","optionIndex":"","ItemName":""},"blocks":{},"block_order":[],"name":"Two Women V2"},"faq_section_reskin_LwrEV":{"type":"faq-section-reskin","disabled":false,"custom_css":[".green-btn {margin-top: 80px !important;}",".heading-2 {letter-spacing: 0px;}",".faq-acc h3 {font-weight: 600 !important; margin-top: 8px;}",".faq-acc a {text-decoration: underline; color: #222;}","@media (max-width: 768px) {.green-btn {margin-top: 32px !important; width: 100% !important; max-width: 100% !important; }}"],"settings":{"enable":true,"color_bg":"#ffffff","class":"","heading":"Frequently asked questions","addScrollBtn":true,"scrollBtnText":"GET OFFER","scrollto":"starterkit-product","top":"0","header-4a8ffb7c7bc8a28d37c65c23911a3481":null,"dataTrack":true,"targetUrl":"","index":10,"funnel_stage":"landing_page","dataModule":"faq","dataTitle":"get_offer","eventValue":"shop_anchor","itemId":"","optionIndex":"","ItemName":""},"blocks":{"text_9V4tV":{"type":"text","disabled":false,"settings":{"open":true,"faq-question":"How do I use Counter Clean?","faq-ans":"<p>To use Counter Clean, simply pour the whole 0.68 FL OZ (20ml) bottle of cleaning concentrate into your Bottle for Life and slowly fill to the top (just below the neck) with tap water. Give the bottle a gentle shake to mix, then enjoy your uplifting clean!<\/p>"}},"text_cLdnr":{"type":"text","disabled":false,"settings":{"open":false,"faq-question":"Which surfaces is Counter Clean suitable for?","faq-ans":"<p>We're pleased to say that Counter Clean is pH neutral, which means it’s safe to use on most surfaces. That includes softer materials like aluminium, wood, stone, quartz and other sealed surfaces. We do recommend patch testing first on any particularly sensitive or precious surfaces you’re concerned about. Just spray onto a cloth and wipe a small patch to see the results. <\/p>"}},"text_gpL3U":{"type":"text","disabled":false,"settings":{"open":false,"faq-question":"Which surfaces is Bathroom Bliss suitable for?","faq-ans":"<p>Bathroom Bliss is suitable for all the surfaces in your bathroom, including glass, mirrors, porcelain and chrome. The naturally powerful formula tackles limescale, hard water deposits and soap scum with a streak-free finish. As with Counter Clean, we recommend patch testing any particularly precious or sensitive areas first.<\/p>"}},"text_Gbxmq":{"type":"text","disabled":false,"settings":{"open":false,"faq-question":"How do I manage my subscription?","faq-ans":"<p>We offer lots of subscription options, upgrade your subscription to more products, changing the frequency of your deliveries or cancelling your membership altogether. Subscriptions are set to a 90-day frequency by default, but you can always move your next billing date if you need to in a few easy steps. We understand there might be times when you need to stop your deliveries, and we’ll always respect your decision to leave - even if we’ll miss you.<\/p><p>If you have any trouble managing your subscription, our Customer Experience Team is always on hand to respond to your questions and requests as soon as possible. They’re very friendly.<\/p>"}},"text_GJWPN":{"type":"text","disabled":false,"settings":{"open":false,"faq-question":"How many uses will I get out of a bottle?","faq-ans":"<p>A 10.14 fl oz (300ml) bottle of Counter Clean (including one 0.68 fl oz (20ml) concentrate) contains about 230 sprays. A typical household will get through one of our 10.14 fl oz bottles in two to four weeks, unless you get a bit addicted to wiping down your surfaces like we have!<\/p>"}},"text_kQq4f":{"type":"text","disabled":true,"settings":{"open":false,"faq-question":"What ingredients do you use?","faq-ans":"<h3>Uplifting Citrus<\/h3><p>Water, Capryleth-4, Fragrances, Polyglycerol-3-Caprate, Lauryl Glucoside, Disodium Cocoyl Glutamate, Myrcene. Contains fragrance allergens.<\/p><p><a href=\"https:\/\/files.purdyandfigg.com\/ingredients-pdfs\/uplifting-citrus\/safety-data-sheet\/uplifting-citrus-counter-clean-en-osha-ghs-sds-2025-07-09.pdf\" target=\"_blank\" title=\"Safety Data Sheet\">Safety Data Sheet<\/a><br\/><a href=\"https:\/\/files.purdyandfigg.com\/ingredients-pdfs\/uplifting-citrus\/ca-ingredient-disclosure\/uplifting-citrus-counter-clean-california-rtk-disclosure-2025-07-14-table.pdf\" target=\"_blank\" title=\"CA Ingredient Disclosure\">CA Ingredient Disclosure<\/a><\/p><h3>Balancing Floral<\/h3><p>Polysorbate 20, Water, Fragrances, Hamamelis Virginiana Extract, Disodium Cocoyl Glutamate, Ethanol, Caprylyl\/Capryl Glucoside, Salicylic Acid, Glycerin, Sorbic Acid, Myrcene. Contains fragrance allergens.<\/p><p><a href=\"https:\/\/files.purdyandfigg.com\/ingredients-pdfs\/balancing-floral\/safety-data-sheet\/balancing-floral-counter-clean-en-osha-ghs-sds-2025-07-09.pdf\" target=\"_blank\" title=\"Safety Data Sheet\">Safety Data Sheet<\/a><br\/><a href=\"https:\/\/files.purdyandfigg.com\/ingredients-pdfs\/balancing-floral\/ca-ingredient-disclosure\/balancing-floral-counter-clean-california-rtk-disclosure-2025-07-14-table.pdf\" target=\"_blank\" title=\"CA Ingredient Disclosure\">CA Ingredient Disclosure<\/a><\/p><h3>Grounding Vetiver<\/h3><p>Water, Capryleth-4, Caprylyl\/Capryl Glucoside, Fragrances, Lauryl Glucoside, Disodium Cocoyl Glutamate. Contains fragrance allergens.<\/p><p><a href=\"https:\/\/files.purdyandfigg.com\/ingredients-pdfs\/grounding-vetiver\/safety-data-sheet\/grounding-vetiver-counter-clean-en-osha-ghs-sds-2025-07-09.pdf\" target=\"_blank\" title=\"Safety Data Sheet\">Safety Data Sheet<\/a><br\/><a href=\"https:\/\/files.purdyandfigg.com\/ingredients-pdfs\/grounding-vetiver\/ca-ingredient-disclosure\/grounding-vetiver-counter-clean-california-rtk-disclosure-2025-07-14-table.pdf\" target=\"_blank\" title=\"CA Ingredient Disclosure\">CA Ingredient Disclosure<\/a><\/p>"}}},"block_order":["text_9V4tV","text_cLdnr","text_gpL3U","text_Gbxmq","text_GJWPN","text_kQq4f"],"name":"FAQ section Reskin"},"footer_2_47VRp":{"type":"footer-2","disabled":true,"custom_css":["@media (max-width: 768px) {.footer-2 .d-flex > div {text-align: left; }}"],"settings":{},"blocks":{},"block_order":[],"name":"footer 2"},"footer_us_383_WaQqT":{"type":"footer-us-383","disabled":true,"settings":{"logo":null,"privacyLink":"","termsLink":""},"blocks":{},"block_ord