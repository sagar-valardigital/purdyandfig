    "common_transformational_scent_blocks_BR6tWt": {
      "type": "common-transformational-scent-blocks",
      "blocks": {
        "image_NUyncU": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/gy2.jpg",
            "tag": "Summer Seasonal",
            "heading": "Geranium & Ylang Ylang",
            "details": "Geranium and Ylang Ylang combine with ho wood and clary sage, to transform your home into a tropical paradise.",
            "textFontStyle": "normal",
            "infoHeading": "Blend details",
            "infoDetails": "<p class=\"value-bold blue-text\">Middle Notes:</p><ul>\n<li>Geranium - Intensely floral, sweet and rosy oil that has a calming and grounding effect.</li>\n<li>Ho Wood - Sweet and floral, Ho Wood essential oil promotes peace and tranquility.</li>\n<li>Coriander - an invigorating, stimulating oil with a powerful, sweet, somewhat spicy and warm aroma, with a lively woody/peppery top note and a balsamic undertone.</li>\n</ul><p class=\"value-bold blue-text\">Base Notes:</p><ul>\n<li>Clary Sage - Clary sage smells sweet and herbaceous with ambery tones of fresh tobacco. The oil promotes inner tranquility and dispels negativity.</li>\n<li>Ylang Ylang - a deep, rich floral aroma that's slightly sweet and promotes relaxation and can kill bacteria and lower blood pressure.</li>\n</ul>"
          }
        },
        "image_amV9bi": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/cn.jpg",
            "tag": "Summer Seasonal",
            "heading": "Citronella & Niaouli",
            "details": "A powerful, fly-repelling blend of citronella java, eucalyptus and peppermint with camphorous niaouli.",
            "textFontStyle": "normal",
            "infoHeading": "Blend details",
            "infoDetails": "<p class=\"value-bold blue-text\">Top Notes:</p><ul>\n<li>Citronella Java - A fresh and citrusy oil with natural insect repellent properties. </li>\n<li>Eucalyptus Peppermint - A fresh and uplifting,insect-repelling scent with a woody-sweet undertone.</li>\n</ul><p class=\"value-bold blue-text\">Middle Notes:</p><ul>\n<li>Niaouli - A camphorous oil with a fresh, minty aroma and eucalyptus-like scent.</li>\n<li>Lavender - Fresh and grassy, this fragrant oil freshens and softens the blend.</li>\n<li>Geranium - a floral and rosy oil that creates a calming and grounding effect.</li>\n</ul>"
          }
        },
        "image_eptkyj": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/LL.jpg",
            "tag": "Summer Seasonal",
            "heading": "Linden & Lavender",
            "details": "A sweet blend of sparkling grapefruit, linden blossom, citrusy neroli and lavender for summer freshness.",
            "textFontStyle": "normal",
            "infoHeading": "Blend details",
            "infoDetails": "<p class=\"value-bold blue-text\">Top Notes:</p><ul><li>White Grapefruit - A sweet and fruity oil that’s known for its uplifting and energising properties.</li></ul><p class=\"value-bold blue-text\">Middle Notes:</p><ul>\n<li>Linden Blossom - Extracted from the delicate, yellow flowers of the Linden tree - it’s a warm, floral and somewhat honey-like aroma with relaxing effects.</li>\n<li>Neroli - Extracted from the flowers of bitter orange trees, this oil has a sweet, floral, citrus aroma.</li>\n<li>Lavender - A delicate, floral scent with grassy, herbal notes. Famed for its calming, sedative properties.</li>\n</ul>"
          }
        }
      },
      "block_order": [
