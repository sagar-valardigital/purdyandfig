            "tag": "Winter",
            "heading": "Cedarwood & Lavender",
            "details": "A blend of chamomile, lavender, and red cedarwood, like a bed freshly made with line-dried linen.",
            "expend-label": "BLEND DETAILS",
            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Middle Notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Lavender</span><br>Fresh and floral\n        </li>\n<li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Roman Chamomile</span><br>Warm and sweet with a hint of green apple\n        </li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Base Notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Red Cedarwood</span><br>Sweet and balsamic\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Vetiver</span><br>Smoky, woody and earthy\n        </li>\n    </ul>\n</div>"
          }
        },
