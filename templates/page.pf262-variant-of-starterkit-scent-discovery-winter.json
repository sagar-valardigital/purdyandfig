            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Top Notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Eucalyptus Blue Gum</span><br>Camphoraceous and medicinal\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Peppermint</span><br>Minty and herbaceous\n        </li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle Notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Cardamom</span><br>Spicy and warm\n        </li>\n<li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Lavandin</span><br>Floral and woody-herbaceous\n        </li>\n<li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Sweet marjoram</span><br>Warm and delicately floral\n        </li>\n<li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Oregano</span><br>Medicinal and herbaceous-camphoraceous\n        </li>\n    </ul>\n</div>"
          }
        },
        "seasonal_GrKaCV": {
          "type": "seasonal",
          "settings": {
            "blockImage": "shopify://shop_images/3_886e6325-105d-4c8c-a3fa-ae47618ae7bc.jpg",
            "mBlockImage": "shopify://shop_images/3_886e6325-105d-4c8c-a3fa-ae47618ae7bc.jpg",
            "tag": "Winter",
            "heading": "Fir & Bergamot",
            "details": "Siberian fir, bergamot, lavender, clary sage and patchouli. Green and coniferous, like a stroll through a pine forest.",
            "expend-label": "BLEND DETAILS",
            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Top Notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Siberian Fir</span><br>A coniferous, piney and woody scent\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Bergamot</span><br>Fresh, sweet and citrusy\n        </li>\n       \n    </ul>\n</div>\n\n<div>\n    <h4 class=\"font-lausanne\">Middle Notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Lavender</span><br>Floral and herbaceous\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Clary Sage</span><br>Floral and slightly fruity\n        </li>\n       \n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Base Notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Patchouli</span><br>A deep, distinctive and earthy aroma\n        </li>\n    </ul>\n</div>"
          }
        },
        "seasonal_CLakRK": {
          "type": "seasonal",
          "settings": {
            "blockImage": "shopify://shop_images/2_d684e6fa-2bd8-4324-9d59-7edf2068bed4.jpg",
