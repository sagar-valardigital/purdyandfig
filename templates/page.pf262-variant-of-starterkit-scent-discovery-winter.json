            "expendable-content1": "<div>\n    <h4 class=\"font-lausanne\">Top Notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Lemon Peel</span><br>A fresh and cheerful citrus oil\n        </li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle Notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Rose Geranium</span><br>A rich, floral aroma\n        </li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Base Notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Vetiver Root</span><br>A calming, earthy and grassy scent\n        </li>\n    </ul>\n</div>"
