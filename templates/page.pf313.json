    "faq_section_2_FUFBYY": {
      "type": "faq-section-2",
      "blocks": {
        "d5f0750c-d1c1-4e82-bde9-e538cec56d97": {
          "type": "text",
          "settings": {
            "open": true,
            "faq-question": "Is this an extra subscription?",
            "faq-ans": "<p>Yes, Lava is only available as a subscription. When you subscribe, you’ll receive a fresh refill every 90 days, automatically delivered to your door, so you never run out.</p>"
          }
        },
        "text_y7G6KB": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How long will my Lava last?",
            "faq-ans": "<p>It depends on how often you use it, however if you are doing a deep clean once a week, it should last you 90 days.</p>"
          }
        },
        "text_mRx7ee": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "What is Lava made from?",
            "faq-ans": "<p>Lava is primarily made from a mixture of citric acid and sodium bicarbonate—these are the key ingredients that give it its fizz. It also contains surfactants, fragrance, and a few other carefully selected ingredients.</p>"
          }
        },
        "text_Le6e6y": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How does Lava work?",
            "faq-ans": "<p>For a maintenance clean, use one scoop. Sprinkle it around the bowl and into the water rather than throwing it in. Wait 30 to 60 seconds, then brush thoroughly.</p><p>For a quick refresh or to prevent limescale, half a scoop is enough. Gently pour it into the water and leave for about 30 minutes.</p>"
          }
        },
        "text_wxnEDA": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How long will the offer last?",
            "faq-ans": "<p>Lava will only be running for a limited amount of time, so we recommend getting your skates on.</p>"
          }
        },
        "text_pPHx9q": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How do I manage my subscription?",
            "faq-ans": "<p>You can view, manage or cancel your subscription by logging into <a href=\"https://purdyandfigg.com/a/account/login\" title=\"https://purdyandfigg.com/a/account/login\">your account</a> with the email address you used to place your first Purdy & Figg order. Once you’re in, you’ll be able to change your order, adjust your delivery and billing date, or pause your subscription.</p>"
          }
        },
        "text_Fg9K4n": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "Where can I use & store Lava?",
            "faq-ans": "<p>Lava is built to work across your bathroom and can be used on any porcelain surface, much like bleach.</p><p>We have designed the container to be stored on display, but please note keeping it in direct sunlight may impact the product.</p>"
          }
        }
      },
