            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Top notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Citronella</span>\n            <br>\n            Strong and citrusy\n        </li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Niaouli </span>\n            <br>\n            Camphoraceous and peppery\n        </li>\n   \n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Eucalyptus Peppermint </span>\n            <br>\n            Cool, minty and fresh\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Lavender </span>\n            <br>\n            Floral and sweet\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Geranium  </span>\n            <br>\n            Rosy, floral and uplifting\n        </li>\n    </ul>\n</div>"
          }
        },
