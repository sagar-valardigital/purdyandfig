    "89f7223e-f789-4b27-afc8-c0e84caf6b1e": {
      "type": "instapage-info-blocks-3",
      "blocks": {
        "2e8762aa-3676-4082-918c-0ff0dc3de0b9": {
          "type": "text",
          "settings": {
            "image": "shopify://shop_images/64618891-0-reusable4.webp",
            "heading": "Reusable glass bottles",
            "info": "You can use our glass Bottle for Life over and over again, which means you’re not throwing away empty plastic containers every time a cleaning product runs out. The reusable bottle has already helped to keep 250,000 plastic bottles out of landfill. It’s 100% recyclable, which means you don’t have to worry about where it’ll end up if the time does come to part ways."
          }
        },
        "44482f62-abc0-4fe0-bc99-6ea0243aee78": {
          "type": "text",
          "settings": {
            "image": "shopify://shop_images/62829729-0-green.webp",
            "heading": "14x lower carbon emissions",
            "info": "Generic surface cleaners are made of 90% water. Over a billion of them are transported around the world in heavy bottles every year. Purdy & Figg eco-concentrates are 97% lighter to ship, since you dilute the concentrates with water from your tap at home."
          }
        },
        "25bcae65-5251-4959-b087-617afbdffed4": {
          "type": "text",
          "settings": {
            "image": "shopify://shop_images/62830338-0-Screen-Shot-2022-10.webp",
            "heading": "Non-toxic",
            "info": "It’s our mission to put your family first, which is why our eco-concentrates are completely plant-based, paraben-free and GMO-free. We use natural essential oils and no synthetic fragrances or dangerous preservatives whatsoever."
          }
        }
      },
