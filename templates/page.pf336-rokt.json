            "blend": "<div>\n    <h4 class=\"font-lausanne\">Top notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Citronella</span><br>Strong and citrusy</li>\n       \n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Niaouli</span><br>Camphoraceous and peppery</li>\n<li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Eucalyptus Peppermint</span><br>Cool, minty and fresh</li>\n<li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Lavender</span><br>Floral and sweet</li>\n<li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Geranium</span><br>Rosy, floral and uplifting</li>\n    </ul>\n</div>"
