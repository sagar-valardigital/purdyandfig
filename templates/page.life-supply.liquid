{% layout none %} 

<script>

  if(document.referrer.includes('/checkouts/')) {
    
    history.back();
    
  }
  
  else {

items = [
  {
    quantity: 1,
    id: 42300995961059,
    properties:{"Next order":"Your next charge after the 30 day trial will automatically trigger. Then delivery will be every 3 months."},
    selling_plan: 3090317539
  }
]
  data = {'items':items}
  var xhr = new XMLHttpRequest();
  xhr.onreadystatechange = function() {
      if (xhr.readyState === 4){
          window.location.href = '/checkout/';
      }
  };
  xhr.open('POST', '/cart/add.js');
  xhr.setRequestHeader('Content-Type', 'application/json');
  xhr.send(JSON.stringify(data));
    
  }

</script>