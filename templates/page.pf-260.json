    "faq_section_2_FUFBYY": {
      "type": "faq-section-2",
      "blocks": {
        "d5f0750c-d1c1-4e82-bde9-e538cec56d97": {
          "type": "text",
          "settings": {
            "open": true,
            "faq-question": "Is this an extra subscription?",
            "faq-ans": "<p>No, this is a buy-once offer just for our members. You won’t be taking out a new subscription.</p>"
          }
        },
        "text_TA9k4H": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "Why am I getting this offer?",
            "faq-ans": "<p>All our members with active subscriptions get access to member benefits, including limited edition scents and exclusive offers. As a member, concentrate refills are always 15% off.</p>"
          }
        },
        "3bef21b1-6cdf-4174-a35c-01e4fa513c76": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How long will this offer last?",
            "faq-ans": "<p>This scent will be available until Valentine's Day or until this limited edition scent lasts, so we recommend getting your skates on.</p>"
          }
        },
        "3c474819-85aa-4a9a-bcc0-dc1e0f54550d": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How do I manage my subscription?",
            "faq-ans": "<p>You can view, manage or cancel your subscription by logging into your account with the email address you used to place your first Purdy & Figg order. Once you’re in, you’ll be able to tweak your subscription however you like. You can change what’s in your order, adjust your delivery and billing date, or pause deliveries completely for a bit.</p>"
          }
        },
        "b3da5911-c83c-46b6-b545-797e91781fff": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How can I track my order?",
            "faq-ans": "<p>We aim to send your products within one working day of receiving your order, and for you to receive it within 48 hours of it being dispatched. For orders being shipped to Europe, please allow two to seven working days from dispatch.<br/>If your order tracking shows it’s been five working days or more since the last tracking scan, please do give us a shout and a member of our Customer Experience team will get back to you as soon as possible.</p>"
          }
        }
      },
