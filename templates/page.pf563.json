            "blend": "<div>\n    <h4 class=\"font-lausanne\">Top notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Lime</span><br>Zesty and juicy</li>\n          <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Cis-3-Hexenyl Acetate</span><br>Crisp and green\n</li>\n         <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Gamma Dodecalactone</span><br>Creamy and fruity</li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Eucalyptus\n</span><br>Cool and fresh</li>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Cardamom\n</span><br>Warm and woody</li>\n       <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Rosemary\n</span><br>Herbal and aromatic</li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Base notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Elemi</span><br>Citrusy and peppery</li>\n       <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Cananga</span><br>Floral and creamy</li>\n    </ul>\n</div>"
          }
