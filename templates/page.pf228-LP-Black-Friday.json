            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Lavender</span><br>A delicate, floral scent with grassy, herbal notes. Famed for its calming, sedative properties.\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Geranium</span><br>A sweet, floral oil with a grounding effect.\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Clary Sage</span><br>A sweet and herbaceous oil that promotes inner tranquility.\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Roman Chamomile</span><br>A calming, warm and grounding aroma.\n        </li>\n    </ul>\n</div>"
          }
        },
        "seasonal_CLakRK": {
          "type": "seasonal",
          "settings": {
            "blockImage": "shopify://shop_images/Patchouli_Cedarwood_a9a0cfcd-5224-4a37-bb45-f648e122bc2b.png",
            "mBlockImage": "shopify://shop_images/Patchouli_Cedarwood_a9a0cfcd-5224-4a37-bb45-f648e122bc2b.png",
            "tag": "",
            "heading": "Patchouli & Cedarwood",
            "details": "A rich blend inspired by scented wooden chests filled with silk.",
            "expend-label": "BLEND DETAILS",
            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Top notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">May Chang</span><br>An intensely fresh and citrusy aroma, with insecticidal and calming properties.\n        </li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Palmarosa</span><br>A sweet, floral-rosy oil that’s antimicrobial and repels insects.\n        </li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Base notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Red Cedar</span><br>A woody, sweetly balsamic aroma, good for masking scents moths are drawn to.\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Patchouli</span><br>A rich, herbaceous aroma and traditional moth and insect repellent.\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Amyris</span><br>A subtle, woody and sweetly balsamic scent with antiseptic and sedative qualities.\n        </li>\n    </ul>\n</div>"
          }
        },
