    "faq_section_reskin_ALn44g": {
      "type": "faq-section-reskin",
      "blocks": {
        "text_wwqHGw": {
          "type": "text",
          "settings": {
            "open": true,
            "faq-question": "How do I know if I’ve won?",
            "faq-ans": "<p>At the end of each day within the 14-day period, our customer service team will choose one lucky winner at random who will receive the Summer Seasonal Starter Kit for free and confirmation of the following year’s worth of Purdy & Figg seasonal concentrates.</p>"
          }
        },
        "text_KaAzJT": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "What happens if I win?",
            "faq-ans": "<p>Each winner will receive our Summer Seasonal Starter Kit, followed by three seasonal concentrates delivered every three months for three cycles thereafter. All for free.</p>"
          }
        },
        "text_RAWacP": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "Can I enter more than once?",
            "faq-ans": "<p>Everyone deserves a fair chance of winning, so only one entry per user (email address) will be deemed valid.</p>"
          }
        },
        "text_nfmURN": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "Where can I read the full terms?",
            "faq-ans": "<p>You can read the full Terms & Conditions <a href=\"/pages/seasonalannualgiveaway-terms-of-services\" target=\"_blank\" title=\"P&F Seasonal Giveaway - Annual Subscription - T&Cs\"><strong>here</strong></a></p>"
          }
        },
        "text_QygHrY": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How do I use Counter Clean?",
            "faq-ans": "<p>To use Counter Clean, simply pour the whole 20ml bottle of cleaning concentrate into your Bottle for Life and slowly fill to the top (just below the neck) with tap water. Give the bottle a gentle shake to mix, then enjoy your uplifting clean!</p>"
          }
        },
        "text_HkQc97": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "Which surfaces is Counter Clean suitable for?",
            "faq-ans": "<p>We're pleased to say that Counter Clean is pH neutral, which means it’s safe to use on most surfaces. That includes softer materials like aluminium, wood, stone, quartz and other sealed surfaces. We do recommend patch testing first on any particularly sensitive or precious surfaces you’re concerned about. Just spray onto a cloth and wipe a small patch to see the results. </p>"
          }
        },
        "text_TLFd9j": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How many uses will I get out of a bottle?",
            "faq-ans": "<p>A 300ml bottle of Counter Clean (including one 20ml concentrate) contains about 230 sprays. A typical household will get through one of our 300ml bottles in two to four weeks, unless you get a bit addicted to wiping down your surfaces like we have!</p>"
          }
        }
      },
