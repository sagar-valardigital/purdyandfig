    "d1fc3792-1def-4a58-aa64-e51227d2a890": {
      "type": "faq-section",
      "blocks": {
        "3d12868e-dcb2-4150-9193-c123de49fd84": {
          "type": "text",
          "settings": {
            "faq-question": "How many uses will I get out of a bottle?",
            "faq-ans": "<p>Each eco-concentrate dilutes to 300ml of Counter Clean. We recommend using one eco-concentrate per month. The Starter Kit is designed to last you 90 days.</p>"
          }
        },
        "772613d3-6cdb-40a4-a467-f4af3df956a3": {
          "type": "text",
          "settings": {
            "faq-question": "Is this more expensive than a regular cleaner?",
            "faq-ans": "<p>Counter Clean costs 16p per day which is 3p more than a typical bottle of supermarket cleaner. However, we replace up to 15 different products under your sink so end up saving you money.</p>"
          }
        },
        "fdb51482-bfb5-461b-838c-79f9db18683a": {
          "type": "text",
          "settings": {
            "faq-question": "How can I be sure it works?",
            "faq-ans": "<p>Our product has been independently tested and proven to be 100% effective at tackling grease, grim and dirt. 93% of our customers would recommend us for our cleaning power.</p>"
          }
        },
        "eed257d4-58fa-44af-9aa3-63a88626d84b": {
          "type": "text",
          "settings": {
            "faq-question": "Is it safe around pets?",
            "faq-ans": "<p>Our founders are pet fantatics and our products have been designed to be safe for use around dogs and other pets. We don't recommend cleaning pet beds or food bowls without rinsing afterwards. If you are worried about allergies, do contact your vet.</p>"
          }
        },
        "a7917ddd-b7fb-4ca8-9bf4-cb6a655f9a5f": {
          "type": "text",
          "settings": {
            "faq-question": "Is it Cruelty Free?",
            "faq-ans": "<p>Yes, Counter Clean has never been tested on animals. We also only work with suppliers who also avoid testing on animals too!</p>"
          }
        },
        "86ebe38d-f956-4264-b4ce-22a9e661af75": {
          "type": "text",
          "settings": {
            "faq-question": "Is it safe to use on all my surfaces?",
            "faq-ans": "<p>Counter Clean has been designed to be used on all surfaces, including softer surfaces like aluminium, wood, stone or any other porous surfaces.</p>"
          }
        }
      },
