    "11e26e64-5410-48f9-9c9a-3698a74d1770": {
      "type": "two-women-2",
      "custom_css": [],
      "settings": {
        "className": "two-women-wrapper-2",
        "background": "",
        "layout": false,
        "main_heading": "Two Women On A Mission",
        "sub_heading": "Two best friends Charlotte Figg and Purdy Rubin got together on a mission to<br>make cleaning products that were safe and they loved using for their home.",
        "heading": "",
        "image": "shopify://shop_images/c0855ba36e497bb2acf6ef7605222d4a.jpg",
        "details": "<div class=\"value-sans\">\n<p class=\"blue-text value-medium\">Fed up with highly toxic cleaning products in plastic packaging, the two friends decided to do something about it.</p>\n<span class=\"gray-text\">They both firmly believed in the power of natural cleaning and its benefit to health &amp; home, so in true Breaking Bad style, they started experimenting with formulas in their garage. It's there that they conjured up their first product, a multi-surface cleaner infused with pure essential oils, Counter Clean.</span>\n</div>"
      }
    },
