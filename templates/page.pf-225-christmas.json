    "pf119_seasonal_scents_UUe6fb": {
      "type": "pf181-expend-blocks",
      "blocks": {
        "image_GymrGe": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/Desktop_1_5266d233-ea3b-40d6-a367-63c2bfd28fdb.jpg",
            "mBlockImage": "shopify://shop_images/Mobile_1_c504fdb6-7e42-4c09-9163-f0a2b853cb69.jpg",
            "tag": "Limited Edition",
            "heading": "Frankincense & Myrrh",
            "details": "A blend of frankincense & myrrh with citrusy and smoky undertones. Inspired by Purdy & Charlotte’s festive memories.",
            "expend-label": "blend details",
            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Top notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Sweet Orange</span><br>An uplifting, sweet-citrus aroma</li>\n<li class=\"font-lausanne fw-200\">\n    <span class=\"fw-400\">Pink Grapefruit</span><br>Zesty, sweet and tangy</li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Coriander Seed</span><br>Spicy and warm</li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Base notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Frankincense</span><br>Woody and resinous</li>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Myrrh</span><br>Earthy and balsamic</li>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Vetiver</span><br>A deep, smoky aroma</li>\n    </ul>\n</div>"
          }
        },
        "image_Fcyxqk": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/Desktop_3_6aae1214-afbd-4e18-8c64-5f2a517a3037.jpg",
            "mBlockImage": "shopify://shop_images/Mobile_3_44417794-2127-43ad-8be4-eca0cda4f7e0.jpg",
            "tag": "Member exclusive",
            "heading": "Orange & Clove",
            "details": "A classically Christmas blend of orange, clove and benzoin. Inspired by the scent of traditional Christmas pomanders.",
            "expend-label": "blend details",
            "expendable-content": "<div>\n<h4 class=\"font-lausanne\">Top notes</h4>\n<ul>\n<li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Sweet Orange</span><br>Uplifting and citrusy</li>\n</ul>\n</div>\n<div>\n<h4 class=\"font-lausanne\">Middle notes</h4>\n<ul>\n<li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Spicy Clove</span><br>Woody and warming</li>\n</ul>\n</div>\n<div>\n<h4 class=\"font-lausanne\">Base notes</h4>\n<ul>\n<li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Benzoin</span><br>Rich and creamy</li>\n</ul>\n</div>"
