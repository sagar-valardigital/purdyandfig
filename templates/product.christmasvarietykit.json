        "cfce42e2-4ceb-4988-82bc-b5024542f18b": {
          "type": "productdes",
          "settings": {
            "productSelection": "christmas-variety-kit",
            "DescriptionHeading": "Overview",
            "description": "The Limited Edition Christmas Variety Kit includes our glass Bottle For Life and four eco-concentrate refills in our three signature scents and our limited edition Christmas scent Frankincense &amp; Myrrh blend. \n<p> </p>\nPour an entire 20ml concentrate into your Bottle for Life and top up with ordinary tap water to make up a 300ml naturally-scented, multisurface cleaner.\n<p> </p>\nShips in 3-5 Days Due to High Demand"
          }
        },
        "4cc01513-34b5-45cf-b953-06211932584a": {
          "type": "productdes",
          "settings": {
            "productSelection": "christmas-variety-kit",
            "DescriptionHeading": "Scent Information",
            "description": "Uplifting Citrus: A characterful blend of Sweet Orange, Grapefruit &amp; Naouli that's easy to love with a refreshing, juicy scent and cheerful, mood-enhancing properties.\n<p> </p>\nBalancing Floral: A beautifully floral blend of Rose Geranium, Lemon Peel and Vetiver Roots, known for their comforting &amp; balancing properties\n<p> </p>\nGrounding Vetiver: A complex and invigorating scent with an earthy blend of Sweet Orange, Coriander Seed and Vetiver, known for their calming &amp; grounding effects.\n<p> </p>\nFrankincense &amp; Myrrh: A festive blend of Frankincense &amp; Myrrh essential oils with fresh and citrusy grapefruit and sweet orange and grounding, comforting vetiver &amp; coriander seed."
          }
        },
        "563eeda1-b6c6-4adf-9764-f118bc95a0ea": {
          "type": "productdes",
          "settings": {
            "productSelection": "christmas-variety-kit",
            "DescriptionHeading": "What's inside the Box?",
