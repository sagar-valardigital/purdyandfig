    "pf119_seasonal_scents_UUe6fb": {
      "type": "pf181-expend-blocks",
      "blocks": {
        "image_GymrGe": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/1_2_9cd30f5c-a5c7-4aa1-88c0-e3029bf684f9.jpg",
            "mBlockImage": "shopify://shop_images/1_509d5515-b98c-4724-aeaf-0cd15db51f20.jpg",
            "tag": "",
            "heading": "Peppermint & Eucalyptus",
            "details": "A blend of eucalyptus and peppermint with cardamom, oregano and marjoram. Clean and cool, like crisp mountain air.",
            "expend-label": "blend details",
            "expendable-content": "<div>\n        <h4 class=\"font-lausanne\">Top notes</h4>\n        <ul>\n            <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Eucalyptus Blue Gum</span><br>Camphoraceous and medicinal</li>\n            <li class=\"font-lausanne\">\n<span class=\"fw-400\">Peppermint</span><br>Minty and herbaceous</li>\n        </ul>\n    </div>\n    <div>\n        <h4 class=\"font-lausanne\">Middle notes</h4>\n        <ul>\n            <li class=\"font-lausanne\">\n<span class=\"fw-400\">Cardamom</span><br>Spicy and warm \n</li>\n<li class=\"font-lausanne\">\n<span class=\"fw-400\">Lavandin</span><br>Floral and woody-herbaceous \n</li>\n<li class=\"font-lausanne\">\n<span class=\"fw-400\">Sweet marjoram</span><br>Warm and delicately floral\n</li>\n<li class=\"font-lausanne\">\n<span class=\"fw-400\">Oregano</span><br>Medicinal and herbaceous-camphoraceous\n</li>\n        </ul>\n    </div>"
          }
        },
        "image_MwnAJy": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/2_2_2427d0e0-9fe5-4a18-a604-f801f171fea4.jpg",
            "mBlockImage": "shopify://shop_images/2_3b5b2585-03aa-4463-8276-e57d6f3470b6.jpg",
            "tag": "",
            "heading": "Fir & Bergamot",
            "details": "Siberian fir, bergamot, lavender, clary sage and patchouli. Green and coniferous, like a fragrant pine forest.",
            "expend-label": "blend details",
            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Top notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Siberian Fir</span><br>A coniferous, piney and woody scent</li>\n<li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Bergamot</span><br>Fresh, sweet and citrusy</li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Lavender</span><br>Floral and herbaceous</li>\n<li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Clary Sage</span><br>Floral and slightly fruity</li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Base notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Patchouli</span><br>A deep, distinctive and earthy aroma</li>\n    </ul>\n</div>"
          }
        },
