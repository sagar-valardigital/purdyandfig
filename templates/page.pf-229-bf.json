          }
        },
        "image_Fcyxqk": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/FM.png",
            "mBlockImage": "shopify://shop_images/Scent_Block_2_Mobile.jpg",
            "tag": "Limited Edition",
            "heading": "Frankincense & Myrrh",
            "details": "A blend of frankincense, myrrh and smoky undertones. Inspired by Purdy & Charlotte’s festive memories.",
            "expend-label": "blend details",
            "expendable-content": "<h4 class=\"font-lausanne\">Top notes</h4>\n    <ul>\n         <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Sweet Orange</span><br>An uplifting, sweet-citrus aroma</li>\n<li class=\"font-lausanne fw-200\">\n    <span class=\"fw-400\">Pink Grapefruit</span><br>Zesty, sweet and tangy</li>\n    </ul>\n\n<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Coriander Seed</span><br>Spicy and warm</li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Base notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Frankincense</span><br>Woody and resinous</li>\n<li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Myrrh</span><br>Earthy and balsamic</li>\n<li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Vetiver</span><br>A deep, smoky aroma</li>\n    </ul>\n</div>"
