    "img_text_blocks_ykdU4h": {
      "type": "img-text-blocks",
      "blocks": {
        "image_with_text_qKGHBH": {
          "type": "Image_with_Text",
          "settings": {
            "width": "w-80",
            "layout": false,
            "heading": "Reusable glass bottles",
            "image": "shopify://shop_images/Image_c68889e8-5b74-48bd-a426-87ff3f263182.png",
            "mimage": "shopify://shop_images/Image_9345c533-1262-4129-a6d9-4ddbc510f321.png",
            "details": "You can use our glass Bottle for Life over and over again, which means you’re not throwing away empty plastic containers every time a cleaning product runs out. The reusable bottle has already helped to keep 1.2 million plastic bottles out of landfill. It’s 100% recyclable, which means you don’t have to worry about where it’ll end up if the time does come to part ways."
          }
        },
        "image_with_text_fbqzm9": {
          "type": "Image_with_Text",
          "settings": {
            "width": "w-90",
            "layout": true,
            "heading": "14 x lower carbon emissions",
            "image": "shopify://shop_images/14x.png",
            "mimage": "shopify://shop_images/14x.png",
            "details": "Generic surface cleaners are made of 90% water. Over a billion of them are transported around the world in heavy bottles every year. Purdy &amp; Figg eco-concentrates are 97% lighter to ship, since you dilute the concentrates with water from your tap at home."
          }
        },
        "image_with_text_XRdKRf": {
          "type": "Image_with_Text",
          "settings": {
            "width": "w-80",
            "layout": false,
            "heading": "Non-toxic",
            "image": "shopify://shop_images/Non_toxic.png",
            "mimage": "shopify://shop_images/Non_toxic.png",
            "details": "It’s our mission to put your family first, which is why our eco-concentrates are completely plant-based, paraben-free and GMO-free. We use natural essential oils and no synthetic fragrances or dangerous preservatives whatsoever."
          }
        }
      },
