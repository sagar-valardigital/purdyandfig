    "pf181_expend_blocks_ndxLFF": {
      "type": "pf181-expend-blocks",
      "blocks": {
        "image_prBBn8": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/1_d6fae610-3512-423c-9449-f6680535b30a.jpg",
            "mBlockImage": "shopify://shop_images/1_d6fae610-3512-423c-9449-f6680535b30a.jpg",
            "tag": "",
            "heading": "Peppermint & Eucalyptus",
            "details": "A blend of eucalyptus and peppermint with cardamom, oregano and marjoram. Clean and cool, like crisp mountain air.",
            "expend-label": "blend details",
            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Top notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Eucalyptus Blue Gum</span>\n            <br>\n           Camphoraceous and medicinal\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Peppermint</span>\n            <br>\n            Minty and herbaceous\n        </li>\n       \n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Cardamom</span>\n            <br>\n             Spicy and warm\n        </li>\n<li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Lavandin</span>\n            <br>\n             Floral and woody-herbaceous\n        </li>\n<li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Sweet marjoram</span>\n            <br>\n             Warm and delicately floral\n        </li>\n<li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Oregano</span>\n            <br>\n             Medicinal and herbaceous-camphoraceous\n        </li>\n    </ul>\n</div>"
          }
        },
        "image_UmBWtk": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/Desktop_Fir_Bergamot.jpg",
            "mBlockImage": "shopify://shop_images/Mobile_Fir_Bergamot.jpg",
            "tag": "",
            "heading": "Fir & Bergamot",
            "details": "Siberian fir, bergamot, lavender, clary sage and patchouli. Green and coniferous, like a fragrant pine forest.",
            "expend-label": "blend details",
            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Top notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Siberian Fir</span>\n            <br>\n           A coniferous, piney and woody scent\n        </li>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Bergamot</span>\n            <br>\n            Fresh, sweet and citrusy\n        </li>\n       \n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Lavender</span>\n            <br>\n             Floral and herbaceous \n        </li>\n<li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Clary Sage</span>\n            <br>\n             Floral and slightly fruity\n        </li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Base notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n            <span class=\"fw-400\">Patchouli</span>\n            <br>\n            A deep, distinctive and earthy aroma\n        </li>\n    </ul>\n</div>\n<div></div>"
          }
        },
        "image_8BaGJY": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/Desktop_Cedarwood_Lavender.jpg",
            "mBlockImage": "shopify://shop_images/Mobile_Cedarwood_Lavender.jpg",
