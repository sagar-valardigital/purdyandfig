    "pf181_expend_blocks_MFq7hH": {
      "type": "pf181-expend-blocks",
      "blocks": {
        "image_GymrGe": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/d-seasonal-1.png",
            "mBlockImage": "shopify://shop_images/m-seasonal-1.png",
            "tag": "",
            "heading": "Juniper & Cardamom",
            "details": "Inspired by a crisp, cold G&T. Uplifting and buoyant, like a brisk walk on an autumn morning.",
            "expend-label": "blend details",
            "expendable-content": "<div>\n        <h4 class=\"font-lausanne\">Top notes</h4>\n        <ul>\n            <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Lemon</span><br>A fresh, citrusy and uplifting aroma. Light and sharp, like slicing fruit.</li>\n            <li class=\"font-lausanne\">\n<span class=\"fw-400\">Cardamom</span><br>A warm and spicy oil with a woody-balsamic undertone and a hint of eucalyptus.</li>\n        </ul>\n    </div>\n    <div>\n        <h4 class=\"font-lausanne\">Middle notes</h4>\n        <ul>\n            <li class=\"font-lausanne\">\n<span class=\"fw-400\">Juniper</span><br>A purifying oil with a fresh, clean aroma and peppery, woody undertones.</li>\n        </ul>\n    </div>"
          }
        },
        "image_Fcyxqk": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/d-seasonal-2.png",
            "mBlockImage": "shopify://shop_images/m-seasonal-2.png",
            "tag": "",
            "heading": "Lavender & Chamomile",
            "details": "Soft and comforting; a classic marriage of fresh herbs, inspired by carefree weekends at a country spa.",
            "expend-label": "blend details",
            "expendable-content": "<div>\n        <h4 class=\"font-lausanne\">Middle notes</h4>\n        <ul>\n            <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Lavender</span><br>A delicate, floral scent with grassy, herbal notes. Famed for its calming, sedative properties.</li>\n            <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Geranium</span><br>A sweet, floral oil with a grounding effect.  </li>\n            <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Clary Sage</span><br>A sweet and herbaceous oil that promotes inner tranquility.</li>\n            <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Roman Chamomile </span><br>A calming, warm and grounding aroma.</li>\n        </ul>\n    </div>"
          }
        },
        "image_MwnAJy": {
          "type": "image",
          "settings": {
            "blockImage": "shopify://shop_images/d-seasonal-3.png",
            "mBlockImage": "shopify://shop_images/m-seasonal-3.png",
            "tag": "",
            "heading": "Patchouli & Cedarwood",
            "details": "Refreshed and relaxed, with spicy undertones and a sherbert-like twist. Rumour has it moths aren’t keen!",
            "expend-label": "blend details",
            "expendable-content": "<div>\n    <h4 class=\"font-lausanne\">Top notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">May Chang</span><br>An intensely fresh and citrusy aroma, with insecticidal and calming properties.</li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Middle notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Palmarosa</span><br>A sweet, floral-rosy oil that’s antimicrobial and repels insects. </li>\n    </ul>\n</div>\n<div>\n    <h4 class=\"font-lausanne\">Base notes</h4>\n    <ul>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Red Cedar</span><br>A woody, sweetly balsamic aroma, good for masking scents moths are drawn to. </li>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Patchouli</span><br>A rich, herbaceous aroma and traditional moth and insect repellent. </li>\n        <li class=\"font-lausanne fw-200\">\n<span class=\"fw-400\">Amyris</span><br>A subtle, woody and sweetly balsamic scent with antiseptic and sedative qualities. </li>\n    </ul>\n</div>"
          }
        }
      },
