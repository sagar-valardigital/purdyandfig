    "a2194449-184e-4118-8225-9a59caeea728": {
      "type": "faq-section-2",
      "blocks": {
        "d5f0750c-d1c1-4e82-bde9-e538cec56d97": {
          "type": "text",
          "settings": {
            "open": true,
            "faq-question": "Is this an extra subscription?",
            "faq-ans": "<p>No, this is a buy-once offer exclusively for members, so you won’t be taking out an additional subscription.</p>"
          }
        },
        "text_A3DYFX": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "Why do I have access to this offer?",
            "faq-ans": "<p>All our members with active subscriptions get access to member benefits, including limited edition scents and exclusive offers. As a member, concentrate refills are always 15% off.</p>"
          }
        },
        "3bef21b1-6cdf-4174-a35c-01e4fa513c76": {
          "type": "text",
          "disabled": true,
          "settings": {
            "open": false,
            "faq-question": "How long will this offer last?",
            "faq-ans": "<p>This is a limited time offer that’ll last while there’s supply of our Seasonal Scents. We recommend you snap yours up straight away if you’re keen to try our latest seasonal range.</p>"
          }
        },
        "3c474819-85aa-4a9a-bcc0-dc1e0f54550d": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How do I cancel my subscription?",
            "faq-ans": "<p>To manage or cancel your subscription, log into your account using the email address you used to place your original order. Once logged in, you’ll be able to edit your subscription however you choose. We offer lots of subscription options, including switching your scent refill pack, changing the frequency of your deliveries or cancelling your membership altogether. Subscriptions are set to a 90-day frequency by default, but you can always move your next billing date if you need to in a few easy steps. We understand there might be times when you need to stop your deliveries, and we’ll always respect your decision to leave - even if we’ll miss you.</p>"
          }
        },
        "b3da5911-c83c-46b6-b545-797e91781fff": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How long does delivery take?",
            "faq-ans": "<p>We do our best to dispatch your order within one working day of receiving it. Once it’s been dispatched, we aim to have it delivered within 48 hours (or two to seven working days for orders being shipped to Europe). If you can see from your tracking that it’s been five working days or more since the last tracking scan, please drop our Customer Service team a note and they’ll give you a hand.</p>"
          }
        },
        "29134be3-da11-47cf-a53b-7f88d2bbe596": {
          "type": "text",
          "disabled": true,
          "settings": {
            "open": false,
            "faq-question": "Are your products safe for pets?",
            "faq-ans": "<p>We would like to reassure you that our products are safe to use around dogs and other domestic pets. If you are worried about allergies, please do contact your vet first, and if you have a pet bird or birds, you will know that they are particularly sensitive to airborne substances, so it is best to take them out of the room while you clean. Additionally, it's important to note that Ylang Ylang and Citronella are toxic to dogs when they are ingested or applied topically, which we would never recommend. Please do not let your pets lick or drink Counter Clean.</p>"
          }
        }
      },
