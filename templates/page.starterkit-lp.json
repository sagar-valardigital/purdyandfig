    "a2194449-184e-4118-8225-9a59caeea728": {
      "type": "faq-section-2",
      "blocks": {
        "d5f0750c-d1c1-4e82-bde9-e538cec56d97": {
          "type": "text",
          "settings": {
            "open": true,
            "faq-question": "How can I be sure it works?",
            "faq-ans": "<p>Our product is completely effective at tackling grease, grim and dirt. What’s more, 93% of our 100k customers would recommend us for our cleaning power.</p>"
          }
        },
        "3bef21b1-6cdf-4174-a35c-01e4fa513c76": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "What ingredients give Counter Clean its powerful cleaning properties?",
            "faq-ans": "<p>Counter Clean contains powerful surfactants with hydrophilic heads and hydrophobic tails that form micelles, which allows it to encapsulate grease and grime, and remove it from any surface.</p>"
          }
        },
        "3c474819-85aa-4a9a-bcc0-dc1e0f54550d": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "Is it safe to use on all my surfaces?",
            "faq-ans": "<p>Counter Clean can be used on all surfaces, including softer surfaces like aluminium, wood, stone or any other porous surfaces.</p>"
          }
        },
        "b3da5911-c83c-46b6-b545-797e91781fff": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "How many uses will I get out of a bottle?",
            "faq-ans": "<p>Each concentrate dilutes to 300ml of Counter Clean, we recommend using one refill per month. The Starter Kit is designed to last you 3 months.</p>"
          }
        },
        "29134be3-da11-47cf-a53b-7f88d2bbe596": {
          "type": "text",
          "settings": {
            "open": false,
            "faq-question": "Is it safe around pets?",
            "faq-ans": "<p>Our products are safe to use around dogs and other pets, however, it's best not to use them to clean beds or food bowls without rinsing afterwards. If you are worried about allergies, do contact your vet.</p>"
          }
        },
        "text_GBEb3b": {
