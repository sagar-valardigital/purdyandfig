    "4f5b5391-b1ab-4116-9ae8-7c2e152c9c8d": {
      "type": "review-slider-4",
      "blocks": {
        "d68c0270-9f27-4238-bdf0-1ea41155f1a5": {
          "type": "text",
          "settings": {
            "heading": "Bliss in a bottle!!!",
            "review": "I have a cleaning business and I am always trying new products, I have now stopped buying anything else other than Purdy & Figg products! I absolutely love everything and all of my customers love it also! A good few of them have gone on to buy from you. Lime & Lemongrass is my favourite scent and cleans effortlessly.",
            "userName": "Gillian T.",
            "poster": "shopify://shop_images/f5ada179-a13d-4870-873a-8f99d0729def_full_s.png",
            "videoURL": "https://cdn.shopify.com/videos/c/o/v/b4c01284cd8547a090756bed9532fadc.mp4",
            "autoplay": true
          }
        },
        "b61362f4-49c7-4865-ab91-c3f0e90c998e": {
          "type": "text",
          "settings": {
            "heading": "Brilliant!",
            "review": "I have been using the counter clean for all sorts of places. There have been marks on our wood floor since we moved in. I have tried many things to get them off. One spray of Purdy and Figg removed the marks!",
            "userName": "Susan T.",
            "poster": "shopify://shop_images/f5ada179-a13d-4870-873a-8f99d0729def_full_size_1_1.png",
            "videoURL": "",
            "autoplay": false
          }
        },
        "e77e13cc-7b69-4b41-982c-6a94724f7795": {
          "type": "text",
          "settings": {
            "heading": "eco Surface cleaner",
            "review": "I was sceptical about these little beauties. But honestly they leave everything they touch looking like new. My taps, handles, toaster, microwave, metal bin all look new! What can I say that hasn’t been said about the fragrances. Pure pleasure to clean the whole place! Thank you Purdy & Figg! 👍",
            "userName": "Carl F.",
            "poster": "shopify://shop_images/43108203-5434-4c9c-b1d8-9bb4e1cad047_full_size_1.png",
            "videoURL": "",
            "autoplay": false
          }
        }
      },
      "block_order": [
