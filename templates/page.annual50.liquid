{% layout none %} 

<script>

  if(document.referrer.includes('/checkouts/')) {
    
    history.back();
    
  }
  
  else {

items = [
  {
    quantity: 1,
    id: 42955566481635,
  },
  {
    quantity: 1,
    id: 42468003250403,
  },
  {
    quantity: 1,
    id: 42955424989411,
  }
]
  data = {'items':items}
  var xhr = new XMLHttpRequest();
  xhr.onreadystatechange = function() {
      if (xhr.readyState === 4){
          window.location.href = '/checkout/?discount=ANNUAL50';
      }
  };
  xhr.open('POST', '/cart/add.js');
  xhr.setRequestHeader('Content-Type', 'application/json');
  xhr.send(JSON.stringify(data));
    
  }

</script>