<script>

 function get_gap_client_id() {
  try {
    const matches = document.cookie.match(/_ga=(.+?);/);
    if (matches && matches.length >= 2) {
      const session_id = matches[1].split('.').slice(-2).join(".");
      console.log("gap client ID:" + session_id);
      return session_id;
    }
  } catch (error) {
    console.error("Error while getting gap client ID:", error);
    return null;
  }
  return null;
}

// Function to get _google-clientID from the cookie _ga_FGQNW4H684
function get_gap_session_id() {
  try {
    const cookieName = "_ga_FGQNW4H684";
    const cookieValue = document.cookie.split('; ').find(cookie => cookie.startsWith(cookieName));
    if (cookieValue) {
      const matches = cookieValue.match(/GS1\.1\.([^.]*)/);
      if (matches && matches.length >= 2) {
        console.log('gap session ID: '+ matches[1]);
        return matches[1];
      }
    }
  } catch (error) {
    console.error("Error while getting gap session ID:", error);
    return null;
  }
  return null;
}
  
