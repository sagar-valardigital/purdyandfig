<script>
  function removeAutocomplete() {
    const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;

    if (isSafari || isIOS) {
      const forms = document.querySelectorAll('#product_form_{{ section.index}}, #product_form_{{ section.index}}_2');
      forms.forEach((form) => {
        if (form) {
          form.removeAttribute('autocomplete');
          const formElements = form.elements;
          for (let i = 0; i < formElements.length; i++) {
            formElements[i].removeAttribute('autocomplete');
          }
        }
      });
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const isRefill = urlParams.has('refills');

    removeAutocomplete();

    if (isRefill) {
      const productSection = document.getElementById('starterkit-product');
      if (productSection) {
        productSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // Handle refill option selection
      const refillsOption = document.querySelector('#buyplan_3_{{ section.id }}, #buyplan_6_{{ section.id }}');
      if (refillsOption) {
        const observer = new MutationObserver((mutations, observer) => {
          const signatureTab = document.querySelector('.gp--product-variants input[data-variantclass="variant_4"]');
          if (signatureTab) {
            signatureTab.checked = true;
            signatureTab.click();
            signatureTab.dispatchEvent(new Event('change', { bubbles: false }));

            refillsOption.checked = true;
            refillsOption.click();
            refillsOption.dispatchEvent(new Event('change', { bubbles: false }));

            observer.disconnect();
          }
        });

        observer.observe(document.body, { childList: true, subtree: true });

        setTimeout(() => {
          const signatureTab = document.querySelector('.gp--product-variants input[data-variantclass="variant_4"]');
          if (signatureTab) {
            signatureTab.checked = true;
            signatureTab.click();
            signatureTab.dispatchEvent(new Event('change', { bubbles: false }));

            refillsOption.checked = true;
            refillsOption.click();
            refillsOption.dispatchEvent(new Event('change', { bubbles: false }));
          }
        }, 500);
      }
    }
  });
</script>
