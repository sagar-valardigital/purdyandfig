<style>
	.link-to-variant {
		height: 0;
		overflow: hidden;
		position: relative;
	}
	.link-to-variant.show {
		display: block !important;
		height: auto;
		margin-top: 4px;
		margin-bottom: 4px;
		overflow: visible;
	}
	.variant-badge {
		position: absolute;
		right: 8.5px;
		top: -10px;
		border-radius: 4px;
		background: #708480;
		color: #fff;
		font-size: 12px;
		padding: 2px 6px;
		z-index: 1;
	}
	.checkout-starterkit-btn {
		background: #11322C !important;
		gap: 4px;
	}
	.worth del {
		font-weight: 400;
		color: #9E9E9E;
	}
	.mbestplan {
		border-top-color: #E55829 !important;
	}
	.mbestvalue {
		background: #E55829;
	}
	.buy--plan input:checked + label, .ms-buy--plan input:checked + label {
		border-top-color: #11322c !important;
	}
	.srt-desc {
		font-weight: 200;
	}
	span.deleted-price, span.gp--sell-price {
		position: relative;
		top: 1px !important;
	}
	.choose-secnt-label {
		font-size: 16px;
	}
	.buy--plan label .link-to-variant {
		font-size: 16px;
		font-weight: 400 !important;
	}
	.gp-19-var-short-desc:not(.show),
	.shopify-product-form:not(.show) {
		display: none !important;
	}
  .unsright {
    margin-right: 4px;
  }

	@media (max-width: 768px) {
		.variant-badge {
			font-size: 10px;
		}
		span.deleted-price, span.gp--sell-price {
			top: 2px !important;
		}
		#id_{{ section.id }} .star-img{width:12px; height:12px;vertical-align:middle;}
		#id_{{ section.id }} .star-img svg{vertical-align:top;}
		#id_{{ section.id }} .star-img + span.font-lausanne.fw-400{font-size:12px !important;vertical-align:middle;}
		
		.buy--plan label .link-to-variant {
			font-size: 12px;
		}
		.buy-block-text span {
			font-size: 14px;
		}
		.choose-secnt-label {
			font-size: 14px;
		}
		.gp-19-var-short-desc {
			font-size: 14px;
			margin: 8px 0 8px 0 !important;
		}
		.gp-5-bottom {
			padding: 0px 0px 0px 0px;
		}
		.heading-3 {
			font-size: 24px !important;
		}
	}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var sourceElement = document.querySelector('.link-to-section');
    if (sourceElement) {
      var sourceId = sourceElement.id;
      var targetElements = document.querySelectorAll('.set-buybox-id');
      targetElements.forEach(function (el) {
        el.id = sourceId;
      });
    }
  });

  const freevariantID1 = '{{ section.settings.variant_id_free_1 }}';
  const freesku1 = '{{ section.settings.sku_free_1 }}';

  const freevariantID2 = '{{ section.settings.variant_id_free_2 }}';
  const freesku2 = '{{ section.settings.sku_free_2 }}';

  /* function to add the product to cart */
  const additemstocart = (form, event) => {
    event.preventDefault();

    const targetBTN = $(event.target);
    targetBTN.addClass('loading');

    fetch(window.Shopify.routes.root + 'cart.js')
      .then((response) => response.json())
      .then((cart) => {
        let allDiscounts = new Set();
        cart.items.forEach((item) => {
          item.discounts.forEach((discountItem) => {
            allDiscounts.add(discountItem.title);
          });
        });
        let discountsString = Array.from(allDiscounts).join(',');

        const additemtocart = (data) => {
          return fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            body: data,
          }).then((response) => response.json());
        };

        let formData;
        let discount;
        const formclasses = form.classList;
        if (formclasses.contains('form_s1')) {
          signatureCounterCleanID = '{{ section.settings.variant_id_1 }}';

          if (form.querySelector('input[name="id"]').value == signatureCounterCleanID) {
            formData = new FormData(form);

            const discount1 = form.querySelector('input[name="discount"]').value;
            if (discountsString && discount1 !== discountsString) {
              if (discount1) {
                if (
                  !discountsString.includes(discount1) &&
                  !discountsString.includes('{{ section.settings.discountPlan_1 }}')
                ) {
                  discountsString = discount1 + ',' + discountsString;
                }
              }
            } else {
              discountsString = discount1;
            }
          } else {
            formData = new FormData();

            const ccID = '{{ section.settings.variant_id_cc_1 }}';
            const ccSKU = '{{ section.settings.sku_cc_1 }}';
            const ccSellingPlan = '{{ section.settings.selling_plan_cc_1 }}';
            const dataItemType = ccSellingPlan ? 'subscription' : 'payg';

            formData.append(`items[0][id]`, ccID);
            formData.append(`items[0][quantity]`, 1);
            if (dataItemType == 'subscription') {
              formData.append(`items[0][purchase_type]`, dataItemType);
              formData.append(`items[0][selling_plan]`, ccSellingPlan);
            }

            formData.append(`items[1][id]`, form.querySelector('input[name="id"]').value);
            formData.append(`items[1][quantity]`, form.querySelector('input[name="quantity"]').value);
            if (form.querySelector('input[name="purchase_type"]').value == 'subscription') {
              formData.append(`items[1][purchase_type]`, form.querySelector('input[name="purchase_type"]').value);
              formData.append(`items[1][selling_plan]`, form.querySelector('input[name="selling_plan"]').value);
            }

            formData.append(`items[2][id]`, freevariantID1);
            formData.append(`items[2][quantity]`, 1);

            {% comment %} if (discountsString) {
              if (discountsString.includes('{{ section.settings.discountPlan_2 }}')) {
                let discountsArray = discountsString
                  .split(',')
                  .filter((d) => d !== '{{ section.settings.discountPlan_2 }}');
                discountsString = discountsArray.join(',');
              }

              discountsString = form.querySelector('input[name="discount"]').value + ',' + discountsString;
            } else {
              discountsString = form.querySelector('input[name="discount"]').value;
            } {% endcomment %}
          }
        } else {
          seasonalCounterCleanID = '{{ section.settings.variant_id_4 }}';

          if (form.querySelector('input[name="id"]').value == seasonalCounterCleanID) {
            formData = new FormData(form);

            const discount1 = form.querySelector('input[name="discount"]').value;
            if (discountsString && discount1 !== discountsString) {
              if (discount1) {
                if (
                  !discountsString.includes(discount1) &&
                  !discountsString.includes('{{ section.settings.discountPlan_4 }}')
                ) {
                  discountsString = discount1 + ',' + discountsString;
                }
              }
            } else {
              discountsString = discount1;
            }
          } else {
            formData = new FormData();

            const ccID = '{{ section.settings.variant_id_cc_2 }}';
            const ccSKU = '{{ section.settings.sku_cc_2 }}';
            const ccSellingPlan = '{{ section.settings.selling_plan_cc_2 }}';
            const dataItemType = ccSellingPlan ? 'subscription' : 'payg';

            formData.append(`items[0][id]`, ccID);
            formData.append(`items[0][quantity]`, 1);
            if (dataItemType == 'subscription') {
              formData.append(`items[0][purchase_type]`, dataItemType);
              formData.append(`items[0][selling_plan]`, ccSellingPlan);
            }

            formData.append(`items[1][id]`, form.querySelector('input[name="id"]').value);
            formData.append(`items[1][quantity]`, form.querySelector('input[name="quantity"]').value);
            if (form.querySelector('input[name="purchase_type"]').value == 'subscription') {
              formData.append(`items[1][purchase_type]`, form.querySelector('input[name="purchase_type"]').value);
              formData.append(`items[1][selling_plan]`, form.querySelector('input[name="selling_plan"]').value);
            }

            formData.append(`items[2][id]`, freevariantID2);
            formData.append(`items[2][quantity]`, 1);

            {% comment %} if (discountsString) {
              if (discountsString.includes('{{ section.settings.discountPlan_5 }}')) {
                let discountsArray = discountsString
                  .split(',')
                  .filter((d) => d !== '{{ section.settings.discountPlan_5 }}');
                discountsString = discountsArray.join(',');
              }

              discountsString = form.querySelector('input[name="discount"]').value + ',' + discountsString;
            } else {
              discountsString = form.querySelector('input[name="discount"]').value;
            } {% endcomment %}
          }
        }

        discount = discountsString;

        additemtocart(formData)
          .then((response) => {
            if (response.status === 'error') {
              throw new Error(response.message);
            }

            targetBTN.removeClass('loading');

            if (discount) {
              window.location.href = window.Shopify.routes.root + 'checkout?discount=' + encodeURIComponent(discount);
            } else {
              window.location.href = window.Shopify.routes.root + 'checkout';
            }
          })
          .catch((error) => {
            targetBTN.removeClass('loading');
            console.error('Error:', error);
          });
      });
  };
</script>

