{% assign mimage = section.settings.image | img_url: '800x' %}
<style>
.{{ section.settings.className }}{
  {% if section.settings.backgroundImage %}
background-image:url({{section.settings.backgroundImage | image_url }});
background-size:cover;
  {% else %}
background-color:{{section.settings.background}};
  {% endif %}
  
}
  .{{ section.settings.className }}:after{
  content:'';
  width:45%;
  height:100%;
  background-image:url({{mimage}});
  background-size:cover;
  background-position:center;
  position:absolute;
  top:0;
  {% if section.settings.layout %}
    right:0;
  {% else %}
    left:0;
  {% endif %}
  }
  .fi-image{opacity:0;}
  @media(max-width:768px){
    .fi-image{opacity:1}
    .{{ section.settings.className }}:after{display:none;}
    .{{ section.settings.className }} .image-with-text-2{
      padding-top:0 !important;
    }
    .{{ section.settings.className }} .image-with-text-2 .fi-image{
      margin-left:-15px;
      margin-right:-15px;
      width:calc(100% + 30px);
      margin-bottom:15px;
    }
  }
</style>

<div class="{{ section.settings.className }} position-relative" >

  <div
    
    class="py-80 image-with-text image-with-text-2 "
  >
    <div class="container">
      <div class="d-flex flex-wrap justify-content-between align-items-center">
        <div class="w-40 {% if section.settings.layout %} order-2 {%endif%}">
          <div class="position-relative">
            {% if section.settings.image %}
              
              <img src="{{ mimage }}" class="w-100 h-auto fi-image" width="700" height="500" alt="image">
             
               
            {% endif %}
          </div>
        </div>
        <div class="w-50 d-flex justify-content-start {% if section.settings.layout %} order-1 {%endif%} image-txt">
          <div class="pb-1 pt-3">
            <h2 class="heading-2 font-gtsuper" style="color:#0A1E1A !important;">
              {{ section.settings.heading }}
            </h2>
            <div class="normal-text font-lausanne fw-200 " style="color:{{section.settings.textcolor}};">
              {{ section.settings.details }}
            </div>
           
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Full Width Image Text",
    "settings": [
      {
        "type": "text",
        "id": "className",
        "label": "Add Section class Name"
      },
      {
        "type": "color",
        "id": "textcolor",
        "label": "Select text color",
        "default": "#212121"
      },
      {
        "type": "color",
        "id": "background",
        "label": "Select background color",
        "default": "#ffffff"
      },
      {
        "type": "image_picker",
        "id": "backgroundImage",
        "label": "Select background Image"
      },
       {
            "type": "checkbox",
            "id": "layout",
            "label": "Image on right"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Poster"
          },
          
          {
            "type": "html",
            "id": "details",
            "label": "Detail Text"
          }
	],
    
	"presets": [
		{
			"name": "Full Width Image With Text"
		}
	]
  }
{% endschema %}
