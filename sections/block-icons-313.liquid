<style>
  .block-icons-313 {
    display: flex;
    padding: 80px 0px;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }
  .block-heading {
    display: flex;
    padding: 0px 16px;
    justify-content: center;
    align-items: center;
    gap: 8px;
    align-self: stretch;
    font-size: 40px;
    font-style: normal;
    font-weight: 400;
    line-height: 50px;
    font-family: "GT Super";
  }
  .block-icons-container {
    display: flex;
    padding: 0px 400px;
    justify-content: center;
    align-items: center;
    align-self: stretch;
  }
  .block-icons {
    display: flex;
    align-items: center;
    gap: 40px;
    align-self: stretch;
    justify-content: space-between;
  }
  .blocks-item {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    text-align: center;
    gap: 16px;
  }
  .blocks-item img {
    width: 41.636px;
    height: 36.37px;
    flex-shrink: 0;
  }
  .text-part {
    display: flex;
    gap: 4px;
    flex-direction: column;
    align-items: center;
  }
  .block-title {
    font-size: 18px;
    font-style: normal;
    font-weight: 600;
    line-height: 27px;
    font-family: "Lausanne";
  }
  .block-description {
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 25.6px;
    font-family: "Lausanne";
  }
  .block-icon-svg {
    width: 5px;
    height: 48.5px;
    stroke-width: 1px;
    stroke: #FFF;
  }
  .blocks-item {
    width: 195px;
  }
  @media (max-width: 767px) {
    .block-icons-313 {
      padding: 32px 0px;
    }
    .block-icons-container {
      padding: 0px 16px;
      width: 100%;
    }
    .block-icons {
      gap: 10px;
    }
    .blocks-item {
      width: 101px;
    }
    .blocks-item img {
      width: 34.763px;
      height: 30.366px;
    }
    .block-heading {
      font-size: 32px;
      line-height: 40px;
    }
    .block-title {
      font-size: 12px;
      line-height: 18px;
      letter-spacing: 0.18px;
    }
    .block-description {
      font-size: 12px;
      line-height: 18px;
      letter-spacing: 0.18px;
      font-weight: 200;
    }
  }
</style>

<div class="block-icons-313" style="background: {{ section.settings.backgroundcolor }};">
  <h2 class="block-heading" style="color: {{ section.settings.headingcolor }};">{{ section.settings.heading }}</h2>
  {% if section.blocks.size > 0 %}
    <div class="block-icons-container">
      <div class="block-icons">
        {% for block in section.blocks %}
          <div class="blocks-item">
            <img src="{{ block.settings.blockicon | image_url: width: 42, height: 38 }}" width="42" height="38">
            <div class="text-part">
              <span class="block-title" style="color: {{ section.settings.blockhedingcolor }}">
                {{- block.settings.title -}}
              </span>
              <span class="block-description" style="color: {{ section.settings.blocksubhedingcolor }}">
                {{- block.settings.description -}}
              </span>
            </div>
          </div>
          {% if forloop.last == false %}
          <svg xmlns="http://www.w3.org/2000/svg" width="2" height="49" viewBox="0 0 2 49" fill="none" class="block-icon-svg">
            <path d="M1.25 0.113892V48.6139" stroke="white"/>
          </svg>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Block icons 313",
  "settings": [
    {
      "type": "text",
      "id": "sectionclass",
      "label": "Add class"
    },
    {
      "type": "color",
      "id": "backgroundcolor",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "headingcolor",
      "label": "Heading color"
    },
    {
      "type": "color",
      "id": "blockhedingcolor",
      "label": "Block heading color"
    },
    {
      "type": "color",
      "id": "blocksubhedingcolor",
      "label": "Block text color"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "block",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "blockicon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Block icons 313"
    }
  ]
}
{% endschema %}
