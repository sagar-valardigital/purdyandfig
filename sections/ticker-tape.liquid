<style>
    .ticker-tape-wrapper {
    display: flex;
    padding-block: 8px;
    width: 100%;
    overflow: hidden;
    white-space: nowrap;
    }

    .text {
    padding-right: 85px; 
    color: #fafafa;
    text-align: center;
    font-family: "GT Super" !important;
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
    letter-spacing: 0.45px;
    text-transform: uppercase;
    }

    .italic-text {
     font-family: "GT Super" !important;
     color: #D89B39; 
     font-style: italic;
    }

    .marquee-content {
     display: flex;
    }

    /* Duplicate content for seamless loop */
    .marquee-content .ticker-group {
      display: flex;
      flex-shrink: 0;
    }

    @keyframes scroll-left {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }
    

/* Hide on mobile */
@media screen and (max-width: 749px) {
  .ticker-tape-wrapper.hide-mobile {
    display: none !important;
  }

.text {
    padding-right: 15px;
}
}

/* Hide on desktop */
@media screen and (min-width: 750px) {
  .ticker-tape-wrapper.hide-desktop {
    display: none !important;
  }
}
</style>

<div class="ticker-tape-wrapper {% if section.settings.desktop-hide %}hide-desktop{% endif %} {% if section.settings.mobile-hide %}hide-mobile{% endif %}" style="background: {{ section.settings.bgcolor }}">
    <div class="marquee-content" {% if section.settings.marquee %}style="animation: scroll-left {{ section.settings.speed }}s linear infinite;"{% endif %}>
      <div class="ticker-group">
        {% for i in (1..11) %}
          <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
        {% endfor %}
      </div>
      <div class="ticker-group">
        {% for i in (1..11) %}
          <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
        {% endfor %}
      </div>
    </div>
</div>

{% schema %}
{
  "name": "Ticker Tape",
  "class": "ticker-tape",
  "settings": [
    {
      "type": "checkbox",
      "id": "marquee",
      "label": "Enable Ticker Animation",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "s",
      "label": "Animation Speed",
      "default": 60,
      "info": "Lower = faster, Higher = slower"
    },
    {
      "type": "color",
      "id": "bgcolor",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "desktop-hide",
      "label": "Hide on Desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "mobile-hide",
      "label": "Hide on Mobile",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Ticker Tape"
    }
  ]
}
{% endschema %}