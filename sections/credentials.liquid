<style>
  .credentials .container {
    display: flex;
    width: 100%;
    max-width: 1440px;
    padding: 80px 112px;
    justify-content: space-between;
    align-items: stretch;
    gap: 32px;
  }

  .credentials .credentials-details {
    width: 100%;
    max-width: 520px;
  }

  .credentials .title {
    color: #2D469E;
    font-family: "Value-Bold";
    font-size: 36px;
    font-style: normal;
    font-weight: 700;
    line-height: 44px;
    letter-spacing: -0.72px;
    margin-bottom: 32px;
  }

  .credentials .credentials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-column-gap: 24px;
    grid-row-gap: 32px;
  }

  .credentials .detail {
    width: 100%;
    max-width: 175px;
    color: #434448;
    font-family: "Value-Sans-Fixed";
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: 24px;
    margin: 0;
  }

  .credentials .number {
    width: 100%;
    color: #434448;
    font-family: "Value-Sans-Fixed";
    font-size: 72px;
    font-style: normal;
    font-weight: 400;
    line-height: 90px;
    letter-spacing: -1.44px;
    margin: 0;
  }

  .credentials .credentials-image-wrapper {
    display: flex;
    align-items: stretch;
    justify-content: center;
    width: 100%;
    max-width: 592px;
    height: 428px;
  }

  .credentials .credentials-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .credentials .credentials-image-wrapper picture {
      width: 100%;
  }

  .credentials .credential .divider {
    display: none;
    border-top: 1px solid #D4D5D7;
    margin-top: 16px;
  }

  .credentials .duplicate {
    display: none;
  }
  
  @media only screen and (max-width: 968px) {
    .credentials .container {
      flex-direction: column;
      padding: 0;
      align-items: center;
      gap: 0;
    }

    .credentials .title {
      font-size: 30px;
      line-height: 38px;
      margin-bottom: 16px;
      letter-spacing: normal;
    }

    .credentials .credentials-grid-wrapper {
      height: 140px;
      overflow: hidden;
    }
    
    .credentials .credentials-grid {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      gap: 0 !important;
    }

    .credentials .duplicate {
      display: block;
    }

    .credentials .number {
      
    }

    .credentials .detail {
      max-width: 100%;
    }

    .credentials .credential .divider {
      display: block;
    }

    .credentials .credentials-image-wrapper {
      order: -1;
      width: 100%;
      height: 375px;
      max-width: none;
    }

    .credentials .credentials-details {
      margin-right: 0;
      padding: 32px 16px;
      width: 100%;
    }

    .credentials .credentials-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .credentials .credentials-image-wrapper picture {
      width: 100%;
    }

    .credentials .animate {
      animation: slide var(--credential-animation-duration) linear infinite;
    }
  }

  :root {
    --credential-count: {{ section.blocks.size }};
    --credential-animation-duration: calc((var(--credential-count) + 1) * 2.5s);
  }

  @keyframes slide {
    {% assign total_credentials = section.blocks.size | plus: 1 %}
    {% assign interval = 100 | divided_by: section.blocks.size %}
    {% for i in (0..section.blocks.size) %}
      {{ i | times: interval }}% { transform: translateY(calc(-{{ i }} * 100% / {{ total_credentials }})); }
      {{ i | times: interval | plus: interval | minus: 3 }}% { transform: translateY(calc(-{{ i }} * 100% / {{ total_credentials }})); }
    {% endfor %}
    100% { transform: translateY(calc(-{{ section.blocks.size }} * 100% / {{ total_credentials }})); }
  }
</style>


<div class="credentials" style="background-color:{{section.settings.background}} !important;">
  <div class="container">
    <div class="credentials-details">
      <h2 class="title">{{ section.settings.title }}</h2>
      <div class="credentials-grid-wrapper">
        <div class="credentials-grid">
          {% for credential in section.blocks %}
            <div class="credential">
              <p class="number">{{ credential.settings.number }}</p>
              <p class="detail">{{ credential.settings.detail }}</p>
              <hr class="divider" />
            </div>
          {% endfor %}
          <!-- Duplicate the first credential to make the transition smooth -->
          {% assign first_credential = section.blocks.first %}
          <div class="credential duplicate">
            <p class="number">{{ first_credential.settings.number }}</p>
            <p class="detail">{{ first_credential.settings.detail }}</p>
            <hr class="divider" />
          </div>
        </div>
      </div>
    </div>

    <div class="credentials-image-wrapper">
      <picture>
        {% assign image = section.settings.image %}
        <source media="(min-width:769px)" srcset="{{ image | img_url: '1200x', crop: 'center' }}">
        <source media="(max-width:768px)" srcset="{{ image | img_url: '1200x', crop: 'center' }}">
        <img
          data-id="{{ image.id }}"
          class="credentials-image"
          width="100%"
          height="100%"
          src="{{ image | img_url: '1200x' }}"
          alt="{{ image.alt }}"
        >
      </picture>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // When the observed elements enter the viewport apply the `animate` class
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if(entry.isIntersecting) {
          entry.target.classList.add("animate");

          // Unobserve to prevent retriggering
          observer.unobserve(entry.target);
        }
      });
    });

    // Set the element with class `credentials-grid` to be observed
    const credentialsGrid = document.querySelector(".credentials .credentials-grid");
    if(credentialsGrid) {
      observer.observe(credentialsGrid);
    }
  });
</script>

{% schema %}
{
  "name": "Credentials",
  "settings": [
    {
      "id": "background",
      "label": "Background color",
      "type": "color"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "We're building the perfect formula for you and your home"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Add Image"
    }
  ],
  "blocks": [
    {
      "type": "credential",
      "name": "Credential",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Credential Number",
          "default": "4+"
        },
        {
          "type": "text",
          "id": "detail",
          "label": "Credential Details",
          "default": "years of research and development"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Credentials"
    }
  ]
}
{% endschema %}