<style>
  .annoucment_bar_timer{
    animation:none !important;
    position: sticky !important;
  top: 0 !important;
  width: 100%;
  z-index: 9999;
  }
span.timer {
  font-size: 18px !important;
  margin-left: 2px;
}

/* MOBILE STYLING */
@media(max-width:768px) {
  .ann-bar-mobile {
    display: flex;
    justify-content: center;
    align-items: center;             
  }

  .ann-bar-mobile p {
    display: flex;
    align-items: center;             
  }

  span.timer {
    font-size: 18px !important;
    margin-left: 4px;
  }
}

</style>

{% assign product = section.settings.landingproduct %}
{% assign s_variant = product.selected_or_first_available_variant %}

<div
  class="annoucment-bar annoucment-bar-reskin annoucment-bar-2 annoucment-bar-343 py-2 {{ section.settings.class }}"
  style="background-color:{{section.settings.bb-color}}"
  id="annoucment_bar_2" 
  {% if section.settings.checkout or section.settings.cart %}
    x-data="{qty:1}"
  {% endif %}
>
  <div class="container text-center">
    <div class="d-flex justify-content-between align-items-center">
      {% if section.settings.logo %}
        <div class="annoucment-bar-logo">
          <a {% if section.settings.logo_link %} href="{{ section.settings.logo_link }}" {% else %} href="javascript:void(0); {% endif %}">
            <svg xmlns="http://www.w3.org/2000/svg" width="148" height="26" viewBox="0 0 148 26" fill="none">
