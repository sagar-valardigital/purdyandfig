          </a>
        </div>
      {% endif %}
      
      <div class="ann-bar-text-2">
        <p class="m-0 font-lausanne fw-400" style="color:{{section.settings.text-color}};">
          {{ section.settings.text }} 
          <span class="timer" 
            data-time="{{ section.settings.end_date }}"
            data-auto-reset="{{ section.settings.auto_reset }}"
            data-reset-duration="{{ section.settings.reset_duration_days }}"
            data-max-cycles="{{ section.settings.max_cycles }}">
            <span class="timer-loading">Loading...</span>
          </span>
        </p>
      </div>
      {% if section.settings.cart %}
<div>
      <li @click="$dispatch('toggle-cart')">
            <a class="menu-item cart-toggle position-relative header-icon">
              <i style="font-size:28px; color:#121212" class="fa-light fa-cart-shopping"></i>
              <span class="cart-item-count">
                {%- if cart.item_count > 0 %}
                  {{ cart.item_count -}}
                {%- endif -%}
              </span></a
            >
          </li>
      </div>
      {% else %}
      <div>
        <form
          @submit.prevent="console.log('submitted')"
          x-ref="product_form_{{ section.index}}"
          enctype="multipart/form-data"
          accept-charset="UTF-8"
          id="product_form_{{ section.index}}"
          class="shopify-product-form"
          data-product-id="{{product.id}}"
          action="/cart/add"
        >
          <input type="hidden" name="id" class="input_variant_id" value="{{ section.settings.varaiantid }}">
          <input type="hidden" class="discout_input" name="discount" value="{{ section.settings.discount }}">
          <input type="hidden" name="quantity" value="1">
          {% if section.settings.sellingid != blank %}  
            <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
            <input
              class="input_selling_plan"
              type="hidden"
              name="selling_plan"
              value="{{section.settings.sellingid}}"
            >
          {% endif %}
        </form>
        
        <span
          style="cursor:pointer; color:{{ section.settings.btn-text }}; background-color:{{ section.settings.btn-bg }}"
          {% unless section.settings.checkout %}
            data-target="{{ section.settings.scrollto }}"
          {% endunless %}
          data-top="{{ section.settings.top }}"
          class="announcement-btn-2 font-lausanne reskin-black-btn fw-400 {% unless section.settings.checkout %}click-scroll{% endunless %}"
          {% if section.settings.dataTrack %}
            data-tracked="true"
            data-page-url="{{ request.path }}"
            data-target-url="{{ section.settings.targetUrl }}"
            data-index="{{ section.settings.index }}"
            data-funnel-stage="{{ section.settings.funnel_stage }}"
            data-module="{{ section.settings.dataModule }}"
            data-event-label="{{ section.settings.annuText | strip_html  | handle | replace: '-', '_'}}"
            data-event-value="{{ section.settings.eventValue }}"
            data-item-id="{{ section.settings.itemId }}"
            data-option-index="{{ section.settings.optionIndex }}"
            data-item-name="{{ section.settings.ItemName }}"
          {% endif %}
          {% if section.settings.checkout %}
            x-on:click="Purdy.CheckoutLanding($refs.product_form_{{ section.index}}, event)"
          {% endif %}
        >
          {{ section.settings.annuText -}}
        </span>
      </div>
   
    {% endif %}
    </div>
  </div>
</div>

<!-- Mobile announcement bar -->
<div class="ann-bar-mobile ann-bar-text-2 desktop-hide text-center white-text py-1" 
     style="background-color:{{ section.settings.bb-color-mobile }}; height:{{ section.settings.heightmobile }}px;">
  <p class="m-0 font-lausanne fw-400" style="color:{{section.settings.text-color-mobile}};">
    {{ section.settings.textmobile }} 
    <span class="timer" 
      data-time="{{ section.settings.end_date }}"
      data-auto-reset="{{ section.settings.auto_reset }}"
      data-reset-duration="{{ section.settings.reset_duration_days }}"
      data-max-cycles="{{ section.settings.max_cycles }}">
      <span class="timer-loading">Loading...</span>
    </span>
  </p>
</div>

<script>
(function() {
  'use strict';
  
  // Namespace to avoid conflicts with other scripts
  window.PurdyTimers = window.PurdyTimers || {};
  
  // Store active intervals to prevent memory leaks
  if (!window.PurdyTimers.intervals) {
    window.PurdyTimers.intervals = new Map();
  }
  
  // Clean up function to clear existing intervals
  function cleanupTimers() {
    if (window.PurdyTimers.intervals) {
      window.PurdyTimers.intervals.forEach(interval => {
        if (interval) clearInterval(interval);
      });
      window.PurdyTimers.intervals.clear();
    }
  }
  
  function startCountdownForElement(el, endTimeStr) {
    // Clean up any existing interval for this element
    const elementId = el.getAttribute('data-timer-id') || Math.random().toString(36).substr(2, 9);
    el.setAttribute('data-timer-id', elementId);
    
    if (window.PurdyTimers.intervals.has(elementId)) {
      clearInterval(window.PurdyTimers.intervals.get(elementId));
    }
    
    try {
      const autoReset = el.getAttribute('data-auto-reset') === 'true';
      const resetDuration = parseInt(el.getAttribute('data-reset-duration')) || 7;
      const maxCycles = parseInt(el.getAttribute('data-max-cycles')) || 0;
      
      // Validate inputs
      if (resetDuration <= 0) {
        console.error('Invalid reset duration:', resetDuration);
        el.textContent = "Configuration Error";
        return;
      }
      
function calculateEndTime() {
  // Parse the date 
  let originalEnd;
  try {
    // Handle different date formats and force UK timezone (GMT)
    const dateStr = endTimeStr.trim().replace(' ', 'T');
    // Append +00:00 to force GMT (UK winter time) if no timezone specified
    const ukDateStr = dateStr.includes('+') || dateStr.includes('Z') ? dateStr : dateStr + '+00:00';
    originalEnd = new Date(ukDateStr);
    
    // Check if date is valid
    if (isNaN(originalEnd.getTime())) {
      console.error('Invalid date format:', endTimeStr);
      return null;
    }
  } catch (e) {
    console.error('Date parsing error:', e);
    return null;
  }
        
        if (!autoReset) {
          return originalEnd;
        }
        
        const now = new Date().getTime();
        
        // If original time hasn't passed yet, use it
        if (originalEnd.getTime() > now) {
          return originalEnd;
        }
        
        // Calculate how many cycles have passed
        const millisecondsSinceEnd = now - originalEnd.getTime();
        const daysSinceEnd = Math.floor(millisecondsSinceEnd / (1000 * 60 * 60 * 24));
        const cyclesPassed = Math.floor(daysSinceEnd / resetDuration);
        
        // Check if exceeded max cycles (if set)
        if (maxCycles > 0 && cyclesPassed >= maxCycles) {
          return null; // No more cycles
        }
        
        // Calculate next end time
        const nextCycle = cyclesPassed + 1;
        const daysToAdd = nextCycle * resetDuration;
        const newEndTime = new Date(originalEnd.getTime() + (daysToAdd * 24 * 60 * 60 * 1000));
        
        return newEndTime;
      }
      
      let endTime = calculateEndTime();
      
      if (!endTime) {
        el.textContent = "Expired";
        return;
      }
      
      // Update function
      function updateTimer() {
        // Check if element is still in DOM
        if (!document.body.contains(el)) {
          if (window.PurdyTimers.intervals.has(elementId)) {
            clearInterval(window.PurdyTimers.intervals.get(elementId));
            window.PurdyTimers.intervals.delete(elementId);
          }
          return;
        }
        
        const now = new Date().getTime();
        const timeLeft = endTime - now;
        
        if (timeLeft <= 0) {
          if (autoReset) {
            // Recalculate end time for next cycle
            endTime = calculateEndTime();
            
            if (!endTime) {
              clearInterval(window.PurdyTimers.intervals.get(elementId));
              window.PurdyTimers.intervals.delete(elementId);
              el.textContent = "Expired";
              return;
            }
            // Continue with new end time
          } else {
            clearInterval(window.PurdyTimers.intervals.get(elementId));
            window.PurdyTimers.intervals.delete(elementId);
            el.textContent = "0s";
            return;
          }
        }
        
        const days = Math.floor(timeLeft / (1000 * 60 * 60 * 24));
        const hours = Math.floor((timeLeft % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((timeLeft % (1000 * 60)) / 1000);
        
        // Build time string dynamically, only showing non-zero values
        const timeParts = [];
        
        if (days > 0) {
          timeParts.push(`${days}d`);
        }
        if (hours > 0) {
          timeParts.push(`${hours}h`);
        }
        if (minutes > 0) {
          timeParts.push(`${minutes}m`);
        }
        // Always show seconds if it's the only unit left, or if there are other units with value
        if (seconds > 0 || timeParts.length === 0) {
          timeParts.push(`${seconds}s`);
        }
        
        const formattedTime = timeParts.join(' ');
        
        // Only update if changed to reduce DOM operations
        if (el.textContent !== formattedTime) {
          el.textContent = formattedTime;
        }
      }
      
      // Initial update
      updateTimer();
      
      // Set up interval
      const interval = setInterval(updateTimer, 1000);
      window.PurdyTimers.intervals.set(elementId, interval);
      
    } catch (error) {
      console.error('Timer initialization error:', error);
      el.textContent = "Error";
    }
  }
  
  // Initialize all timers
  function initializeTimers() {
    // Clean up any existing timers first
    cleanupTimers();
    
    // Find all timer elements
    const timerElements = document.querySelectorAll('.timer');
    
    timerElements.forEach(timerEl => {
      const endTime = timerEl.getAttribute('data-time');
      if (endTime) {
        // Remove loading text if present
        const loadingSpan = timerEl.querySelector('.timer-loading');
        if (loadingSpan) {
          loadingSpan.remove();
        }
        
        startCountdownForElement(timerEl, endTime);
      } else {
        timerEl.textContent = "No end time configured";
      }
    });
  }
  
  // Handle visibility change to pause/resume timers
  document.addEventListener('visibilitychange', function() {
    if (document.hidden) {
      // Page is hidden, clear intervals to save resources
      cleanupTimers();
    } else {
      // Page is visible again, reinitialize timers
      setTimeout(initializeTimers, 100); // Small delay to ensure smooth restart
    }
  });
  
  // Clean up on page unload
  window.addEventListener('beforeunload', cleanupTimers);
  
  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeTimers);
  } else {
    // DOM is already ready
    initializeTimers();
  }
  
  // Reinitialize if Shopify theme editor reloads section
  if (Shopify && Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(event) {
      setTimeout(initializeTimers, 100);
    });
  }
  
})();
</script>

