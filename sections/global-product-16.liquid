{% assign product = section.settings.landingproduct %}
{% assign s_variant = product.selected_or_first_available_variant %}

<style>
  .global-product-16 .heading-3 {
    font-family: "Value-Medium-Fixed";
    font-weight: 700;
  }

  .global-product-16 .gp-5-subheading {
    margin-top: 4px !important;
  }

  .global-product-16 .total-reviews {
    font-family: "Pier Sans";
    font-size: 14px;
    font-weight: 600;
  }

  .global-product-16 .stars-img-review {
    gap: 8px;
    margin-bottom: 24px !important;
  }

  .global-product-16 .stars-container {
    gap: 2px;
    margin-top: auto;
    margin-bottom: auto;
  }

  .global-product-16 .gp-4-details {
    width: 100% !important;
    margin-left: 32px;
  }

  .global-product-16 .total-reviews-value {
    font-family: "Pier Sans";
    color: #434448;
    font-size: 14px;
  }

  .global-product-16 .gp-5-price-points {
    border: none;
    margin-top: 8px;
  }

  .global-product-16 .gp-5-price-points > ul {
    padding: 0;
    padding-top: 12px;
  }

  .global-product-16 .gp-5-price-points > div {
    padding-left: 0;
    padding-bottom: 12px;
    margin: 0;
  }

  .global-product-16 .gp-5-variants > li label {
    color: #2D469E;
    font-family: "Value-Sans-Fixed" !important;
    font-weight: 700;
    justify-content: center;
    background-image: none !important;
    box-shadow: none;
    border: 1.5px solid #DFE0E1;
    border-radius: 8px;
  }

  .global-product-16 .gp-5-variants > li input:checked + label {
    border: 2px solid #2D469E;
  }

  .global-product-16 .gp-5-price-points > ul:before {
    width: 100%;
    left: 0;
  }

  .global-product-16 .link-to-variant.show {
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .global-product-16 .gp-4-details {
      width: 100% !important;
      margin-left: 0;
    }

    .global-product-16 .gp-5-top {
      padding-left: 16px;
      padding-right: 16px;
    }

    .global-product-16 .gp-5-bottom {
      background-color: {{section.settings.background}} !important;
      margin: 0 !important;
      padding-top: 24px;
    }

    .global-product-16 .gp-5-price-points {
      background-color: {{section.settings.background}} !important;
    }

    .global-product-16 .container {
      padding: 0 !important;
    }
  }
</style>

<div
  class="{{ section.settings.className }} global-product-5 global-product-16 py-80"
  id="id_{{ section.id }}"
  style="background-color:{{section.settings.background}} !important;"
  x-data="{qty:1}"
>
  <div class="">
    <div class=" mb-4 container heading-2-wrapper">
      {% if section.settings.mainheading != '' %}
        <h2 class="heading-2 blue-text-3 mt-0 text-center value-bold m-text-left">
          {{ section.settings.mainheading }}
        </h2>
      {% endif %}
    </div>
    {% if section.settings['before-mobile'] %}
      <div class="mb-3 container">
        <div class="gp-5-top  desktop-hide " style="background-color:{{section.settings.background}} !important;">
          <h2 class="heading-3 blue-text-3 value-bold mb-0 mt-0">
            {{ section.settings.heading }}
          </h2>
          {% if section.settings.mainsubheading != '' -%}
            <p class="value-sans mt-2 mb-2 gp-5-subheading">{{ section.settings.mainsubheading }}</p>
          {%- endif %}
          <div class="text-left mt-2 reviews-scroll-block">
            <div
              class="d-flex value-sans theme-text mt-0 mb-3 stars-img-review click-scroll"
              data-target="{{ section.settings.scrollto }}"
            >
              <div class="d-flex stars-container">
                {% for i in (1..5) %}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path id="star-default--filled" d="M3.65832 15.8404C3.13234 16.1832 2.82552 15.9547 2.96797 15.3375L4.15143 10.126L0.283284 6.65159C-0.176949 6.24015 -0.0673695 5.85157 0.546274 5.80585L5.61979 5.38299L7.58126 0.445725C7.80042 -0.148575 8.18395 -0.148575 8.41406 0.445725L10.3865 5.38299L15.449 5.80585C16.0627 5.863 16.1832 6.22872 15.712 6.65159L11.8439 10.126L13.0273 15.3375C13.1698 15.9547 12.8739 16.1832 12.337 15.8404L7.99766 13.0632L3.65832 15.8404Z" fill="#2D469E"/>
                  </svg>
                {% endfor %}
              </div>
              <span class="total-reviews blue-text-3 value-medium">4.9</span>
              <span class="total-reviews-value">{{- settings.gloabalreviews }} Reviews</span>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
    <div
      class="d-flex product-block-4-wrapper flex-wrap justify-content-between align-items-start container"
      id="{{ section.settings.p_id }}"
    >
      <div class="w-50 {% if section.settings.verticalThumbnails %}vertical-thumbnails-slider-wrapper{% endif %} {% if section.settings.layout %} order-2 {%endif%}">
        <div class="two-women position-relative">
          {% if section.settings.tag != '' %}
            <span class="tag theme-text value-sans">{{ section.settings.tag }}</span>
          {% endif %}
          {% assign mediacount = 0 %}
          <div class="gp-5-product-gallery  new-product-gallery-wrapper link-to-variant variant_1 show">
            {% for block in section.blocks %}
              {% if block.type == 'productImage' %}
                {% assign image = block.settings.image %}
                {% assign mimage = block.settings.mimage %}
                {% if block.settings.is_video %}
                  <div class="main-product-img">
                    <video
                      class=" w-100 lazy"
                      poster="{{ block.settings.poster | img_url : '800x'}}"
                      width="520"
                      height="520"
                      controls
                    >
                      <source src="{{ block.settings.videoURL }}" type="video/mp4">
                    </video>
                  </div>
                {% else %}
                  <div class="main-product-img ">
                    <picture>
                      <source media="(min-width:650px)" srcset="{{ image | img_url: 'master'}}">
                      <source media="(max-width:650px)" srcset="{{ mimage | img_url: 'master' }}">
                      <img
                        {% if forloop.index == 1 %}
                          skip-lazy
                        {% else %}
                          loading="lazy"
                        {% endif %}
                        data-id="{{image.id}}"
                        class="img-responsive w-100 h-auto lazy"
                        src="{{ image | img_url: 'master'}}"
                        width="800"
                        height="700"
                        alt="{{ image }}"
                      >
                    </picture>
                  </div>
                {% endif %}
              {% endif %}
              {% assign mediacount = mediacount | plus: '1' %}
            {% endfor %}
          </div>
          <div class="gp-5-product-gallery  new-product-gallery-wrapper link-to-variant variant_2">
            {% for block in section.blocks %}
              {% if block.type == 'productImage2' %}
                {% assign image = block.settings.image_2 %}
                {% assign mimage = block.settings.mimage_2 %}
                {% if block.settings.is_video_2 %}
                  <div class="main-product-img">
                    <video
                      class=" w-100 lazy"
                      poster="{{ block.settings.poster_2 | img_url : '800x'}}"
                      width="520"
                      height="520"
                      controls
                    >
                      <source src="{{ block.settings.videoURL_2 }}" type="video/mp4">
                    </video>
                  </div>
                {% else %}
                  <div class="main-product-img ">
                    <picture>
                      <source media="(min-width:650px)" srcset="{{ image | img_url: 'master'}}">
                      <source media="(max-width:650px)" srcset="{{ mimage | img_url: 'master'}}">
                      <img
                        {% if forloop.index == 1 %}
                          skip-lazy
                        {% else %}
                          loading="lazy"
                        {% endif %}
                        data-id="{{image.id}}"
                        class="img-responsive w-100 h-auto lazy"
                        src="{{ image | img_url: 'master'}}"
                        width="800"
                        height="700"
                        alt="{{ image }}"
                      >
                    </picture>
                  </div>
                {% endif %}
              {% endif %}
              {% assign mediacount = mediacount | plus: '1' %}
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="w-50  d-flex justify-content-center">
        <div class="w-90   bg-white gp-4-details">
          <div
            class="gp-5-top {% if section.settings.before-mobile %} mobile-hide {% endif %}"
          >
            <h2 class="heading-3 blue-text-3 value-bold mb-0 mt-0">
              {{ section.settings.heading }}
            </h2>
            {% if section.settings.mainsubheading != '' -%}
              <p class="value-sans mt-2 mb-2 gp-5-subheading">{{ section.settings.mainsubheading }}</p>
            {%- endif %}
            <div class="text-left mt-2 reviews-scroll-block">
              <div
                class="d-flex value-sans theme-text mt-0 mb-3 stars-img-review click-scroll"
                data-target="{{ section.settings.scrollto }}"
              >
                <div class="d-flex stars-container">
                  {% for i in (1..5) %}
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path id="star-default--filled" d="M3.65832 15.8404C3.13234 16.1832 2.82552 15.9547 2.96797 15.3375L4.15143 10.126L0.283284 6.65159C-0.176949 6.24015 -0.0673695 5.85157 0.546274 5.80585L5.61979 5.38299L7.58126 0.445725C7.80042 -0.148575 8.18395 -0.148575 8.41406 0.445725L10.3865 5.38299L15.449 5.80585C16.0627 5.863 16.1832 6.22872 15.712 6.65159L11.8439 10.126L13.0273 15.3375C13.1698 15.9547 12.8739 16.1832 12.337 15.8404L7.99766 13.0632L3.65832 15.8404Z" fill="#2D469E"/>
                    </svg>
                  {% endfor %}
                </div>
                <span class="total-reviews blue-text-3 value-medium">4.9</span>
                <span class="total-reviews-value">{{- settings.gloabalreviews }} Reviews</span>
              </div>
            </div>
          </div>
          <div class="gp-5-bottom">
            <ul class="list-unstyle   var_{{ product.variants | size  }}  gp-5-variants ">
              {% assign checked = true %}
              {% for block in section.blocks %}
                {% if block.type == 'variant' %}
                  {% assign product_v = block.settings.variantProduct %}
                  {% assign s_variant_v = product_v.selected_or_first_available_variant %}
                  {% assign sub_discount_price = s_variant_v.selling_plan_allocations[0].price_adjustments[0].price %}
                  {% assign sub_discount_percentage = product_v.price
                    | minus: sub_discount_price
                    | times: 100
                    | divided_by: product.price
                  %}

                  <li
                    data-title="{{block.settings.text_heading | downcase }}"
                    class="gp-5-variant-li value-sans {% if block.settings.outofstock %}disabled var-out-of-stock{% endif %}"
                    {{ product_v | json }}
                  >
                    <input
                      class="{{ section.settings.className }}"
                      data-planid="{{block.settings.sellingid}}"
                      data-name="{{block.settings.text_heading}}"
                      data-include="{{variant.metafields.metadata.includes}}"
                      value="{{block.settings.varaiantid }}"
                      data-subprice="{{ block.settings.sellPrice | money }}"
                      data-price="{{block.settings.delPrice |  money}}"
                      data-image="{{ block.settings.varImage | img_url : '100x'}}"
                      data-variantid="{{block.settings.varaiantid}}"
                      data-productid="{{product_v.id}}"
                      data-variantclass="variant_{{ block.settings.varCount }}"
                      data-discount="{{ block.settings.discount }}"
                      type="radio"
                      name="id_{{ section.id }}"
                      {% if block.settings.dataTrack %}
                        data-tracked="true"
                        data-page-url="{{ request.path }}"
                        data-target-url="{{ block.settings.targetUrl }}"
                        data-index="{{ block.settings.index }}"
                        data-funnel-stage="{{ block.settings.funnel_stage }}"
                        data-module="{{ block.settings.dataModule }}"
                        data-event-label="{{ block.settings.dataTitle }}"
                        data-event-value="{{ block.settings.eventValue }}"
                        data-item-id="{{ block.settings.sku }}"
                        data-option-index="{{ block.settings.optionIndex }}"
                        data-item-name="{{ product_v.title }}"
                      {% endif %}
                      data-section="id_{{ section.id }}"
                      id="id_{{ section.id }}_{{block.settings.text_heading | escape }}"
                      {% if product_v.available and checked %}
                        checked {% assign checked = false -%}
                      {% else %}

                      {% endif %}
                    >

                    <label
                      style="background-image:url({{block.settings.varImage | img_url : '100x'}})"
                      {% if product_v.available %}
                        class="value-sans var_bg_{{ block.settings.text_heading | handle }}"
                      {% else %}
                        class="disabled  value-sans var_bg_{{ block.settings.text_heading | handle }}"
                      {% endif %}
                      for="id_{{ section.id }}_{{block.settings.text_heading | escape}}"
                      data-include="{{variant.metafields.metadata.includes}}"
                      data-value="{{block.settings.text_heading}}"
                    >
                      {{- block.settings.text_heading -}}
                    </label>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>

            <div class="black-text mt-3 gp-5-price-points mb-3">
              <div class="d-flex justify-content-between value-sans gp-5-var">
                <div class="gp-5-price">
                  <del style="color:#707279; font-size:16px;" class="gp-5-del-price">
                    {{- section.settings.delPrice -}}</del
                  >&nbsp;<span style="color:#A94442; font-size:16px;" class="value-medium gp-5-sell-price">
                    {{- section.settings.price -}}
                  </span>
                </div>
                <div style="color:#434448;">Subscribe & Save 50%</div>
              </div>
              <div style="color:#434448;" class="value-medium gp-5-var gp-5-var-ab link-to-variant variant_1 show">
                {{ section.settings.tab_description_1 }}
              </div>
              <div style="color:#434448;" class="value-medium gp-5-var gp-5-var-ab link-to-variant variant_2 ">
                {{ section.settings.tab_description_2 }}
              </div>
              <ul class="gp-5-points text-left">
                {% for block in section.blocks %}
                  {% if block.type == 'text' %}
                    <li class="value-sans gray-text link-to-variant variant_{{ block.settings.listClass }} ">
                      {{ block.settings.listItem }}
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>

            <form
              @submit.prevent="console.log('submitted')"
              x-ref="product_form_{{ section.index}}"
              enctype="multipart/form-data"
              accept-charset="UTF-8"
              id="product_form_{{ section.index}}"
              class="shopify-product-form"
              data-product-id="{{product.id}}"
              action="/cart/add"
            >
              <input type="hidden" name="id" class="input_variant_id" value="{{ section.settings.varaiantid }}">
              <input type="hidden" class="discout_input" name="discount" value="{{ section.settings.discount }}">
              <input type="hidden" name="quantity" value="1">
              {% if section.settings.isSub %}
                <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
                <input
                  class="input_selling_plan"
                  type="hidden"
                  name="selling_plan"
                  value="{{section.settings.sellingid}}"
                >
              {% endif %}
            </form>

            <div class="text-left  g4-btn-wrapper m-auto">
              {% if section.settings.redirectLink %}
                <a
                  class="btn w-100 blue-btn value-sans btn-loader checkout-starterkit-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                  href="{{ section.settings.redirectLink }}"
                >
                  {% if section.settings.outOfStock %}
                    Out of Stock
                  {% else %}
                    {{ section.settings.btnText }}
                  {% endif -%}
                </a>
              {% else %}
                {% if section.settings.isCheckout %}
                  <span
                    x-on:click="Purdy.CheckoutLanding($refs.product_form_{{ section.index}}, event)"
                    class="btn w-100 blue-btn value-medium btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                    style="background-color:#2D469E"

                    data-add-to-cart="true"
                    data-page-url="{{ request.path }}"
                    data-target-url="{{ section.settings.targetUrl }}"
                    data-index="{{ section.settings.index }}"
                    data-funnel-stage="{{ section.settings.funnel_stage }}"
                    data-module="{{ section.settings.dataModule }}"
                    data-event-label="{{ section.settings.dataTitle }}"
                    data-event-value="{{ section.settings.eventValue }}"
                    data-item-id="{{ section.settings.sku }}"
                    data-option-index="{{ section.settings.optionIndex }}"
                    data-item-name="{{ product.title }}"
                    data-quantity="{{ section.settings.quantity }}"
                    data-price="{{ section.settings.price }}"
                  >
                    {% if section.settings.outOfStock %}
                      Out of Stock
                    {% else %}
                      <span class="buy-text">{{ section.settings.btnText }}</span> |
                      <span class="deleted-price value-sans white-text gp-5-del-price">
                        {{- section.settings.delPrice -}}
                      </span>
                      <span class="value-sans white-text gp-5-sell-price">{{ section.settings.price }} </span>
                    {% endif -%}
                  </span>
                {% else %}
                  <span
                    class="btn w-100 theme-btn value-sans btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                    x-on:click="Purdy.AddToCart($refs.product_form, true, false, $event)"
                    {% if section.settings.dataTrack %}
                      data-add-to-cart="true"
                      data-page-url="{{ request.path }}"
                      data-target-url="{{ section.settings.targetUrl }}"
                      data-index="{{ section.index }}"
                      data-funnel-stage="{{ section.settings.funnel_stage }}"
                      data-module="{{ section.settings.dataModule }}"
                      data-event-label="{{ section.settings.dataTitle }}"
                      data-event-value="{{ section.settings.eventValue }}"
                      data-item-id="{{ section.settings.sku }}"
                      data-option-index="{{ section.settings.optionIndex }}"
                      data-item-name="{{ product.title }}"
                      data-quantity="{{ section.settings.quantity }}"
                      data-price="{{ section.settings.price }}"
                    {% endif %}
                  >
                    {% if section.settings.outOfStock %}
                      Out of Stock
                    {% else %}
                      {{ section.settings.btnText }}
                    {% endif -%}
                  </span>
                {% endif %}
              {% endif -%}
              <div class="text-center value-sans theme-text mt-2 guarantee-text" style="font-size:14px;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Global Product 16",
  "settings": [
    {
      "type": "checkbox",
      "id": "outOfStock",
      "label": "Enable If product out Of Stock",
      "default": true
    },
    {
      "id": "isSub",
      "label": "Product subscription",
      "type": "checkbox",
      "default": false
    },
    {
      "id": "isCheckout",
      "label": "Go to Checkout",
      "type": "checkbox",
      "default": false
    },
    {
      "id": "scrollto",
      "label": "Review Scroll to",
      "type": "text"
    },
    {
      "id": "background",
      "label": "Background color",
      "type": "color"
    },
    {
      "id": "p_id",
      "label": "Product Section Scroll ID",
      "type": "text"
    },
    {
      "id": "landingproduct",
      "label": "Choose the landing product",
      "type": "product"
    },
    {
      "type": "text",
      "id": "varaiantid",
      "label": "Variant ID"
    },
    {
      "type": "text",
      "id": "sellingid",
      "label": "Selling ID"
    },
    {
      "type": "text",
      "id": "sku",
      "label": "SKU"
    },
    {
      "type": "text",
      "id": "discount",
      "label": "Discount Code"
    },
    {
      "id": "tab_description_1",
      "label": "Tab 1 Description",
      "default": "Transform your home with new natural scents each season",
      "type": "text"
    },
    {
      "id": "tab_description_2",
      "label": "Tab 2 Description",
      "default": "Our best-selling citrus for a beautifully scented home",
      "type": "text"
    },
    {
      "type": "text",
      "id": "className",
      "label": "Section Class"
    },
    {
      "type": "html",
      "id": "mainheading",
      "label": "Main Heading"
    },
    {
      "type": "html",
      "id": "mainsubheading",
      "label": "Sub Heading"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Product Title"
    },
    {
      "id": "subtext",
      "label": "Banner Sub Text",
      "type": "html"
    },
    {
      "id": "price",
      "label": "Price",
      "type": "text"
    },
    {
      "id": "delPrice",
      "label": "Compare Price",
      "type": "text"
    },
    {
      "id": "btnText",
      "label": "Button label",
      "type": "text",
      "default": "BUY NOW"
    },
    {
      "id": "redirectLink",
      "label": "Button Link",
      "type": "url"
    },
    {
      "id": "ctaDetails",
      "label": "Button Details Text",
      "type": "html"
    },
    {
      "id": "shopbtnLabel",
      "label": "Shop Button label",
      "type": "text"
    },
    {
      "id": "shopbtnLink",
      "label": "Shop Button link",
      "type": "url"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "checkbox",
      "id": "heading-position",
      "label": "Heading After Image"
    },
    {
      "type": "checkbox",
      "id": "before-mobile",
      "label": "Heading before Image"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "landing_page"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "quantity",
      "label": "Item Quantity",
      "type": "number",
      "default": 1
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "block",
      "settings": [
        {
          "type": "text",
          "id": "listClass",
          "label": "Add list Class",
          "default": "1 show",
          "info": "add number 1, 2, 3 according to related variant number"
        },
        {
          "type": "text",
          "id": "listItem",
          "label": "Add Item"
        }
      ]
    },
    {
      "type": "productImage",
      "name": "Product Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Add Product Image"
        },
        {
          "type": "image_picker",
          "id": "mimage",
          "label": "Mobile Product Image"
        },
        {
