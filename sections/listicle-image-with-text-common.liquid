<style>
  .w-45 {
    width: 48% !important;
  }
  .image-txt .heading-2 {
    font-size: 24px !important;
    line-height: 36px !important;
    font-family: "Lausanne" !important;
  }
  .image-txt .normal-text {
    font-size: 16px;
    font-weight: 200;
    line-height: 25.6px;
    font-family: "Lausanne";
    padding-top: 4px !important;
  }
  .shop-now-cta {
    background: #11322c !important;
    color: #ffffff;
    width: 343px;
    font-size: 16px !important;
    line-height: 16px !important;
    letter-spacing: 0.4px;
    font-family: "Lausanne";
    min-height: 48px;
    padding: 15px 16px !important;
    border: 0 !important;
    margin-top: 1rem;
  }
  .two-women-details {
    width: 100%;
  }
  .two-women-details .heading-2 {
    width: 80%;
  }
  .two-women-details .normal-text {
    width: 90%;
  }
  @media (max-width: 768px) {
    .w-45 {
      width: 100% !important;
    }
    .two-women-details {
      margin-top: unset !important;
    }
    .image-txt .heading-2 {
      font-size: 20px !important;
      line-height: 30px !important;
      padding-top: 16px !important;
    }
    .image-txt .normal-text {
      font-size: 14px;
      line-height: 21px;
      padding-top: 4px !important;
    }
    .shop-now-cta {
      width: 100% !important;
    }
    .two-women-details .heading-2 {
      width: 100%;
    }
    .two-women-details .normal-text {
      width: 100%;
    }
    .image-with-text-2:not(:first-child) {
      padding-top: unset !important;
      padding-bottom: 32px;
    }
  }
</style>

<div class="{{ section.settings.className }}">
  {% for block in section.blocks %}
  <div
    style="background-color:{{section.settings.background}};"
    class="py-5 image-with-text image-with-text-2"
  >
    <div class="container">
      <div class="d-flex flex-wrap justify-content-between align-items-center">
        <div class="w-45 {% if block.settings.layout %} order-2 {%endif%}">
          <div class="two-women">
            {% if block.settings.image %}
              {% assign mImage = block.settings.image | img_url: '800x' %}
              {% assign mmImage = block.settings.mimage | img_url: '800x' %}
              <img
                loading="lazy"
                src="{{mImage}}"
                width="800px"
                height="800px"
                class="img-responsive w-100 h-auto mobile-hide"
                alt="{{ block.settings.image.alt }}"
              >
              <img
                loading="lazy"
                src="{{mmImage}}"
                width="800px"
                height="800px"
                class="img-responsive w-100 h-auto desktop-hide"
                alt="{{ block.settings.mimage.alt }}"
              >
            {% endif %}
          </div>
        </div>
        <div class="w-45 d-flex justify-content-start {% if block.settings.layout %} order-1 {%endif%} image-txt">
          <div class="two-women-details  pb-2 {{block.settings.width}}">
            <h2 class="heading-2 value-bold blue-text {{section.settings.textcolor}}">
              {{ block.settings.heading }}
            </h2>
            <div class="normal-text {{section.settings.textcolor}}">
              {{ block.settings.details }}
            </div>
            {% if block.settings.shop_now_cta %}
            <span class="shop-now-cta btn click-scroll" 
              data-target="{{ block.settings.scrollto }}"
              data-top="{{ block.settings.top }}"
              {% if block.settings.dataTrack %}
                data-tracked="true"
                data-page-url="{{ request.path }}"
                data-target-url="{{ block.settings.targetUrl }}"
                data-index="{{ block.settings.index }}"
                data-funnel-stage="{{ block.settings.funnel_stage }}"
                data-module="{{ block.settings.dataModule }}"
                data-event-label="{{ block.settings.dataTitle }}"
                data-event-value="{{ block.settings.eventValue }}"
                data-item-id="{{ block.settings.itemId }}"
                data-option-index="{{ block.settings.optionIndex }}"
                data-item-name="{{ block.settings.ItemName }}"
              {% endif %}
            >
              {{ block.settings.shop_now_cta }}
            </span>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endfor %}
</div>

{% schema %}
  {
    "name": "Image with text",
    "settings": [
      {
        "type": "text",
        "id": "className",
        "label": "Add Section class Name"
      },
      {
        "type": "color",
        "id": "background",
        "label": "Select background color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "headingcolor",
        "label": "Select heading color",
        "default": "#0A1E1A"
      },
      {
        "type": "color",
        "id": "textcolor",
        "label": "Select details text color",
        "default": "#212121"
      }
	],
    "blocks": [
      {
        "type": "text",
        "name": "block",
        "settings": [
          {
            "type": "select",
            "id": "width",
            "label": "Select text area width",
            "options": [
              {
                "value": "w-90",
                "label": "90%"
              },
              {
                "value": "w-80",
                "label": "80%"
              },
              {
                "value": "w-70",
                "label": "70%"
              },
              {
                "value": "w-60",
                "label": "60%"
              }
            ],
            "default": "w-80"
          },
          {
            "type": "checkbox",
            "id": "layout",
            "label": "Image on right"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Add Desktop Image"
          },
          {
            "type": "image_picker",
            "id": "mimage",
            "label": "Add Mobile Image"
          },
          {
            "type": "html",
            "id": "details",
            "label": "Detail Text"
          },
          {
            "type": "text",
            "id": "shop_now_cta",
            "label": "Button Label"
          },
          {
              "type": "text",
              "id": "scrollto",
              "label": "Scroll to section id",
              "default": "javascript:void(0);"
          },
          {
              "type": "text",
              "id": "top",
              "label": "On scroll top position",
              "default": "0"
          },
          {
            "type": "header",
            "content": "Mobile"
          },
          {
            "type": "checkbox",
            "id": "heading-position",
            "label": "Heading After Image"
          },
          {
            "type": "header",
            "content": "GA4"
          },
          {
            "id": "dataTrack",
            "label":"Data Track",
            "type": "checkbox"
          },
          {
            "id": "targetUrl",
            "label":"Target Url",
            "type": "url"
          },
          {
            "id": "index",
            "label":"Index",
            "type": "number",
            "default" : 0
          },
          {
            "id": "funnel_stage",
            "label":"Funnel Stage",
            "type": "text",
            "default" : "landing_page"
          },
          {
            "id": "dataModule",
            "label":"Module",
            "type": "text",
            "default" : "announcement_bar"
          },
          {
            "id": "dataTitle",
            "label":"Event Label",
            "type": "text",
            "default": "get_your_offer"
          },
          {
            "id": "eventValue",
            "label":"Event Value",
            "type": "text",
            "default" : "shop_anchor"
          },
          {
            "id": "itemId",
            "label":"Item Id",
            "type": "text"
          },
          {
            "id": "optionIndex",
            "label":"Option Index",
            "type": "text"
          },
          {
            "id": "ItemName",
            "label":"Item Name",
            "type": "text"
          }
        ]
      }
    ],
	"presets": [
		{
			"name": "Listicle image with text common"
		}
	]
  }
{% endschema %}
