                        {% endif %}
                      </form>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    // Next step button click handler
    document.querySelectorAll(".next-step-btn").forEach((btn) => {
        btn.addEventListener("click", function () {
            // Check which form/variant is currently selected before moving to step 2
            let selectedForm;
            const form1 = document.querySelector('.form_s1');
            const form2 = document.querySelector('.form_s2');
            
            // Check which variant is visible
            const variant1 = document.querySelector('.variant_1');
            if (variant1 && variant1.classList.contains('show')) {
                selectedForm = form1;
            } else {
                selectedForm = form2;
            }
            
            // Show step 2, hide step 1
            document.querySelectorAll(".step-1").forEach(el => el.classList.add("height-0"));
            document.querySelectorAll(".step-2").forEach(el => el.classList.remove("height-0"));
            
            // Get the gallery value from the first checked plan radio in the selected form
            if (selectedForm) {
                const checkedPlanInput = selectedForm.querySelector('.buy_plan_radio_:checked');
                if (checkedPlanInput) {
                    const galleryValue = checkedPlanInput.getAttribute("data-gallery");
                    if (galleryValue) {
                        updateGallery(galleryValue);
                    }
                }
            }
        });
    });
    
    // Back button click handler
    document.querySelectorAll(".back-btn").forEach((btn) => {
        btn.addEventListener("click", function () {
            document.querySelectorAll(".step-2").forEach(el => el.classList.add("height-0"));
            document.querySelectorAll(".step-1").forEach(el => el.classList.remove("height-0"));
        });
    });
    
    // Scent selector change handler
    document.querySelectorAll(".scent-selector-radio").forEach(function (input) {
        input.addEventListener("change", function (e) {
            e.preventDefault();
            const variantClass = this.getAttribute("data-variantclass");
            
            // Hide all variant galleries
            document.querySelectorAll(".step-1 .link-to-variant").forEach(function (el) {
                el.classList.remove("show");
            });
            
            // Show selected variant gallery
            const targetGallery = document.querySelector(".step-1 ." + variantClass);
            if (targetGallery) {
                targetGallery.classList.add("show");
            }
            
            // Hide all variant forms
            document.querySelectorAll(".step-2 .link-to-variant").forEach(function (el) {
                el.classList.remove("show");
            });
            
            // Show selected variant form
            const targetForm = document.querySelector(".step-2 ." + variantClass);
            if (targetForm) {
                targetForm.classList.add("show");
            }
        });
    });
    
    // Function to update gallery based on plan selection
    function updateGallery(galleryClass) {
        if (!galleryClass) return;
        
        // Find the target element
        const selector = ".step-2 ." + galleryClass;
        const targetElement = document.querySelector(selector);
        
        if (!targetElement) return;
        
        // Remove 'active-gallery' class from all plan galleries EXCEPT the target
        document.querySelectorAll(".step-2 .link-to-plan").forEach(function (el) {
            if (el !== targetElement) {
                el.classList.remove("active-gallery");
            }
        });
        
        // Add 'active-gallery' class to the target gallery
        targetElement.classList.add("active-gallery");
        
        // Reinitialize or refresh Slick slider for this gallery
        setTimeout(function() {
            const gallerySlider = targetElement.querySelector('.gp-5-product-gallery');
            if (gallerySlider && typeof jQuery !== 'undefined') {
                const $slider = jQuery(gallerySlider);
                if ($slider.hasClass('slick-initialized')) {
                    // Refresh existing slider
                    $slider.slick('setPosition');
                } else {
                    // Initialize new slider
                    $slider.slick({
                        slidesToShow: 1,
                        slidesToScroll: 1,
                        arrows: true,
                        dots: false,
                        infinite: true,
                        adaptiveHeight: true
                    });
                }
            }
        }, 100);
    }
    
    // Plan selector change handler
    document.querySelectorAll(".buy_plan_radio_").forEach(function (input) {
        input.addEventListener("change", function () {
            updateGallery(this.getAttribute("data-gallery"));
            
            const dataFormSelector = input.getAttribute('data-form');
            const itemType = input.getAttribute('data-item-type');
            
            // Hide guarantee sub-text for PAYG plans
            if (itemType === 'PAYG' || itemType === 'payg') {
                const guaranteeText = document.querySelector('#' + dataFormSelector + ' .guarantee-sub-text');
                if (guaranteeText) {
                    guaranteeText.style.display = 'none';
                }
            } else {
                const guaranteeText = document.querySelector('#' + dataFormSelector + ' .guarantee-sub-text');
                if (guaranteeText) {
                    guaranteeText.style.display = 'block';
                }
            }
        });
    });
});
</script>

