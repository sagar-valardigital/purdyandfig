<style>
  .banner-section-381 {
    width: 100%;
    height: 400px;
    padding: 80px 184px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    background: url('{{ section.settings.desktop_image | image_url: width: 3200 }}');
    background-color: lightgray;
    background-size: cover;
    background-position: top center;
  }

  .banner-image-381 {
    display: none;
  }

  .banner-heading-381 h2 {
    font-family: "GT Super";
    font-size: 48px;
    font-style: normal;
    font-weight: 400;
    line-height: 60px;
    color: {{ section.settings.text_color }};
  }

  @media (max-width: 767px) {
    .banner-section-381 {
      height: 310px;
      padding: 32px 16px;
      background: url('{{ section.settings.mobile_image | image_url: width: 1200 }}');
      background-size: cover;
      background-position: top center;
    }

    .banner-heading-381 h2 {
      font-size: 36px;
      line-height: 45px;
    }
  }
</style>

<section class="banner-section-381 position-relative">
  <div class="banner-heading-381">
    <h2>{{ section.settings.heading }}</h2>
    <p class="banner-sub-heading font-lausanne fw-200" style="color:{{ section.settings.text_color }} !important">{{ section.settings.sub_heading }}</p>
  </div>
</section>

{% schema %}
  {
    "name": "Banner 447",
    "settings": [
      {
        "type": "color",
        "id": "text_color",
        "label": "Text color"
      },
      {
        "type": "image_picker",
        "id": "desktop_image",
        "label": "Desktop image"
      },
      {
        "type": "image_picker",
        "id": "mobile_image",
        "label": "Mobile image"
      },
      {
        "type": "textarea",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "textarea",
        "id": "sub_heading",
        "label": "Sub Heading"
      }
    ],
    "presets": [
      {
        "name": "Banner 447"
      }
    ]
  }
{% endschema %}