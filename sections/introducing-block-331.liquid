<style>
  .shop-now-cta {
     background: #11322c !important;
     color: #ffffff !important;
     width: 343px;
     font-size: 16px !important;
     line-height: 16px !important;
     letter-spacing: 0.4px;
     font-family: "Lausanne";
     min-height: 48px;
     padding: 15px 16px !important;
     border: 0 !important;
     margin-top: 1rem;
   }

   @media (max-width: 768px) {
     .shop-now-cta {
       width: 100% !important;
       margin-top: 0;
     }

      #body .heading-2 {
            font-size: 32px !important;
            margin-bottom: 12px !important;
        }

        .two-women-details {
            margin-top: 32px;
        }
   }
</style>
<div class="{{ section.settings.className }}">
  <div
    style="background-color:{{section.settings.background}};"
    class="py-5  image-with-text image-with-text-2"
  >
    <div class="container">
      <h2 class="heading-2  {{section.settings.textcolor}} {% if section.settings.heading-position%} mobile-hide {% endif %} desktop-hide mt-0 text-center">
        {{ section.settings.heading }}
      </h2>
      <div class="normal-text {{section.settings.textcolor}} {% if section.settings.heading-position%} mobile-hide {% endif %} desktop-hide mt-0 mb-4">
        {{ section.settings.details }}
      </div>
      <div class="d-flex flex-wrap justify-content-between align-items-center">
        <div class="w-50 {% if section.settings.layout %} order-2 {%endif%}">
          <div class="two-women">
            {% if section.settings.image %}
              {% assign mImage = section.settings.image | img_url: '800x' %}
              {% assign mmImage = section.settings.mimage | img_url: '800x' %}
              <img
                loading="lazy"
                src="{{mImage}}"
                width="800px"
                height="800px"
                class="img-responsive w-100 h-auto mobile-hide"
                alt="{{ section.settings.image.alt }}"
              >
              <img
                loading="lazy"
                src="{{mmImage}}"
                width="800px"
                height="800px"
                class="img-responsive w-100 h-auto desktop-hide"
                alt="{{ section.settings.mimage.alt }}"
              >
            {% endif %}
          </div>
        </div>
        <div class="w-50  d-flex justify-content-start {% if section.settings.layout %} order-1 {%endif%} ">
          <div class="two-women-details  pb-2 {{section.settings.width}}">
            <h2 class="heading-2 value-bold blue-text {{section.settings.textcolor}} {% if section.settings.heading-position%} {% else %}mobile-hide{% endif %}">
              {{ section.settings.heading }}
            </h2>
            <div class="normal-text {{section.settings.textcolor}} {% if section.settings.heading-position%} {% else %}mobile-hide{% endif %}">
              {{ section.settings.details }}
            </div>
            {% if section.settings.shop_now_cta != '' %}
              <span
                class="shop-now-cta btn click-scroll"
                data-target="{{ section.settings.scrollto }}"
                data-top="{{ section.settings.top }}"
                {% if section.settings.dataTrack %}
                  data-tracked="true"
                  data-page-url="{{ request.path }}"
                  data-target-url="{{ section.settings.targetUrl }}"
                  data-index="{{ section.settings.index }}"
                  data-funnel-stage="{{ section.settings.funnel_stage }}"
                  data-module="{{ section.settings.dataModule }}"
                  data-event-label="{{ section.settings.dataTitle }}"
                  data-event-value="{{ section.settings.eventValue }}"
                  data-item-id="{{ section.settings.itemId }}"
                  data-option-index="{{ section.settings.optionIndex }}"
                  data-item-name="{{ section.settings.ItemName }}"
                {% endif %}
              >
                {{ section.settings.shop_now_cta }}
              </span>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "PF331 intro block",
    "settings": [

      {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
{
            "type": "color",
            "id": "textcolor",
            "label": "Select text color",
            "default": "#3541BF"
          },
{
            "type": "color",
            "id": "background",
            "label": "Select background color",

            "default": "#ffffff"
          },
{
            "type": "select",
            "id": "width",
            "label": "Select text area width",
            "options": [
              {
                "value": "w-90",
                "label": "90%"
              },
              {
                "value": "w-80",
                "label": "80%"
              },
{
                "value": "w-70",
                "label": "70%"
              },
              {
                "value": "w-60",
                "label": "60%"
              }
            ],
            "default": "w-80"
          },
          {
            "type": "checkbox",
            "id": "layout",
            "label": "Image on right"

          },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Add Desktop Image"
    },
      {
      "type": "image_picker",
      "id": "mimage",
      "label": "Add Mobile Image"
    },
        {
          "type": "html",
          "id": "details",
          "label": "Detail Text"
        },
        {
            "type": "text",
            "id": "shop_now_cta",
            "label": "Button Label"
          },
          {
              "type": "text",
              "id": "scrollto",
              "label": "Scroll to section id",
              "default": "javascript:void(0);"
          },
          {
              "type": "text",
              "id": "top",
              "label": "On scroll top position",
              "default": "0"
          },
          {
            "type": "header",
            "content": "Mobile"
          },
          {
            "type": "checkbox",
            "id": "heading-position",
            "label": "Heading After Image"
          },
          {
            "type": "header",
            "content": "GA4"
          },
          {
            "id": "dataTrack",
            "label":"Data Track",
            "type": "checkbox"
          },
          {
            "id": "targetUrl",
            "label":"Target Url",
            "type": "url"
          },
          {
            "id": "index",
            "label":"Index",
            "type": "number",
            "default" : 0
          },
          {
            "id": "funnel_stage",
            "label":"Funnel Stage",
            "type": "text",
            "default" : "landing_page"
          },
          {
            "id": "dataModule",
            "label":"Module",
            "type": "text",
            "default" : "announcement_bar"
          },
          {
            "id": "dataTitle",
            "label":"Event Label",
            "type": "text",
            "default": "get_your_offer"
          },
          {
            "id": "eventValue",
            "label":"Event Value",
            "type": "text",
            "default" : "shop_anchor"
          },
          {
            "id": "itemId",
            "label":"Item Id",
            "type": "text"
          },
          {
            "id": "optionIndex",
            "label":"Option Index",
            "type": "text"
          },
          {
            "id": "ItemName",
            "label":"Item Name",
            "type": "text"
          }
	],

	"presets": [
		{
			"name": "PF331 intro block"
		}
	]
  }
{% endschema %}
