    </div>
    {% render 'pf119-mobile-menu' %}
  </div>
</header>

{% schema %}
  {
    "name": "PF119 Header",
    "class": "section-header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "url",
        "id": "shopall",
        "label": "Shop All Link"
      },
      {
        "type": "link_list",
        "id": "menu2",
        "default": "main-menu",
        "label": "header-2"
      },
      {
        "type": "link_list",
        "id": "mobilemenu",
        "default": "main-menu",
        "label": "Mobile menu"
      },
      {
        "type": "link_list",
        "id": "mobilemenu2",
        "default": "main-menu",
        "label": "Mobile menu 2"
      },
      {
        "type": "link_list",
        "id": "mobilemenuAB",
        "default": "main-menu",
        "label": "Mobile menu AB"
      },
      {
        "type": "text",
        "id": "ourstoryheading",
        "label": "Our Story Heading"
      },
      {
        "type": "text",
        "id": "ourstorytext",
        "label": "Our Story Text"
      },
      {
        "type": "url",
        "id": "ourstorylink",
        "label": "Our Story Link"
      },
      {
        "type": "url",
        "id": "blog",
        "label": "Blogs Link"
      },
      {
        "type": "text",
        "id": "ctaText",
        "label": "CTA Text",
        "default": "Shop Starter Kit"
      },
      {
        "type": "text",
        "id": "ctaScrollTo",
        "label": "CTA Scroll to ID"
      },
      {
        "type": "product",
        "id": "top_product_link",
        "label": "Header Product CTA selection"
      },
      {
        "type": "header",
        "content": "Hamburger GA4"
      },
      {
        "id": "toggle_dataTrack",
        "label": "Data Track",
        "type": "checkbox"
      },
      {
        "id": "toggle_index",
        "label": "Index",
        "type": "number",
        "default": 0
      },
      {
        "id": "toggle_funnel_stage",
        "label": "Funnel Stage",
        "type": "text",
        "default": "hp"
      },
      {
        "id": "toggle_dataModule",
        "label": "Module",
        "type": "text",
        "default": "announcement_bar"
      },
      {
        "id": "toggle_dataTitle",
        "label": "Event Label",
        "type": "text",
        "default": "get_your_offer"
      },
      {
        "id": "toggle_eventValue",
        "label": "Event Value",
        "type": "text",
        "default": "shop_anchor"
      },
      {
        "type": "header",
        "content": "Menu GA4"
      },
      {
        "id": "dataTrack",
        "label": "Data Track",
        "type": "checkbox"
      },
      {
        "id": "index",
        "label": "Index",
        "type": "number",
        "default": 0
      },
      {
        "id": "funnel_stage",
        "label": "Funnel Stage",
        "type": "text",
        "default": "hp"
      },
      {
        "id": "dataModule",
        "label": "Module",
        "type": "text",
        "default": "announcement_bar"
      },
      {
        "id": "eventValue",
        "label": "Event Value",
        "type": "text",
        "default": "shop_anchor"
      }
    ],
    "blocks": [
      {
        "type": "menu",
        "name": "Starter Kit Menu",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Title"
          },
          {
            "type": "text",
            "id": "tag",
            "label": "Tag"
          },
          {
            "type": "color",
            "id": "tagColor",
            "label": "Tag Background"
          },
          {
            "type": "url",
            "id": "menulink",
            "label": "Link"
          },
          {
            "type": "image_picker",
            "id": "menuImage",
            "label": "Choose Image"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "PF119 Header"
      }
    ]
  }
{% endschema %}
