{% if section.settings.enable %}
<div class="how-it-work-section position-relative">
        <div class="">
            <div class="heading-section text-center theme-text my-5 ">
                <h2 class="heading-2 m-0">{{section.settings.heading}}</h2>
                <div class="normal-text font-2 my-2">{{section.settings.subheading}}</div>
            </div>
         
            <div class="how-it-work-content ">
              {% for block in section.blocks %}
                <div class="how-it-work-wrapper d-flex flex-wrap align-items-center theme-text {{block.settings.bclass}}">
                    <div class="w-50 how-it-work-img-wrapper position-relative py-3">
                        <div class="how-it-work-img ">
                          {% if block.settings.video %}
                          <video muted autoplay loop playsinline class="w-100 img-responsie" loading="lazy">
                          <source src="{{block.settings.video}}" type="video/mp4">
                          </video>
                          {% endif %}
                          
                          {%- assign imageURL = block.settings.desktopimage | img_url:"500x" -%}
                 		 <img loading="lazy" class="img-responsie w-100 {% if block.settings.video %} d-none{%endif%}" width="" height="" src="{{imageURL}}" alt="">
                        </div>
                    </div>
                    <div class="w-50">
                        <div class="how-it-work-text hiw-scent  p-5 w-70">
                            <h3 class="heading-3 mb-3">{{block.settings.heading}}</h3>
                            <p class="normal-text">{{block.settings.details}}</p>
                        </div>
                        
                    </div>
                </div>
              {% endfor %}
                
            </div>
        </div>
    </div>
{% endif %}
{% schema %}
 {
    "name": "How it work",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },
 {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
 {
      "type": "richtext",
      "id": "subheading",
      "label": "Sub Heading"
    },
{
            "type": "image_picker",
            "id": "desktopimage",
            "label": "Block Image"
          }
	],
"max_blocks": 3,
	"blocks": [
      {
        "type": "text",
        "name": "block",
        "settings": [ 
{
            "type": "image_picker",
            "id": "desktopimage",
            "label": "Block Image"
          },
{
            "type": "url",
            "id": "video",
            "label": "Video Link"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Block Heading"
          },
{
            "type": "text",
            "id": "details",
            "label": "Detail"
          },
{
            "type": "text",
            "id": "bclass",
            "label": "Add Class on block"
          }
		
        ]
      }
	],
	"presets": [
		{
			"name": "How it work"
		}
	]
  }
{% endschema %}


