{% if localization.market.handle == 'en-us' %}
<div class="annoucment-bar py-2 font-pier" style="background-color:{{section.settings.bg-color}}">
  <div class="container text-center" style="color:{{section.settings.text-color}}">
    <a
      {% if section.settings.dataTrack %}
        data-tracked="true"
        data-page-url="{{ request.path }}"
        data-target-url="{{ section.settings.targetUrl }}"
        data-index="{{ section.settings.index }}"
        data-funnel-stage="{{ section.settings.funnel_stage }}"
        data-module="{{ section.settings.dataModule }}"
        data-event-label="{{ section.settings.text | strip_html  | handle | replace: '-', '_'}}"
        data-event-value="{{ section.settings.eventValue }}"
        data-item-id="{{ section.settings.itemId }}"
        data-option-index="{{ section.settings.optionIndex }}"
        data-item-name="{{ section.settings.ItemName }}"
      {% endif %}
      {% if section.settings.scrollto != 'blank' %}
        {% if template.name == 'index' %}
          href="javascript:void(0);"
          class="click-scroll" data-target="{{ section.settings.scrollto }}" data-top="{{ section.settings.top }}"
        {% else %}
          href="/en-us/#{{ section.settings.scrollto }}"
        {% endif %}

      {% else %}
        href="{{ section.settings.annuLink }}"
      {% endif %}
      style="color:{{section.settings.text-color}}"
    >
      {{ section.settings.text }}
    </a>
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar US",
  "settings": [
    {
      "type": "html",
      "id": "text",
      "default": "Welcome to our store",
      "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
    },
    {
      "type": "color",
      "id": "bg-color",
      "default": "#CB3C8E",
      "label": "Background Colour"
    },
    {
      "type": "color",
      "id": "text-color",
      "default": "#fff",
      "label": "text Colour"
    },
    {
      "type": "url",
      "id": "annuLink",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "scrollto",
      "label": "Scroll to"
    },
    {
      "type": "text",
      "id": "top",
      "label": "Scroll to position"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "hp"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "itemId",
      "label": "Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label": "Item Name",
      "type": "text"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar US",
      "category": "Announcement Bar"
    }
  ]
}
{% endschema %}
