<style>
{% assign desktop = section.settings.bg | image_url %}
{% assign mobile = section.settings.m-bg | image_url %}
.copafeel-section.{{section.id}}{
  height:800px;
  background-image:url('{{ desktop }}');
  background-size:cover;
}
@media(max-width:768px){
 
  .copafeel-section.{{section.id}}{
     height:630px;
  background-image:url('{{ mobile }}');
    background-size:cover;
}
  .copafeel-section.py-80{
    padding:32px 0 32px 0;
  }
}
</style>

<div class="copafeel-section py-80 {{ section.id }}">
  <div class="container h-100">
    <div class="copafeel-content-block h-100">
      <div><h2 class="heading-2 white-text font-gtsuper">{{ section.settings.heading }}</h2></div>
      <div>
        <div class="mb-2">
          <img src="{{ section.settings.partnerImage | image_url}}" width="196" height="58" class="h-auto" />
        </div>
        <p class="fw-200 white-text partner-content font-lausanne">{{ section.settings.coppafeel_text }}</p>
        <a
        {% if section.settings.dataTrack %}
          {% render 'ga4-events' %}
        {% endif %}
        href="javascript:void(0);"
        class="click-scroll btn banner-10-btn"
        style="background-color:{{ section.settings.btn-bg }}; color:{{ section.settings.btn-txt-color }}"
        data-top="{{ section.settings.top }}"
        data-target="{{ section.settings.button_link }}"
      >
        {{- section.settings.button_label -}}
      </a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Copafeel",
  "settings": [
    {
      "type" : "image_picker",
      "label" : "Desktop Image",
      "id" : "bg"
    },
    {
      "type" : "image_picker",
      "label" : "Mobile Image",
      "id" : "m-bg"
    },
    
    {
      "type" : "html",
      "label" : "Heading",
      "id" : "heading"
    },
    {
      "type" : "image_picker",
      "label" : "Mobile Image",
      "id" : "partnerImage"
    },
    {
      "type" : "html",
      "label" : "Text",
      "id" : "coppafeel_text"
    },
    {
      "type" : "color",
      "label" : "Button BG Colour",
      "id" : "btn-bg",
      "default": "#ffffff"
    },
    {
      "type" : "color",
      "label" : "Button Text Colour",
      "id" : "btn-txt-color",
      "default": "#11322C"
    },
    {
      "type" : "text",
      "label" : "Button label",
      "id" : "button_label"
    },
    {
      "type" : "text",
      "label" : "Button Link",
      "id" : "button_link"
    }
   ,
    {
         "type": "text",
         "id": "top",
         "label": "Scroll position"
     },
     {
      "id": "dataTrack",
      "label":"Data Track",
      "type": "checkbox"
      },
      {
      "id": "targetUrl",
      "label":"Target Url",
      "type": "url"
      },
      {
      "id": "index",
      "label":"Index",
      "type": "number",
      "default" : 0
          },
          {
      "id": "funnel_stage",
      "label":"Funnel Stage",
      "type": "text",
       "default" : "landing_page"
          },
          {
      "id": "dataModule",
      "label":"Module",
      "type": "text",
       "default" : "announcement_bar"
          },
            {
      "id": "dataTitle",
      "label":"Event Label",
      "type": "text",
      "default": "get_your_offer"
          }
          ,
            {
      "id": "eventValue",
      "label":"Event Value",
      "type": "text",
      "default" : "shop_anchor"
          },
            {
      "id": "itemId",
      "label":"Item Id",
      "type": "text"
          }
          ,
            {
      "id": "optionIndex",
      "label":"Option Index",
      "type": "text"
          }
          ,
            {
      "id": "ItemName",
      "label":"Item Name",
      "type": "text"
          }
  ],
 
  "presets": [
    {
      "name": "Copafeel"
    }
  ]
}
{% endschema %}
