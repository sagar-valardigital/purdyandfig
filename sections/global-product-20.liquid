<script>
  function removeAutocomplete() {
    const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;

    if (isSafari || isIOS) {
      const form = document.getElementById('product_form_{{ section.index}}');

      if (form) {
        form.removeAttribute('autocomplete');

        const formElements = form.elements;

        for (let i = 0; i < formElements.length; i++) {
          formElements[i].removeAttribute('autocomplete');
        }
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
      const urlParams = new URLSearchParams(window.location.search);
      const isRefill = urlParams.has('refills');

      removeAutocomplete();

      if (isRefill) {
          document.getElementById("starterkit-product").scrollIntoView({ behavior: 'smooth', block: 'start' });
          const refillsOption = document.querySelector('#buyplan_refill_{{ section.id }}');

          if (refillsOption) {
              const observer = new MutationObserver((mutations, observer) => {
                const signatureTab = document.querySelector('.gp-10-variants input[data-variantclass="variant_2"]');
                if (signatureTab) {
                    // Automatically select the second "Signature" tab and click
                    signatureTab.checked = true;
                    signatureTab.click();
                    const tabChangeEvent = new Event('change', { bubbles: false });
                    signatureTab.dispatchEvent(tabChangeEvent);

                    // Automatically select the "Refills" option after Signature tab selection
                    refillsOption.checked = true;
                    refillsOption.click();
                    const event = new Event('change', { bubbles: false });
                    refillsOption.dispatchEvent(event);

                    // Stop observing once the element is found and handled
                    observer.disconnect();
                }
            });

            // Start observing for changes in the DOM
            observer.observe(document.body, { childList: true, subtree: true });

            // Fallback in case the observer doesn't trigger
            setTimeout(() => {
                const signatureTab = document.querySelector('.gp-10-variants input[data-variantclass="variant_2"]');
                if (signatureTab) {
                    signatureTab.checked = true;
                    signatureTab.click();
                    const tabChangeEvent = new Event('change', { bubbles: false });
                    signatureTab.dispatchEvent(tabChangeEvent);

                    refillsOption.checked = true;
                    refillsOption.click();
                    const event = new Event('change', { bubbles: false });
                    refillsOption.dispatchEvent(event);
                }
            }, 500);
          }
      }
  });

  var screenSize = window.innerWidth;
  document.querySelectorAll('li.gp-5-variant-li.gp-14-variant-li.value-sans').forEach(function(li) {
    var radioInput = li.querySelector('input[type="radio"]');

    if (radioInput) {
      radioInput.addEventListener('change', function() {
        var radiosection = this.getAttribute('data-section');
        var dataAttributes = radioInput.dataset;
        var variantSub = this.getAttribute('data-variantclass');
        var variantOnce = this.getAttribute('data-variantclassonce');
        var refill_price = this.getAttribute('data-refill-price');
        var price = this.getAttribute('data-price');
        var sub_price = this.getAttribute('data-subprice');

        var subInput = document.querySelector('.gp-14-sub-option');
        var refillInput = document.querySelector('.gp-14-refill-option');
        subInput.setAttribute("data-variantclass", variantSub);
        refillInput.setAttribute("data-variantclass", variantOnce);
        var element = document.querySelector('#' + dataAttributes['section'] + ' .gp-10-refill-only input');
        var element2 = document.querySelector('#' + dataAttributes['section'] + ' .gp-10-subscribe input');

        var ispaygchecked = $('input[data-variantclass="'+variantOnce+'"]:checked').length;
        if(ispaygchecked > 0) {
          setTimeout(() => {
            $('#' + radiosection + ' .ga4-checkout-btn').attr("data-price", refill_price);
          }, 300);

          if(variantOnce === 'variant_3') {
            setTimeout(() => {
              $('#' + radiosection + ' input[data-variantclass="variant_3"]').attr("data-item-name", '{{ section.settings.refill_variant_name_1 }}');
              $('#' + radiosection + ' .ga4-checkout-btn').attr("data-item-name", '{{ section.settings.refill_variant_name_1 }}');
            }, 300);
          } else {
            setTimeout(() => {
              $('#' + radiosection + ' input[data-variantclass="variant_4"]').attr("data-item-name", '{{ section.settings.refill_variant_name_2 }}');
              $('#' + radiosection + ' .ga4-checkout-btn').attr("data-item-name", '{{ section.settings.refill_variant_name_2 }}');
            }, 300);
          }
        }

        if (dataAttributes['variantclass'] === 'variant_2') {
          element.setAttribute("data-variantid", dataAttributes['refillVariantid-2']);
          element.setAttribute("data-id", dataAttributes['refillVariantid-2']);
          element.setAttribute("data-item-id", dataAttributes['refillSku2']);
          element.setAttribute("data-sku", dataAttributes['refillSku2']);
          element.setAttribute("data-price", dataAttributes['refillPrice']);
          element2.setAttribute("data-price", sub_price);
          element2.setAttribute("data-discount-price", price);
        } else {
          element.setAttribute("data-variantid", dataAttributes['refillVariantid']);
          element.setAttribute("data-id", dataAttributes['refillVariantid']);
          element.setAttribute("data-item-id", dataAttributes['refillSku']);
          element.setAttribute("data-sku", dataAttributes['refillSku']);
          element.setAttribute("data-price", dataAttributes['refillPrice']);
          element2.setAttribute("data-price", sub_price);
          element2.setAttribute("data-discount-price", price);
        }
        document.querySelector('.refill-price').textContent = dataAttributes['refillPrice'];

        for (var key in dataAttributes) {
          if (dataAttributes.hasOwnProperty(key)) {
            console.log(key + ": " + dataAttributes[key]);
          }
        }
      });
    }
  });


  document.querySelectorAll('.buy_plan_radio').forEach(function(element) {
    element.addEventListener('change', function() {
      this.setAttribute('checked', true);

      var radiosection = this.getAttribute('data-section');
      var itemType = this.getAttribute('data-item-type');
      var price = this.getAttribute('data-price');
      var variant = this.getAttribute('data-variantclass');
      const dicountedPrice = this.getAttribute('data-discount-price');

      if(itemType == 'PAYG') {
        $('.gp-14-sub-option').removeAttr('checked');
        $('.gp-14-refill-option').attr('checked', 'checked');

        if(variant === 'variant_3') {
          setTimeout(() => {
            $('#' + radiosection + ' input[data-variantclass="variant_3"]').attr("data-item-name", '{{ section.settings.refill_variant_name_1 }}');
            $('#' + radiosection + ' .ga4-checkout-btn').attr("data-item-name", '{{ section.settings.refill_variant_name_1 }}');
          }, 300);
        } else {
          setTimeout(() => {
            $('#' + radiosection + ' input[data-variantclass="variant_4"]').attr("data-item-name", '{{ section.settings.refill_variant_name_2 }}');
            $('#' + radiosection + ' .ga4-checkout-btn').attr("data-item-name", '{{ section.settings.refill_variant_name_2 }}');
          }, 300);
        }
      } else {
        $('.gp-14-sub-option').attr('checked', 'checked');
        $('.gp-14-refill-option').removeAttr('checked');
        $('#' + radiosection + ' .ga4-checkout-btn').attr("data-item-name", this.getAttribute('data-item-name'));
      }

      setTimeout(() => {
        $('#' + radiosection + ' .ga4-checkout-btn').attr("data-price", price);
      }, 300);

      var allSlider = document.querySelectorAll('.gp-14-2-sliders .link-to-variant');
      allSlider.forEach(function(slider) {
        slider.classList.remove('show');
        if (slider.classList.contains(variant)) {
          slider.classList.add('show');
        }
      })
      document.querySelectorAll('.checkout-starterkit-btn').forEach(function(btn) {
        // Find the span with class name 'buy-text' inside the button
        var buyTextSpan = btn.querySelector('.buy-text');
        var buySellPrice = btn.querySelector('.gp-5-sell-price');
        var buyPriceSpan = btn.querySelector('.deleted-price');


        buyTextSpan.textContent = itemType == 'PAYG' ? "BUY ONCE" : "TRY IT RISK FREE";

        if (itemType == 'PAYG') {
          buyPriceSpan.style.display = 'none';
          buyPriceSpan.textContent = '';
          buySellPrice.textContent = price;

          btn.setAttribute('data-event-label', 'buy_once');
        } else {
          buyPriceSpan.style.display = 'flex';
          buyPriceSpan.textContent = dicountedPrice;
          buySellPrice.textContent = price;

          btn.setAttribute('data-event-label', '{{ section.settings.dataTitle }}');
        }

        btn.setAttribute('data-item-type', itemType);
      });
    });
  });
</script>
