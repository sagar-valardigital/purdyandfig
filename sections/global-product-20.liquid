                  {{- settings.gloabalreviews }} verified 5-star reviews</span
                >
              </div>
            </div>
          </div>
          <form
            name="shopify-product-form"
            autocomplete="off"
            @submit.prevent="console.log('submitted')"
            x-ref="product_form_{{ section.index}}"
            enctype="multipart/form-data"
            accept-charset="UTF-8"
            id="product_form_{{ section.index}}"
            class="shopify-product-form"
            data-product-id="{{product.id}}"
            action="/cart/add"
          >
            <div class="gp-5-bottom">
              {% if section.settings.scent_label != blank %}
                <div class="mb-2 mt-2 choose-secnt-label value-medium">{{ section.settings.scent_label }}</div>
              {% endif %}

              <ul class="list-unstyle   var_{{ product.variants | size  }}  gp-10-variants ">
                {% assign checked = true %}
                {% for block in section.blocks %}
                  {% if block.type == 'variant' %}
                    {% assign product_v = block.settings.variantProduct %}
                    {% assign s_variant_v = product_v.selected_or_first_available_variant %}
                    {% assign sub_discount_price = s_variant_v.selling_plan_allocations[0].price_adjustments[0].price %}
                    {% assign sub_discount_percentage = product_v.price
                      | minus: sub_discount_price
                      | times: 100
                      | divided_by: product.price
                    %}

                    <li
                      data-title="{{block.settings.text_heading | downcase }}"
                      class="gp-5-variant-li gp-14-variant-li value-sans {% if block.settings.outofstock %}disabled var-out-of-stock{% endif %}"
                    >
                      <input
                        autocomplete="off"
                        data-planid="{{block.settings.selling_plan}}"
                        data-planid-2="{{block.settings.selling_plan_2}}"
                        data-variantid="{{block.settings.variant_id}}"
                        data-variantid-2="{{block.settings.variant_id_2}}"

                        data-refill-variantid="{{section.settings.refill_variant_id}}"
                        data-refill-variantid-2="{{section.settings.refill_variant_id_2}}"
                        data-refill-sku="{{ section.settings.refill_sku }}"
                        data-refill-sku2="{{ section.settings.refill_sku_2 }}"

                        data-refill-price="{{ block.settings.refillPrice | money }}"

                        data-sku-1="{{ block.settings.sku }}"
                        data-sku-2="{{ block.settings.sku2 }}"

                        class="homepage_global_14_v2 {{ section.settings.className }} {{ block.settings.class }} "

                        data-name="{{block.settings.text_heading}}"
                        data-include="{{variant.metafields.metadata.includes}}"
                        value="{{s_variant_v.id }}"
                        data-subprice="{{ block.settings.sellPrice | money }}"
                        data-price="{{block.settings.delPrice |  money}}"
                        data-image="{{ block.settings.varImage | img_url : '100x'}}"

                        data-productid="{{product_v.id}}"
                        data-variantclass="variant_{{ block.settings.varCount }}"
                        data-variantclassonce="variant_{{ block.settings.varCountOnce }}"
                        data-discount="{{ block.settings.discount }}"
                        data-discount-one-time="{{ block.settings.Oncediscount }}"
                        {% if block.settings.onetimedisabled %}
                          data-disabled="disabled"
                        {% endif %}
                        type="radio"
                        name="id_{{ section.id }}"

                        {% if block.settings.dataTrack %}
                          data-tracked="true" data-page-url="{{ request.path }}"
                          data-target-url="{{ block.settings.targetUrl }}" data-index="{{ block.settings.index }}"
                          data-funnel-stage="{{ block.settings.funnel_stage }}"
                          data-module="{{ block.settings.dataModule }}"
                          data-event-label="{{ block.settings.dataTitle }}"
                          data-event-value="{{ block.settings.eventValue }}" data-item-id="{{ block.settings.sku }}"
                          data-option-index="{{ block.settings.optionIndex }}" data-item-name="{{ product_v.title }}"
                        {% endif %}
                        data-section="id_{{ section.id }}"
                        id="id_{{ section.id }}_{{block.settings.text_heading | escape }}"
                        {% if product_v.available and checked %}
                          checked {% assign checked = false -%}
                        {% else %}

                        {% endif %}
                      >
                      {{ count }}
                      <label
                        style="background-image:url({{block.settings.varImage | img_url : '100x'}})"
                        {% if product_v.available %}
                          class="value-medium var_bg_{{ block.settings.text_heading | handle }} "
                        {% else %}
                          class="disabled  value-medium var_bg_{{ block.settings.text_heading | handle }}"
                        {% endif %}
                        for="id_{{ section.id }}_{{block.settings.text_heading | escape}}"
                        data-include="{{variant.metafields.metadata.includes}}"
                        data-value="{{block.settings.text_heading}}"
                      >
                        {{- block.settings.text_heading -}}
                      </label>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>

              {% if section.settings.tab_description_1 != blank %}
                <div
                  style=""
                  class="gp-19-var-short-desc gp-10-tab-desc mt-3 mb-3 value-sans gp-5-var gp-5-var-ab link-to-variant variant_1 show"
                >
                  {{ section.settings.tab_description_1 }}
                </div>
              {% endif %}
              {% if section.settings.tab_description_2 != blank %}
                <div
                  style=""
                  class="gp-19-var-short-desc gp-10-tab-desc mt-3 mb-3 value-sans gp-5-var gp-5-var-ab link-to-variant variant_2 "
                >
                  {{ section.settings.tab_description_2 }}
                </div>
              {% endif %}
              <div class="gp-10-buyplan mt-0">
                {% if section.settings.buyonce or section.settings.refillOnly %}
                  <div class="mb-3 mt-0 choose-secnt-label value-medium">Choose your plan</div>
                {% else %}
                  <div class="mb-3 mt-0 choose-secnt-label value-medium">Your Plan</div>
                {% endif %}
                <div class="gp-10-subscribe gp-10-input-buy position-relative mt-1">
                  {% if section.settings.sub_tag != blank and section.settings.buyonce %}
                    <span class="buybox-tag value-sans">{{ section.settings.sub_tag }}</span>
                  {%- endif %}
                  <input
                    autocomplete="off"
                    type="radio"
                    id="buyplan_sub_{{ section.id }}"
                    name="buyplan_{{ section.id }}"
                    class="gp-10-buyoption buy_plan_radio gp-14-sub-option"
                    data-option="subscription"
                    data-section="id_{{ section.id }}"
                    data-discount="{{ section.settings.discount }}"
                    data-planid="{{ section.settings.selling_plan }}"
                    data-variantid="{{ section.settings.variant_id }}"
                    data-sku="{{ section.settings.sku }}"

                    data-page-url="{{ request.path }}"
                    data-target-url=""
                    data-index="{{ section.settings.index }}"
                    data-funnel-stage="{{ section.settings.funnel_stage }}"
                    data-module="{{ section.settings.dataModule }}"
                    data-event-label="subscription"
                    data-event-value="plan_selector"
                    data-item-id="{{ section.settings.sku }}"
                    data-option-index="1"
                    data-item-name="{{ product.title }}"
                    data-price="{{ localization.country.currency.symbol }}{{ section.settings.price }}"
                    data-id="{{ section.settings.variant_id }}"
                    data-item-type="subscription"
                    data-variantclass="variant_1"
                    data-discount-price="{{ localization.country.currency.symbol }}{{ section.settings.delPrice }}"
                    checked
                  >
                  <label
                    for="buyplan_sub_{{ section.id }}"
                    class="value-sans {% if section.settings.buyonce or section.settings.refillOnly %} {% else %} no-buy-once{% endif %}"
                  >
                    {% if section.settings.buyonce or section.settings.refillOnly %}
                      <div class="d-flex justify-content-between buy-block-text mt-1 mb-1">
                        <span class="value-medium">90 day plan</span>
                        <span class="d-flex justify-content-end">
                          <span class="text-decoration-line-through gp-5-del-price">
                            {{ localization.country.currency.symbol }}
                            {{- section.settings.delPrice -}}
                          </span>
                          <span class="gp-5-sell-price value-medium">
                            {{ localization.country.currency.symbol -}}
                            {{- section.settings.price -}}
                          </span>
                        </span>
                      </div>
                    {% endif %}
                    <div
                      class="d-flex"
                      style="flex-direction: column; {% if section.settings.flipPoints %}margin-top: 6px;{% endif %}"
                    >
                      {% for block in section.blocks %}
                        {% if block.type == 'text' %}
                          <span class="d-none value-sans link-to-variant gp-14-2-text variant_{{ block.settings.listClass }}">
                            {{ block.settings.listItem }}
                          </span>
                        {% endif %}
                      {% endfor %}
                      {% if section.settings.permanentPoint != '' %}
                        <hr
                          style="border:0; border-top:1px solid #DFE0E1; {% if section.settings.flipPoints %}order: -1;{% endif %}"
                          class=""
                        >

                        <span class="value-sans" style="{% if section.settings.flipPoints %}order: -2;{% endif %}"
                          ><img
                            src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/repeat.png?v=1707886062"
                            width="18px"
                            height="19px"
                            style="vertical-align:top"
                            class="sub-repeat-img"
                          >
                          &nbsp;{{ section.settings.permanentPoint -}}
                        </span>
                      {% endif %}
                    </div>
                  </label>
                </div>
                {% if section.settings.buyonce %}
                  <div class="gp-10-onetime gp-10-input-buy position-relative {% if section.settings.buyoncedisable %}disabled{% endif %}">
                    <input
                      autocomplete="off"
                      type="radio"
                      id="buyplan_onetime_{{ section.id }}"
                      name="buyplan_{{ section.id }}"
                      class="gp-10-buyoption buy_plan_radio "
                      data-section="id_{{ section.id }}"
                      data-option="oneoff"
                      data-discount="{{ section.settings.Oncediscount }}"
                      data-planid="{{ section.settings.selling_plan_2 }}"
                      data-variantid="{{ section.settings.variant_id_2 }}"
                      data-sku="{{ section.settings.sku2 }}"

                      data-tracked="true"
                      data-page-url="{{ request.path }}"
                      data-target-url=""
                      data-index="{{ section.settings.index }}"
                      data-funnel-stage="{{ section.settings.funnel_stage }}"
                      data-module="{{ section.settings.dataModule }}"
                      data-event-label="payg"
                      data-event-value="plan_selector"
                      data-item-id="{{ section.settings.sku2 }}"
                      data-option-index="2"
                      data-item-name="{{ product.title }}"
                      data-price="{{ localization.country.currency.symbol }}{{- section.settings.delPrice -}}"
                      data-id="{{ section.settings.variant_id_2 }}"
                      data-item-type="PAYG"
                      data-discount-price=""
                    >
                    <label for="buyplan_onetime_{{ section.id }}">
                      <div class="d-flex justify-content-between buy-block-text">
                        <span class="value-medium">Buy Once</span>
                        <span class="gp-5-del-price value-medium">
                          {{ localization.country.currency.symbol }}
                          {{- section.settings.delPrice -}}
                        </span>
                      </div>
                    </label>
                  </div>
                {% endif %}
                {% if section.settings.refillOnly %}
                  <div class="gp-10-refill-only gp-10-input-buy position-relative ">
                    <input
                      autocomplete="off"
                      type="radio"
                      id="buyplan_refill_{{ section.id }}"
                      name="buyplan_{{ section.id }}"
                      class="gp-10-buyoption buy_plan_radio gp-14-refill-option"
                      data-section="id_{{ section.id }}"
                      data-option="oneoff"
                      data-variantclass="variant_3"
                      data-variantid="{{ section.settings.refill_variant_id }}"
                      data-sku="{{ section.settings.refill_sku }}"

                      data-tracked="true"
                      data-page-url="{{ request.path }}"
                      data-target-url=""
                      data-index="{{ section.settings.index }}"
                      data-funnel-stage="{{ section.settings.funnel_stage }}"
                      data-module="{{ section.settings.dataModule }}"
                      data-event-label="payg"
                      data-event-value="plan_selector"
                      data-item-id="{{ section.settings.refill_sku }}"
                      data-option-index="2"
                      data-item-name="{% if section.settings.refill_variant_name_1 != blank %}{{ section.settings.refill_variant_name_1 }}{% else %}3 Cleaning Concentrates only{% endif %}"
                      data-price="{{ localization.country.currency.symbol }}{{- section.settings.refillPrice -}}"
                      data-id="{{ section.settings.refill_variant_id }}"
                      data-item-type="PAYG"
                      data-discount-price=""
                    >
                    <label for="buyplan_onetime_{{ section.id }}">
                      <div class="d-flex justify-content-between buy-block-text">
                        <span class="value-medium">{{ section.settings.refillOnlyHeading }}</span>
                        <span class=" value-medium refill-price">
                          {{ localization.country.currency.symbol }}
                          {{- section.settings.refillPrice -}}
                        </span>
                      </div>
                    </label>
                  </div>
                {% endif %}
              </div>

              <input
                autocomplete="off"
                type="hidden"
                name="id"
                class="input_variant_id"
                value="{{ section.settings.variant_id }}"
              >
              <input
                autocomplete="off"
                type="hidden"
                class="discout_input"
                name="discount"
                value="{{ section.settings.discount }}"
              >
              <input autocomplete="off" type="hidden" name="quantity" value="1">
              {% if section.settings.isSub %}
                <input
                  autocomplete="off"
                  type="checkbox"
                  name="purchase_type"
                  value="subscription"
                  checked
                  class="d-none gp-10-buyoption-input"
                >
                <input
                  autocomplete="off"
                  class="input_selling_plan"
                  type="hidden"
                  name="selling_plan"
                  value="{{ section.settings.selling_plan }}"
                >
              {% endif %}

              <div class="text-left  g4-btn-wrapper m-auto">
                {% if section.settings.redirectLink %}
                  <a
                    class="btn w-100 blue-btn value-sans btn-loader checkout-starterkit-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                    href="{{ section.settings.redirectLink }}"
                  >
                    {% if section.settings.outOfStock %}
                      Out of Stock
                    {% else %}
                      {{ section.settings.btnText }}
                    {% endif -%}
                  </a>
                {% else %}
                  {% if section.settings.isCheckout %}
                    <span
                      x-on:click="Purdy.CheckoutLandingV2($refs.product_form_{{ section.index}}, event)"
                      class="btn w-100 blue-btn value-medium btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                      style="background-color:#2D469E"
                      {% if section.settings.dataTrack %}
                        data-add-to-cart="true" data-page-url="{{ request.path }}"
                        data-target-url="{{ section.settings.targetUrl }}" data-index="{{ section.settings.index }}"
                        data-funnel-stage="{{ section.settings.funnel_stage }}"
                        data-module="{{ section.settings.dataModule }}"
                        data-event-label="{{ section.settings.dataTitle }}"
                        data-event-value="{{ section.settings.eventValue }}" data-item-id="{{ section.settings.sku }}"
                        data-option-index="{{ section.settings.optionIndex }}" data-item-name="{{ product.title }}"
                        data-quantity="{{ section.settings.quantity }}"
                        data-price="{{ localization.country.currency.symbol }}{{ section.settings.price }}"
                        data-item-type="subscription"
                        data-checkout="true"
                      {% endif %}
                    >
                      {% if section.settings.outOfStock %}
                        Out of Stock
                      {% else %}
                        <span class="buy-text">{{ section.settings.btnText }}</span> |
                        <span class="deleted-price value-sans white-text gp-5-del-price">
                          {{ localization.country.currency.symbol }}
                          {{- section.settings.delPrice -}}
                        </span>
                        <span class="value-sans white-text gp-5-sell-price">
                          {{- localization.country.currency.symbol -}}
                          {{- section.settings.price }}
                        </span>
                      {% endif -%}
                    </span>
                  {% else %}
                    <span
                      class="btn w-100 theme-btn value-sans btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                      x-on:click="Purdy.AddToCart($refs.product_form, true, false, $event)"
                      {% if section.settings.dataTrack %}
                        data-add-to-cart="true" data-page-url="{{ request.path }}"
                        data-target-url="{{ section.settings.targetUrl }}" data-index="{{ section.index }}"
                        data-funnel-stage="{{ section.settings.funnel_stage }}"
                        data-module="{{ section.settings.dataModule }}"
                        data-event-label="{{ section.settings.dataTitle }}"
                        data-event-value="{{ section.settings.eventValue }}" data-item-id="{{ section.settings.sku }}"
                        data-option-index="{{ section.settings.optionIndex }}" data-item-name="{{ product.title }}"
                        data-quantity="{{ section.settings.quantity }}"
                        data-price="{{ localization.country.currency.symbol }}{{ section.settings.price }}"
                        data-item-type="subscription"
                      {% endif %}
                    >
                      {% if section.settings.outOfStock %}
                        Out of Stock
                      {% else %}
                        {{ section.settings.btnText }}
                      {% endif -%}
                    </span>
                  {% endif %}
                {% endif -%}
