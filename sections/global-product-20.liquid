<style>
    .link-to-variant.show {
      display: block !important;
      height: auto;
      margin-top: 4px;
      margin-bottom: 4px;
    }
    .gp-14-2-text{
      position: relative;
      padding-left:25px;
    }
    .gp-14-2-text:before{
      content:'';
      position:absolute;
      width:14px;
      height:8px;
      border-left:2px solid #434448;
      border-bottom:2px solid #434448;
      transform:rotate(-45deg);
      left:0;
      top:4px;
    }
    .global-product-10 .gp-10-input-buy input:checked + label .gp-14-2-text:before{
       border-color:#2D469E;
    }
    .text-decoration-line-through {
     display:inline-block;
     position:relative;
     margin-right: 10px;
     font-weight: bold;
  }

    .text-decoration-line-through::before {
      content:'';
      position: absolute;
      width: 100%;
      height: 1px;
      background: #2c469d;
      top: calc(50% - 2px);
      left: 0;
    }

    @media (max-width: 768px) {
      .buybox-anchor {
        position: absolute;
        top: 250px;
      }
    }
</style>

