                  {{- settings.gloabalreviews }} verified 5-star reviews</span
                >
              </div>
            </div>
          </div>
          {% comment %} {% assign first_variant_block = null %} {% endcomment %}
          <form
            name="shopify-product-form"
            autocomplete="off"
            @submit.prevent="console.log('submitted')"
            x-ref="product_form_{{ section.index}}"
            enctype="multipart/form-data"
            accept-charset="UTF-8"
            id="product_form_{{ section.index}}"
            class="shopify-product-form show"
            data-product-id="{{product.id}}"
            action="/cart/add"
          >
            <div class="gp-5-bottom buy--plan pt-0" style="padding-top:0 !important;">
              {% if section.settings.choosescent != '' -%}
                <div class="choose-heading-scent-div">
                  <span class="font-lausanne choose-heading-scent">
                    {{- section.settings.choosescent -}}
                  </span>
                </div>
              {% endif %}
              {% assign variant_block_count = 0 %}
              {% for block in section.blocks %}
                {% if block.type == 'variant' %}
                  {% assign variant_block_count = variant_block_count | plus: 1 %}
                {% endif %}
              {% endfor %}
              <ul
                class="list-unstyle var_{{ product.variants | size }} gp-5-variants"
                {% if variant_block_count <= 1 %}
                  style="display:none"
                {% endif %}
              >
                {% assign checked = true %}
                {% assign count = 0 %}
                {% assign varCount = 0 %}
                {% for block in section.blocks %}
                  {% if block.type == 'variant' %}
                    {% assign varCount = varCount | plus: 1 %}
                    
                    {% comment %} Get variant ID from metaobject and find matching variant {% endcomment %}
                    {% assign variant_mo = block.settings.variantid %}
                    {% assign s_variant_v = null %}
                    {% assign actual_variant_id = null %}
                    {% assign product_v = block.settings.variantProduct %}
                    
                    {% if variant_mo and variant_mo.variant_id %}
                      {% comment %} Extract numeric ID from GID format (gid://shopify/ProductVariant/12345) {% endcomment %}
                      {% assign variant_id_gid = variant_mo.variant_id %}
                      {% assign actual_variant_id = variant_id_gid | remove: 'gid://shopify/ProductVariant/' %}
                      
                      {% comment %} Loop through product variants to find matching variant {% endcomment %}
                      {% if actual_variant_id and product_v %}
                        {% for v in product_v.variants %}
                          {% assign v_id_str = v.id | append: '' %}
                          {% if v_id_str == actual_variant_id %}
                            {% assign s_variant_v = v %}
                            {% break %}
                          {% endif %}
                        {% endfor %}
                      {% endif %}
                    {% endif %}
                    
                    {% comment %} Fallback if no variant found {% endcomment %}
                    {% unless s_variant_v %}
                      {% if product_v %}
                        {% assign s_variant_v = product_v.selected_or_first_available_variant %}
                      {% endif %}
                    {% endunless %}
                    
                    {% comment %} Get selling plan from variant's first selling plan allocation {% endcomment %}
                    {% assign selling_plan_id = null %}
                    {% if s_variant_v.selling_plan_allocations.size > 0 %}
                      {% assign selling_plan_id = s_variant_v.selling_plan_allocations[0].selling_plan.id %}
                    {% endif %}
                    {% assign sub_discount_price = s_variant_v.selling_plan_allocations[0].price_adjustments[0].price %}
                    {% assign sub_discount_percentage = product_v.price
                      | minus: sub_discount_price
                      | times: 100
                      | divided_by: product.price
                    %}
                    {% assign count = count | plus: 1 %}
                    <li
                      data-title="{{ block.settings.text_heading | downcase }}"
                      class="gp-5-variant-li value-sans {% if block.settings.outofstock %}disabled var-out-of-stock{% endif %}"
                      {{ product_v | json }}
                    >
                      {% if block.settings.variantBadge != blank %}
                        <span class="variant-badge">{{ block.settings.variantBadge }}</span>
                      {% endif %}
                      <input
                        autocomplete="off"
                        class="{{ section.settings.className }}"
                        data-name="{{ block.settings.text_heading }}"
                        data-include="{{ variant.metafields.metadata.includes }}"
                        value="{{ actual_variant_id }}"
                        data-subprice="{{ block.settings.price | times: 100 | money }}"
                        data-price="{{ block.settings.delPrice | times: 100 | money }}"
                        data-image="{{ block.settings.varImage | img_url: '100x' }}"
                        data-variantid="{{ actual_variant_id }}"
                        data-planid="{{ selling_plan_id }}"

                        data-productid="{{ product_v.id }}"
                        data-variantclass="variant_{{ count }}"
                        data-discount="{{ block.settings.discount }}"
                        type="radio"
                        name="id_{{ section.id }}"
                        {% if block.settings.dataTrack %}
                          data-tracked="true"
                          data-page-url="{{ request.path }}"
                          data-target-url="{{ block.settings.targetUrl }}"
                          data-index="{{ block.settings.index }}"
                          data-funnel-stage="{{ block.settings.funnel_stage }}"
                          data-module="{{ block.settings.dataModule }}"
                          data-event-label="{{ block.settings.dataTitle }}"
                          data-event-value="{{ block.settings.eventValue }}"
                          data-item-id="{{ block.settings.sku }}"
                          data-option-index="{{ block.settings.optionIndex }}"
                          data-item-name="{{ product_v.title }}"
                        {% endif %}
                        data-section="id_{{ section.id }}"
                        id="id_{{ section.id }}_{{ block.settings.text_heading | escape }}"
                        {{ product_v.available }}
                        {% if product_v.available and checked %}
                          checked {% assign checked = false -%}
                        {% endif %}
                      >
                      <label
                        {% if block.settings.varImage %}
                          style="background-image:url({{ block.settings.varImage | img_url: '100x' }})"
                        {% endif %}
                        {% if product_v.available %}
                          class="value-sans var_bg_{{ block.settings.text_heading | handle }}"
                        {% else %}
                          class="disabled value-sans var_bg_{{ block.settings.text_heading | handle }}"
                        {% endif %}
                        for="id_{{ section.id }}_{{ block.settings.text_heading | escape }}"
                        data-include="{{ variant.metafields.metadata.includes }}"
                        data-value="{{ block.settings.text_heading }}"
                      >
                        {{- block.settings.text_heading -}}
                      </label>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
              <input type="radio" checked class="" style="position:absolute;">
              <label class="black-text mt-3 gp-5-price-points mb-3 product-box-border" style="display:block;">
                <div class="d-flex justify-content-between value-sans gp-5-var">
                  <div class="gp-5-price">
                    <del style="color:#707279; font-size:16px;" class="gp-5-del-price">
                      {{ localization.country.currency.symbol }}
                      {{- first_variant_block.settings.delPrice -}}</del
                    >&nbsp;<span
                      style="color:#A94442; font-size:16px;"
                      class="value-medium gp-5-sell-price"
                    >
                      {{ localization.country.currency.symbol }}
                      {{- first_variant_block.settings.price -}}
                    </span>
                  </div>
                  <div style="color:#434448;">Subscribe & Save 50%</div>
                </div>

                {% assign tab_count = 0 %}
                {% for block in section.blocks %}
                  {% if block.type == 'variant' %}
                    {% assign tab_count = tab_count | plus: 1 %}
                    {% if block.settings.tab_description != blank %}
                      <div class="d-flex justify-content-between buy-block-text mt-0 p-0 {%  if layout2 %}mb-2 {%else%}mb-1 {% endif %}">
                        <span class="font-lausanne fw-600 chlabel">{{ block.settings.tab_description }}</span>
                        <span class="d-flex justify-content-end chlabelprice {%  if layout2 %}d-none{% endif %}" style="width:140px;">
                          <del class="font-lausanne fw-400 unsright" style="color:#9e9e9e;">
                            {{- localization.country.currency.symbol }}{{- first_variant_block.settings.delPrice -}}
                          </del>&nbsp;
                          <span class="gp-5-sell-price font-lausanne fw-500 ">
                            {{- localization.country.currency.symbol -}}
                            {{- first_variant_block.settings.price -}}
                          </span>
                        </span>
                      </div>
                    {% endif %}
                  {% endif %}
                {% endfor %}
                <ul class="gp-5-points text-left">
                  {% assign feat_count = 0 %}
                  {% for block in section.blocks %}
                    {% if block.type == 'variant' %}
                      {% assign feat_count = feat_count | plus: 1 %}
                      {% if block.settings.features_html != blank %}
                        {% assign features_raw = block.settings.features_html
                          | replace: '<br/>', '||'
                          | replace: '<br />', '||'
                          | replace: '<br>', '||'
                        %}
                        {% assign features_list = features_raw | split: '||' %}
                        {% for feature in features_list %}
                          {% assign feature_trimmed = feature | strip %}
                          {% if feature_trimmed != blank %}
                            <li class="value-sans gray-text link-to-variant variant_{{ feat_count }} {% if feat_count == 1 %}show{% endif %}">
                              {{ feature_trimmed }}
                            </li>
                          {% endif %}
                        {% endfor %}
                      {% else %}
                        {% assign plan_features = null %}
                        {% assign feat_variant_mo = block.settings.variantid %}
                        {% assign feat_variant_id = null %}
                        {% if feat_variant_mo %}
                          {% assign feat_variant_id = feat_variant_mo.variant_id.value %}
                        {% endif %}
                        {% if feat_variant_id %}
                          {% for v in block.settings.variantProduct.variants %}
                            {% assign v_id_str = v.id | append: '' %}
                            {% if v_id_str == feat_variant_id %}
                              {% assign plan_features = v.metafields.custom.plan_features.value %}
                              {% break %}
                            {% endif %}
                          {% endfor %}
                        {% endif %}
                        {% for feature in plan_features %}
                          <li class="value-sans gray-text link-to-variant variant_{{ feat_count }} {% if feat_count == 1 %}show{% endif %}">
                            {{ feature }}
                          </li>
                        {% endfor %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                </ul>
              </label>
              <input
                autocomplete="off"
                type="hidden"
                name="id"
                class="input_variant_id"
                value="{{ first_variant_id }}"
              >
              <input
                autocomplete="off"
                type="hidden"
                class="discout_input"
                name="discount"
                value="{{ first_variant_block.settings.discount }}"
              >
              {% if section.settings.isSub %}
                <input
                  autocomplete="off"
                  type="checkbox"
                  name="purchase_type"
                  value="subscription"
                  checked
                  class="d-none"
                >
                <input
                  autocomplete="off"
                  class="input_selling_plan"
                  type="hidden"
                  name="selling_plan"
                  value="{{ first_selling_plan_id }}"
                >
              {% endif %}

              {% assign discount_titles = '' %}
              {% for item in cart.items %}
                {% for discount in item.discounts %}
                  {% if discount_titles != '' %}
                    {% assign discount_titles = discount_titles | append: ',' %}
                  {% endif %}
                  {% assign discount_titles = discount_titles | append: discount.title %}
                {% endfor %}
              {% endfor %}

              <input
                autocomplete="off"
                type="hidden"
                name="already_discount"
                value="{{ discount_titles }}"
              >
              <input autocomplete="off" type="hidden" name="quantity" value="1">

              <div class="text-left g4-btn-wrapper m-auto">
                {% if section.settings.redirectLink %}
                  <a
                    class="btn w-100 blue-btn value-sans btn-loader checkout-starterkit-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                    href="{{ section.settings.redirectLink }}"
                  >
                    {% if section.settings.outOfStock %}
                      Out of Stock
                    {% else %}
                      {{ section.settings.btnText }}
                    {% endif -%}
                  </a>
                {% else %}
                  {% if section.settings.isCheckout %}
                    <span
                      x-on:click="Purdy.CheckoutLandingV2($refs.product_form_{{ section.index }}, event)"
                      class="btn w-100 blue-btn value-medium btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                      {% if section.settings.button_bg %}
                      style="background-color:{{ section.settings.button_bg }} !important"
                      {% endif %}
                      data-add-to-cart="true"
                      data-page-url="{{ request.path }}"
                      data-target-url="{{ section.settings.targetUrl }}"
                      data-index="{{ section.settings.index }}"
                      data-funnel-stage="{{ section.settings.funnel_stage }}"
                      data-module="{{ section.settings.dataModule }}"
                      data-event-label="{{ section.settings.dataTitle }}"
                      data-event-value="{{ section.settings.eventValue }}"
                      data-item-id="{{ first_variant_block.settings.sku }}"
                      data-option-index="{{ section.settings.optionIndex }}"
                      data-item-name="{{ product.title }}"
                      data-quantity="{{ section.settings.quantity }}"
                      data-price="{{ localization.country.currency.symbol }}{{ first_variant_block.settings.price }}"
                      data-checkout="true"
                     
                    >
                      {% if section.settings.outOfStock %}
                        Out of Stock
                      {% else %}
                        <span class="buy-text">{{ section.settings.btnText }}</span> |
                        <span class="deleted-price value-sans white-text gp-5-del-price">
                          {{ localization.country.currency.symbol }}{{- first_variant_block.settings.delPrice -}}
                        </span>
                        <span class="value-medium white-text gp-5-sell-price">
                          {{- localization.country.currency.symbol -}}{{- first_variant_block.settings.price }}
                        </span>
                      {% endif -%}
                    </span>
                  {% else %}
                    <span
                      class="btn w-100 theme-btn value-sans btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                      x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_{{section.index}}, false, false, $event)"
                     {% if section.settings.button_bg %}
                      style="background-color:{{ section.settings.button_bg }} !important"
                      {% endif %}
                      {% if section.settings.dataTrack %}
                        data-add-to-cart="true"
                        data-page-url="{{ request.path }}"
                        data-target-url="{{ section.settings.targetUrl }}"
                        data-index="{{ section.index }}"
                        data-funnel-stage="{{ section.settings.funnel_stage }}"
                        data-module="{{ section.settings.dataModule }}"
                        data-event-label="{{ section.settings.dataTitle }}"
                        data-event-value="{{ section.settings.eventValue }}"
                        data-item-id="{{ first_variant_block.settings.sku }}"
                        data-option-index="{{ section.settings.optionIndex }}"
                        data-item-name="{{ product.title }}"
                        data-quantity="{{ section.settings.quantity }}"
                        data-price="{{ localization.country.currency.symbol }}{{ first_variant_block.settings.price }}"
                      {% endif %}
                      
                    >
                      {% if section.settings.outOfStock %}
                        Out of Stock
                      {% else %}
                        <span class="buy-text">{{ section.settings.btnText }}</span> |
                        <span class="deleted-price value-sans white-text gp-5-del-price">
                          {{ localization.country.currency.symbol }}{{- first_variant_block.settings.delPrice -}}
                        </span>
                        <span class="value-medium white-text gp-5-sell-price">
                          {{- localization.country.currency.symbol -}}{{- first_variant_block.settings.price }}
                        </span>
                      {% endif -%}
                    </span>
                  {% endif %}
                {% endif -%}
                {% if section.settings.guaranteeText %}
                  <div
                    class="moneybackguarateetext text-center fw-600 font-lausanne mt-12"
                    style="color: {{ section.settings.guaranteeTextColor }}"
                  >
                    {{ section.settings.guaranteeDescription }}
                  </div>
                {% endif %}
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function removeAutocomplete() {
    const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;

    if (isSafari || isIOS) {
      const form = document.getElementById('product_form_{{ section.index}}');

      if (form) {
        form.removeAttribute('autocomplete');

        const formElements = form.elements;

        for (let i = 0; i < formElements.length; i++) {
          formElements[i].removeAttribute('autocomplete');
        }
      }
    }
  }

  document.addEventListener('DOMContentLoaded', removeAutocomplete);

  (function () {
    function init341Slider() {
      var $g1 = $('.product-gallery-341-1:not(.slick-initialized)');
      var $t1 = $('.product-gallery-thumb-341-1:not(.slick-initialized)');
      if ($g1.children('.main-product-img').length) {
        $g1.slick({
          arrows: false,
          dots: false,
          infinite: true,
          speed: 300,
          fade: true,
          slidesToShow: 1,
          prevArrow: '<div class="slick-arrow slick-prev"></div>',
          nextArrow: '<div class="slick-arrow slick-next"> </div>',
          asNavFor: '.product-gallery-thumb-341-1',
        });
        $t1.slick({
          slidesToShow: 5,
          slidesToScroll: 1,
          asNavFor: '.product-gallery-341-1',
          dots: false,
          focusOnSelect: true,
          infinite: true,
        });
      }
      var $g2 = $('.product-gallery-341-2:not(.slick-initialized)');
      var $t2 = $('.product-gallery-thumb-341-2:not(.slick-initialized)');
      if ($g2.children('.main-product-img').length) {
        $g2.slick({
          arrows: false,
          dots: false,
          infinite: true,
          speed: 300,
          fade: true,
          slidesToShow: 1,
          prevArrow: '<div class="slick-arrow slick-prev"></div>',
          nextArrow: '<div class="slick-arrow slick-next"> </div>',
          asNavFor: '.product-gallery-thumb-341-2',
        });
        $t2.slick({
          slidesToShow: 5,
          slidesToScroll: 1,
          asNavFor: '.product-gallery-341-2',
          dots: false,
          focusOnSelect: true,
          infinite: true,
        });
      }
    }

    function destroy341Slider() {
      [
        '.product-gallery-341-1',
        '.product-gallery-thumb-341-1',
        '.product-gallery-341-2',
        '.product-gallery-thumb-341-2',
      ].forEach(function (sel) {
        var $el = $(sel);
        if ($el.hasClass('slick-initialized')) $el.slick('unslick');
      });
    }

    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail.sectionId === '{{ section.id }}') {
        destroy341Slider();
        init341Slider();
      }
    });

    ['shopify:block:load', 'shopify:block:unload'].forEach(function (evt) {
      document.addEventListener(evt, function (e) {
        if (e.detail.sectionId === '{{ section.id }}') {
          destroy341Slider();
          init341Slider();
        }
      });
    });
  })();
</script>

