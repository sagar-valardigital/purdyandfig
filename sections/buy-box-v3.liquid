{% if section.settings['link-section'] %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var sourceElement = document.querySelector('.link-to-section');
      if (sourceElement) {
        var sourceId = sourceElement.id;
        var targetElements = document.querySelectorAll('.set-buybox-id');
        targetElements.forEach(function (el) {
          el.id = sourceId;
        });
      }
    });
  </script>
{% endif %}
{% assign layout2 = section.settings.layout2 %}
{% assign first_variant_block = null %}
{% for block in section.blocks %}
  {% if block.type == 'variant' and first_variant_block == null %}
    {% assign first_variant_block = block %}
  {% endif %}
{% endfor %}

{% comment %} Get variant ID from metaobject and find matching variant {% endcomment %}
{% assign first_variant_mo = first_variant_block.settings.variantid %}
{% assign s_variant = null %}
{% assign first_variant_id = null %}
{% assign product = first_variant_block.settings.variantProduct %}

{% if first_variant_mo and first_variant_mo.variant_id %}
  {% comment %} Extract numeric ID from GID format (gid://shopify/ProductVariant/12345) {% endcomment %}
  {% assign variant_id_gid = first_variant_mo.variant_id %}
  {% assign first_variant_id = variant_id_gid | remove: 'gid://shopify/ProductVariant/' %}
  {% comment %} Loop through product variants to find matching variant {% endcomment %}
  {% if first_variant_id and product %}
    {% for v in product.variants %}
      {% assign v_id_str = v.id | append: '' %}
      {% if v_id_str == first_variant_id %}
        {% assign s_variant = v %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endif %}
{% comment %} Fallback if no variant found {% endcomment %}
{% unless s_variant %}
  {% if product %}
    {% assign s_variant = product.selected_or_first_available_variant %}
  {% endif %}
{% endunless %}

{% comment %} Get selling plan from variant's first selling plan allocation {% endcomment %}
{% assign first_selling_plan_id = null %}
{% if s_variant.selling_plan_allocations.size > 0 %}
  {% assign first_selling_plan_id = s_variant.selling_plan_allocations[0].selling_plan.id %}
{% endif %}
<style>
  .variant-badge {
    position: absolute;
    right: 8.5px;
    top: -10px;
    border-radius: 4px;
    background: #c8393c !important;
    color: #fff;
    font-size: 12px;
    padding: 2px 6px;
    z-index: 1;
  }
  .guarantee-text {
    font-size: 15.5px;
  }

  .cls-1,
  .slick-arrow svg path {
    fill: #11322c !important;
  }
  .value-medium.gp-5-var.gp-5-var-ab.link-to-variant.variant_1.show,
  .value-medium.gp-5-var.gp-5-var-ab.link-to-variant.variant_2.show {
    font-weight: 600 !important;
    font-family: 'Lausanne';
    color: #11322c !important;
  }
  .var_bg_seasonal {
    opacity: 1 !important;
  }
  .gp-5-variant-li input:checked + label {
    background: #f5f5f5 !important;
  }

  .buybox-oldprice {
    text-decoration: line-through;
    color: #9e9e9e;
    font-weight: 200;
  }

  .choose-heading-scent-div {
    margin-bottom: 20px;
    font-size: 14px !important;
    display: none;
    font-weight: 200;
  }

  #body .global-product-19-wrapper .gp-4-details .gp-5-bottom {
    padding: 16px 0 0 !important;
  }

  .global-product-19-wrapper .gp-4-details .gp-5-bottom .gp-5-variant-li label {
    font-weight: 600 !important;
  }

  .font-w600 {
    font-weight: 600;
  }

  .banner-10-content .banner-10-reviews .star-img {
    width: 20px !important;
    height: 20px !important;
  }

  .customers-reviews {
    margin-top: 4px !important;
  }

  .banner-10-content {
    bottom: 32px !important;
  }

  @media (max-width: 768px) {
    .gp-5-bottom {
      overflow: visible;
    }

    .faq-pf427 {
      padding-bottom: 16px !important;
    }
  }

  .new-product-gallery-wrapper-thumb {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    max-width: 288px;
    width: 100%;
  }
  .new-product-gallery-wrapper-thumb .main-product-img {
    padding: 5px;
  }
  .new-product-gallery-wrapper-thumb .main-product-img img {
    border-radius: 4px;
    border: 2px solid transparent;
  }
  .new-product-gallery-wrapper-thumb .main-product-img.slick-current img {
    border: 2px solid #0f2d28;
  }
  .new-product-gallery-wrapper-thumb .main-product-img.slick-current .imglay {
    background-color: #00000040;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 8px;
    pointer-events: none;
  }
  .new-product-gallery-wrapper-thumb .slick-track {
    display: flex;
    justify-content: center;
    gap: 10px;
  }
  .new-product-gallery-wrapper-thumb .main-product-img {
    width: 48px !important;
    padding: 0 !important;
  }
  .new-product-gallery-wrapper-thumb .slick-track {
    transform: none !important;
  }

  .global-product-19-wrapper .gp-4-details .blue-btn {
    font-size: 18px !important;
    gap: 8px !important;
  }

  @media (max-width: 768px) {
    .new-product-gallery-wrapper-thumb .main-product-img {
      width: 48px !important;
      height: 48px !important;
    }

    .global-product-5.py-80 {
      padding-top: 32px;
      padding-bottom: 32px;
    }

    .choose-heading-scent-div {
      display: block;
    }

    .global-product-19-wrapper .gp-4-details .blue-btn {
      font-size: 18px !important;
      gap: 8px !important;
    }

    .banner-10-content {
      bottom: 16px !important;
    }
  }

  @media (max-width: 560px) {
    .new-product-gallery-wrapper-thumb {
      bottom: 8px;
    }
    .new-product-gallery-wrapper-thumb .main-product-img {
      width: 35px !important;
      height: 35px !important;
    }
  }

  .gp-5-points li {
    background-image:none !important;
    padding-left:0;
  }
  .buy--plan label:before, .ms-buy--plan label:before{top:17px}
  {%  if layout2 %}
    .chlabel{margin-left:-31px;}
    .buy--plan label:before{display:none !important;}
  {% endif %}
</style>
