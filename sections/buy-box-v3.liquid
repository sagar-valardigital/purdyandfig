    <div
      class="d-flex product-block-4-wrapper flex-wrap justify-content-between align-items-start container"
      id="{{ section.settings.p_id }}"
    >
      <div class="w-50 {% if section.settings.verticalThumbnails %}vertical-thumbnails-slider-wrapper{% endif %} {% if section.settings.layout %} order-2 {%endif%}">
        <div class="two-women position-relative">
          {% if section.settings.tag != '' %}
            <span class="tag theme-text value-sans">{{ section.settings.tag }}</span>
          {% endif %}
          {% assign v_count = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'variant' %}
              {% assign v_count = v_count | plus: 1 %}
              {% if v_count == 1 %}
                {% assign override_type = 'productImage' %}
              {% elsif v_count == 2 %}
                {% assign override_type = 'productImage2' %}
              {% else %}
                {% assign override_type = '' %}
              {% endif %}
              {% assign has_override = false %}
              {% if override_type != '' %}
                {% for b in section.blocks %}
                  {% if b.type == override_type %}
                    {% if b.settings.is_video or b.settings.image != blank %}
                      {% assign has_override = true %}
                      {% break %}
                    {% endif %}
                  {% endif %}
                {% endfor %}
              {% endif %}
              <div class="gp-19-gallery-block link-to-variant variant_{{ v_count }} {% if v_count == 1 %}show{% endif %} position-relative">
                {% if has_override %}
                  <div class="product-gallery-341-{{ v_count }} new-product-gallery-wrapper">
                    {% for b in section.blocks %}
                      {% if b.type == override_type %}
                        {% if b.settings.is_video %}
                          <div class="main-product-img">
                            <video
                              class=" w-100"
                              poster="{{ b.settings.poster | image_url: width: 800 }}"
                              width="520"
                              height="520"
                              controls
                            >
                              <source src="{{ b.settings.videoURL }}" type="video/mp4">
                            </video>
                          </div>
                        {% else %}
                          <div class="main-product-img ">
                            <picture>
                              <source
                                media="(min-width:650px)"
                                srcset="{{ b.settings.image | image_url: width: 1200, crop: 'center' }}"
                              >
                              <source
                                media="(max-width:650px)"
                                srcset="{{ b.settings.mimage | image_url: width: 800, crop: 'center' }}"
                              >
                              <img
                                data-id="{{ b.settings.image.id }}"
                                class="img-responsive w-100 h-auto"
                                src="{{ b.settings.image | image_url: width: 800, crop: 'center' }}"
                                width="800"
                                height="700"
                                alt="{{ b.settings.image.alt }}"
                              >
                            </picture>
                          </div>
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  </div>
                  <div class="product-gallery-thumb-341-{{ v_count }} new-product-gallery-wrapper-thumb">
                    {% for b in section.blocks %}
                      {% if b.type == override_type %}
                        {% if b.settings.is_video %}
                          <div class="main-product-img">
                            <video
                              class=" w-100"
                              poster="{{ b.settings.poster | image_url: width: 100 }}"
                              width="48"
                              height="48"
                              controls
                            >
                              <source src="{{ b.settings.videoURL }}" type="video/mp4">
                            </video>
                          </div>
                        {% else %}
                          <div class="main-product-img">
                            <picture class="position-relative">
                              <source
                                media="(min-width:650px)"
                                srcset="{{ b.settings.image | image_url: width: 100, crop: 'center' }}"
                              >
                              <source
                                media="(max-width:650px)"
                                srcset="{{ b.settings.image | image_url: width: 100, crop: 'center' }}"
                              >
                              <img
                                data-id="{{ b.settings.image.id }}"
                                class="img-responsive w-100 h-auto"
                                src="{{ b.settings.image | image_url: width: 100 }}"
                                width="48"
                                height="48"
                                alt="{{ b.settings.image.alt }}"
                              >
                              <div class="imglay"></div>
                            </picture>
                          </div>
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  </div>
                {% else %}
                  <div class="product-gallery-341-{{ v_count }} new-product-gallery-wrapper mobile-hide">
                    {% for gallery_item in block.settings.variant_gallery %} 
                      {% for img in gallery_item.desktop_images.value %}
                        <div class="main-product-img ">
                          <picture>
                            <source
                              media="(min-width:650px)"
                              srcset="{{ img | image_url: width: 1200, crop: 'center' }}"
                            >
                            <source
                              media="(max-width:650px)"
                              srcset="{{ img | image_url: width: 800, crop: 'center' }}"
                            >
                            <img
                              data-id="{{ img.id }}"
                              class="img-responsive w-100 h-auto"
                              src="{{ img | image_url: width: 800, crop: 'center' }}"
                              width="800"
                              height="700"
                              alt="{{ img.alt }}"
                            >
                          </picture>
                        </div>
                      {% endfor %}
                    {% endfor %}
                  </div>
                  <div class="product-gallery-341-{{ v_count }} new-product-gallery-wrapper desktop-hide">
                    {% for gallery_item in block.settings.variant_gallery %} 
                      {% for img in gallery_item.mobile_images.value %}
                        <div class="main-product-img ">
                          <picture>
                            <source
                              media="(min-width:650px)"
                              srcset="{{ img | image_url: width: 1200, crop: 'center' }}"
                            >
                            <source
                              media="(max-width:650px)"
                              srcset="{{ img | image_url: width: 800, crop: 'center' }}"
                            >
                            <img
                              data-id="{{ img.id }}"
                              class="img-responsive w-100 h-auto"
                              src="{{ img | image_url: width: 800, crop: 'center' }}"
                              width="800"
                              height="700"
                              alt="{{ img.alt }}"
                            >
                          </picture>
                        </div>
                      {% endfor %}
                    {% endfor %}
                  </div>
                  <div class="product-gallery-thumb-341-{{ v_count }} new-product-gallery-wrapper-thumb">
                    {% for gallery_item in block.settings.variant_gallery %}
                      {% for img in gallery_item.desktop_images.value %}
                        <div class="main-product-img">
                          <picture class="position-relative">
                            <source
                              media="(min-width:650px)"
                              srcset="{{ img | image_url: width: 100, crop: 'center' }}"
                            >
                            <source
                              media="(max-width:650px)"
                              srcset="{{ img | image_url: width: 100, crop: 'center' }}"
                            >
                            <img
                              data-id="{{ img.id }}"
                              class="img-responsive w-100 h-auto"
                              src="{{ img | image_url: width: 100 }}"
                              width="48"
                              height="48"
                              alt="{{ img.alt }}"
                            >
                            <div class="imglay"></div>
                          </picture>
                        </div>
                      {% endfor %}
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="w-50  d-flex justify-content-center">
        <div class="w-90   bg-white gp-4-details">
          <div
            class="gp-5-top {% if section.settings.before-mobile %} mobile-hide {% endif %}"
          >
            <h2 class="heading-3 blue-text-3 value-bold mb-0 mt-0">
              {{ section.settings.heading }}
            </h2>
            {% if section.settings.mainsubheading != '' -%}
              <p class="value-sans mt-2 mb-2 gp-5-subheading">
                {{ section.settings.mainsubheading }}
              </p>
            {%- endif %}
            <div class="text-left mt-2 reviews-scroll-block">
              <div
                class="value-sans theme-text mt-0 mb-3 stars-img-review click-scroll"
                data-target="{{ section.settings.scrollto }}"
              >
                <span class="star-img">
