<style>
  .meet-founder-box {
  	width: 100%;
  	position: relative;
  	background: {{ section.settings.bgcolor }};
  	justify-content: space-between;
  	align-items: center;
  	gap: 48px;
  	display: inline-flex;
  }
	.meet-founder-container {
		padding-top: 80px;
    padding-bottom: 80px;
    padding-left: 112px;
	}
	.meet-founder-section-block {
		max-width: 520px;
		flex-direction: column;
		justify-content: flex-start;
		align-items: flex-start;
		gap: 24px;
		display: inline-flex;
	}
	.meet-founder-heading h2 {
		color: #0A1E1A;
		font-size: 40px;
		font-family: "GT Super";
		font-weight: 400;
		line-height: 50px;
		word-wrap: break-word;
		margin-bottom: unset !important;
	}
	.meet-bold-summary {
		color: #212121;
		font-size: 18px;
		font-family: "Lausanne";
		font-weight: 400;
		line-height: 27px;
		word-wrap: break-word;
	}
	.meet-normal-summary {
		color: #424242;
		font-size: 16px;
		font-family: "Lausanne";
		font-weight: 200;
		line-height: 25.60px;
		word-wrap: break-word;
	}
	.meet-founder-heading-block {
		align-self: stretch;
		flex-direction: column;
		justify-content: flex-start;
		align-items: flex-start;
		gap: 12px;
		display: flex;
	}
	.meet-founder-container .green-btn {
		margin-top: unset !important;
	}
	.meet-founder-image-block {
		width: 50%;
	}
	.meet-founder-image-block img {
		width: 100%;
		height: 100% !important;
	}

	@media (max-width: 768px) {
		.meet-founder-box {
			gap: 24px;
			padding-top: 32px;
			padding-bottom: 32px;
			flex-direction: column;
			align-items: flex-start;
		}
		.meet-founder-heading h2 {
			font-size: 32px;
			line-height: 40px;
		}
		.meet-bold-summary,
		.meet-normal-summary {
			font-size: 16px;
			line-height: 24px;
		}
		.meet-founder-image-block {
			width: 100%;
		}
		.meet-founder-heading.desktop-hide,
		.meet-bold-summary.desktop-hide,
		.meet-normal-summary.desktop-hide,
		.ctcbtn.text-center.desktop-hide {
			padding-left: 16px;
    	padding-right: 16px;
		}
		.ctcbtn.text-center.desktop-hide {
			width: 100%;
		}
	}
</style>

<div class="meet-founder-box">
	<div class="meet-founder-heading desktop-hide">
		<h2 style="{{ section.settings.headingcolor }}">{{ section.settings.heading }}</h2>
	</div>
	<div class="meet-founder-container {{ section.settings.className }} mobile-hide">
		<div class="meet-founder-section-block">
			<div class="meet-founder-heading-block">
				<div class="meet-founder-heading">
					<h2 style="{{ section.settings.headingcolor }}">{{ section.settings.heading }}</h2>
				</div>
				<div class="meet-bold-summary" style="{{ section.settings.boldcolor }}">{{ section.settings.bold_summary }}</div>
				<div class="meet-normal-summary" style="{{ section.settings.normalcolor }}">{{ section.settings.summary }}</div>
			</div>
			{% if section.settings.showbtn %}
				<div class="text-center mobile-hide">
					<span
						{% if section.settings.dataTrack %}
							{% render 'ga4-events' %}
						{% endif %}
						data-target="{{ section.settings.scrollto }}"
						data-top="{{ section.settings.top }}"
						class="btn click-scroll green-btn"
						style="background: {{ section.settings.btnbgcolor }} !important; color: {{ section.settings.btntxtcolor }} !important;"
					>
						{{- section.settings.btntext -}}
					</span>
				</div>
			{% endif %}
		</div>
	</div>
	<div class="meet-founder-image-block">
		<picture>
			<source media="(min-width:769px)" srcset="{{ section.settings.desk_image | image_url: width: 1600 }}">
			<source media="(max-width:768px)" srcset="{{ section.settings.mob_image | image_url: width: 1600 }}">
			<img
				data-id="{{ section.settings.desk_image.id }}"
				class="img-responsive w-100 h-auto lazy"
				src="{{ section.settings.desk_image | image_url: width: 1600 }}"
				width="800"
				height="700"
				alt="{{ section.settings.desk_image.alt }}"
			>
		</picture>
	</div>
	<div class="meet-bold-summary desktop-hide" style="{{ section.settings.boldcolor }}">{{ section.settings.bold_summary }}</div>
	<div class="meet-normal-summary desktop-hide" style="{{ section.settings.normalcolor }}">{{ section.settings.summary }}</div>
	{% if section.settings.showbtn %}
		<div class="ctcbtn text-center desktop-hide">
			<span
				{% if section.settings.dataTrack %}
					{% render 'ga4-events' %}
				{% endif %}
				data-target="{{ section.settings.scrollto }}"
				data-top="{{ section.settings.top }}"
				class="btn click-scroll green-btn"
				style="background: {{ section.settings.btnbgcolor }} !important; color: {{ section.settings.btntxtcolor }} !important;"
			>
				{{- section.settings.btntext -}}
			</span>
		</div>
	{% endif %}
</div>

{% schema %}
{
  "name": "Meet founder",
  "settings": [
    {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
    {
      "type": "color",
      "id": "bgcolor",
      "label": "Background color"
    },
    {
      "type": "checkbox",
      "id": "layout",
      "label": "Image on right - Desktop"
    },
    {
      "type": "image_picker",
      "id": "desk_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mob_image",
      "label": "Mobile image"
    },
    {
      "type": "color",
      "id": "headingcolor",
      "label": "Heading color"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "boldcolor",
      "label": "Bold summary color"
    },
    {
      "type": "html",
      "id": "bold_summary",
      "label": "Bold summary"
    },
    {
      "type": "color",
      "id": "normalcolor",
      "label": "Normal summary color"
    },
    {
      "type": "html",
      "id": "summary",
      "label": "Normal summary"
    },
    {
      "type": "checkbox",
      "id": "showbtn",
      "label": "Show button",
      "default": false
    },
    {
      "type": "color",
      "id": "btnbgcolor",
      "label": "Button background"
    },
    {
      "type": "color",
      "id": "btntxtcolor",
      "label": "Button text color"
    },
    {
      "type": "text",
      "id": "btntext",
      "label": "Button label"
    },
    {
      "type": "text",
      "id": "scrollto",
      "label": "Scroll to"
    },
    {
      "type": "text",
      "id": "top",
      "label": "On scroll top position",
      "default": "0"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "landing_page"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "itemId",
      "label": "Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label": "Item Name",
      "type": "text"
    }
  ],
  "presets": [
    {
      "name": "Meet founder"
    }
  ]
}
{% endschema %}
