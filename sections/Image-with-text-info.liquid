<div class="{{ section.settings.className }}">
  <div
    style="background-color:{{section.settings.background}};"
    class="py-5  image-with-text image-with-text-2"
  >
    <div class="container">
      <h2 class="heading-2  {{section.settings.textcolor}} {% if section.settings.heading-position%} mobile-hide {% endif %} desktop-hide mt-0 text-center">
        {{ section.settings.heading }}
      </h2>
      <div class="d-flex flex-wrap justify-content-between align-items-center">
        <div class="w-50 {% if section.settings.layout %} order-2 {%endif%}">
          <div class="two-women">
            {% if section.settings.image %}
              {% assign mImage = section.settings.image | img_url: '800x' %}
              {% assign mmImage = section.settings.mimage | img_url: '800x' %}
              <img
                loading="lazy"
                src="{{mImage}}"
                width="800px"
                height="800px"
                class="img-responsive w-100 h-auto mobile-hide"
                alt="image"
              >
              <img
                loading="lazy"
                src="{{mmImage}}"
                width="800px"
                height="800px"
                class="img-responsive w-100 h-auto desktop-hide"
                alt="image"
              >
            {% endif %}
          </div>
        </div>
        <div class="w-50  d-flex justify-content-start {% if section.settings.layout %} order-1 {%endif%} ">
          <div class="two-women-details  pb-2 {{section.settings.width}}">
            <h2 class="heading-2 value-bold blue-text {{section.settings.textcolor}} {% if section.settings.heading-position%} {% else %}mobile-hide{% endif %}">
              {{ section.settings.heading }}
            </h2>
            <div class="normal-text {{section.settings.textcolor}}">
              {{ section.settings.details }}
            </div>
            {% if section.settings.infoHeading != blank %}
              <details>
                <summary>{{ section.settings.infoHeading }}</summary>
                <div>
                  {{ section.settings.infoDetails }}
                </div>
              </details>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Image with Text Info",
    "settings": [

      {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
{
            "type": "color",
            "id": "textcolor",
            "label": "Select text color",
            "default": "#3541BF"
          },
{
            "type": "color",
            "id": "background",
            "label": "Select background color",

            "default": "#ffffff"
          },
{
            "type": "select",
            "id": "width",
            "label": "Select text area width",
            "options": [
              {
                "value": "w-90",
                "label": "90%"
              },
              {
                "value": "w-80",
                "label": "80%"
              },
{
                "value": "w-70",
                "label": "70%"
              },
              {
                "value": "w-60",
                "label": "60%"
              }
            ],
            "default": "w-80"
          },
{
            "type": "checkbox",
            "id": "layout",
            "label": "Image on right"

          },
{
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
{
      "type": "image_picker",
      "id": "image",
      "label": "Add Desktop Image"
    },
      {
      "type": "image_picker",
      "id": "mimage",
      "label": "Add Mobile Image"
    },

{
      "type": "html",
      "id": "details",
      "label": "Detail Text"
    },
      {
      "type": "text",
      "id": "infoHeading",
      "label": "Info Heading"
    },
      {
      "type": "richtext",
      "id": "infoDetails",
      "label": "Info Detail Text"
    },

{
      "type": "header",
      "content": "Mobile"
    },

{
            "type": "checkbox",
            "id": "heading-position",
            "label": "Heading After Image"

          }
	],

	"presets": [
		{
			"name": "Image With Text Info"
		}
	]
  }
{% endschema %}
