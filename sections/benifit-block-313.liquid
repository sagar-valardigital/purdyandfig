{% assign mimage = section.settings.image | image_url: width: 1440, height: 702 %}
{% assign mmimage = section.settings.mimage | image_url: width: 1600 %}

<style>
  .benifit-313-container {
    margin-top: -140px;
  }
  .benifit-block-313 {
    width: 100%;
    position: relative;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 170px 216px 130px 216px;
    box-sizing: border-box;
    gap: 67px;
    background-image: url({{ mimage }});
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    aspect-ratio: 1440 / 702;
  }
  .left-section {
    display: flex;
    width: 488px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 32px;
    flex-shrink: 0;
  }
  .btn-blocks {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 24px;
  }
  .btn-inner-block {
    display: flex;
    padding: 5px 7px;
    align-items: center;
    gap: 8px;
    border-radius: 30px;
    background: #EAFF65;
    font-size: 18px;
    line-height: 27px;
    font-weight: 200;
    color: {{ section.settings.subtextcolor }};
  }
  .ic-round {
    display: flex;
    width: 20px;
    height: 20px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 10px;
    border-radius: 80px;
    background: #294741;
  }
  .benifit-heading {
    font-size: 40px;
    font-style: normal;
    font-weight: 400;
    line-height: 50px;
    font-family: "GT Super";
  }
  .benifit-subheading {
    font-size: 18px;
    font-style: normal;
    font-weight: 200;
    line-height: 27px;
    font-family: "Lausanne";
  }
  @media (max-width: 767px) {
    .benifit-313-container {
      margin-top: -130px;
    }
    .benifit-block-313 {
      width: 100%;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      padding: 140px 16px 32px 16px;
      box-sizing: border-box;
      background-image: url({{ mmimage }});
      background-size: cover;
      background-repeat: no-repeat;
      background-position: top;
      height: auto;
    }
    .left-section {
      width: 100%;
    }
    .rectangle-parent {
      width: 100%;
      position: relative;
      height: 273px;
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
    }
    .benifit-heading {
      font-size: 32px;
      line-height: 40px;
    }
    .benifit-subheading {
      font-size: 16px;
      line-height: 24px;
    }
    .btn-blocks {
      gap: 16px;
    }
    .btn-inner-block {
      font-size: 14px;
      line-height: 21px;
      font-weight: 200;
    }
    .shop-now-cta {
      /* margin-top: 16px !important; */
    }
    .btn-blocks {
      margin-top: 70px;
    }
    .chi-head {
      margin-bottom: 12px;
    }
    .chi-subhead {
      margin-bottom: 16px;
    }
  }
  @media (max-width: 400px) {
    .btn-blocks {
      margin-top: 70px;
    }
  }
</style>

<section class="benifit-block-313">
  <div class="left-section">
    <div class="left-section-texts">
      <h2 class="benifit-heading" style="color: {{ section.settings.textcolor }};">{{ section.settings.heading }}</h2>
      <p class="benifit-subheading" style="color: {{ section.settings.subtextcolor }};">{{ section.settings.details }}</p>
      <div class="rectangle-parent desktop-hide"></div>
      <div class="btn-blocks">
        <span class="btn-inner-block">
          <span class="ic-round">
            <img
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/check_05b1beba-381c-477f-a74f-cb1e0cc6032f.svg?v=1750397977"
              width=""
              height=""
            >
          </span>
          Powerful clean
        </span>
        <span class="btn-inner-block">
          <span class="ic-round">
            <img
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/check_05b1beba-381c-477f-a74f-cb1e0cc6032f.svg?v=1750397977"
              width=""
              height=""
            >
          </span>
          Natural ingredients
        </span>
        <span class="btn-inner-block">
          <span class="ic-round">
            <img
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/check_05b1beba-381c-477f-a74f-cb1e0cc6032f.svg?v=1750397977"
              width=""
              height=""
            >
          </span>
          100% Essential oil scent
        </span>
        <span class="btn-inner-block">
          <span class="ic-round">
            <img
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/check_05b1beba-381c-477f-a74f-cb1e0cc6032f.svg?v=1750397977"
              width=""
              height=""
            >
          </span>
          Multi-purpose
        </span>
      </div>
    </div>
    {% if section.settings.shop_now_cta != '' %}
      <span
        class="shop-now-cta btn click-scroll"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
          data-tracked="true"
          data-page-url="{{ request.path }}"
          data-target-url="{{ section.settings.targetUrl }}"
          data-index="{{ section.settings.index }}"
          data-funnel-stage="{{ section.settings.funnel_stage }}"
          data-module="{{ section.settings.dataModule }}"
          data-event-label="{{ section.settings.dataTitle }}"
          data-event-value="{{ section.settings.eventValue }}"
          data-item-id="{{ section.settings.itemId }}"
          data-option-index="{{ section.settings.optionIndex }}"
          data-item-name="{{ section.settings.ItemName }}"
        {% endif %}
        style="background: {{ section.settings.btn-bg }} !important; color: {{ section.settings.btn-text }} !important;"
      >
        {{ section.settings.shop_now_cta }}
      </span>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Benefit block 313",
  "class": "benifit-313-container",
  "settings": [
    {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
    {
      "type": "color",
      "id": "textcolor",
      "label": "Select heading color"
    },
    {
      "type": "color",
      "id": "subtextcolor",
      "label": "Select subheading color"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Select background color",
      "default": "#ffffff"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Add Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mimage",
      "label": "Add Mobile Image"
    },
    {
      "type": "html",
      "id": "details",
      "label": "Detail Text"
    },
    {
      "type": "color",
      "id": "btn-bg",
      "label": "Button background"
    },
    {
      "type": "color",
      "id": "btn-text",
      "label": "Button text color"
    },
    {
      "type": "text",
      "id": "shop_now_cta",
      "label": "Button Label"
    },
    {
      "type": "text",
      "id": "scrollto",
      "label": "Scroll link"
    },
    {
      "type": "number",
      "id": "top",
      "label": "Scroll to position"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label":"Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label":"Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label":"Index",
      "type": "number",
      "default" : 0
    },
    {
      "id": "funnel_stage",
      "label":"Funnel Stage",
      "type": "text",
      "default" : "landing_page"
    },
    {
      "id": "dataModule",
      "label":"Module",
      "type": "text",
      "default" : "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label":"Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label":"Event Value",
      "type": "text",
      "default" : "shop_anchor"
    },
    {
      "id": "itemId",
      "label":"Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label":"Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label":"Item Name",
      "type": "text"
    }
 ],
 "presets": [
 	{
 		"name": "Benefit block 313"
 	}
 ]
}
{% endschema %}