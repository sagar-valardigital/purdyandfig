<div class="shop-starter position-relative">
  <img class="w-100 vertical-middle desktop-img" src="{{ section.settings.bg_image | img_url: "1900x" }}">
  <img class="w-100 vertical-middle mobile-img" src="{{ section.settings.bg_image2 | img_url: "800x" }}">
  <div class="container position-absolute">
    <p
      class="mb-0 value-sans"
      style="color:{{ section.settings.content_color }}; text-align:{{ section.settings.content_align }};"
    >
      {{ section.settings.textId }}
    </p>
    <h1
      style="color:{{ section.settings.content_color }}; text-align:{{ section.settings.content_align }};"
      class="heading-2 my-4 value-pro"
    >
      {{ section.settings.section_heading }}
    </h1>
    <div class="shop-starter-section-btn" style="text-align:{{ section.settings.content_align }};">
      {% if section.settings.btnLink != blank %}
        <a
          href="{{section.settings.btnLink}}"
          class="buy-btn col-12 col-lg-5 col-xl-4 col-md-6 col-sm-7 value-sans "
          {% if section.settings.dataTrack %}
            {% render 'ga4-events' %}
          {% endif %}
        >
          {{ section.settings.btnLabel }}
        </a>
      {% else %}
        <button
          class="buy-btn col-12 col-lg-5 col-xl-4 col-md-6 col-sm-7 value-sans click-scroll"
          data-top="{{ section.settings.top }}"
          data-target="{{ section.settings.scrollID }}"
          {% if section.settings.dataTrack %}
            {% render 'ga4-events' %}
          {% endif %}
        >
          {{ section.settings.btnLabel }}
        </button>
      {% endif %}
    </div>
  </div>
</div>
{% schema %}
  {
    "name": "Shop Starter",
    "settings": [
        {
          "type": "image_picker",
          "id": "bg_image",
          "label": "Choose image for desktop"
        },
        {
          "type": "image_picker",
          "id": "bg_image2",
          "label": "Choose image for mobile"
        },
        {
          "type": "text",
          "id": "textId",
          "label": "Enter section sub heading",
          "default": "your section sub heading"
        },
        {
          "type": "text",
          "id": "section_heading",
          "label": "Enter section heading",
          "default": "your section heading"
        },
        {
          "type": "color",
          "id": "content_color",
          "label": "Choose content color",
          "default": "#fff"
        },
        {
          "type": "select",
          "id": "content_align",
          "label": "alignment your section content",
          "options": [
            {
              "value": "start",
              "label": "Start"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "end",
              "label": "End"
            }
            ],
            "default": "center"
          },
      {
          "type": "text",
          "id": "btnLabel",
          "label": "Button Label",
          "default": "Shop Bundles"
        },
      {
          "type": "text",
          "id": "scrollID",

          "label": "Scroll Section Id"
      },
      {
          "type": "text",
          "id": "top",
          "label": "Scroll Position"
        },
      {
          "type": "url",
          "id": "btnLink",
          "label": "Button Link"
        },
     {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
    ],
     "presets": [
  {
      "name" : "Shop Starter"
  }
]
  }
{% endschema %}
