      };

      // MutationObserver to watch for the arrows being added
      const observer = new MutationObserver((mutationsList, observer) => {
        mutationsList.forEach((mutation) => {
          if (mutation.addedNodes.length) {
            setArrows();
            // Disconnect the observer once the arrows are set
            observer.disconnect();
          }
        });
      });

      // Start observing the product gallery for child nodes being added
      observer.observe(productGallery, { childList: true, subtree: true });
    }

    // Function to update .product-buy-type text
    const updateBuyTypeText = (element) => {
      const text = element.innerHTML.trim();
      if (text === 'subscription') {
        element.innerHTML = 'Subscribe and save {{sub_discount_percentage}}%';
      } else if (text === 'onetime') {
        element.innerHTML = 'One-time purchase';
      }
    };

    // Initial update for existing elements
    document.querySelectorAll('.product-buy-type').forEach(updateBuyTypeText);

    // Set up a targeted MutationObserver
    const buyTypeObserver = new MutationObserver((mutationsList) => {
      mutationsList.forEach((mutation) => {
        if (mutation.type === 'childList' || mutation.type === 'characterData') {
          updateBuyTypeText(mutation.target);
        }
      });
    });

    // Observe changes specifically on .product-buy-type elements
    document.querySelectorAll('.product-buy-type').forEach((node) => {
      buyTypeObserver.observe(node, { childList: true, characterData: true });
    });
  });
</script>
