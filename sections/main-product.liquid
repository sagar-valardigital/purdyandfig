<script>
  document.querySelectorAll('input[name="purchase_type"]').forEach(function (element) {
    element.addEventListener('change', function () {
      // Access specific data attributes by their key names
      var price = this.getAttribute('data-subprice');

      var value = this.value === 'onetime' ? 'PAYG' : this.value;

      document.querySelectorAll('.product-btn').forEach(function (btn) {
        btn.setAttribute('data-price', price);
        btn.setAttribute('data-item-type', value);
      });
    });
  });

  document.addEventListener('DOMContentLoaded', (event) => {
    let productGallery = document.querySelector('.product-gallery');

    if (productGallery) {
      // Function to set the inner HTML of the arrows
      const setArrows = () => {
        let prevArrow = productGallery.querySelector('.slick-prev');
        let nextArrow = productGallery.querySelector('.slick-next');
        let slickTrack = productGallery.querySelector('.slick-track');

        if (slickTrack.childElementCount <= 1) {
          productGallery.querySelector('.slick-dots').classList.add('d-none');
        }

        if (prevArrow && nextArrow) {
          prevArrow.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="30" height="31" viewBox="0 0 30 31" fill="none">
            <g clip-path="url(#clip0_2159_176)">
              <path d="M12.3932 15.5718L17.4376 10.5273L16.4968 9.54615L10.4712 15.5718L16.4968 21.5974L17.4376 20.6162L12.3932 15.5718ZM14.833 1.05566C16.8404 1.05566 18.7276 1.43656 20.4946 2.19836C22.2618 2.96019 23.799 3.99857 25.1061 5.31349C26.4134 6.62841 27.4482 8.16516 28.2107 9.92377C28.9732 11.6823 29.3545 13.5632 29.3545 15.5664C29.3545 17.5737 28.9736 19.4609 28.2118 21.2281C27.45 22.9952 26.4161 24.5324 25.1101 25.8396C23.8041 27.1467 22.2684 28.1816 20.503 28.9441C18.7375 29.7066 16.8511 30.0879 14.8438 30.0879C12.8364 30.0879 10.9537 29.707 9.19557 28.9452C7.4374 28.1834 5.90024 27.1495 4.58408 25.8435C3.26792 24.5375 2.22859 23.0018 1.46605 21.2364C0.70353 19.4709 0.322267 17.5845 0.322266 15.5772C0.322266 13.574 0.703164 11.6923 1.46497 9.93207C2.2268 8.17184 3.26517 6.63363 4.58009 5.31747C5.895 4.00133 7.43073 2.96198 9.18726 2.19946C10.9438 1.43693 12.8257 1.05566 14.833 1.05566ZM14.8384 2.42042C11.1797 2.42042 8.07316 3.69766 5.51871 6.25212C2.96425 8.80655 1.68703 11.9131 1.68703 15.5718C1.68703 19.2346 2.96425 22.3422 5.51871 24.8946C8.07316 27.4469 11.1797 28.7232 14.8384 28.7232C18.5012 28.7232 21.6088 27.4469 24.1611 24.8946C26.7136 22.3422 27.9898 19.2346 27.9898 15.5718C27.9898 11.9131 26.7136 8.80655 24.1611 6.25212C21.6088 3.69766 18.5012 2.42042 14.8384 2.42042Z" fill="#11322C"/>
