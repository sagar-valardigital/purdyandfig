<div class="review-blocks-section py-80">
  <div class="container">
    <div class="section-heading text-center">
      <h2 class="heading-2">{{ section.settings.heading }}</h2>
    </div>
    <div class="reviews-blocks">
      {% for block in section.blocks %}
        <div class="review-block">
          <p class="review">
            {{ block.settings.review }}
          </p>
          <div class="user-img">
            {% assign userIMG = block.settings.user_img | img_url : '80x80', crop : "center" %}
            <img src="{{ userIMG }}" alt="{{ user.alt }}" width="60" height="60">
          </div>
          <p class="user-name">
            {{ block.settings.username }}
          </p>
        </div>
      {% endfor %}
    </div>
  </div>
  
  
</div>


{% schema %}
  {
    "name": "Review Blocks",
    "settings": [
      {
        "type": "text",
        "id" : "heading",
        "label" : "Heading"
      }
    ],
    	"blocks": [
      {
        "type": "Review",
        "name": "block",
        "settings": [ 
         
{
      "type": "text",
      "id": "review",
      "label": "Review"
    },
{
      "type": "text",
      "id": "username",
      "label": "User Name"
    },
           {
      "type": "image_picker",
      "id": "user_img",
      "label": "User Image"
    }

        ]
      }
	],
    "presets": [
      {
        "name" : "Review Blocks"
      }
    ]
  }
{% endschema %}