<style>
  .mobile-tss-block {
    display: flex;
    margin: 24px 16px;

    .tss-image {
      max-width: 98px;
      margin-right: 16px;
      img {
        border-radius: 4px;
      }
      
    }

    .tss-mobile-heading {
        font-size: 16px;
        font-style: normal;
        font-weight: 400;
        line-height: 150%;
        margin-bottom: 0;
    }

    .tss-mobile-details {
      font-size: 12px;
      font-style: normal;
      font-weight: 200;
      line-height: 150%; 
      letter-spacing: 0.18px;
    }

    .tss-mobile-tag {
        border-radius: 4px;
        border: 1px solid var(--Secondary-200, #F2D4B9);
        background: var(--Secondary-50, #FBF1E8);
        font-size: 14px;
        padding: 2px 4px;
      
    }
    
  }

  @media (max-width: 768px) {
      .discoverBtmBtn {
          margin-top: 0 !important;
      }
    }
  .tss-tag {
        border-radius: 4px;
        border: 1px solid var(--Secondary-200, #F2D4B9);
        background: var(--Secondary-50, #FBF1E8);
        font-size: 14px;
        padding: 2px 4px;
        height: auto;
        color: #212121;
    }
</style>
{% assign count = 0 %}
{% for block in section.blocks %}
  {% assign count = count | plus: 1 %}
{% endfor %}
<div id="{{ section.settings.sectionId }}">
  <div
    style="background-color:{{ section.settings.bgcolor }}"
    class="py-80  transformational-scents-section scents-reskins  {{ section.settings.class }}"
  >
    <div class="container">
      <div
        {% if count < 2 %}
          class="d-flex align-items-center justify-content-between tss-one-block-wrapper"
        {% endif %}
      >
        <div class="tss-main-header">
          <h2 class="heading-2 text-center white-text font-gtsuper mt-0 ">{{ section.settings.heading }}</h2>
{% if section.settings.subtext != blank %}          
<p style="" class="normal-text font-lausanne fw-200 text-center">
            {{ section.settings.subtext }}
          </p>
  {% endif %}
        </div>
        <div class="mt-4">
          <div class="transformational-scents-slider mobile-hide {% if count > 2 %}tss-slider{% endif %}">
            {% for block in section.blocks %}
              <div class="tss-block">
                <div class="tss-image position-relative">
                  <picture>
                    {% assign image = block.settings.blockImage %}
                    {% assign mimage = block.settings.mBlockImage %}

                    <source media="(min-width:769px)" srcset="{{ image | img_url: '400x'}}">
                    <source media="(max-width:768px)" srcset="{{ mimage | img_url: '400x' }}">
                    <img
                      data-id="{{image.id}}"
                      class="img-responsive w-100 h-auto lazy"
                      src="{{ image | img_url: '400x'}}"
                      width="400"
                      height="300"
                      alt="{{ image.alt }}"
                    >
                  </picture>
                  {% if block.settings.tag != blank %}
                    <span class="tss-tag font-lausanne">{{ block.settings.tag }}</span>
                  {% endif %}
                </div>
                <div class="tss-content">
                  <h3 class="tss-heading  font-lausanne fw-400">{{ block.settings.heading }}</h3>
                  <p class="tss-details black-text normal-text font-lausanne fw-200">{{ block.settings.details }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
          <div class="transformational-scents-no-slider desktop-hide ">
            {% for block in section.blocks %}
              <div class="tss-block mobile-tss-block">
                <div class="tss-image position-relative">
                  <picture>
                    {% assign image = block.settings.blockImage %}
                    {% assign mimage = block.settings.mBlockImage %}

                    <source media="(min-width:769px)" srcset="{{ image | img_url: '400x'}}">
                    <source media="(max-width:768px)" srcset="{{ mimage | img_url: '400x' }}">
                    <img
                      data-id="{{image.id}}"
                      class="img-responsive w-100 h-auto lazy"
                      src="{{ image | img_url: '400x'}}"
                      width="400"
                      height="300"
                      alt="{{ image.alt }}"
                    >
                  </picture>
                 
                </div>
                <div class="tss-content">
                  <h3 class="tss-mobile-heading  font-lausanne fw-400">{{ block.settings.heading }}</h3>
                  <p class="tss-mobile-details black-text normal-text font-lausanne fw-200">{{ block.settings.details }}</p>
                   {% if block.settings.tag != blank %}
                    <span class="tss-mobile-tag font-lausanne">{{ block.settings.tag }}</span>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
           {% if section.settings.addScrollBtn %}
    <div class="discoverBtmBtn">
      <span
          class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto common-btn-width"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >{{ section.settings.btnLabel }}</span
      >
    </div>
    {% endif %}
  </div>
</div>
{% schema %}
{
  "name": "Scents Reskin 397",
  "settings": [
    {
      "type": "text",
      "id": "sectionId",
      "label": "Section ID"
    },
    {
      "type": "color",
      "id": "bgcolor",
      "label": "Background color"
    },
  {
      "type": "text",
      "id": "class",
      "label": "Section Class"
    },
  {
      "type": "html",
      "id": "heading",
      "label": "Heading"
    },
     {
      "type": "text",
      "id": "subtext",
      "label": "Sub Heading"
    },
    {
          "type": "checkbox",
          "id": "addScrollBtn",
          "label": "Show Scroll to Btn",
          "default": false
    },
   {
          "type": "text",
          "id": "btnLabel",
          "label": "Button Label",
          "default": "GET YOUR OFFER"
    },
    {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      }
     ,
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
       {
        "id": "dataTrack",
        "label":"Data Track",
        "type": "checkbox"
        },
        {
        "id": "targetUrl",
        "label":"Target Url",
        "type": "url"
        },
        {
        "id": "index",
        "label":"Index",
        "type": "number",
        "default" : 0
            },
            {
        "id": "funnel_stage",
        "label":"Funnel Stage",
        "type": "text",
         "default" : "landing_page"
            },
            {
        "id": "dataModule",
        "label":"Module",
        "type": "text",
         "default" : "announcement_bar"
            },
              {
        "id": "dataTitle",
        "label":"Event Label",
        "type": "text",
        "default": "get_your_offer"
            }
            ,
              {
        "id": "eventValue",
        "label":"Event Value",
        "type": "text",
        "default" : "shop_anchor"
            },
              {
        "id": "itemId",
        "label":"Item Id",
        "type": "text"
            }
            ,
              {
        "id": "optionIndex",
        "label":"Option Index",
        "type": "text"
            }
            ,
              {
        "id": "ItemName",
        "label":"Item Name",
        "type": "text"
            }
  ],
  "blocks": [
      {
        "type": "image",
        "name": "Scent block",
        "settings": [
          {
            "type": "image_picker",
            "id": "blockImage",
            "label": "Desktop Image"
          },
          {
            "type": "image_picker",
            "id": "mBlockImage",
            "label": "Mobile Image"
          },
          {
            "type": "text",
            "id": "tag",
            "label": "Tag"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "text",
            "id": "details",
            "label": "text"
          }
        ]
      }
	],
  "presets": [
    {
        "name": "Scents Reskin 397"
    }
]
}
{% endschema %}
