{% if section.settings.enable%}
<div style="background:{{ section.settings.bgColor }}" class="{{ section.settings.className }}">
        <div class="heading-section pt-4 pb-2">
            <div class="">
                <h2 class="heading-2  theme-text text-center value-pro">
                    {{section.settings.heading}}
                </h2>
              
            </div>
        </div>
    </div>

{% endif %}


{% schema %}
  {
    "name": "Heading",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },
      {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
      {
      "type": "color",
      "id": "bgColor",
      "label": "Background Color"
    },

{
      "type": "text",
      "id": "heading",
      "label": "Heading"
    }


	],
	
	"presets": [
		{
			"name": "Heading"
		}
	]
  }
{% endschema %}


