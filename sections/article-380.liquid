<div class="article-section-wrapper">
  {% if section.settings.showancbar %}
  <div class="art2-anc-bar" style="background: {{ section.settings.ancbgcolor }}; color: {{ section.settings.anctxtcolor }};">
    <p>{{ section.settings.anctext }}</p>
  </div>
  {% endif %}
  <div class="article2-wrapper">
    <div class="topsplit">
      <div class="topsplit-image">
        <div class="article2-main-image">
            <img src="{{ section.settings.main_image | image_url }}" class="article-main-img" alt="article image"
              width="630" height="630">
        </div>
      </div><!-- END topsplitleft -->
      <div class="topsplit-title">
        <div class="article2-details">
          <div class="article2-details-category">
            {{ section.settings.article-category }}
          </div><!-- END article2-details-category -->
          <div class="article2-line-divider"></div>
        <div class="article2-details-title">
              <h2>
                {{ section.settings.article-heading }}
              </h2>
        </div>
              <div class="article2-details-author">
                <span class="author-text">by michael rinaldi</span>
                <div class="article2-line-divider-vertical"></div>
                <span class="article2-details-date">{{ section.settings.article-date }}</span>
</div>
            <div class="article2-details-share-options">
              {% for block in section.blocks %}
              {% if block.type == "share" %}
              <a  class="{{ block.settings.share_icon_class }}" {% if block.settings.redirect %}target="_blank"{% endif %} href="{% if block.settings.redirect %}{{ block.settings.redirect_link }}{% else %}javascript:void(0);{% endif %}" data-link="{{ block.settings.share_link }}">
                <img src="{{ block.settings.share_icon | image_url}}" width="40" height="40"
                  alt="{{ block.settings.share_icon.alt }}">
              </a>
              {% endif %}
              {% endfor %}
            </div>
        </div><!-- END article2-details -->
      </div><!-- END topsplitright -->
    </div><!-- END article2-container -->
 
          <div class="article2-content-wrapper">
            {% for block in section.blocks %}
              {% case block.type %}
                  {% when 'article_image' %}
                    <div class="article2-image-block">
                      <img src="{{ block.settings.article_img | image_url }}" width="" height="" class="img-responsive" alt="{{ block.settings.article_img.alt }}"> 
                    </div>
                  {% when 'article_image_gif' %}
                    <div class="{% if block.settings.article_img_gif_layout %}article2-image-block-gif{% else %}article2-image-block-gif-left{% endif %}">
                      <div class="article2-image-block-gif-bg">
                        <img src="{{ block.settings.article_img_gif | img_url: '886x' }}" 
                          width="886" 
                          height="550" 
                          class="img-responsive" 
                          alt="{{ block.settings.article_img_gif.alt }}"
                          onerror="this.onerror=null; this.src='{{ block.settings.article_img_gif_fallback | img_url: '886x' }}';">
                      </div>
                      <div class="article2-image-block-gif-overlay">
                        <img src="{{ block.settings.article_img_gif_overlay | img_url: '445x' }}"
                          width="445"
                          height="558"
                          class="img-responsive"
                          alt="{{ block.settings.article_img_gif_overlay.alt }}">
                      </div>
                    </div>
                  {% when 'article_heading' %}
                    <div class="article2-block-heading">
                      <h3>{{ block.settings.heading }}</h3>
                    </div>
                  {% when 'article_quote' %}
                    <div class="article2-block-quote desktop-only">
                      {{ block.settings.quote }}
                    </div>
                    <div class="article2-block-quote mobile-only">
                      {{ block.settings.quote-mobile }}
                    </div>
                  {% when 'article_content' %}
                    <div class="article2-block-paragraph {{ block.settings.content_class }}">
                      <div class="font-open fw-400">{{ block.settings.content }}</div>
                    </div>
              {% endcase %}
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="bottom-section">
        <div class="cta-block">
          <div class="cta-image">
            {% assign exploreImage = section.settings.explore_image | image_url %}
            <img src="{{ exploreImage }}" width="350" height="400" alt="{{ exploreImage.alt }}" class="w-100 h-auto">
          </div>
          <div class="cta-header">
          <!-- Desktop heading -->
          <h3 class="heading text-center font-poppin fw-600 desktop-only">
            {{ section.settings.explore-heading }}
          </h3>

          <!-- Mobile heading -->
          <h3 class="heading text-center font-poppin fw-600 mobile-only">
            {{ section.settings.explore-heading-mobile }}
          </h3>
          </div>
          {% if section.settings.btn_link %}
          <div class="cta-button-container">
            <a href="{{ section.settings.btn_link }}" target="_blank" class="btn cta-button"
              style="background-color:{{ section.settings.btn_bg }}; color:{{ section.settings.btn_text_color }}">{{
              section.settings.btn_label }}</a>
          </div>
          {% endif %}
        </div>
      </div>
<div id="link-copied" class="link-copied font-open fw-600">
  Link Copied
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
  let noticeTimeout; // Track the current timeout to prevent overlapping
  
  function showCopiedNotice() {
    const copiedNotice = document.getElementById('link-copied');
    if (copiedNotice) {
      // Clear any existing timeout to prevent overlapping animations
      if (noticeTimeout) {
        clearTimeout(noticeTimeout);
      }
      
      // Remove class first in case it's already showing
      copiedNotice.classList.remove('show');
      
      // Force reflow to ensure the class removal takes effect
      copiedNotice.offsetHeight;
      
      // Add show class
      copiedNotice.classList.add('show');
      
      // Set timeout to remove the class
      noticeTimeout = setTimeout(() => {
        copiedNotice.classList.remove('show');
        noticeTimeout = null;
      }, 3000);
    }
  }
  
  // Handle links that also redirect
  document.querySelectorAll('.copy-redirect-link').forEach(link => {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      const linkToCopy = this.getAttribute('data-link');
      const actualHref = this.getAttribute('href');
      
      navigator.clipboard.writeText(linkToCopy)
        .then(() => {
          
            window.open(actualHref, '_blank');
        
        })
        .catch(err => {
          console.error('Clipboard copy failed:', err);
          window.open(actualHref, '_blank');
        });
    });
  });
  
  // Handle plain copy buttons
  document.querySelectorAll('.copy-link').forEach(button => {
    button.addEventListener('click', () => {
      const link = button.getAttribute('data-link');
      
      navigator.clipboard.writeText(link)
        .then(() => {
          showCopiedNotice(); // Show the notice every time
        })
        .catch(err => {
          console.error('Clipboard copy failed:', err);
        });
    });
  });
});

</script>


