<style>
  /* Main wrapper for content centering and max-width */
        .main-wrapper {
            width: 100%;
            margin-left: auto;
            margin-right: auto;
        }

        /* Testimonial section container */
        .testimonial-section {
            background-color: #F0F7E5; /* Section background */
            padding: 1rem; /* Equivalent to p-6 */
           
        }

        /* Grid container for testimonials */
        .testimonial-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr)); /* Equivalent to grid-cols-2 */
            gap: 1rem; /* Equivalent to gap-4 */
            margin-bottom: 2rem; /* Equivalent to mb-8 */
            
        }

        /* Individual testimonial card */
        .testimonial-card {
            display: flex;
            flex-direction: column; 
            width: 280px;
        }

        /* Container for the image/video in a card */
        .card-image-container {
            position: relative; /* Equivalent to relative */
            width: 100%; /* Equivalent to w-full */
            height: 100%; /* Equivalent to h-36 */
            border-radius: 0.375rem; /* Equivalent to rounded-md */
            overflow: hidden; /* Equivalent to overflow-hidden */
            height: fit-content;
        }

        /* Image styling within a card */
        .card-image {
            width: 100%; /* Equivalent to w-full */
            height: 100%; /* Equivalent to h-full */
            object-fit: cover; /* Equivalent to object-cover */
        }

        /* Quote text styling */
        .card-quote{
            color: #212121;
            margin-bottom: 0.25rem;
            margin-top: 16px;
            flex-grow: 1;
            font-family: "Lausanne";
            font-size: 18px;
            font-style: normal;
            font-weight: 200;
            line-height: 150%;
            max-height: fit-content;
        }

        /* Author text styling */
        .card-author {
            color: #9E9E9E;
            font-family: "Lausanne";
            font-size: 16px;
            font-style: normal;
            font-weight: 400;
            line-height: 160%;
        }

      
      
       

        /* Medium screens and up (md: 768px) */
        @media (min-width: 768px) {
            .testimonial-section {
                padding: 3rem; 
                padding-block: 80px;
            }
           
            .testimonial-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr)); /* Equivalent to md:grid-cols-4 */
                gap: 0; /* Equivalent to md:gap-6 */
                margin-bottom: 40px;
                margin-top: 40px;
                padding: 0px 35px !important;
            }
            
        }

        @media (max-width: 768px) {
          .testimonial-section {
                padding-block: 32px;
            }

         .testimonial-grid {
              grid-template-columns: repeat(1, minmax(0, 1fr)); /* Equivalent to md:grid-cols-4 */
              gap: 2rem; 
              margin-bottom: 2rem; 
              margin-top: 20px;
          }

          .testimonial-card {
              width: 165px;
          }

          .testimonial-card-3 .card-author {
            margin-bottom: 0;
          }

          .card-quote {
            font-size: 16px;
          }

          .card-author {
            font-size: 14px;
          }
          
          .testimonial-card-1 { order: 1; }
          .testimonial-card-2 { order: 2; }
          .testimonial-card-3 { order: 4; } /* Will appear as 4th item */
          .testimonial-card-4 { order: 3; } /* Will appear as 3rd item */
        }

  .testimonial-group {
    display: flex;
    justify-content: space-around;
  }
</style>

 <div class="main-wrapper">
        <section class="testimonial-section">
           
          <h2 class="heading-2 text-center blue-text font-gtsuper fw-400 mt-0"> {{ section.settings.heading }}</h2>

            <div class="testimonial-grid ">
                {% for block in section.blocks %}
                  {%  if forloop.index0 == 0 %}
                    {% assign plusOneIndex = forloop.index0 | plus: 1 %}
                  {% else %}
                    {% assign plusOneIndex = forloop.index0 | plus: 2 %}
                  {% endif %}
                  <div class="testimonial-group">
                <div class="testimonial-card testimonial-card-{{ plusOneIndex }}" >
                    <div class="card-image-container">
                        <img
                            src="{{ block.settings.image | img_url : '200x200' }}"
                            width="200"
                            height="200"
                            alt="{{ block.settings.image.alt }}"
                            class="img-responsive h-auto w-100"
                          >
                        </div>
                    <p class="card-quote">
                    {{ block.settings.review }}
                    </p>
                    <p class="card-author">{{ block.settings.userName }}</p>
                </div>
                 {%  if forloop.index0 == 0 %}
                   {% assign plusTwoIndex = forloop.index0 | plus: 2 %}
                 {% else %}
                  {% assign plusTwoIndex = forloop.index0 | plus: 3 %}
                 {% endif %}
                <div class="testimonial-card testimonial-card-{{ plusTwoIndex }}">
                    <div class="card-image-container">
                        <video
                    class="img-responsive w-100"
                    loading="lazy"
                    id="video_{{ block.id }}"
                    poster="{{ block.settings.poster | img_url : '400x' }}"
                  >
                    <source src="{{ block.settings.videoURL }}" type="video/mp4">
                  </video>

                  <div class="video-pp-icon">
                    <img
                      width="50"
                      height="50"
                      src="{{ 'play-button.png' | asset_img_url }}"
                      data-target="video_{{ block.id }}"
                      class="t-video-play"
                      alt="Play"
                    >
                  </div>
                    </div>
                    
                </div>
                </div>
                {% endfor %}

            </div>

           <div class="w-100 ">
              <div class="mt-4">
                <span
                  class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto"
                  style="max-width:100%"
                  data-target="{{ section.settings.scrollto }}"
                  data-top="{{ section.settings.top }}"
                  {% if section.settings.dataTrack %}
                    {% render 'ga4-events' %}
                  {% endif %}
                  >GET YOUR OFFER</span
                >
              </div>
            </div>
        </section>
    </div>

