{% liquid
  assign arrows = section.settings.arrows
  assign background = section.settings['bg-color']
  assign textColor = section.settings['text-color']
  assign slide__time = section.settings.slideTime | times: 1000
%}
<div class="annoucment-bar anc-bar-slider-box py-2" style="background-color:{{background}}">
  <div class="container text-center">
    <div class="slideshow-container position-relative">
      {% assign slide__count = 0 %}
      {% for block in section.blocks %}
        {% assign template = template.suffix %}
        {% if block.settings.forAll %}
          <div class="slide {% if block.settings.active  %}active{% endif %}">
            <span
              class="font-lausanne fw-400 {% if block.settings.scrollto != blank %}click-scroll{% endif %}"
              data-target="{{ block.settings.scrollto }}"
              data-top="{{ block.settings.top_position }}"
              {% if block.settings.dataTrack %}
                data-tracked="true"
                data-page-url="{{ request.path }}"
                data-target-url="{{ block.settings.targetUrl }}"
                data-index="{{ block.settings.index }}"
                data-funnel-stage="{{ block.settings.funnel_stage }}"
                data-module="{{ block.settings.dataModule }}"
                data-event-label="{{ block.settings.text | strip_html  | handle | replace: '-', '_'}}"
                data-event-value="{{ block.settings.eventValue }}"
                data-item-id=""
                data-option-index=""
                data-item-name="{{ block.settings.ItemName }}"
              {% endif %}
              style="color: {{textColor}};"
            >
              {{ block.settings.text }}
            </span>
          </div>
        {% elsif block.settings.template == template %}
          <div class="slide {% if  block.settings.active %}active{% endif %}">
            <span
              class="font-lausanne fw-400 {% if block.settings.scrollto != blank %}click-scroll{% endif %}"
              data-target="{{ block.settings.scrollto }}"
              data-top="{{ block.settings.top_position }}"
              {% if block.settings.dataTrack %}
                data-tracked="true"
                data-page-url="{{ request.path }}"
                data-target-url="{{ block.settings.targetUrl }}"
                data-index="{{ block.settings.index }}"
                data-funnel-stage="{{ block.settings.funnel_stage }}"
                data-module="{{ block.settings.dataModule }}"
                data-event-label="{{ block.settings.text | strip_html  | handle | replace: '-', '_'}}"
                data-event-value="{{ block.settings.eventValue }}"
                data-item-id=""
                data-option-index=""
                data-item-name="{{ block.settings.ItemName }}"
              {% endif %}
              style="color: {{textColor}};"
            >
              {{ block.settings.text }}
            </span>
          </div>
        {% endif %}
        {% assign slide__count = slide__count | plus: 1 %}
      {% endfor %}
      {% if arrows and slide__count > 1 %}
        <span class="nav-arrow prev" style="color:{{textColor}}" onclick="prevSlide()">
          <i class="fa-regular fa-angle-left"></i>
        </span>
        <span class="nav-arrow next" style="color:{{textColor}}" onclick="nextSlide()">
          <i class="fa-regular fa-angle-right"></i>
        </span>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .slide {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      opacity: 0;
      font-size: 14px;
  }
  .slide.active {
      opacity: 1;
  }
  .nav-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      font-size: 16px;
      cursor: pointer;
  }
  .nav-arrow.prev {
      left: 0px;
  }
  .nav-arrow.next {
      right: 0px;
  }
  .slideshow-container{
      position: relative;
      height: 40px;
      border-radius: 10px;
      overflow: hidden;
  }
  .slide {
    pointer-events: none;
  }
  .slide.active {
    pointer-events: auto;
  }
</style>

{% if slide__count > 1 %}
  <script>
    let slideIndex = 0;
    let slideInterval;
    const slides = document.querySelectorAll('.slide');
    const slideDelay = {{slide__time}}; // 5 seconds

    function showSlide(index) {
        // Remove active class from all slides
        slides.forEach(slide => {
            slide.classList.remove('active', 'prev');
        });

        // Add prev class to current slide before switching
        if (slides[slideIndex]) {
            slides[slideIndex].classList.add('prev');
        }

        // Update slide index
        slideIndex = index;

        // Show new active slide
        if (slides[slideIndex]) {
            slides[slideIndex].classList.add('active');
        }
    }

    function nextSlide() {
        const nextIndex = (slideIndex + 1) % slides.length;
        showSlide(nextIndex);
        resetTimer();
    }

    function prevSlide() {
        const prevIndex = (slideIndex - 1 + slides.length) % slides.length;
        showSlide(prevIndex);
        resetTimer();
    }

    function resetTimer() {
        clearInterval(slideInterval);
        slideInterval = setInterval(() => {
            const nextIndex = (slideIndex + 1) % slides.length;
            showSlide(nextIndex);
        }, slideDelay);
    }

    // Initialize slideshow
    function initSlideshow() {
        slideInterval = setInterval(() => {
            const nextIndex = (slideIndex + 1) % slides.length;
            showSlide(nextIndex);
        }, slideDelay);
    }

    // Start the slideshow when page loads
    window.addEventListener('load', initSlideshow);

    // Pause on hover
    const container = document.querySelector('.slideshow-container');
    container.addEventListener('mouseenter', () => {
        clearInterval(slideInterval);
    });

    container.addEventListener('mouseleave', resetTimer);

    const sliderAnnouncementBox = document.querySelector('.anc-bar-slider-box');
    if(sliderAnnouncementBox) {
      sliderAnnouncementBox.querySelectorAll('.click-scroll').forEach(function(element) {
        element.addEventListener('click', function(event) {
          const searchforID = document.querySelector(`#${event.currentTarget.dataset.target}`);

          if(!searchforID) {
            window.location.href = `${window.Shopify.routes.root}#${event.currentTarget.dataset.target}`
          }
        });
      });
    }
  </script>
{% endif %}

{% schema %}
{
  "name": "Announcement bar Slider",
  "settings": [
    {
      "type": "checkbox",
      "id": "arrows",
      "label": "Show Arrows"
    },
    {
      "type": "color",
      "id": "bg-color",
      "label": "Background Color",
      "default": "#FFEDE4"
    },
    {
      "type": "color",
      "id": "text-color",
      "default": "#fff",
      "label": "Text Color",
      "default": "#D15E14"
    },
    {
      "type": "number",
      "id": "slideTime",
      "label": "Slide Duration (seconds)",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Announcement bar Slide",
      "settings": [
        {
          "type": "checkbox",
          "id": "forAll",
          "label": "Show Slide for all pages"
        },
        {
          "type": "checkbox",
          "id": "active",
          "label": "Active Slide"
        },
        {
          "type": "text",
          "id": "template",
          "label": "Template Name"
        },
        {
          "type": "html",
          "id": "text",
          "label": "Slide Text"
        },
        {
          "type": "text",
          "id": "scrollto",
          "label": "Section ID",
          "info": "To enable smooth scrolling to a specific section when clicked, add a section ID to the target area where you want the page to scroll. This allows users to navigate directly to particular sections with on-click scroll functionality."
        },
        {
          "type": "number",
          "id": "top_position",
          "label": "Scroll Position"
        },
        {
          "type": "header",
          "content": "GA4"
        },
        {
          "id": "dataTrack",
          "label": "Data Track",
          "type": "checkbox"
        },
        {
          "id": "targetUrl",
          "label": "Target Url",
          "type": "url"
        },
        {
          "id": "index",
          "label": "Index",
          "type": "number",
          "default": 0
        },
        {
          "id": "funnel_stage",
          "label": "Funnel Stage",
          "type": "text",
          "default": "hp"
        },
        {
          "id": "dataModule",
          "label": "Module",
          "type": "text",
          "default": "announcement_bar"
        },
        {
          "id": "dataTitle",
          "label": "Event Label",
          "type": "text",
          "default": "get_your_offer"
        },
        {
          "id": "eventValue",
          "label": "Event Value",
          "type": "text",
          "default": "shop_anchor"
        },
        {
          "id": "ItemName",
          "label": "Item Name",
          "type": "text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar Slider",
      "category": "Announcement bar",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "forAll": true,
            "active": true,
            "template": "",
            "text": "Save £28 with FREE bottle &amp; cloth",
            "scrollto": "starterkit-product",
            "top_position": 0
          }
        }
      ]
    }
  ]
}
{% endschema %}
