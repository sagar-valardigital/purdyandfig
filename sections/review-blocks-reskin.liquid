<style>
   @media (max-width: 768px) {
	  .review-blocks-section .section-heading .heading-2 {
		 text-align: left;
	}
}
  .review-blocks-section .reviews-blocks {
	 margin-top: 10px;
	 display: grid;
	 grid-template-columns: repeat(3, 1fr);
	 grid-gap: 50px;
	 align-items: center;
}
  .review-blocks-section .reviews-blocks .review-block {
	 padding-bottom: 30px;
	 padding-top: 30px;
	 border-bottom: 1px solid #eee;
	 height: 100%;
	 text-align: center;
}
  .review-blocks-section .reviews-blocks .review-block .review {
	 margin: 0;
	 font-size: 18px;
	 font-family: 'GT Super Ds Trial Lt It';
	 font-style: italic;
	 color: #212121;
	 font-weight: 200;
}
 @media (max-width: 768px) {
	  .review-blocks-section .reviews-blocks .review-block .review {
		 font-size: 18px;
	}
}
  .review-blocks-section .reviews-blocks .review-block .user-img {
	 width: 60px;
	 margin: 20px auto 12px;
}
  .review-blocks-section .reviews-blocks .review-block .user-img img {
	 width: 100%;
}
  .review-blocks-section .reviews-blocks .review-block .user-name {
	 font-family: 'Lausanne';
	 font-weight: 400;
	 font-size: 16px;
	 margin: 0;
}
 @media (max-width: 768px) {
	  .review-blocks-section .reviews-blocks .review-block .user-name {
		 font-size: 14px;
	}
}
 @media (max-width: 768px) {
	  .review-blocks-section .reviews-blocks {
		 grid-template-columns: 1fr;
		 grid-gap: 5px;
	}
}
 @media (max-width: 768px) {
	  .review-blocks-section {
		 padding: 32px 0;
	}
}
</style>

<div class="review-blocks-section py-80">
  <div class="container">
    <div class="section-heading text-center">
      <h2 class="heading-2">{{ section.settings.heading }}</h2>
    </div>
    <div class="reviews-blocks">
      {% for block in section.blocks %}
        <div class="review-block">
          <p class="review">
            {{ block.settings.review }}
          </p>
          <div class="user-img">
            {% assign userIMG = block.settings.user_img | img_url : '80x80', crop : "center" %}
            <img src="{{ userIMG }}" alt="{{ user.alt }}" width="60" height="60">
          </div>
          <p class="user-name">
            {{ block.settings.username }}
          </p>
        </div>
      {% endfor %}
    </div>
  </div>
  
  
</div>


{% schema %}
  {
    "name": "Review Blocks",
    "settings": [
      {
        "type": "text",
        "id" : "heading",
        "label" : "Heading"
      }
    ],
    	"blocks": [
      {
        "type": "Review",
        "name": "block",
        "settings": [ 
         
{
      "type": "text",
      "id": "review",
      "label": "Review"
    },
{
      "type": "text",
      "id": "username",
      "label": "User Name"
    },
           {
      "type": "image_picker",
      "id": "user_img",
      "label": "User Image"
    }

        ]
      }
	],
    "presets": [
      {
        "name" : "Review Blocks Reskin"
      }
    ]
  }
{% endschema %}