<style>
  .citrus-desktop-hide {
    display: none;
  }
  .citrus-mobile-hide {
    display: block;
  }
  .citrus-section-381 {
    padding: 80px 112px;
    display: flex;
    gap: 32px;
    justify-content: center;
    align-items: flex-start;
    background: {{ section.settings.background_color }};
    flex-wrap: wrap;
    width: 100%;
  }
  .citrus-container {
    display: flex;
    gap: 104px;
    justify-content: center;
    align-items: flex-start;
    flex-wrap: wrap;
  }
  .citrus-product-box {
    order: 1;
    display: flex;
    flex-direction: column;
    width: calc(55% - 52px);;
    justify-content: center;
    align-items: flex-start;
    gap: 10px;
  }
  .citrus-product-box img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    cursor: pointer;
  }
  .prdetail-box {
    display: flex;
    padding: 0 8px;
    flex-direction: column;
    align-items: flex-start;
    align-self: stretch;
  }
  .citrus-product-title {
    font-family: "Lausanne";
    font-size: 18px;
    font-weight: 600;
    line-height: 27px;
    color: #212121;
    cursor: pointer;
  }
  .citrus-product-summary {
    font-family: "Lausanne";
    font-size: 14px;
    font-weight: 200;
    line-height: 21px;
    color: #424242;
  }
  .citrus-price {
    font-family: "Lausanne";
    font-size: 14px;
    font-weight: 400;
    line-height: 14px;
    color: #424242;
    letter-spacing: 0.35px;
  }
  .citrus-deleted-price {
    font-family: "Lausanne";
    font-size: 14px;
    font-weight: 400;
    line-height: 14px;
    color: #9E9E9E;
    letter-spacing: 0.35px;
    text-decoration: line-through;
  }
  .citrus-product-box form {
    width: 100%;
  }
  .citrus-product-box .checkout-starterkit-btn {
    font-size: 18px !important;
    width: 100%;
  }
  .citrus-heading-box {
    order: 2;
    width: calc(45% - 52px);
    /* height: 265px; */
    display: flex;
    align-self: center;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
    flex-shrink: 1;
  }
  .heading-brd {
    display: flex;
    padding: 16px 0;
    align-items: flex-start;
    border-top: 0.5px solid #003176;
    border-bottom: 0.5px solid #003176;
    width: 100%;
  }
  .citrus-heading {
    font-family: "GT Super" !important;
    font-size: 48px;
    font-weight: 400;
    line-height: 60px;
    color: #003176;
  }
  .citrus-heading .fi-lic {
    font-style: italic;
  }
  .citrus-summary {
    width: calc(90% - 30px);
    max-width: 416px;
    font-family: "Lausanne";
    font-size: 18px;
    font-weight: 200;
    line-height: 27px;
    color: #003176;
  }
  .citrus-summary .weight-extra {
    font-weight: 600;
  }
  .sc-btn-381 {
    display: flex;
    gap: 4px;
  }
  .sc-btn-del-price-381 {
    color: #9E9E9E;
    font-weight: 400;
  }

  @media (max-width: 768px) {
    .citrus-desktop-hide {
      display: block;
    }
    .citrus-mobile-hide {
      display: none;
    }
    
    .citrus-section-381 {
      padding: 32px 16px;
      gap: 24px;
    }

    .citrus-container {
      flex-direction: column;
      gap: 24px;
      align-items: flex-start;
      width: 100%;
    }

    .citrus-product-box {
      order: 2;
      width: 100%;
    }
    .citrus-product-box img {
      height: auto;
    }
    .citrus-product-title {
      font-size: 16px;
      line-height: 24px;
    }
    .citrus-product-summary {
      font-size: 12px;
      line-height: 18px;
      letter-spacing: 0.18px;
    }
    .citrus-product-box form {
      width: 100%;
    }
    .citrus-product-box .checkout-starterkit-btn {
      width: 100%;
    }
    
    .citrus-heading-box {
      order: 1;
      width: 100%;
      height: unset;
    }

    .heading-border-box {
      width: 343px;
    }
    .citrus-heading {
      font-size: 32px;
      line-height: 40px;
      /* max-width: 343px; */
    }
    .citrus-summary {
      width: 343px;
      font-size: 16px;
      line-height: 24px;
    }
  }
</style>

{% assign product = section.settings.landing_product %}

<section class="citrus-section-381" x-data="{qty:1}">
  <div class="citrus-container">
    <div class="citrus-product-box" id="{{ section.settings.scroll_id }}">
      <img
        loading="lazy"
        src="{{ section.settings.desktop_image | image_url: width: 3200 }}"
        width="592"
        height="592"
        class="citrus-image citrus-mobile-hide"
        alt="{{ section.settings.desktop_image.alt }}"
        onclick="firepopupblock(this);"
      >
      <img
        loading="lazy"
        src="{{ section.settings.mobile_image | image_url: width: 1200 }}"
        width="343"
        height="343"
        class="citrus-image citrus-desktop-hide image-main-381"
        alt="{{ section.settings.mobile_image.alt }}"
        onclick="firepopupblock(this);"
      >
      <div class="prdetail-box">
        <span class="citrus-product-title" onclick="firepopupblock(this);">{{ section.settings.product_title }}</span>
        <span class="citrus-product-summary">{{ section.settings.product_summary }}</span>
        <span class="citrus-price-block">
          <span class="citrus-price">
            {{- localization.country.currency.symbol -}}
            {{- section.settings.product_price -}}
          </span>
          <span class="citrus-deleted-price">
            {{- localization.country.currency.symbol -}}
            {{- section.settings.product_cross_price -}}
          </span>
        </span>
      </div>
      
      <input type="hidden" class="toast-sub" data-pop-sub="{{ section.settings.isSub }}" />
      <div class="bulletpoints1" style="display: none;">{{ section.settings.bulletpoints1 }}</div>
      <div class="bulletpoints2" style="display: none;">{{ section.settings.bulletpoints2 }}</div>
      <div class="bulletpoints3" style="display: none;">{{ section.settings.bulletpoints3 }}</div>
      <div class="bulletpoints4" style="display: none;">{{ section.settings.bulletpoints4 }}</div>
      <div class="bulletpoints5" style="display: none;">{{ section.settings.bulletpoints5 }}</div>
      <div class="bulletpoints6" style="display: none;">{{ section.settings.bulletpoints6 }}</div>
      <div class="bulletpoints7" style="display: none;">{{ section.settings.bulletpoints7 }}</div>
      <div class="bulletpoints8" style="display: none;">{{ section.settings.bulletpoints8 }}</div>
      <div class="popup-title" style="display: none;">{{ section.settings.popuptitle }}</div>
      <div class="popup-summary" style="display: none;">{{ section.settings.popupsummary }}</div>
      <div class="pop-bullet-heading" style="display: none;">{% if section.settings.bulletlabel != blank %}{{ section.settings.bulletlabel }}{% else %}Pack includes:{% endif %}</div>
      <div class="out-of-stock" style="display: none;">{{ section.settings.out_of_stock }}</div>

      <form
        name="shopify-product-form"
        autocomplete="off"
        @submit.prevent="console.log('submitted')"
        x-ref="product_citrus_form"
        enctype="multipart/form-data"
        accept-charset="UTF-8"
        id="product_citrus_form"
        class="shopify-product-form show"
        data-product-id="{{product.id}}"
        action="/cart/add"
      >
        <input
          autocomplete="off"
          type="hidden"
          name="id"
          class="input_variant_id_"
          value="{{ section.settings.variant_id }}"
        >
        <input
          autocomplete="off"
          type="hidden"
          class="discout_input disc"
          name="discount"
          value="{{ section.settings.discount_code }}"
        >
        <input autocomplete="off" type="hidden" name="quantity" value="1">
        <input
          autocomplete="off"
          type="checkbox"
          name="purchase_type"
          {% if section.settings.isSub %}
            value="subscription"
          {% else %}
            value="payg"
          {% endif %}
          class="d-none gp--buyoption-input purc_type"
        >
        <input
          autocomplete="off"
          class="input_selling_plan_"
          type="hidden"
          name="selling_plan"
          value="{{ section.settings.selling_plan }}"
        >
        {% if section.settings.out_of_stock %}
        <span
          class="btn w-100 green-btn value-medium checkout-starterkit-btn ga4-checkout-btn sc-btn-381 btn-main-381"
          {% if section.settings.dataTrack %}
            data-target-url="{{ section.settings.targetUrl }}"
            data-index="{{ section.settings.index }}"
            data-funnel-stage="{{ section.settings.funnel_stage }}"
            data-module="{{ section.settings.dataModule }}"
            data-event-label="{{ section.settings.dataTitle }}"
            data-event-value="{{ section.settings.eventValue }}"
            data-item-id="{{ section.settings.product_sku }}"
            data-option-index="{{ section.settings.optionIndex }}"
            data-item-name="{{ section.settings.ItemName }}" data-quantity="{{ section.settings.quantity }}"
            data-price="{{ localization.country.currency.symbol }}{{ section.settings.product_price }}"
            data-cross-price="{{ localization.country.currency.symbol }}{{ section.settings.product_cross_price }}"
            data-item-type="{% if section.settings.isSub %}subscription{% else %}PAYG{% endif %}"
          {% endif %}
          disabled="disabled"
          style="background: {{ section.settings.btn_bg_color }} !important; color: {{ section.settings.btn_text_color }}; opacity: 0.6"
        >
          <span class="sc-btn-txt-381">OUT OF STOCK</span>
          <!-- <del class="sc-btn-del-price-381">{{ localization.country.currency.symbol }}{{ section.settings.product_cross_price }}</del>
          <span class="sc-btn-price-381">{{ localization.country.currency.symbol }}{{ section.settings.product_price }}</span> -->
        </span>
        {% else %}
        <span
          x-on:click="Purdy.AddToCartWithDiscount($refs.product_citrus_form, false, false, $event)"
          class="btn w-100 green-btn value-medium btn-loader checkout-starterkit-btn ga4-checkout-btn sc-btn-381 btn-main-381"
          {% if section.settings.dataTrack %}
            data-checkout="true"
            data-add-to-cart="true" data-page-url="{{ request.path }}"
            data-target-url="{{ section.settings.targetUrl }}"
            data-index="{{ section.settings.index }}"
            data-funnel-stage="{{ section.settings.funnel_stage }}"
            data-module="{{ section.settings.dataModule }}"
            data-event-label="{{ section.settings.dataTitle }}"
            data-event-value="{{ section.settings.eventValue }}"
            data-item-id="{{ section.settings.product_sku }}"
            data-option-index="{{ section.settings.optionIndex }}"
            data-item-name="{{ section.settings.ItemName }}" data-quantity="{{ section.settings.quantity }}"
            data-price="{{ localization.country.currency.symbol }}{{ section.settings.product_price }}"
            data-cross-price="{{ localization.country.currency.symbol }}{{ section.settings.product_cross_price }}"
            data-item-type="{% if section.settings.isSub %}subscription{% else %}PAYG{% endif %}"
          {% endif %}
          style="background: {{ section.settings.btn_bg_color }} !important; color: {{ section.settings.btn_text_color }};"
        >
          <span class="sc-btn-txt-381">{{ section.settings.btn_text }}</span>
          <!-- <del class="sc-btn-del-price-381">{{ localization.country.currency.symbol }}{{ section.settings.product_cross_price }}</del>
          <span class="sc-btn-price-381">{{ localization.country.currency.symbol }}{{ section.settings.product_price }}</span> -->
        </span>
        {% endif %}
      </form>
    </div>
    <div class="citrus-heading-box">
      <div class="heading-brd">
        <div class="heading-border-box">
          <span class="citrus-heading">{{ section.settings.heading }}</span>
        </div>
      </div>
      <span class="citrus-summary">{{ section.settings.summary }}</span>
    </div>
  </div>
</section>

