{% schema %}
{
  "name": "Banner optimized",
  "settings": [
    {
      "type": "color",
      "label": "Heading Color",
      "id": "heading-color"
    },
    {
      "type": "color",
      "label": "Sub heading Color",
      "id": "subheading-color"
    },
    {
      "type": "image_picker",
      "label": "Desktop Image",
      "id": "desktop_img"
    },
    {
      "type": "image_picker",
      "label": "Mobile Image",
      "id": "mobile_img"
    },
    {
      "type": "checkbox",
      "id": "isavatar",
      "label": "Contains reviews image"
    },
    {
      "type": "image_picker",
      "label": "Reviews image",
      "id": "review_image"
    },
    {
      "type": "html",
      "label": "Heading",
      "id": "heading"
    },
    {
      "type": "html",
      "label": "Sub Heading",
      "id": "sub_heading"
    },
    {
      "type": "color",
      "label": "Button BG Colour",
      "id": "btn-bg",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "label": "Button Text Colour",
      "id": "btn-txt-color",
      "default": "#11322C"
    },
    {
      "type": "text",
      "label": "Button label",
      "id": "button_label"
    },
    {
      "type": "text",
      "label": "Button Link",
      "id": "button_link"
    },
    {
      "type": "text",
      "id": "top",
      "label": "Scroll to Position"
    },
    {
      "type": "checkbox",
      "label": "Show Reviews",
      "id": "showreview",
      "default": true
    },
    {
      "type": "color",
      "label": "Review star color",
      "id": "star_color"
    },
    {
      "type": "color",
      "label": "Review text color",
      "id": "star_text_color"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "landing_page"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "itemId",
      "label": "Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label": "Item Name",
      "type": "text"
    }
  ],
  "presets": [
    {
      "name": "Banner optimized"
    }
  ]
}
{% endschema %}
