<style>
  .banner-us-container {
  	position: relative;
  	overflow: hidden;
  	background-image: url({{section.settings.desktop_img | image_url: width: 3200 }});
  	background-position: center;
  	background-size: cover;
  	background-repeat: no-repeat;
  	display: flex;
  	gap: 10px;
  	flex-direction: column;
  	justify-content: flex-end;
  	align-items: center;
  	width: 100%;
  	{% if section.settings.showreview %}
  		min-height: 656px;
  	{% else %}
  		min-height: 600px;
  	{% endif %}
  	height: 90vh;
  }
  .banner-us-container-block {
  	align-self: stretch;
  	padding: 32px 16px;
  	display: flex;
  	gap: 16px;
  	flex-direction: column;
  	justify-content: flex-end;
  	align-items: center;
  }
  .banner-us-heading-block-inner {
  	align-self: stretch;
  	display: flex;
  	gap: 4px;
  	flex-direction: column;
  	justify-content: flex-start;
  	align-items: flex-start;
  }
  .banner-us-heading-content {
  	align-self: stretch;
  	display: flex;
  	flex-direction: column;
  	justify-content: flex-start;
  	align-items: flex-start;
  }
  .banner-us-heading {
  	align-self: stretch;
  	text-align: center;
  	color: {{ section.settings.heading-color }};
  	font-size: 48px;
  	font-family: "GT Super";
  	font-weight: 400;
  	line-height: 60px;
  	word-wrap: break-word;
  }
  .banner-us-subheading-content {
  	align-self: stretch;
  	display: flex;
  	gap: 8px;
  	flex-direction: column;
  	justify-content: flex-start;
  	align-items: flex-start;
  }
  .banner-us-subheading {
  	align-self: stretch;
  	text-align: center;
  	color: {{ section.settings.subheading-color }};
  	font-size: 18px;
  	font-family: "Lausanne";
  	font-weight: 200;
  	line-height: 27px;
  	word-wrap: break-word;
  }
  .banner-us-button-block {
  	align-self: stretch;
  	height: 48px;
  	border-radius: 4px;
  	display: flex;
  	gap: 10px;
  	justify-content: center;
  	align-items: center;
  }
  .banner-us-button-content {
  	flex: 1 1 0;
  	height: 48px;
  	padding: 12px 16px;
  	background: {{ section.settings.btn-bg }};
  	border-radius: 4px;
  	display: flex;
  	gap: 10px;
  	justify-content: center;
  	align-items: center;
  	max-width: 343px;
  }
  .banner-us-button {
  	color: {{ section.settings.btn-txt-color }};
  	font-size: 16px;
  	font-family: "Lausanne";
  	font-weight: 400;
  	text-transform: uppercase;
  	line-height: 16px;
  	letter-spacing: 0.40px;
  	word-wrap: break-word;
  }
  .banner-us-reviews-block {
  	justify-content: flex-start;
  	align-items: center;
  	gap: 8px;
  	display: flex;
  }
  .banner-us-reviews-content {
  	justify-content: flex-start;
  	align-items: center;
  	gap: 6px;
  	display: flex;
  }
  .rev-img-tr .banner-us-reviews-content {
  	flex-direction: column;
  	gap: 4px;
  	align-items: flex-start;
  }
  .banner-us-reviews {
  	justify-content: flex-start;
  	align-items: center;
  	gap: 4px;
  	display: flex;
  }
  .banner-us-reviews-block .star-img {
  	width: 16px; height: 16px; overflow: hidden; flex-direction: column; justify-content: flex-start; align-items: center; gap: 10px; display: flex;
  }
  .banner-us-reviews-text {
  	color: {{section.settings.star_text_color}};
  	font-size: 16px;
  	font-family: "Lausanne";
  	font-weight: 200;
  	line-height: 25.6px;
  	word-wrap: break-word;
  }
  .rev-img-tr .banner-us-reviews-text {
  	font-size: 12px;
  	line-height: 18px;
  	font-weight: 400;
  }
  .rev-stars {
  	display: flex;
  }
  .rev-text {
  	color: {{section.settings.star_text_color}};
  	font-size: 16px;
  	font-family: "Lausanne";
  	font-weight: 600;
  	line-height: 24px;
  	word-wrap: break-word;
  }
  @media(max-width: 767px) {
  	.banner-us-container {
  		background-image: url({{section.settings.mobile_img | image_url: width: 1600 }});
  		{% if section.settings.showreview %}
  			height: 650px;
  		{% endif %}
  	}
  	.banner-us-heading {
  		font-size: 36px;
  		line-height: 45px;
  	}
  	.banner-us-subheading {
  		font-size: 16px;
  		line-height: 24px;
  	}
  	.banner-us-button-content {
  		width: 100%;
  		max-width: 100%;
  	}
  	.banner-us-reviews-block .star-img {
  		width: 12px;
  		height: 12px;
  	}
  	.banner-us-reviews-text {
  		font-size: 14px;
  		line-height: 21px;
  	}
  }
</style>

<div class="banner-us-container">
  <div class="banner-us-container-block">
    <div class="banner-us-heading-block-inner">
      <div class="banner-us-heading-content">
        <div class="banner-us-heading">{{ section.settings.heading }}</div>
      </div>
      <div class="banner-us-subheading-content">
        <div class="banner-us-subheading">{{ section.settings.sub_heading }}</div>
      </div>
    </div>
    <div class="banner-us-button-block">
      <a
        {% if section.settings.dataTrack %}
          {% render 'ga4-events' %}
        {% endif %}
        class="banner-us-button click-scroll banner-us-button-content"
        href="javascript: void(0);"
        data-top="{{ section.settings.top }}"
        data-target="{{ section.settings.button_link }}"
      >
        {{- section.settings.button_label -}}
      </a>
    </div>
    {% if section.settings.showreview %}
      <div class="banner-us-reviews-block {% if section.settings.isavatar %}rev-img-tr{% endif %}">
        {% if section.settings.isavatar %}
          <img src="{{ section.settings.review_image | image_url: width: 300 }}" width="144" height="40">
        {% endif %}
        <div class="banner-us-reviews-content">
          <div class="banner-us-reviews">
            <div class="rev-stars">
