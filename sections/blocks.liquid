{% if section.settings.enable%}
<div class="block-section pt-5 pb-3">
        <div class="container">
            <h2 class="heading-2 text-center theme-text mt-0  m-heading-2">{{section.settings.heading}}</h2>
          {%if section.settings.subtext%}
          <p class="heading-4 theme-text  text-center">{{section.settings.subtext}}</p>
          {%endif%}
            <div class="d-flex flex-wrap justify-content-between mobile-slider-block_ theme-text my-1">
              {% for block in section.blocks %}
                <div class="w-25 p-2">
                    <div class="text-center ">
                        <div class="block-img-wrapper {%if block.settings.rounded%}rounded-img{%endif%}">
							{% assign image = block.settings.image | img_url:'300x300', crop : 'center'%}
                          	<img loading="lazy" src="{{image}}" class="img-responsive w-100" alt="{{ block.settings.image.alt }}" width="300px" height="300px">
                        </div>
                        <h3 class="heading-4 my-3">{{block.settings.heading}}</h3>
                      {%if block.settings.details%}
                        <p class="theme-text font-lausanne  fw-400">{{block.settings.details}}</p>
                      {% endif%}
                    </div>
                </div>
                {%endfor%}
            </div>
          <div class="d-none flex-wrap justify-content-between mobile-nav-slider-block theme-text my-1">
              {% for block in section.blocks %}
                <div class="w-25 p-2">
                    <div class="text-left ">
                        
                        <h3 class="heading-4 my-0">{{block.settings.heading}}</h3>
                      
                    </div>
                </div>
                {%endfor%}
            </div>
        </div>
    </div>
{% endif %}

{% schema %}
  {
    "name": "Blocks",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },
{
            "type": "select",
            "id": "width",
            "label": "Select block width",
            "options": [
              {
                "value": "w-100",
                "label": "100%"
              },
              {
                "value": "w-50",
                "label": "50%"
              },
{				
                "value": "w-33",
                "label": "33%"
              },
              {
                "value": "w-25",
                "label": "25%"
              }
            ],
            "default": "w-25"
          },
{
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
{
      "type": "text",
      "id": "subtext",
      "label": "Text"
    }
	],
	"blocks": [
      {
        "type": "text",
        "name": "block",
        "settings": [ 
          {
      "type": "image_picker",
      "id": "image",
      "label": "Add Image"
    },
{
      "type": "checkbox",
      "id": "rounded",
      "label": "Image rounded"
    },
{
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
{
      "type": "text",
      "id": "details",
      "label": "Detail Text"
    }

        ]
      }
	],
	"presets": [
		{
			"name": "Image blocks"
		}
	]
  }
{% endschema %}

