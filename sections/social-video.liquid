<div class="video-block-wrapper py-80" style="background-color:{{ section.settings.bgColor }}">
  <div class="container">
    <div class="text-center m-text-left">
      <h2 class="heading-2  blue-text value-bold mt-0 ">Our product is viral on social media</h2>
    </div>
    <div class="social-videos-slider">
      {% for block in section.blocks %}
        <div class="social-video-wrapper">
          <div class="position-relative">
            <video loading="lazy" id="video_{{ block.id }}" poster="{{ block.settings.poster | img_url : '400x550' }}">
              <source src="{{ block.settings.videoURL }}" type="video/mp4">
            </video>

            <div class="video-pp-icon">
              <img
                src="{{ 'play-button.png' | asset_img_url }}"
                data-target="video_{{ block.id }}"
                class="t-video-play"
                alt="video"
              >
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="mt-4">
      <span
        class="d-block text-center blue-starterkit-btn m-auto click-scroll"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >GET YOUR OFFER</span
      >
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Social Video",
  "settings": [
    {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      },
    {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
    {
      "type": "color",
      "id": "bgColor",
      "label": "Background color"
    },
    {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
  ],
  "blocks": [
      {
        "type": "video",
        "name": "video block",
        "settings": [
          {
      "type": "image_picker",
      "id": "poster",
      "label": "Add Image"
    },

{
      "type": "url",
      "id": "videoURL",
      "label": "Video URL"
    }
        ]
      }
	],
  "presets": [
    {
      "name": "Social Video",
      "category": "Video"
    }
  ]
}
{% endschema %}
