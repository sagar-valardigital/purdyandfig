<div
  class="review-section-3 py-80 review-slider-reskin {{ section.settings.className }}"
  style="background-color:{{ section.settings.bgColor }}"
>
  <div class="container">
    <div class="d-flex review-section-3-wrapper">
      <div class="w-25 review-section-3-fixed p-0">
        <div class="">
       
          <h2 class="heading-3 font-gtsuper fw-400 text-dark-green">
            {{ section.settings.heading }}
          </h2>
          <div class="rs-3-arrows hide-below-991">
            <span class="rs-left">
              <img
                alt="Previous arrow"
                width="51"
                height="51"
                src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Button_a82f79a0-1e21-4c5f-a5ec-e1eb44a238ad.png?v=1723267531"
              >
            </span>
            <span class="rs-right ml-2">
              <img
                alt="Next arrow"
                width="51"
                height="51"
                src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Button.png?v=1723267461"
              >
            </span>
          </div>
        </div>
        <div class="mt-4 hide-below-991">
          <span
            class="d-block text-center blue-starterkit-btn green-btn click-scroll"
            style="max-width:100%"
            data-target="{{ section.settings.scrollto }}"
            data-top="{{ section.settings.top }}"
            {% if section.settings.dataTrack %}
              {% render 'ga4-events' %}
            {% endif %}
            >{% if section.settings.reviews_button_text %} 
              {{ section.settings.reviews_button_text }} 
            {% else %}
              GET YOUR OFFER
            {% endif %}</span
          >
        </div>
      </div>
      <div class="w-75 pr-0">
        <div class="review-slider-3">
          {% for block in section.blocks %}
            <div class="rs-3-slide">
              <div class="d-grid">
                <div class="">
                  <div class="rs-3-user">
                    <img
                      src="{{ block.settings.image | img_url : '200x200' }}"
                      width="200"
                      height="200"
                      alt="{{ block.settings.image.alt }}"
                      class="img-responsive h-auto w-100"
                    >
                    <div class="hide-below-991">
                      <h4 class="heading-4 black-text font-lausanne fw-400">{{ block.settings.heading }}</h4>
                      <p class=" font-lausanne fw-200 rs3-review">{{ block.settings.review }}</p>
                      <span class="font-lausanne fw-400 rs3-user-name">{{ block.settings.userName }}</span>
                    </div>
                  </div>
                </div>
                <div class=" position-relative">
                  <video
                    class="img-responsive w-100"
                    loading="lazy"
                    id="video_{{ block.id }}"
                    poster="{{ block.settings.poster | img_url : '400x' }}"
                  >
                    <source src="{{ block.settings.videoURL }}" type="video/mp4">
                  </video>

                  <div class="video-pp-icon">
                    <img
                      width="50"
                      height="50"
                      src="{{ 'play-button.png' | asset_img_url }}"
                      data-target="video_{{ block.id }}"
                      class="t-video-play"
                      alt="Play"
                    >
                  </div>
                </div>
              </div>
              <div class="hide-above-991 mt-3 rs-3-user">
                <h4 class="heading-4 black-text font-lausanne fw-400">{{ block.settings.heading }}</h4>
                <p class="font-lausanne fw-200 rs3-review">{{ block.settings.review }}</p>
                <span class="font-lausanne fw-400 rs3-user-name">{{ block.settings.userName }}</span>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="w-100 hide-above-991">
        <div class="rs-3-arrows">
          <span class="rs-left">
            <img
              alt="Previous arrow"
              width="48"
              height="48"
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Button_a82f79a0-1e21-4c5f-a5ec-e1eb44a238ad.png?v=1723267531"
            >
          </span>
          <span class="rs-right ml-2">
            <img
              alt="Next arrow"
              width="48"
              height="48"
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Button.png?v=1723267461"
            >
          </span>
        </div>
        <div class="mt-4">
          <span
            class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto"
            style="max-width:100%"
            data-target="{{ section.settings.scrollto }}"
            data-top="{{ section.settings.top }}"
            {% if section.settings.dataTrack %}
              {% render 'ga4-events' %}
            {% endif %}
            >{% if section.settings.reviews_button_text %} 
              {{ section.settings.reviews_button_text }} 
            {% else %}
              GET YOUR OFFER
            {% endif %}</span
          >
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
 {
   "name": "Reviews Slider Reskin 212",
   "class": "review-slider-3-section",
   "settings": [
     {
       "type": "text",
       "id": "reviews_button_text",
       "label": "Get offer label",
       "default": "GET YOUR OFFER"
     },
     {
     "type": "text",
      "id" : "heading",
      "label": "Heading",
      "default": "Join 200k+ happy customers who are transforming their homes to spa"
    },
     {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      },
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
   {
     "type": "text",
     "id": "className",
     "label": "Section Class"
   },

     {
     "type": "color",
     "id": "bgColor",
     "label": "Background Color"
   },
   {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
     {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
     {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
],
"blocks": [
     {
       "type": "text",
       "name": "Review",
       "settings": [
	{
           "type": "image_picker",
           "id": "image",
           "label": "User Image"
         },
         {
     "type": "text",
     "id": "heading",
     "label": "Review Heading"
   },
         {
     "type": "text",
     "id": "review",
     "label": "Review"
   },
         {
     "type": "text",
     "id": "userName",
     "label": "User Name"
   }, {
      "type": "image_picker",
      "id": "poster",
      "label": "Add Image"
    },

{
      "type": "url",
      "id": "videoURL",
      "label": "Video URL"
    }
       ]
     }
],
"presets": [
	{
		"name": "Review Slider Reskin 212"
	}
]
 }
{% endschema %}