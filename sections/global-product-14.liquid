    <div
      class="d-flex product-block-4-wrapper flex-wrap justify-content-between align-items-start container"
      id="{{ section.settings.p_id }}"
    >
      <div
        class="w-50 {% if section.settings.verticalThumbnails %}vertical-thumbnails-slider-wrapper{% endif %} {% if section.settings.layout %} order-2 {%endif%}"
      >
        <div class="two-women position-relative">
          {% assign mediacount = 0 %}
          <div class="link-to-variant variant_1 show position-relative">
            {% if section.settings.media_tag_1 != blank %}
              <span class="media_tag value-medium">{{ section.settings.media_tag_1 }}</span>
            {% endif %}
            <div class="gp-5-product-gallery  new-product-gallery-wrapper">
              {% for block in section.blocks %}
                {% if block.type == 'productImage' %}
                  {% assign image = block.settings.image %}
                  {% assign mimage = block.settings.mimage %}
                  {% if block.settings.is_video %}
                    <div class="main-product-img">
                      <video
                        class=" w-100 lazy"
                        poster="{{ block.settings.poster | img_url : '800x'}}"
                        width="520"
                        height="520"
                        controls
                      >
                        <source src="{{ block.settings.videoURL }}" type="video/mp4">
                      </video>
                    </div>
                  {% else %}
                    <div class="main-product-img ">
                      <picture>
                        <source media="(min-width:650px)" srcset="{{ image | img_url: 'master'}}">
                        <source media="(max-width:650px)" srcset="{{ mimage | img_url: 'master' }}">
                        <img
                          {% if forloop.index == 1 %}
                            skip-lazy
                          {% else %}
                            loading="lazy"
                          {% endif %}
                          data-id="{{image.id}}"
                          class="img-responsive w-100 h-auto lazy"
                          src="{{ image | img_url: 'master'}}"
                          width="800"
                          height="700"
                          alt="{{ image }}"
                        >
                      </picture>
                    </div>
                  {% endif %}
                {% endif %}
                {% assign mediacount = mediacount | plus: '1' %}
              {% endfor %}
            </div>
          </div>
          <div class="link-to-variant variant_2 position-relative">
            {% if section.settings.media_tag_2 != blank -%}
              <span class="media_tag value-medium">{{ section.settings.media_tag_2 }}</span>
            {%- endif %}
            <div class="gp-5-product-gallery  new-product-gallery-wrapper">
              {% for block in section.blocks %}
                {% if block.type == 'productImage2' %}
                  {% assign image = block.settings.image_2 %}
                  {% assign mimage = block.settings.mimage_2 %}
                  {% if block.settings.is_video_2 %}
                    <div class="main-product-img">
                      <video
                        class=" w-100 lazy"
                        poster="{{ block.settings.poster_2 | img_url : '800x'}}"
                        width="520"
                        height="520"
                        controls
                      >
                        <source src="{{ block.settings.videoURL_2 }}" type="video/mp4">
                      </video>
                    </div>
                  {% else %}
                    <div class="main-product-img ">
                      <picture>
                        <source media="(min-width:650px)" srcset="{{ image | img_url: 'master'}}">
                        <source media="(max-width:650px)" srcset="{{ mimage | img_url: 'master'}}">
                        <img
                          {% if forloop.index == 1 %}
                            skip-lazy
                          {% else %}
                            loading="lazy"
                          {% endif %}
                          data-id="{{image.id}}"
                          class="img-responsive w-100 h-auto lazy"
                          src="{{ image | img_url: 'master'}}"
                          width="800"
                          height="700"
                          alt="{{ image }}"
                        >
                      </picture>
                    </div>
                  {% endif %}
                {% endif %}
                {% assign mediacount = mediacount | plus: '1' %}
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
