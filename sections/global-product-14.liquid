<style>
  .link-to-variant.show {
    display: block !important;
    height: auto;
    margin-top: 4px;
    margin-bottom: 4px;
  }
</style>

{% assign product = section.settings.landingproduct %}
{% assign s_variant = product.selected_or_last_available_variant %}

<div
  class="{{ section.settings.className }} global-product-5 gp-14 global-product-10 py-80"
  id="id_{{ section.id }}"
  style="background-color:{{section.settings.background}};"
  x-data="{qty:1}"
>
  <div class="">
