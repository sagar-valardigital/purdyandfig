<style>
  .seasonal-scents-1 .tss-block {
    height: max-content !important;
  }

  .seasonal-scents-1 .tss-heading {
    color: #161718;
    font-size: 14px;
    font-weight: 700;
    line-height: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid #DFE0E1;
  }
  
  .seasonal-scents-1 .tss-details {
    color: #434448;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    font-style: normal;
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    margin-top: 8px;
    margin-bottom: 24px;
    transition: height 0.2s ease, -webkit-line-clamp 0.2s ease;
    height: calc(1.5em * 3);
  }

  .seasonal-scents-1 .tss-details.expanded {
    -webkit-line-clamp: unset;
    display: block;
    height: auto;
  }

  .seasonal-scents-1 .see-more-container {
    padding-top: 12px;
    border-top: 1px solid #DFE0E1;
    cursor: pointer;
  }
  
  .seasonal-scents-1 .see-more {
    color: #2D469E;
    text-decoration: none;
    font-size: 16px;
    font-weight: 700;
  }

  .seasonal-scents-1 .plus-minus {
    margin-left: auto;
  }

  .seasonal-scents-1 .plus-minus svg {
    margin: auto;
  }
</style>

{% assign count = 0 %}
{% for block in section.blocks %}
  {% assign count = count | plus: 1 %}
{% endfor %}
<div id="{{ section.settings.sectionId }}">
  <div
    style="background-color:{{ section.settings.bgcolor }}"
    class="py-80 transformational-scents-section link-to-variant seasonal-scents-1 variant_{{ section.settings.linkVariant }} {{ section.settings.class }}"
  >
    <div class="container">
      <div
        {% if count < 2 %}
          class="d-flex align-items-center justify-content-between tss-one-block-wrapper"
        {% endif %}
      >
        <div class="tss-main-header">
          <h2 class="heading-2 text-center white-text value-bold mt-0 ">{{ section.settings.heading }}</h2>
          <p style="color:#EAEAEB" class="normal-text value-sans text-center">
            {{ section.settings.subtext }}
          </p>
        </div>
        <div class="mt-4">
          <div class="transformational-scents-slider {% if count > 2 %}tss-slider{% endif %}">
            {% for block in section.blocks %}
              <div class="tss-block">
                <div class="tss-image position-relative">
                  <picture>
                    {% assign image = block.settings.blockImage %}
                    {% assign mimage = block.settings.mBlockImage %}

                    <source media="(min-width:769px)" srcset="{{ image | img_url: 'master'}}">
                    <source media="(max-width:768px)" srcset="{{ mimage | img_url: 'master' }}">
                    <img
                      data-id="{{image.id}}"
                      class="img-responsive w-100 h-auto lazy"
                      src="{{ image | img_url: 'master'}}"
                      width="400"
                      height="300"
                      alt="{{ image }}"
                    >
                  </picture>
                  {% if block.settings.tag != blank %}
                    <span class="tss-tag">{{ block.settings.tag }}</span>
                  {% endif %}
                </div>
                <div class="tss-content">
                  <h3 class="tss-heading blue-text-3 value-sans">{{ block.settings.heading }}</h3>
                  <p class="tss-details black-text normal-text value-sans" id="details-{{ forloop.index }}">{{ block.settings.details }}</p>
                  <div class="see-more-container d-flex w-100" data-target="details-{{ forloop.index }}">
                    <div>
                      <span class="see-more value-sans">See more</span>
                    </div>

                    <div class="plus-minus d-flex">
                      <svg class="plus-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <g clip-path="url(#clip0_1172_318)">
                          <path d="M9 6V12M6 9H12M16.5 9C16.5 13.1421 13.1421 16.5 9 16.5C4.85786 16.5 1.5 13.1421 1.5 9C1.5 4.85786 4.85786 1.5 9 1.5C13.1421 1.5 16.5 4.85786 16.5 9Z" stroke="#2D469E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </g>
                        <defs>
                          <clipPath id="clip0_1172_318">
                            <rect width="18" height="18" fill="white"/>
                          </clipPath>
                        </defs>
                      </svg>
                      <svg class="minus-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none" style="display: none;">
                        <g clip-path="url(#clip0_1172_318)">
                          <path d="M6 9H12M16.5 9C16.5 13.1421 13.1421 16.5 9 16.5C4.85786 16.5 1.5 13.1421 1.5 9C1.5 4.85786 4.85786 1.5 9 1.5C13.1421 1.5 16.5 4.85786 16.5 9Z" stroke="#2D469E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </g>
                        <defs>
                          <clipPath id="clip0_1172_318">
                            <rect width="18" height="18" fill="white"/>
                          </clipPath>
                        </defs>
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const seeMoreContainers = document.querySelectorAll(".see-more-container");
  
    const toggleDetails = (container, detailsElement) => {
      if (detailsElement.classList.contains("expanded")) {
        // For collapsing
        detailsElement.style.height = `${detailsElement.scrollHeight}px`;
        requestAnimationFrame(() => {
          detailsElement.style.height = 'calc(1.5em * 3)';
        });
        detailsElement.classList.remove("expanded");
      } else {
        // For expanding
        detailsElement.style.height = 'calc(1.5em * 3)';
        requestAnimationFrame(() => {
          detailsElement.style.height = `${detailsElement.scrollHeight}px`;
        });
        detailsElement.classList.add("expanded");
        detailsElement.addEventListener('transitionend', function handler() {
          detailsElement.style.height = 'auto';
          detailsElement.removeEventListener('transitionend', handler);
        });
      }
  
      const seeMoreText = container.querySelector(".see-more");
      seeMoreText.textContent = detailsElement.classList.contains("expanded") ? "See less" : "See more";
  
      const plusIcon = container.querySelector(".plus-icon");
      const minusIcon = container.querySelector(".minus-icon");
      if (detailsElement.classList.contains("expanded")) {
        plusIcon.style.display = "none";
        minusIcon.style.display = "block";
      } else {
        plusIcon.style.display = "block";
        minusIcon.style.display = "none";
      }
    };
  
    seeMoreContainers.forEach(container => {
      container.addEventListener("click", () => {
        const targetId = container.getAttribute("data-target");
        const detailsElement = document.getElementById(targetId);
        toggleDetails(container, detailsElement);
      });
    });
  
    const closeAllDetails = () => {
      document.querySelectorAll('.tss-details.expanded').forEach(detailsElement => {
        detailsElement.style.height = `${detailsElement.scrollHeight}px`;
        requestAnimationFrame(() => {
          detailsElement.style.height = 'calc(1.5em * 3)';
        });
        detailsElement.classList.remove("expanded");
  
        // Use parentElement to ensure we are selecting the correct container
        const container = detailsElement.closest(".tss-block").querySelector(".see-more-container");
        if (container) {
          const seeMoreText = container.querySelector(".see-more");
          if (seeMoreText) seeMoreText.textContent = "See more";
  
          const plusIcon = container.querySelector(".plus-icon");
          const minusIcon = container.querySelector(".minus-icon");
          if (plusIcon && minusIcon) {
            plusIcon.style.display = "block";
            minusIcon.style.display = "none";
          }
        }
      });
    };
  
    let previousTransform = null;
  
    // MutationObserver to detect changes in .slick-track transform
    const observeSlickTrack = () => {
      const slickTrack = document.querySelector('.seasonal-scents-1 .slick-track');
      if (slickTrack) {
        const observer = new MutationObserver(mutations => {
          mutations.forEach(mutation => {
            if (mutation.type === 'attributes' && mutation.attributeName === 'style') {
              const transform = slickTrack.style.transform;
              if (transform) {
                const match = transform.match(/translate3d\(([-\d.]+)px, ([-\d.]+)px, ([-\d.]+)px\)/);
                if (match) {
                  const currentX = parseFloat(match[1]);
                  if (previousTransform !== null) {
                    const previousX = parseFloat(previousTransform[1]);
                    const distanceMoved = Math.abs(currentX - previousX);
                    if (distanceMoved >= 20) {
                      closeAllDetails();
                    }
                  }
                  previousTransform = match;
                }
              }
            }
          });
        });
  
        observer.observe(slickTrack, { attributes: true, attributeFilter: ['style'] });
      }
    };
  
    // Initial call to attach observer if slick-track is already present
    observeSlickTrack();
  
    // MutationObserver to detect when .slick-track is added
    const observer = new MutationObserver(mutations => {
      mutations.forEach(mutation => {
        if (mutation.addedNodes.length) {
          observeSlickTrack();
        }
      });
    });
  
    const config = { childList: true, subtree: true };
    const targetNode = document.querySelector('.seasonal-scents-1');
  
    if (targetNode) {
      observer.observe(targetNode, config);
    }
  });
</script>

