<div class="product-info product-info-2-ab-2 {{ section.settings.class }}">
  <div class="product-info-inner d-flex flex-wrap mx-0 px-0 align-items-center justify-content-between">
    <div class="w-50 d-flex align-items-center justify-content-center">
      <div class="product-container">
        <h1 class="mb-0-5rem value-pro" style="color:{{ section.settings.content_color }};">
          {{ section.settings.section_heading }}
        </h1>
        <div class="product-content-container">
          <div
            class="d-flex align-items-center mb-1-5rem product-review {% if section.settings.scrollto !=''%}click-scroll{% endif %}"
            {% if section.settings.scrollto != '' %}
              data-target="{{ section.settings.scrollto }}"
            {% endif %}
          >
            <img src="{{'review-icon-2.svg' | asset_url}}" width="70px" height="14px" alt="">
            <span class="product-review-title ms-2 value-sans">
              {{- section.settings.reviewtitle -}}
            </span>
          </div>
          <h4 class="product-subheading value-sans">
            {{ section.settings.subheading }}
          </h4>
          <div class="product-blocks-container">
            {% for block in section.blocks %}
              <div class="d-flex align-items-center product-blocks mb-1 value-sans">
                <span class="d-flex align-items-center me-2"
                  ><img src="{{'checkbox-circle-icon-2.svg' | asset_url}}" width="24px" height="24px" alt=""
                ></span>
                <span>{{ block.settings.title }}</span>
              </div>
            {% endfor %}
          </div>
          <div class="product-cta-container w-100">
            {% if section.settings.btnLink %}
              <div class="d-flex flex-column w-100">
                <a
                  href="{{section.settings.btnLink}}"
                  class="buy-btn w-100 value-sans d-inline-block text-center"
                  {% if section.settings.dataTrack %}
                    data-tracked="true"
                    data-page-url="{{ request.path }}"
                    data-target-url="{{ section.settings.targetUrl }}"
                    data-index="{{ section.settings.index }}"
                    data-funnel-stage="{{ section.settings.funnel_stage }}"
                    data-module="{{ section.settings.dataModule }}"
                    data-event-label="{{ section.settings.eventLabel }}"
                    data-event-value="{{ section.settings.eventValue }}"
                    data-item-id="{{ section.settings.itemId }}"
                    data-option-index="{{ section.settings.optionIndex }}"
                    data-item-name="{{ section.settings.ItemName }}"
                  {% endif %}
                >
                  {{ section.settings.btnLabel }}
                </a>

                <a
                  href="{{section.settings.btnLink2}}"
                  class="products-btn all-products w-100 value-sans d-inline-block text-center"
                  {% if section.settings.dataTrack %}
                    data-tracked="true"
                    data-page-url="{{ request.path }}"
                    data-target-url="{{ section.settings.targetUrl2 }}"
                    data-index="{{ section.settings.index }}"
                    data-funnel-stage="{{ section.settings.funnel_stage }}"
                    data-module="{{ section.settings.dataModule }}"
                    data-event-label="{{ section.settings.eventLabel2 }}"
                    data-event-value="{{ section.settings.eventValue2 }}"
                    data-item-id="{{ section.settings.itemId }}"
                    data-option-index="{{ section.settings.optionIndex }}"
                    data-item-name="{{ section.settings.ItemName }}"
                  {% endif %}
                >
                  {{ section.settings.btnLabel2 }}
                </a>
              </div>
            {% else %}
              <button
                class="buy-btn col-12 col-md-10 mb-2 value-sans click-scroll"
                data-target="{{ section.settings.scrollID }}"
                {% if section.settings.dataTrack %}
                  data-tracked="true"
                  data-page-url="{{ request.path }}"
                  data-target-url="{{ section.settings.targetUrl }}"
                  data-index="{{ section.settings.index }}"
                  data-funnel-stage="{{ section.settings.funnel_stage }}"
                  data-module="{{ section.settings.dataModule }}"
                  data-event-label="{{ section.settings.eventLabel }}"
                  data-event-value="{{ section.settings.eventValue }}"
                  data-item-id="{{ section.settings.itemId }}"
                  data-option-index="{{ section.settings.optionIndex }}"
                  data-item-name="{{ section.settings.ItemName }}"
                {% endif %}
              >
                {{ section.settings.btnLabel }}
              </button>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
    <div class="w-100 image-container">
      <!--
        <img class="w-100 vertical-middle" style="max-height: 320px;" src="{{ section.settings.image | img_url: "1900x" }}">
      -->
      <div class="image-bg"></div>
    </div>
  </div>
  <div class="usps d-flex">
    <div class="d-flex justify-content-center column">
      <span class="d-flex align-items-center me-2"
        ><img src="{{'icon-delivery.svg' | asset_url}}" width="21px" height="20px" alt=""
      ></span>
      <span class="ms-2">Free delivery with orders over £40</span>
    </div>
    <div class="d-flex justify-content-center column">
      <span class="d-flex align-items-center me-2"
        ><img src="{{'icon-money.svg' | asset_url}}" width="21px" height="20px" alt=""
      ></span>
      <span class="ms-2">Money Back Guarantee</span>
    </div>
    <div class="d-flex justify-content-center column">
      <span class="d-flex align-items-center me-2"
        ><img src="{{'icon-cube.svg' | asset_url}}" width="21px" height="20px" alt=""
      ></span>
      <span class="ms-2">Eco Packaging</span>
    </div>
  </div>
</div>

{% style %}
  .product-info-2-ab-2 h1 {
    letter-spacing: -0.546px;
    line-height: 50.4px;
  }

  .product-info-2-ab-2 .usps {
    margin-top: 16px;
    margin-bottom: 16px;
    font-size: 12px;
  }

  .product-info-2-ab-2 {
    margin-top: 56px;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
  }

  .product-info-2-ab-2 .product-info-inner {
    padding-left: 112px !important;
    padding-right: 112px !important;
    min-height: 562px !important;
  }

  .product-info-2-ab-2 .product-content-container {
      display: flex;
      flex-wrap: wrap;
      width: 100%;
  }

  .product-info-2-ab-2 .product-review {
    justify-content: left !important;
  }

  .product-info-2-ab-2 .product-blocks-container {
    order: 1;
    margin-bottom: 2rem;
  }

  .product-info-2-ab-2 .product-subheading {
    order: -1;
    margin-bottom: 16px;
  }

  .product-info-2-ab-2 .product-cta-container {
    order: 2;
  }

  .product-info-2-ab-2 .column {
    flex: 1;
    text-align: center;
  }

  .product-info-2-ab-2 .image-container {
    position: absolute;
    left: 0;
    z-index: -1;
    width: 100%;
    margin-top: 32px;
    height: 562px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .product-info-2-ab-2 .image-bg {
    background-image: url('{{ section.settings.image | img_url: "1900x" }}');
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center center;
    width: 100%;
    height: 100%;
  }

  .product-info-2-ab-2 .product-container {
    max-width: 488px;
    background-color: #fff;
    margin-right: auto;
    padding: 32px;
  }

  .product-info-2-ab-2 .product-subheading {
    color: #344054;
    font-size: 24px !important;
    line-height: 30px;
  }

  .product-info-2-ab-2 .product-review-title {
    color: #101828;
    font-size: 16px !important;
  }

  .product-info-2-ab-2 .product-benefit {
    color: #101828;
    font-size: 16px !important;
  }

  .product-info-2-ab-2 .product-blocks span {
    font-size: 16px !important;
  }

  .product-info-2-ab-2 .mb-0-5rem {
    margin-bottom: 0.5rem;
  }

  .product-info-2-ab-2 .mb-1-5rem {
    margin-bottom: 1.5rem;
  }

  .product-info-2-ab-2 .mb-2rem {
    margin-bottom: 2rem;
  }

  .product-info-2-ab-2 .buy-btn {
    margin-right: 1rem;
  }

  .product-info-2-ab-2 .buy-btn:hover {
    background-color: #203271 !important;
  }

  .product-info-2-ab-2 .products-btn {
    display: none;
  }

  .product-info-2-ab-2 .buy-btn, .product-info-2-ab-2 .products-btn {
    height: 100%;
    transition: all .3s ease;
    -webkit-transition: all .3s ease;
    -moz-transition: all .3s ease;
    -ms-transition: all .3s ease;
    -o-transition: all .3s ease;
  }

  .product-info-2-ab-2 .products-btn {
    font-size: 16px;
    padding: 10px;
    color: #101828;
    border-radius: 500px;
    border: 1.5px solid #334FB4;
    background: #FFF;
  }

  @media (max-width: 995px) {
    .product-info-2-ab-2 .product-info-inner {
      padding-left: 32px !important;
      padding-right: 32px !important;
    }

    .product-info-2-ab-2 h1 {
      font-size: 30px !important;
      letter-spacing: -0.39px;
      line-height: 36px;
    }

    .product-info-2-ab-2 .product-subheading {
      font-size: 20px !important;
      line-height: 25px;
    }
  }

  @media (max-width: 768px) {
    .product-info-2-ab-2 .product-info-inner {
      padding-left: 0px !important;
      padding-right: 0px !important;
    }

    .product-info-2-ab-2 .products-btn {
      display: block;
    }

    .product-info-2-ab-2 .d-flex.flex-column {
      flex-direction: column;
    }

    .product-info-2-ab-2 .buy-btn {
      margin-right: 0;
      margin-bottom: 1rem;
    }
  }

  @media (max-width: 768px) {
    .product-info-2-ab-2 {
      position: relative;
      margin-top: 0px;
    }

    .product-info-2-ab-2 .product-review {
      order: -1;
    }

    .product-info-2-ab-2 .product-subheading {
      order: 0;
    }

    .product-info-2-ab-2 .product-cta-container {
      order: 1;
      margin-bottom: 24px;
    }

    .product-info-2-ab-2 .product-blocks-container {
      order: 2;
      margin-bottom: 0px;
    }

    .product-info-2-ab-2 .product-container {
      margin-top: 334px;
      margin-left: 0px;
      margin-right: 0px;
      padding: 16px !important;
    }

    .product-info-2-ab-2 .usps {
      display: none;
    }

    .product-info-2-ab-2 .image-container {
      top: 0px;
      order: -1;
      margin-top: 40px;
      padding: 0px;
      height: 100%;
      flex-shrink: 0;
    }

    .product-info-2-ab-2 .image-bg {
      transform: scale(1.45);
      background-image: url('{{ section.settings.mobile_image | img_url: "1900x" }}');
      background-position: center -75px !important;
    }
  }

  @media (max-width: 413px) {
    .product-info-2-ab-2 .image-bg {
      background-position: 0px -70px !important;
    }
  }

  @media (max-width: 400px) {
    .product-info-2-ab-2 .image-bg {
      background-position: 0px -55px !important;
    }
  }

  @media (max-width: 380px) {
    .product-info-2-ab-2 .image-bg {
      background-position: 0px -40px !important;
    }
  }

  @media (max-width: 350px) {
    .product-info-2-ab-2 .image-bg {
      background-position: 0px -10px !important;
    }
  }

  @media (min-width: 769px) {
    .product-info-2-ab-2 .image-container {
      width: 100%;
      order: 2;
      margin-top: 0;
    }
  }
{% endstyle %}

