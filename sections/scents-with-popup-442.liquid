       color: #212121;
       display: inline-block;
       white-space: nowrap;
       width: auto;
       max-width: fit-content;
   }
   .discoverBtmBtn {
     margin-top: 40px !important;
   }
   .line-break {
     font-family: "GT Super";
   }
  .scent-tag-heading {
  	display: flex;
  	gap: 8px;
  	align-items: center;
  }
  .range-tag-div {
  	height: 24px;
     padding: 2px 4px;
     border-radius: 4px;
     border: solid 1px #F2D4B9;
     display: flex;;
     align-items: center;
  	background: #FBF1E8;
  }
  .range-tag {
  	font-size: 16px;
  	font-weight: 400;
  	color: #212121;
  }
  .scent-tag-link {
  	font-size: 14px;
  	font-weight: 600;
  	color: #11322C;
  	text-decoration: underline;
  	line-height: 21px;
     cursor: pointer
  }

   /* popup css starts here */
   .product-range-optimized {
   	width: 358px;
   	background: #FFFFFF;
   	border-radius: 16px;
   	position: fixed;
     top: 50%;
     right: 0px;
     z-index: 999999;
     transform: translate(200%, -50%);
     transition: transform 300ms ease-in-out, right 300ms ease-in-out;
   	display: flex;
   	flex-direction: column;
   	align-items: flex-start;
  	height: auto;
   	max-height: calc(100vh - 100px);
   }
   .product-range-optimized.scents-easein-open {
     right: 16px;
     transform: translate(0%, -50%);
   }
   .product-range-optimized .scent-blc-wrapper {
     width: 100%;
   }
   .product-range-optimized .scent-blc-inner {
   	display: flex;
   	padding: 0px 8px 24px 8px;
   	flex-direction: column;
   	align-items: flex-end;
   	align-self: stretch;
   }
   .product-range-optimized .scent-blc-top-block {
   	display: flex;
   	padding: 0 8px;
   	flex-direction: column;
   	align-items: center;
   	gap: 12px;
   	align-self: stretch;
   }
   .product-range-optimized .scent-blc-title {
   	display: flex;
   	flex-direction: column;
   	align-items: center;
   	gap: 4px;
   	align-self: stretch;
   }
   .product-range-optimized .scent-blc-title h2 {
   	color: #212121;
   	font-family: "Lausanne";
   	font-size: 20px;
   	font-style: normal;
   	font-weight: 400;
   	line-height: 30px;
   	margin-bottom: unset !important;
   }
   .product-range-optimized .scent-blc-title p {
   	color: #424242;
   	text-align: center;
   	font-family: "Lausanne";
   	font-size: 14px;
   	font-style: normal;
   	font-weight: 200;
   	line-height: 21px;
   	margin-bottom: unset !important;
   }
   .product-range-optimized .scent-blc-blends {
   	display: flex;
   	padding: 24px 16px;
   	flex-direction: column;
   	align-items: flex-start;
   	gap: 16px;
   	align-self: stretch;
   	{% comment %} background: var(--Neutral-50, #FAFAFA); {% endcomment %}
  	height: auto;
  	max-height: calc(45vh - 30px);
  	overflow: auto;
  	border-bottom-right-radius: 16px;
     border-bottom-left-radius: 16px;
   }
   .product-range-optimized .scent-blc-blends h5 {
   	color: #212121;
   	font-family: "Lausanne";
   	font-size: 16px;
   	font-style: normal;
   	font-weight: 400;
   	line-height: 24px;
   }
   .product-range-optimized .scent-blc-blend-content {
   	display: flex;
   	width: 311px;
   	flex-direction: column;
   	align-items: flex-start;
   	gap: 8px;
   }
   .product-range-optimized .scent-blc-blend-content span {
   	color: #424242;
   	font-family: "Lausanne";
   	font-size: 14px;
   	font-style: normal;
   	font-weight: 400;
   	line-height: 21px;
   }
   .product-range-optimized .scent-blc-blend-content ul {
   	margin-top: 0px;
     margin-left: -12px;
   	margin-bottom: unset;
   }
   .product-range-optimized .scent-blc-blend-content ul li,
   .product-range-optimized .scent-blc-blend-content ul li span {
   	color: #424242;
   	font-family: "Lausanne";
   	font-size: 14px;
   	font-style: normal;
   	font-weight: 200;
   	line-height: 21px;
   }
   .product-range-optimized .scent-blc-blend-content ul li span {
   	display: inline-block;
   }
   .product-range-optimized .scent-blc-blend-content ul li:not(:last-child) {
     padding-bottom: 4px;
   }
   .product-range-optimized .scent-blc-close {
     display: flex;
     flex-direction: column;
     align-items: flex-end;
     align-self: flex-end;
   	width: 100%;
   	height: 40px;
   	padding: 4px 6px 4px 0;
     padding-left: calc(100% - 28px);
   }
   .product-range-optimized .scent-blc-close-icon {
     display: flex;
     height: 32px;
     flex-direction: column;
     justify-content: center;
     align-self: stretch;
     color: #212121;
     text-align: center;
     leading-trim: both;
     text-edge: cap;
     font-family: "Font Awesome 6 Pro";
     font-size: 20px;
     font-style: normal;
     font-weight: 300;
     line-height: 30px;
     letter-spacing: -0.4px;
     cursor: pointer;
   }
   .rangebodyoverlay {
     overflow: hidden;
   }
   .rangebodyoverlay::before {
     content: "";
     position: fixed;
     top: 0;
     left: 0;
     width: 100%;
     height: 100%;
     background-color: #000000;
     opacity: 0.25;
     z-index: 999998;
   }
   .product-range-optimized .scent-blc-top-block img {
     border-radius: 4px;
   }
   .product-range-optimized .blue-starterkit-btn {
     font-size: 18px !important;
   }
   .product-range-optimized .blctga {
     position: absolute;
     height: 24px;
     padding: 2px 4px;
     background: #FBF1E8;
     border: solid 1px #F2D4B9;
     border-radius: 4px;
     right: 8px;
     top: 8px;
     display: flex;
     align-items: center;
     font-size: 16px;
     line-height: 20.48px;
   }
   {% if section.settings.class contains 'rg-423' %}
   .product-range-optimized {
     max-height: calc(100vh - 20px);
   }
   .product-range-optimized .blctga {
     background: #c8393c;
     border: solid 1px #c8393c;
     color: #FFFFFF;
   }
   {% endif %}
   .product-range-optimized .scents-blends-tag-img {
     width: 247px;
     height: 247px;
   }
   .product-range-optimized .scents-blends-tag-img img {
     object-fit: cover;
     width: 100%;
     object-position: center center;
   }
   /* popup css ends here */

  .scimage, .scent-tag-heading {
    cursor: pointer;
  }

   @media (min-width: 769px) {
     .trans-scents-desktop {
       display: block;
     }
     .trans-scents-mobile {
       display: none;
     }
   }
   @media (max-width: 768px) {
     .trans-scents-desktop {
       display: none;
     }
     .trans-scents-mobile {
       display: block;
     }
     .common-btn-width {
       width: 100%;
     }
  	.scents-with-popup .trans-scents-mobile p.tss-details {
  		font-size: 14px !important;
       letter-spacing: 0px !important;
       line-height: 21px !important;
  	}
  	.scents-with-popup .tss-mobile-content {
  		gap: 4px;
  		word-wrap: break-word;
  	}
  	.scents-with-popup .tss-mobile-content .tss-details {
  		margin-bottom: unset !important;
  	}
  	.scents-with-popup .tss-mobile-content .scent-tag-heading h3.tss-heading {
  		margin-bottom: unset !important;
  	}
  	.tss-mobile-content .range-tag-div {
  		height: 22px;
  	}
  	.tss-mobile-content .range-tag {
  		font-size: 14px;
  	}
  	.scent-tag-link {
  		font-size: 12px;
  		line-height: 18px;
  	}

     /* popup css starts here - mobile */
     .product-range-optimized {
  		width: calc(100% - 16px);
       margin: 0 auto;
  	}
  	.product-range-optimized.scents-easein-open {
  		right: 8px;
       left: 8px;
  	}
  	.product-range-optimized .scent-blc-title h2 {
  		font-size: 20px;
  		line-height: 30px;
  	}
  	.product-range-optimized .scent-blc-title p {
  		font-size: 14px;
  		line-height: 21px;
  	}
  	.product-range-optimized .scent-blc-blends {
  		max-height: calc(40vh - 30px);
  	}
  	.product-range-optimized .scent-blc-blends h5 {
  		font-size: 16px;
  		line-height: 24px;
  	}
  	.product-range-optimized .scent-blc-blend-content span {
  		font-size: 12px;
  		line-height: 18px;
  		letter-spacing: 0.18px;
  	}
  	.product-range-optimized .scent-blc-blend-content ul li, .scent-blc-blend-content ul li span {
  		font-size: 14px;
  		line-height: 21px;
  	}
  	.product-range-optimized .scent-blc-blend-content {
  		width: 100%;
  	}
     /* popup css ends here - mobile */
  }
</style>

{% assign count = 0 %}
{% for block in section.blocks %}
  {% assign count = count | plus: 1 %}
{% endfor %}
<div id="{{ section.settings.sectionId }}">
  <div
    style="background-color:{{ section.settings.bgcolor }}"
    class="py-80  transformational-scents-section scents-reskins variant_{{ section.settings.linkVariant }} {{ section.settings.class }}"
  >
    <div class="container">
      <div
        {% if count < 2 %}
          class="d-flex align-items-center justify-content-between tss-one-block-wrapper"
        {% endif %}
      >
        <div class="tss-main-header">
          <h2 class="heading-2 text-center font-gtsuper mt-0 " style="color: #0A1E1A !important;">
            {{ section.settings.heading }}
          </h2>
          {% if section.settings.subtext != blank %}
            <p style="color: #424242" class="normal-text font-lausanne fw-200 text-center">
              {{ section.settings.subtext }}
            </p>
          {% endif %}
        </div>
        <!-- DESKTOP VERSION -->
        <div class="mt-4 trans-scents-desktop">
          <div class="transformational-scents-slider {% if count > 2 %}tss-slider{% endif %}">
            {% for block in section.blocks %}
              <div class="tss-block">
                <div class="tss-image position-relative scimage">
                  <picture>
                    {% assign image = block.settings.blockImage %}
                    {% assign mimage = block.settings.mBlockImage %}

                    <source media="(min-width:769px)" srcset="{{ image | image_url: width: 800 }}">
                    <source media="(max-width:768px)" srcset="{{ mimage | image_url: width: 800 }}">
                    <img
                      data-id="{{image.id}}"
                      class="img-responsive w-100 h-auto lazy"
                      src="{{ image | image_url: width: 800 }}"
                      width="400"
                      height="300"
                      alt="{{ image.alt }}"
                    >
                  </picture>
                  {% if block.settings.tag != blank %}
                    <span class="tss-tag font-lausanne">{{ block.settings.tag }}</span>
                  {% endif %}
                </div>
                <div class="tss-content">
                  <div class="scent-tag-heading">
                    <h3 class="tss-heading  font-lausanne fw-400">
                      {{ block.settings.heading }}
                    </h3>
                    {% if block.settings.headingtag != blank %}
                      <div class="range-tag-div">
                        <span class="range-tag">{{ block.settings.headingtag }}</span>
                      </div>
                    {% endif %}
                  </div>
                  <p class="tss-details black-text normal-text font-lausanne fw-200">{{ block.settings.details }}</p>
                  {% if block.settings.linktext != blank %}
                    <span class="scent-tag-link">{{ block.settings.linktext }}</span>
                  {% endif %}
                  {% if block.settings.popup_title != '' %}
                    <div class="prc-dupe" style="display: none;">
                      <div class="scent-blc-wrapper">
                        <div class="scent-blc-close">
                          <div class="scent-blc-close-icon">&times;</div>
                        </div>
                        <div class="scent-blc-inner">
                          <div class="scent-blc-top-block">
                            <div class="scents-blends-tag-img position-relative">
                              <img
                                src="{{ block.settings.dpopup | image_url: width: 800 }}"
                                width="247"
                                height="247"
                                class="mobile-hide"
                              >
                              <img
                                src="{{ block.settings.mpopup | image_url: width: 800 }}"
                                width="247"
                                height="247"
                                class="desktop-hide"
                              >
                              {% if block.settings.headingtag != blank %}
                                <span class="blctga">{{ block.settings.headingtag }}</span>
                              {% endif %}
                            </div>
                            <div class="scent-blc-title">
                              <h2>{{ block.settings.popup_title }}</h2>
                              <p>{{ block.settings.popup_summary }}</p>
                            </div>
                          </div>
                        </div>
                        {% if block.settings.lidetails != blank %}
                        <div class="scent-blc-blends" style="border-top: 1px solid var(--opaque-dark-black-10, rgba(0, 0, 0, 0.10));">
                          <h5>{{ block.settings.popuplabel }}</h5>
                          {% if block.settings.lidetails != blank %}
                            <div class="scent-blc-blend-content">
                              <ul>
                                {{ block.settings.lidetails }}
                              </ul>
                            </div>
                          {% endif %}
                        </div>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
        <!-- END: DESKTOP VERSION -->

        <!-- MOBILE VERSION (NEW STACKED) -->
        <div class="mt-4 trans-scents-mobile">
          <div class="tss-mobile-stack">
            {% for block in section.blocks %}
              <div class="tss-mobile-card d-flex mb-4">
                <div class="tss-mobile-image position-relative scimage">
                  <picture>
                    {% assign image = block.settings.blockImage %}
                    {% assign mimage = block.settings.mBlockImage %}
                    <source media="(min-width:769px)" srcset="{{ image | image_url: width: 800 }}">
                    <source media="(max-width:768px)" srcset="{{ mimage | image_url: width: 800 }}">
                    <img
                      data-id="{{image.id}}"
                      class="img-responsive w-100 h-auto lazy"
                      src="{{ mimage | image_url: width: 800 }}"
                      width="120"
                      height="120"
                      alt="{{ image.alt }}"
                    >
                  </picture>
                  {% if block.settings.tag != blank %}
                    <span class="tss-tag font-lausanne">{{ block.settings.tag }}</span>
                  {% endif %}
                </div>
                <div class="tss-mobile-content flex-grow-1 ps-3">
                  <div class="scent-tag-heading">
                    <h3 class="tss-heading font-lausanne fw-400">{{ block.settings.heading }}</h3>
                    {% if block.settings.headingtag != blank %}
                      <div class="range-tag-div">
                        <span class="range-tag">{{ block.settings.headingtag }}</span>
                      </div>
                    {% endif %}
                  </div>
                  <p class="tss-details black-text normal-text font-lausanne fw-200">
                    {{ block.settings.details }}
                  </p>
                  {% if block.settings.linktext != blank %}
                    <span class="scent-tag-link">{{ block.settings.linktext }}</span>
                  {% endif %}
                  {% if block.settings.popup_title != '' %}
                    <div class="prc-dupe" style="display: none;">
                      <div class="scent-blc-wrapper">
                        <div class="scent-blc-close">
                          <div class="scent-blc-close-icon">&times;</div>
                        </div>
                        <div class="scent-blc-inner">
                          <div class="scent-blc-top-block">
                            <div class="scents-blends-tag-img position-relative">
                              <img
                                src="{{ block.settings.dpopup | image_url: width: 800 }}"
                                width="247"
                                height="247"
                                class="mobile-hide"
                              >
                              <img
                                src="{{ block.settings.mpopup | image_url: width: 800 }}"
                                width="247"
                                height="247"
                                class="desktop-hide"
                              >
                              {% if block.settings.headingtag != blank %}
                                <span class="blctga">{{ block.settings.headingtag }}</span>
                              {% endif %}
                            </div>
                            <div class="scent-blc-title">
                              <h2>{{ block.settings.popup_title }}</h2>
                              <p>{{ block.settings.popup_summary }}</p>
                            </div>
                          </div>
                        </div>
                        <div class="scent-blc-blends">
                          <h5>{{ block.settings.popuplabel }}</h5>
                          {% if block.settings.lidetails != blank %}
                            <div class="scent-blc-blend-content">
                              <ul>
                                {{ block.settings.lidetails }}
                              </ul>
                            </div>
                          {% endif %}
                        </div>
                      </div>
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
        <!-- END: MOBILE VERSION -->
      </div>
    </div>
    {% if section.settings.addScrollBtn %}
      <div class="discoverBtmBtn">
        <span
          class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto common-btn-width"
          data-target="{{ section.settings.scrollto }}"
          data-top="{{ section.settings.top }}"
          {% if section.settings.dataTrack %}
            {% render 'ga4-events' %}
          {% endif %}
        >
          {{- section.settings.btnLabel -}}
        </span>
      </div>
    {% endif %}
  </div>
</div>

<script>
  const mainrangecont = document.querySelector('.scents-with-popup');

  const createprcpopup = document.createElement('div');
  createprcpopup.className = 'product-range-optimized';
  document.body.appendChild(createprcpopup);

  mainrangecont.querySelectorAll('.scent-tag-link').forEach(function (blcbtn) {
    blcbtn.addEventListener('click', function (event) {
      let blccontainer = event.target.nextElementSibling;
      
      document.body.classList.add('rangebodyoverlay');
      blccontainer.classList.add('scents-easein-open');

      document.body.classList.add('rangebodyoverlay');
      document.querySelector('.product-range-optimized').innerHTML = blccontainer.innerHTML;
      document.querySelector('.product-range-optimized').classList.add('scents-easein-open');

      document.querySelector('.product-range-optimized .scent-blc-close-icon').addEventListener('click', bindprclickclose);
    });
  });

  function bindprclickclose(event) {
    resetrangepopup();
  }

  document.addEventListener('click', function (event) {
    const prblendpopup = document.querySelector('.product-range-optimized.scents-easein-open');

    const alltaglinks = document.querySelectorAll('.scent-tag-link');
    const clickedtaglinks = [...alltaglinks].some((trigger) => trigger.contains(event.target));

    const allimagelinks = document.querySelectorAll('.scimage');
    const clickedimagelinks = [...allimagelinks].some((trigger) => trigger.contains(event.target));

    const allheadinglinks = document.querySelectorAll('.scent-tag-heading');
    const clickedheadinglinks = [...allheadinglinks].some((trigger) => trigger.contains(event.target));

    if (prblendpopup && !clickedtaglinks && !clickedimagelinks && !clickedheadinglinks && !prblendpopup.contains(event.target)) {
      resetrangepopup();
    }
  });

  function resetrangepopup() {
    document.body.classList.remove('rangebodyoverlay');
    document.querySelector('.product-range-optimized').classList.remove('scents-easein-open');
    setTimeout(function () {
      document.querySelector('.product-range-optimized').innerHTML = '';
    }, 200);
  }

  document.querySelectorAll('.scimage').forEach(function(spimage) {
    spimage.addEventListener('click', function(event) {
      const elps = event.currentTarget.parentElement.querySelector('.scent-tag-link');
      elps.dispatchEvent(new Event('click', { bubbles: true }));
    });
  });

  document.querySelectorAll('.scent-tag-heading').forEach(function(spheading) {
    spheading.addEventListener('click', function(event) {
      const elps = event.currentTarget.parentElement.querySelector('.scent-tag-link');
      elps.dispatchEvent(new Event('click', { bubbles: true }));
    });
  });
</script>

{% schema %}
{
  "name": "Scents with popup 442",
  "settings": [
    {
      "type": "text",
      "id": "sectionId",
      "label": "Section ID"
    },
    {
      "type": "color",
      "id": "bgcolor",
      "label": "Background color"
    },
    {
      "type": "text",
      "id": "class",
