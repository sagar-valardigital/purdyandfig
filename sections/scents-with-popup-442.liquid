     letter-spacing: 0.015em;
     margin-bottom: 12px;
     padding-top: 0;
     font-style: normal;
     font-weight: 200;
   }
   .tss-mobile-content .tss-mobile-tag {
       font-size: 14px;
       font-weight: 400;
       border-radius: 4px;
       padding: 2px 4px;
       border: 1px solid var(--Secondary-200, #f2d4b9);
       background: var(--Secondary-50, #fbf1e8);
