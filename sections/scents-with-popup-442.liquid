     padding: 0;
   }
   .transformational-scents-slider {
     margin-top: 40px !important;
   }
   .scents-with-popup .tss-image {
     margin-bottom: 16px;
   }
   .scents-with-popup .tss-block .tss-content .tss-heading {
     margin-bottom: 8px !important;
   }
   .tss-tag {
     font-size: 14px;
     font-weight: 400;
     border-radius: 4px;
     right: 16px;
     top: 16px;
     padding: 2px 4px;
     border: 1px solid #F2D4B9;
     background: #FBF1E8;
     line-height: 128%;
     color: #212121;
   }
   .tss-details {
     font-size: 14px;
   }
   .blue-starterkit-btn {
     font-size: 16px;
   }
   .tss-block .tss-details {
     line-height: 1.6 !important;
     margin: 0 !important;
   }
   .tss-mobile-stack {
     width: 100%;
     padding: 0 16px;
   }
   .tss-mobile-card {
     align-items: flex-start;
   }
   .tss-mobile-card:last-child {
     margin-bottom: 0 !important;
   }
   .tss-mobile-image {
     flex-shrink: 0;
     width: 98px;
     height: 98px;
     border-radius: 4px;
     overflow: hidden;
   }
   .tss-mobile-image img {
     width: 100%;
     height: 100%;
     object-fit: cover;
   }
   .tss-mobile-content {
     position: relative;
     display: flex;
     flex-direction: column;
     justify-content: space-between;
   }
   .tss-mobile-content .tss-heading {
