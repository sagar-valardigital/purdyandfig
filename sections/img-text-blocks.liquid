<div class="{{ section.settings.className }}">
  <div
    style="background-color:{{section.settings.background}};"
    class="py-5  image-with-text image-with-text-2"
  >
    <div class="container">
      <div class="section-heading">
      <h2 class="heading-2  {{section.settings.textcolor}}  mt-0 text-center">
        {{ section.settings.heading }}
      </h2>
      <p class="subheading text-center">{{ section.settings.sub_heading }}</p>
      </div>
      {% for block in section.blocks %}
        <div class="d-flex flex-wrap justify-content-between align-items-center img_text_block">
        <div class="w-50 {% if block.settings.layout %} order-2 {%endif%}">
          <div class="two-women">
            {% if block.settings.image %}
              {% assign mImage = block.settings.image | img_url: '800x' %}
              {% assign mmImage = block.settings.mimage | img_url: '800x' %}
              <img
                loading="lazy"
                src="{{mImage}}"
                width="800px"
                height="800px"
                class="img-responsive w-100 h-auto mobile-hide"
                alt="{{ block.settings.image.alt }}"
              >
              <img
                loading="lazy"
                src="{{mmImage}}"
                width="800px"
                height="800px"
                class="img-responsive w-100 h-auto desktop-hide"
                alt="{{ block.settings.mimage.alt }}"
              >
            {% endif %}
          </div>
        </div>
        <div class="w-50  d-flex justify-content-start  text-block-wrap {% if block.settings.layout %} order-1 {%endif%} ">
          <div class="two-women-details  pb-2 ">
            <h2 class="heading-3 value-medium  {{section.settings.textcolor}}">
              {{ block.settings.heading }}
            </h2>
            <div class="normal-text value-sans {{section.settings.textcolor}}">
              {{ block.settings.details }}
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
      <div class="text-center mt-3">
      <a 
        href="javascript:void(0);" 
        class="click-scroll btn green-btn"
        {% if section.settings.dataTrack %}
          {% render 'ga4-events' %}
        {% endif %}
        data-target="{{ section.settings.scrollto }}">
          GET OFFER
      </a>
    </div>
    </div>
    
  </div>
</div>

{% schema %}
  {
    "name": "Img with Text Blocks",
    "settings": [

      {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
      {
      "type": "text",
      "id": "scrollto",
      "label": "Scroll To"
    },
{
            "type": "color",
            "id": "textcolor",
            "label": "Select text color",
            "default": "#3541BF"
          },
{
            "type": "color",
            "id": "background",
            "label": "Select background color",

            "default": "#ffffff"
          },{
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },{
      "type": "html",
      "id": "sub_heading",
      "label": "Sub Heading"
    },
      {
        "type": "header",
        "content": "GA4"
      },
      {
        "id": "dataTrack",
        "label": "Data Track",
        "type": "checkbox"
      },
      {
        "id": "targetUrl",
        "label": "Target Url",
        "type": "url"
      },
      {
        "id": "index",
        "label": "Index",
        "type": "number",
        "default": 0
      },
      {
        "id": "funnel_stage",
        "label": "Funnel Stage",
        "type": "text",
        "default": "landing_page"
      },
      {
        "id": "dataModule",
        "label": "Module",
        "type": "text",
        "default": "announcement_bar"
      },
      {
        "id": "dataTitle",
        "label": "Event Label",
        "type": "text",
        "default": "get_your_offer"
      },
      {
        "id": "eventValue",
        "label": "Event Value",
        "type": "text",
        "default": "shop_anchor"
      },
      {
        "id": "itemId",
        "label": "Item Id",
        "type": "text"
      },
      {
        "id": "optionIndex",
        "label": "Option Index",
        "type": "text"
      },
      {
        "id": "ItemName",
        "label": "Item Name",
        "type": "text"
      }

	],
"blocks": [
      {
        "type": "Image_with_Text",
        "name": "block",
        "settings": [
          
{
            "type": "select",
            "id": "width",
            "label": "Select text area width",
            "options": [
              {
                "value": "w-90",
                "label": "90%"
              },
              {
                "value": "w-80",
                "label": "80%"
              },
{
                "value": "w-70",
                "label": "70%"
              },
              {
                "value": "w-60",
                "label": "60%"
              }
            ],
            "default": "w-80"
          },
{
            "type": "checkbox",
            "id": "layout",
            "label": "Image on right"

          },
{
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
{
      "type": "image_picker",
      "id": "image",
      "label": "Add Desktop Image"
    },
      {
      "type": "image_picker",
      "id": "mimage",
      "label": "Add Mobile Image"
    },

{
      "type": "html",
      "id": "details",
      "label": "Detail Text"
    },
        ]
      }
	],
	"presets": [
		{
			"name": "Img with Text Blocks"
		}
	]
  }
{% endschema %}
