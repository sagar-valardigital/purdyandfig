{% assign product = section.settings.landingproduct %}
{% assign s_variant = product.selected_or_first_available_variant %}
<style>
  {%- assign DimageURL = section.settings.desktopimage | img_url:"1900x" -%}
  {%- assign MimageURL = section.settings.mobileimage | img_url:"768x" -%}
  {%- assign MMimageURL = section.settings.mobileimage | img_url:"500x" -%}
  
  .banner-3{{ section.id }} .banner-inner-container{padding:65px 15px;}
  .banner-3{
    height:656px;
  }
  .banner3-points ul{
    margin:0;
    padding:0;
    list-style:none;
  }
  .banner3-points li.banner3-point{
    background-image:url('https://cdn.shopify.com/s/files/1/0360/1347/3931/files/check-cricle.png?v=1710738687');
    background-repeat:no-repeat;
    padding:5px 0 3px 25px;
    background-size:17px 17px;
    background-position:left 6px;
    font-size:17px
  }
  
  @media(min-width:768px){
    
  .banner-3{{ section.id }}{background-image:url({{DimageURL}});
    background-size:cover;
    background-position:center;
    }
    .banner3-points li.banner3-point{font-size:15px;}
.banner-6-price .heading-1{font-size:3rem}
  }
    @media(max-width:768px){
    .banner-3{{ section.id }} .banner-inner-container{padding:0;}
  .banner-3{{ section.id }}{background-image:url({{MimageURL}});
    background-size:cover;background-position:top right;}
  }
    @media(max-width:560px){
                            .banner-3{{ section.id }}{
    height:680px !important;
  }
    .banner-3 .banner-2-btn{margin:10px 0 !important;}
    .banner-3 .heading-2{
      margin-bottom:0 !important;
      font-size: 29.883px;
      font-weight: 700;
      line-height: 38px; /* 127.163% */
      letter-spacing: -0.8px;
    }
    .banner-6-price .heading-1{font-size:2rem}
    .banner-6-price .heading-2{font-size:1.6rem}
    }
     @media(max-width:400px){
  .banner-3{{ section.id }}{background-image:url({{MMimageURL}})}
  }
</style>

<div
  class="pt-3 position-relative banner-3 banner-3{{ section.id }} {{ section.settings.className }}"
  {% if section.settings.checkout %}
x-data="{qty:1}"
  {% endif %}
>
  <form
              @submit.prevent="console.log('submitted')"
              x-ref="product_form_{{ section.index}}"
              enctype="multipart/form-data"
              accept-charset="UTF-8"
              id="product_form_{{ section.index}}"
              class="shopify-product-form"
              data-product-id="{{product.id}}"
              action="/cart/add"
            >
              <input type="hidden" name="id" class="input_variant_id" value="{{ section.settings.varaiantid }}">
              <input type="hidden" class="discout_input" name="discount" value="{{ section.settings.discount }}">
              <input type="hidden" name="quantity" value="1">
          {% if section.settings.sellingid != blank %}  
                <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
             
          <input
                  class="input_selling_plan"
                  type="hidden"
                  name="selling_plan"
                  value="{{section.settings.sellingid}}"
                >
          {% endif %}
            </form>
  <div class="">
    <div class="banner-inner-container" id="{{ section.settings.scrollid }}">
      <div class="d-flex justify-content-between flex-wrap">
        <div class="lander-banner-details white-bg">
          <h2 class="heading-2 value-bold" style="color:#2D469E">{{ section.settings.title }}</h2>
          <div class="white-text value-sans py-2">
            <h3 class="mt-0 value-medium sub-text" style="color:#434448">{{ section.settings.subtext }}</h3>
          </div>

          <div class="banner3-points">
            <ul>
              {% for block in section.blocks %}
                <li class="banner3-point value-sans">{{ block.settings.text }}</li>
              {% endfor %}
            </ul>
          </div>
          {% if section.settings.price != blank %}
          <div class="banner-6-price pt-2">
            <del class="value-bold heading-2 " style="color:#2D469E">{{ section.settings.crossprice }}</del> &nbsp;&nbsp; <span class="value-bold  heading-1" style="color:#2D469E">{{ section.settings.price }}</span>
          </div>
          {% endif %}
          <div class=" mt-3 banner-2-btn mb-2">
            <a
              {% if section.settings.dataTrack %}
                {% render 'ga4-events' %}
              {% endif %}
              {% if section.settings.scrollto != '' %}
                data-target="{{ section.settings.scrollto }}"
                data-top="{{ section.settings.top }}"
              {% endif -%}
{% if section.settings.checkout %}
              x-on:click="Purdy.CheckoutLanding($refs.product_form_{{ section.index}}, event)"
          {% endif %}
              href="javascript:void(0);"

              class="btn w-100 btn-loader  value-medium checkout-banner-btn {% if section.settings.scrollto !='' %} {% if section.settings.checkout %}{% else %}click-scroll{% endif %}{% endif %} {% if section.settings.outOfStock %} bb-disable {% endif %}"
              style="background-color:#2D469E !important"
            >
              {{ section.settings.btnText -}}</a
            ><br>
          </div>
          <div class="text-center value-medium" style="color:#2D469E">
            {{ section.settings.afterbtntext }}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Banner 6",
  "settings": [
{
    "type": "checkbox",
    "id": "checkout",
    "label": "Enable Checkout",
    "default": false
  },
    {
    "type": "product",
    "id": "landingproduct",
    "label": "Choose product"
  },
    {
    "type": "text",
    "id": "discount",
    "label": "Discount code"
  },
    {
    "type": "text",
    "id": "varaiantid",
    "label": "Variant id"
  },
    {
    "type": "text",
    "id": "sellingid",
    "label": "Selling plan id"
  },
    {
      "id": "className",
      "label": "Section Class",
      "type": "text"
    },
    {
    "type": "text",
    "id": "scrollid",
    "label": "section ID"
  },

    {
      "id": "desktopimage",
      "label": "Desktop Image",
      "type": "image_picker"
    },
	{
      "id": "mobileimage",
      "label": "Mobile Image",
      "type": "image_picker"
    },

	{
      "id": "title",
      "label": "Banner Title",
      "type": "html"
    },

	{
      "id": "subtext",
      "label": "Banner Sub Text",
      "type": "html"
    },
    {
      "id": "price",
      "label": "Sell Price",
      "type": "text"
    },
    {
      "id": "crossprice",
      "label": "Cross Price",
      "type": "text"
    },

{
      "id": "btnText",
      "label": "Button Label",
      "type": "text",
	  "default" : "BUY NOW"
	},
    {
      "id": "afterbtntext",
      "label": "After btn Text",
      "type": "text"
	},

    {
  "id": "scrollto",
  "label":"Scroll to ID",
  "type": "text",
      "default":"javascript:void(0);"
},
    {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
    {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
  ],
"blocks": [
      {
        "type": "text",
        "name": "Points",
        "settings": [
          {
            "type": "text",
            "id": "text",
            "label": "Points"
          }

        ]
      }
	],
  "presets": [
		{
			"name": "Banner 6"
		}
	]
}
{% endschema %}
