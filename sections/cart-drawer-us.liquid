  </style>
  {% for block in section.blocks %}
    {% if block.type == 'product' and block.settings.product != blank %}
      <div id="okendo-widget-{{ block.settings.variant }}" style="display: none;">
        {% render 'okendo-reviews-product-rating-summary', product: block.settings.product %}
      </div>
    {% endif %}
  {% endfor %}

  <!-- Liquid Template Section -->
  <script type="application/json" id="upsellConfig">
    {
      "products": [
        {% assign valid_products = false %}
        {% for block in section.blocks %}
          {% if block.type == 'product' and block.settings.product != blank %}
            {% if valid_products %},{% endif %}
            {
              "product_title": {{ block.settings.product.title | json }},
              "handle": {{ block.settings.product.handle | json }},
              "url": {{ block.settings.product.url | json }},
              "image_url": {{ block.settings.product.featured_image | img_url: '280x200', crop: 'center' | json }},
              {% if block.settings.variant_image %}
              "variant_image": {{ block.settings.variant_image | img_url: '280x200', crop: 'center' | json }},
              {% else %}
                "variant_image" : null,
              {% endif %}
              "variant_id": {{ block.settings.variant | json }},
              {% if block.settings.subscription %}
              "selling_plan_id": {{ block.settings.selling_plan | json }},
              {% endif %}
              "discount": {{ block.settings.discount | json }},
              "price": {{ block.settings.price | json }},
              "compare_price": {{ block.settings.compare_price | json }},
              "button_text": {{ block.settings.button_text | default: 'ADD' | json }},
              "includes": {{ block.settings.product.variants.first.metafields.metadata.includes | default: "" | json }},
              "tags": {{ block.settings.product.tags | json }}
            }
            {% assign valid_products = true %}
          {% endif %}
        {% endfor %}
      ],
      "empty_products": [
        {% assign valid_empty_products = false %}
        {% for block in section.blocks %}
          {% if block.type == 'empty_cart' and block.settings.product != blank %}
            {% if valid_empty_products %},{% endif %}
            {
              "product_title": {{ block.settings.product.title | json }},
              "handle": {{ block.settings.product.handle | json }},
              "url": {{ block.settings.product.url | json }},
              "image_url": {{ block.settings.product.featured_image | img_url: '280x200', crop: 'center' | json }},
              {% if block.settings.variant_image %}
              "variant_image": {{ block.settings.variant_image | img_url: '280x200', crop: 'center' | json }},
              {% else %}
                "variant_image" : null,
              {% endif %}
              "variant_id": {{ block.settings.variant | json }},
              {% if block.settings.subscription %}
              "selling_plan_id": {{ block.settings.selling_plan | json }},
              {% endif %}
              "discount": {{ block.settings.discount | json }},
              "price": {{ block.settings.price | json }},
              "compare_price": {{ block.settings.compare_price | json }},
              "button_text": {{ block.settings.button_text | default: 'ADD' | json }},
              "includes": {{ block.settings.product.variants.first.metafields.metadata.includes | default: "" | json }},
              "tags": {{ block.settings.product.tags | json }}
            }
            {% assign valid_empty_products = true %}
          {% endif %}
        {% endfor %}
      ]
    }
  </script>
  <div class="cart-drawer-wrapper-sections ">
    {% render 'cart-drawer-us', cart_blocks: section.blocks %}
  </div>
  <script>
    /**
     * Utility functions
     */
    const UpsellUtils = {
      // Get upsell configuration from JSON script
      getUpsellConfig() {
        try {
          const configElement = document.getElementById('upsellConfig');
          if (!configElement) {
            console.error('Upsell config not found');
            return { products: [], empty_products: [] };
          }
          return JSON.parse(configElement.textContent);
        } catch (error) {
          console.error('Error parsing upsell config:', error);
          return { products: [], empty_products: [] };
        }
      },

      // Format price display
      formatPrice(price) {
        if (!price) return '';
        return typeof price === 'string' ? price : `$${price}`;
      },

      // Format compare price display
      formatComparePrice(compare_price) {
        if (!compare_price) return '';
        return typeof compare_price === 'string' ? compare_price : `$${compare_price}`;
      },

      // Create product tags HTML
      createTagsHTML(tags) {
        if (!tags || !Array.isArray(tags)) return '';

        return tags
          .filter((tag) => tag.includes('tag:'))
          .map((tag) => `<span class="collection-tag">${tag.split(':')[1]}</span>`)
          .join('');
      },

      // Create form inputs for subscription/one-time purchase
      createPurchaseTypeInputs(product) {
        if (product.selling_plan_id) {
          return `
        <input type="checkbox" name="purchase_type" value="subscription" checked>
        <div class="selling_plan_wrapper d-none">
          <input type="hidden" name="selling_plan" value="${product.selling_plan_id}">
        </div>
      `;
        }
        return '<input type="checkbox" name="purchase_type" value="one-time" checked>';
      },

      // Check if product is already in cart
      isProductInCart(cart, variantId) {
        return cart.items && cart.items.some((item) => item.variant_id === parseInt(variantId));
      },

      // Initialize Okendo widgets with error handling
      initializeOkendoWidgets(products) {
        if (typeof window.okeWidgetApi === 'undefined') {
          console.warn('Okendo widget API not available');
          return;
        }

        setTimeout(() => {
          products.forEach((product) => {
            try {
              const widgetElement = document.querySelector(`[data-oke-widget-${product.variant_id}]`);
              if (widgetElement) {
                window.okeWidgetApi.setProduct(widgetElement, `shopify-${product.variant_id}`);
              }
            } catch (error) {
              console.error(`Error initializing Okendo widget for product ${product.variant_id}:`, error);
            }
          });
        }, 100);
      },
    };

    /**
     * Render empty cart products
     */
    const renderEmptyCartProducts = () => {
  const config = UpsellUtils.getUpsellConfig();
  const emptyUpsells = config.empty_products;

  if (!emptyUpsells || emptyUpsells.length === 0) return '';

  let html = '';

  emptyUpsells.forEach((product) => {
    const formattedPrice = UpsellUtils.formatPrice(product.price);
    const formattedComparePrice = UpsellUtils.formatComparePrice(product.compare_price);
    const safeTitleForJS = product.product_title.replace(/'/g, "\\'");

    html += `
      <div class="cart--upsell show">
        <div class="upsell-product-wrapper upsell-2 ${product.handle}">
          <div class="upsell-product">
            <div class="upsell-product-section">
              <div class="up-product-img">
                <img
                  class="w-100 h-auto"
                  src="${product.variant_image || product.image_url}"
                  alt="${product.product_title}"
                  width="75"
                  height="75"
                  loading="lazy"
                >
              </div>
              <div class="up-add-cart-option">
                <div class="up-top">
                  <div class="up-title">
                    <h4 class="theme-text font-lausanne fw-600">${product.product_title}</h4>
                    <div class="up-price" style="align-items:baseline;">
                      <span class="upsell-price theme-text font-lausanne fw-400" style="font-size:12px;">
                        ${formattedPrice}
                      </span>
                      ${formattedComparePrice ? `
                        &nbsp;
                        <span class="upsell-compare-price theme-text font-lausanne fw-400"
                          style="font-size:10px; text-decoration:line-through; vertical-align:bottom;">
                          ${formattedComparePrice}
                        </span>
                      ` : ''}
                    </div>
                  </div>
                  <form
                    @submit.prevent
                    x-ref="product_form_${product.variant_id}_e"
                    enctype="multipart/form-data"
                    accept-charset="UTF-8"
                    id="product_form_${product.variant_id}_e"
                    class="shopify-product-form"
                    data-product-id="${product.variant_id}"
                    action="/cart/add"
                  >
                    <input type="hidden" name="id" value="${product.variant_id}">
                    <input type="hidden" name="quantity" value="1">
                    <input autocomplete="off" type="hidden" name="discount" value="${product.discount || ''}">
                    ${product.selling_plan_id ? `
                      <input type="hidden" name="selling_plan" value="${product.selling_plan_id}">
                      <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
                    ` : `
                      <input type="checkbox" name="purchase_type" value="one-time" checked class="d-none">
                    `}
                    <button
                      type="button"
                      class="btn green-btn theme-btn btn-loader"
                      x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_${product.variant_id}_e, false, '${safeTitleForJS}', $event)"
                    >
                      ADD
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    `;
  });

  return html;
};

    /**
     * Render upsell products
     */
    const renderUpsells = (cart) => {
      console.log('Cart data:', cart);

      if (!cart || cart.item_count === 0) {
        const emptyContainer = document.querySelector('.empty-cart-products');
        if (emptyContainer) {
          emptyContainer.innerHTML = renderEmptyCartProducts();
        }
        return;
      }

      const upsellContainer = document.querySelector('[data-upsells-container]');
      if (!upsellContainer) {
        console.warn('Upsell container not found');
        return;
      }

      const config = UpsellUtils.getUpsellConfig();
      const upsells = config.products;

      if (!upsells || upsells.length === 0) {
        console.warn('No upsell products configured');
        return;
      }

      // Filter out products already in cart
      const availableUpsells = upsells.filter((upsell) => !UpsellUtils.isProductInCart(cart, upsell.variant_id));

      // Hide upsell heading if no products to show
      const upsellHeading = document.querySelector('.cart-upsell-heading');
      if (availableUpsells.length === 0) {
        if (upsellHeading) {
          upsellHeading.classList.add('d-none');
        }
        upsellContainer.innerHTML = '';
        return;
      }

      // Show upsell heading if products are available
      if (upsellHeading) {
        upsellHeading.classList.remove('d-none');
      }

      let upsellHTML = '<div class="cart--upsell show">';

      availableUpsells.forEach((upsell) => {
        const formattedPrice = UpsellUtils.formatPrice(upsell.price);
        const formattedComparePrice = UpsellUtils.formatPrice(upsell.compare_price);
        const safeTitleForJS = upsell.product_title.replace(/'/g, "\\'");

        upsellHTML += `
      <div class="upsell-product-wrapper upsell-2 ${upsell.handle}">
        <div class="upsell-product">
          <div class="upsell-product-section">
            <div class="up-product-img">
              <img 
                class="w-100" 
                src="${upsell.variant_image || upsell.image_url}" 
                alt="${upsell.product_title}"
                loading="lazy"
              >
            </div>
            <div class="up-add-cart-option">
              <div class="up-top">
                <div class="up-title">
                  <h4 class="theme-text font-lausanne fw-600">${upsell.product_title}</h4>
                  ${
                    upsell.includes
                      ? `
                    <p class="theme-text font-lausanne fw-200 mb-1">
                      Include: ${upsell.includes}
                    </p>
                  `
                      : ''
                  }
                  <div class="up-price" style="align-items: baseline;">
                    <span class="upsell-price theme-text font-lausanne fw-400" style="font-size: 12px;">
                      ${formattedPrice}
                    </span>
                    ${
                      formattedComparePrice
                        ? `
                      &nbsp;
                      <span class="upsell-compare-price theme-text font-lausanne fw-400" 
                            style="font-size: 10px; text-decoration: line-through; vertical-align: bottom;">
                        ${formattedComparePrice}
                      </span>
                    `
                        : ''
                    }
                  </div>
                </div>

                <form 
                  @submit.prevent
                  x-ref="product_form_${upsell.variant_id}"
                  enctype="multipart/form-data"
                  accept-charset="UTF-8"
                  id="product_form_${upsell.variant_id}"
                  class="shopify-product-form"
                  data-product-id="${upsell.variant_id}"
                  action="/cart/add"
                >
                  <input type="hidden" name="id" value="${upsell.variant_id}">
                  <input type="hidden" name="quantity" value="1">
                  ${
                    upsell.discount
                      ? `
                    <input type="hidden" name="discount" value="${upsell.discount}">
                  `
                      : ''
                  }
                  ${
                    upsell.selling_plan_id
                      ? `
                    <input type="hidden" name="selling_plan" value="${upsell.selling_plan_id}">
                    <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
                  `
                      : ''
                  }

                  <button 
                    type="button"
                    class="btn green-btn theme-btn btn-loader"
                    x-on:click="typeof Purdy !== 'undefined' && Purdy.AddToCartWithDiscount ? Purdy.AddToCartWithDiscount($refs.product_form_${
                      upsell.variant_id
                    }, false, '${safeTitleForJS}', $event) : console.error('Purdy.AddToCartWithDiscount not available')"
                    aria-label="Add ${upsell.product_title} to cart"
                  >
                    ADD
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    `;
      });

      upsellHTML += '</div>';
      upsellContainer.innerHTML = upsellHTML;
    };

    // Export functions for global access (if needed)
    window.UpsellModule = {
      renderUpsells,
      renderEmptyCartProducts,
      getUpsellConfig: UpsellUtils.getUpsellConfig,
    };
  </script>

