<style>
  .video-container-pf313 {
    padding: 80px 112px;
  }
  .video-container-pf313 .video-box-313 {
    display: flex;
    align-items: center;
    align-self: stretch;
    gap: 32px;
    width: 100%;
    max-width: 1216px;
    margin: auto;
    justify-content: center;
  }
  .video-container-pf313 .video-item {
    order: 2;
    width: 57.237%;
    flex-shrink: 1;
  }
  .video-container-pf313 .video-text-box {
    order: 1;
    width: 40.132%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    flex-shrink: 1;
  }
  .video-container-pf313 .video-heading,
  .video-container-pf313 .video-subheading {
    max-width: 416px;
  }
  .video-container-pf313 .video-heading {
    font-size: 40px;
    font-style: normal;
    font-weight: 400;
    line-height: 50px;
    font-family: "GT Super";
  }
  .video-container-pf313 .video-subheading {
    font-size: 18px;
    font-style: normal;
    font-weight: 200;
    line-height: 27px;
    font-family: "Lausanne";
  }
  @media (max-width: 767px) {
    .video-container-pf313 {
      padding: 32px 16px;
    }
    .video-container-pf313 .video-box-313 {
      width: 100%;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      gap: 16px;
    }
    .video-container-pf313 .video-item {
      width: 100%;
    }
    .video-container-pf313 .video-heading,
    .video-container-pf313 .video-subheading {
      max-width: 343px;
    }
    .video-container-pf313 .video-heading {
      font-size: 32px;
      font-style: normal;
      font-weight: 400;
      line-height: 40px;
    }
    .video-container-pf313 .video-subheading {
      font-size: 16px;
      font-style: normal;
      font-weight: 200;
      line-height: 24px;
    }
    .video-container-pf313 .video-subheading,
    .video-container-pf313 .shop-now-cta {
      margin-top: 16px !important;
    }
  }
</style>

<div
  class="{{ section.settings.className }} video-container-pf313"
  style="background-color: {{section.settings.background}};"
>
  <div class="video-box-313">
    <div class="video-item">
      {% if section.settings.image %}
        {% assign mimage = section.settings.image | image_url: width: 800 %}
        <video
          class="w-100 h-100"
          width="320"
          height="240"
          autoplay
          muted
          loop
          playsinline
          poster="{{ mimage }}"
        >
          <source src="{{ section.settings.video }}" type="video/mp4">
        </video>
      {% endif %}
      <div class="desktop-hide">
        <div class="video-subheading font-lausanne fw-200 " style="color: {{section.settings.subtextcolor}};">
          {{ section.settings.details }}
        </div>
        {% if section.settings.shop_now_cta != '' %}
          <span
            class="shop-now-cta btn click-scroll"
            data-target="{{ section.settings.scrollto }}"
            data-top="{{ section.settings.top }}"
            {% if section.settings.dataTrack %}
              data-tracked="true"
              data-page-url="{{ request.path }}"
              data-target-url="{{ section.settings.targetUrl }}"
              data-index="{{ section.settings.index }}"
              data-funnel-stage="{{ section.settings.funnel_stage }}"
              data-module="{{ section.settings.dataModule }}"
              data-event-label="{{ section.settings.dataTitle }}"
              data-event-value="{{ section.settings.eventValue }}"
              data-item-id="{{ section.settings.itemId }}"
              data-option-index="{{ section.settings.optionIndex }}"
              data-item-name="{{ section.settings.ItemName }}"
            {% endif %}
            style="background: {{ section.settings.btn-bg }} !important; color: {{ section.settings.btn-text }} !important;"
          >
            {{ section.settings.shop_now_cta }}
          </span>
        {% endif %}
      </div>
    </div>
    <div class="video-text-box">
      <div class="text-video">
        <h2 class="video-heading" style="color: {{section.settings.textcolor}};">
          {{ section.settings.heading }}
        </h2>
        <div class="video-subheading mobile-hide" style="color: {{section.settings.subtextcolor}};">
          {{ section.settings.details }}
        </div>
      </div>
      {% if section.settings.shop_now_cta != '' %}
        <span
          class="shop-now-cta btn click-scroll mobile-hide videoctabtn"
          data-target="{{ section.settings.scrollto }}"
          data-top="{{ section.settings.top }}"
          {% if section.settings.dataTrack %}
            data-tracked="true"
            data-page-url="{{ request.path }}"
            data-target-url="{{ section.settings.targetUrl }}"
            data-index="{{ section.settings.index }}"
            data-funnel-stage="{{ section.settings.funnel_stage }}"
            data-module="{{ section.settings.dataModule }}"
            data-event-label="{{ section.settings.dataTitle }}"
            data-event-value="{{ section.settings.eventValue }}"
            data-item-id="{{ section.settings.itemId }}"
            data-option-index="{{ section.settings.optionIndex }}"
            data-item-name="{{ section.settings.ItemName }}"
          {% endif %}
          style="background: {{ section.settings.btn-bg }} !important; color: {{ section.settings.btn-text }} !important;"
        >
          {{ section.settings.shop_now_cta }}
        </span>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Video with Text 313",
  "settings": [
    {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
    {
      "type": "color",
      "id": "textcolor",
      "label": "Select heading color"
    },
    {
      "type": "color",
      "id": "subtextcolor",
      "label": "Select subheading color"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Select background color",
      "default": "#ffffff"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Poster"
    },
    {
      "type": "url",
      "id": "video",
      "label": "Video Link"
    },
    {
      "type": "html",
      "id": "details",
      "label": "Detail Text"
    },
    {
      "type": "color",
      "id": "btn-bg",
      "label": "Button background"
    },
    {
      "type": "color",
      "id": "btn-text",
      "label": "Button text color"
    },
    {
      "type": "text",
      "id": "shop_now_cta",
      "label": "Button Label"
    },
    {
      "type": "text",
      "id": "scrollto",
      "label": "Scroll link"
    },
    {
      "type": "number",
      "id": "top",
      "label": "Scroll to position"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label":"Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label":"Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label":"Index",
      "type": "number",
      "default" : 0
    },
    {
      "id": "funnel_stage",
      "label":"Funnel Stage",
      "type": "text",
      "default" : "landing_page"
    },
    {
      "id": "dataModule",
      "label":"Module",
      "type": "text",
      "default" : "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label":"Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label":"Event Value",
      "type": "text",
      "default" : "shop_anchor"
    },
    {
      "id": "itemId",
      "label":"Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label":"Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label":"Item Name",
      "type": "text"
    }
 ],
 "presets": [
 	{
 		"name": "Video With Text 313"
 	}
 ]
}
{% endschema %}
