    </div>
  </div>
</section>

{% if section.settings.enable_swipe == true %}
<script>
  if (window.innerWidth < 768) {
    const swipeinterval = setInterval(enableswipeonbanner, 300);

    function enableswipeonbanner() {
      slickInstance423 = $('.banner-slider-343').slick('getSlick');

      if(slickInstance423) {
        slickInstance423.options.swipe = true;
        clearInterval(swipeinterval);

        console.log('Banner swipe interval cleared.');
      }
    }
  }
</script>
{% endif %}

{% schema %}
{
  "name": "Banner 462",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_swipe",
      "label": "Enable swipe - Mobile"
    },
    {
      "type": "color",
      "label": " BG Colour",
      "id": "bg",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "label": "Text Colour",
      "id": "txt-color",
      "default": "#ffffff"
    },

    {
      "type": "html",
      "label": "Heading",
      "id": "heading"
    },
    {
      "type": "html",
      "label": "Sub Heading",
      "id": "sub_heading"
    },
    {
      "type": "color",
      "label": "Sub Heading Color",
      "id": "sub_heading_color",
      "default": "#212121"
    },
    {
      "type": "color",
      "label": "Button BG Colour",
      "id": "btn-bg",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "label": "Button Text Colour",
      "id": "btn-txt-color",
      "default": "#11322C"
    },
    {
      "type": "html",
      "label": "Button label",
      "id": "button_label"
    },
    {
      "type": "text",
      "label": "Button Link",
      "id": "button_link"
    },
    {
      "type": "text",
      "id": "top",
      "label": "Scroll to Position"
    },
    {
      "type": "checkbox",
      "label": "Show Reviews",
      "id": "showreview",
      "default": true
    },
    {
      "type": "color",
      "label": "Review star color",
      "id": "star_color"
    },
    {
      "type": "color",
      "label": "Review text color",
      "id": "star_text_color"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "landing_page"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "itemId",
      "label": "Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label": "Item Name",
      "type": "text"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "label": "Desktop Image",
          "id": "desktop_img"
        },
        {
          "type": "image_picker",
          "label": "Mobile Image",
          "id": "mobile_img"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner 462",
      "category": "Banner Slider"
    }
  ]
}
{% endschema %}
