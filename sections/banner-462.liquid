<style>
  @font-face {
    font-family: 'SloopScriptPro';
    src: url('https://cdn.shopify.com/s/files/1/0360/1347/3931/files/SloopScriptPro-Regular.otf?v=1760762258') format('opentype');
    font-weight: normal;
    font-style: normal;
  }
  .banner-section-wrapper{
    background-color:{{section.settings.bg}};
    padding-bottom:0px;
  }
  #body .banner-341-content{
    width:1000px;
    max-width:calc(100% - 30px);
    margin:-110px auto 0px;
    padding:40px 20px;
    background-color:#ffffff;
    position:relative;
    z-index:99;
  }
  .sloppitalic {
    font-family: 'SloopScriptPro' !important;
    font-size: 72px;
    font-style: normal;
    font-weight: 400;
    line-height: 100%;
    margin-right: 5px;
  }
  .banner-290-reviews {
    display: grid;
    justify-content: center;
    margin-top: 15px;
  }
  .star-img {
    width: 16px;
  }
  .show-star-flex {
    display: flex;
    align-items: center;
  }
  .customers-reviews {
    font-size: 16px;
  }
  #body .banner-341-content .banner-sub-heading{
    font-size:16px;
    color:#424242;
    font-weight:200;
  }
  @media(max-width:768px){
    .star-img {
      width: 14px;
    }
    .customers-reviews {
        font-size: 14px;
    }
    #body .banner-341-content{
      margin:-110px auto 0px;
    }
    #body .banner-341-content{
      padding:16px;
    }
    #body .banner-341-content .banner-heading{
      font-size:32px !important;
    }
    #body .banner-341-content .banner-sub-heading{
      font-size:14px;
      font-weight:200;
    }
    .sloppitalic {
      font-size: 52px;
    }
  }

  /* Sets the color for the current, active dot */
  .slick-dots li.slick-active button::before {
    color: #11322c; /* A dark green for the active dot */
    opacity: 1;
  }
  .banner-slider-343 .slick-dots li.slick-active button:before {
    color: #11322c;
  }
  .banner-slider-343:not(.slick-initialized){
    min-height:400px;
  }
  .banner-slider-343:not(.slick-initialized) picture:not(:first-child) img{
    display:none;
  }
  {% if section.blocks.size < 2  %}
  .banner-section-wrapper .section_{{ section.id }} .slick-dots{
    opacity:0 !important;
  }
  {% endif %}

.custom-button,
.common-btn-width,
.blue-starterkit-btn,
.banner-10-btn {
  font-size: 18px !important;
}
</style>

<section class="banner-section-wrapper  position-relative ">
  <div class="banner-section banner-slider-343 section_{{ section.id }}">
    {% for block in section.blocks %}
      <picture>
        <source media="(min-width:769px)" srcset="{{ block.settings.desktop_img | image_url: width: 3200 }}">
        <source media="(max-width:768px)" srcset="{{ block.settings.mobile_img | image_url: width: 1200 }}">
        <img class="w-100 h-auto" src="{{ block.settings.desktop_img | image_url: width: 1800 }}" alt="banner" width="1400" height="600">
      </picture>
    {% endfor %}
  </div>
  <div class="banner-10-content banner-341-content">
    <div class="text-center">
      <h2 class="banner-heading heading-1 font-gtsuper" style="color:{{ section.settings.txt-color }} !important">
        {{ section.settings.heading }}
      </h2>
      <p class="banner-sub-heading font-lausanne fw-200" style="color:{{section.settings.sub_heading_color}} !important">
        {{ section.settings.sub_heading }}
      </p>
      {% if section.settings.button_link != blank %}
        <a
          {% if section.settings.dataTrack %}
            {% render 'ga4-events' %}
          {% endif %}
          href="javascript:void(0);"
          class="click-scroll btn banner-10-btn"
          style="background-color:{{ section.settings.btn-bg }}; color:{{ section.settings.btn-txt-color }}"
          data-top="{{ section.settings.top }}"
          data-target="{{ section.settings.button_link }}"
        >
          {{- section.settings.button_label -}}
        </a>
      {% endif %}
      {% if section.settings.showreview %}
        <div class="banner-10-reviews">
          <div class="reviews-images">
            <img
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Avatar.png?v=1721733107"
              style="width:144px; height:auto;"
              width=""
              height=""
            >
          </div>
          <div class="text-left">
            <div class="font-pier theme-text mt-0 stars-img-review">
              <span class="star-img">
