<style>

.tss-block .tss-details {
  line-height: 1.6 !important;
  margin: 0 !important;
}
  
.tss-mobile-stack {
  width: 100%;
  padding: 0 16px;
}

.tss-mobile-card {
  align-items: flex-start;
}

.tss-mobile-card:last-child {
  margin-bottom: 0 !important;
}
  
.tss-mobile-image {
  flex-shrink: 0;
  width: 98px;
  height: 98px;
  border-radius: 4px;
  overflow: hidden;
}

.tss-mobile-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.tss-mobile-content {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.tss-mobile-content .tss-heading {
  font-size: 16px;
  font-weight: 400;
  line-height: 1.5;
  margin-bottom: 4px !important;
  padding-top: 0;
  padding-bottom: 0;
  border-bottom: none;
  color: #212121;
}

.tss-mobile-content .tss-details {
  font-size: 12px !important;
  color: #212121;
  line-height: 1.6 !important;
  letter-spacing: 0.015em;
  margin-bottom: 12px;
  padding-top: 0;
  font-style: normal;
  font-weight: 200;
}

.tss-mobile-content .tss-mobile-tag {
    font-size: 14px;
    font-weight: 400;
    border-radius: 4px;
    padding: 2px 4px;
    border: 1px solid var(--Secondary-200, #f2d4b9);
    background: var(--Secondary-50, #fbf1e8);
    line-height: 128%;
    color: #212121;
    display: inline-block;
    white-space: nowrap;
    width: auto;
    max-width: fit-content;
}

.heading-2 {
  letter-spacing: 0px;
  color: #212121 !important;
}
.pf388-kit .tss-tag {
  font-size: 14px;
  font-weight: 400;
  border-radius: 4px;
  right: 8px;
  top: 8px;
  padding: 2px 4px;
  border: 1px solid var(--Secondary-200, #f2d4b9);
  background: var(--Secondary-50, #fbf1e8);
  line-height: 128%;
  color: #212121;
}
.tss-details {
  font-size: 14px;
}

.pf388-scents .tss-block {
  padding: 15px 16px 0px 16px !important;
}

.pf388-kit .tss-heading {
    font-size: 18px !important;
}

.pf388-scents .blue-starterkit-btn {
  margin-top: 40px !important;
  font-family: 'Lausanne';
  font-size: 16px;
    border: 0;
    font-weight: 400;
    border-radius: 4px;
    color: #fff;
    padding: 10px 15px;
}

/* Popup functionality for pf388-kit */
.pf388-kit .pf388-popup-detail-icon {
  position: absolute;
  color: #FFFFFF;
  background-color: #ffffff33;
  width: 24px;
  height: 24px;
  border: solid 1px #FFFFFF;
  border-radius: 50%;
  text-align: center;
  font-family: "Lausanne";
  font-size: 16px;
  font-style: normal;
  font-weight: 400;
  line-height: 150%;
  bottom: 8px;
  right: 8px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.pf388-popup-wrapper {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  transition: all 0.3s ease;
  z-index: 9999999;
}

.pf388-popup-wrapper.display-none {
  right: -100vw;
}

.pf388-popup-overlay {
  display: block;
  width: 100%;
  height: 100%;
  background-color: #ffffff20;
  backdrop-filter: blur(2px);
}

.pf388-detail-popup {
  width: 360px;
  max-width: calc(100% - 30px);
  height: auto;
  position: absolute;
  right: 15px;
  top: 15px;
  background-color: #fff;
  border-radius: 16px;
  box-shadow: 0 0 4px #ccc;
  overflow: hidden;
}

.pf388-close-icon {
  display: flex;
  height: 32px;
  flex-direction: column;
  justify-content: center;
  align-self: stretch;
  color: #212121;
  font-size: 24px;
  font-weight: 300;
  line-height: 150%;
  align-items: flex-end;
  cursor: pointer;
  padding: 0 5px;
}

.pf388-inner-block-content {
  display: flex;
  padding: 8px 0px 12px 0px;
  justify-content: flex-end;
  align-items: flex-start;
  align-self: stretch;
  flex-direction: column;
}

.pf388-above-content {
  display: flex;
  padding: 0px 8px 24px 8px;
  flex-direction: column;
  align-items: center;
  gap: 0;
  flex: 1 0 0;
}

.pf388-popup-image {
  display: flex;
  width: 240px;
  flex-direction: column;
  align-items: flex-end;
  position: relative;
}

.pf388-popup-title {
  color: #212121;
  text-align: center;
  font-family: "Lausanne";
  font-size: 24px;
  font-style: normal;
  font-weight: 400;
  line-height: 150%;
  padding: 0;
  margin-bottom: 4px;
}

.pf388-popup-summary {
  color: #424242;
  text-align: center;
  font-family: "Lausanne" !important;
  font-size: 14px !important;
  font-style: normal;
  font-weight: 200;
  line-height: 160%;
  padding: 0 10px;
  margin-bottom: 12px;
}

.pf388-popup-details {
  display: flex;
  padding: 24px 16px 0px;
  flex-direction: column;
  align-items: flex-start;
  align-self: stretch;
  border-radius: 0px 0px 16px 16px;
  border-top: 1px solid rgba(0, 0, 0, 0.10);
}

.pf388-popup-details h3 {
  color: #212121;
  font-family: "Lausanne" !important;
  font-size: 16px;
  font-style: normal;
  font-weight: 400;
  line-height: 150%;
}

.pf388-popup-desc p {
  color: #424242;
  font-family: "Lausanne";
  font-size: 14px;
  font-style: normal;
  font-weight: 200;
  line-height: 160%;
}

.pf388-popup-saving-tag {
  position: absolute;
  top: 8px;
  right: 8px;
  color: #212121;
  background-color: #FBF1E8;
  padding: 2px 4px;
  border: solid 1px #F2D4B9;
  border-radius: 4px;
  font-size: 14px;
  font-style: normal;
  font-weight: 400;
  line-height: 128%;
}

  @media (min-width: 769px) {
  .trans-scents-desktop {
    display: block;
  }
  .trans-scents-mobile {
    display: none;
  }
}
  
  @media (max-width: 768px) {
  .pf388-kit .tss-mobile-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    width: 100%;
    padding: 0 16px;
  }

  .pf388-kit .tss-mobile-card {
    flex: 0 0 calc(50% - 8px);
    max-width: calc(50% - 8px);
    margin-bottom: 0 !important;
    flex-direction: column;
    align-items: stretch;
  }

 .pf388-kit .tss-heading {
    font-size: 14px !important;
}
  
  .pf388-kit .tss-mobile-image {
    position: relative;
    width: 100%;
    height: auto;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 12px;
  }
  
  .pf388-kit .tss-mobile-image .tss-mobile-tag {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 14px;
    font-weight: 400;
    border-radius: 4px;
    padding: 2px 4px;
    border: 1px solid var(--Secondary-200, #f2d4b9);
    background: var(--Secondary-50, #fbf1e8);
    line-height: 128%;
    color: #212121;
    display: inline-block;
    white-space: nowrap;
    z-index: 2;
  }
  
  .pf388-kit .tss-mobile-content {
    padding-left: 0 !important;
  }

  .common-btn-width {
    width: 100%;
}

.pf388-scents .blue-starterkit-btn {
    margin-top: 24px !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    max-width: 100% !important;
    width: 100%;
}

.pf388-popup-image {
  display: flex;
  width: 171px;
}

  .pf388-popup-title {
    font-size: 20px;
    padding-left: 20px;
    padding-right: 20px;
  }
  .pf388-popup-summary,
  .pf388-popup-desc {
    font-size: 14px;
  }
  .pf388-popup-summary {
    padding: 5px 20px;
  }
  .pf388-popup-details h3 {
    font-size: 16px;
    margin-bottom: 0 !important;
  }
  .pf388-detail-popup {
    width: 100%;
  }

}
  
</style>


{% assign count = 0 %}
{% for block in section.blocks %}
  {% assign count = count | plus: 1 %}
{% endfor %}
<div id="{{ section.settings.sectionId }}">
  <div
    style="background-color:{{ section.settings.bgcolor }}"
    class="py-80  pf388-kit transformational-scents-section scents-reskins variant_{{ section.settings.linkVariant }} {{ section.settings.class }}"
  >
    <div class="container">
      <div
        {% if count < 2 %}
          class="d-flex align-items-center justify-content-between tss-one-block-wrapper"
        {% endif %}
      >
        <div class="tss-main-header">
          <h2 class="heading-2 text-center white-text font-gtsuper mt-0 ">{{ section.settings.heading }}</h2>
{% if section.settings.subtext != blank %}          
<p style="color: #424242" class="normal-text font-lausanne fw-200 text-center">
            {{ section.settings.subtext }}
          </p>
  {% endif %}
        </div>
        <!-- DESKTOP VERSION -->
        <div class="mt-4 trans-scents-desktop">
          <div class="transformational-scents-slider {% if count > 2 %}tss-slider{% endif %}">
            {% for block in section.blocks %}
              <div class="tss-block">
                <div class="tss-image position-relative">
                  <picture>
                    {% assign image = block.settings.blockImage %}
                    {% assign mimage = block.settings.mBlockImage %}

                    <source media="(min-width:769px)" srcset="{{ image | img_url: 'master'}}">
                    <source media="(max-width:768px)" srcset="{{ mimage | img_url: 'master' }}">
                    <img
                      data-id="{{image.id}}"
                      class="img-responsive w-100 h-auto lazy"
                      src="{{ image | img_url: 'master'}}"
                      width="400"
                      height="300"
                      alt="{{ image.alt }}"
                    >
                  </picture>
                  {% if block.settings.tag != blank %}
                    <span class="tss-tag font-lausanne">{{ block.settings.tag }}</span>
                  {% endif %}
            {% if block.settings.popup_summary != blank %}
  <span class="pf388-popup-detail-icon" 
    data-id="{{ forloop.index }}"
    data-title="{{ block.settings.popup_title }}"
    data-summary="{{ block.settings.popup_summary }}"
    data-details="{{ block.settings.popup_details }}"
    data-image="{{ image | image_url: width: 1600 }}"
    data-tag="{{ block.settings.tag }}"
  >i</span>
{% endif %}
                </div>
                <div class="tss-content">
                  <h3 class="tss-heading  font-lausanne fw-400">{{ block.settings.heading }}</h3>
                  <p class="tss-details black-text normal-text font-lausanne fw-200">{{ block.settings.details }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
        <!-- END: DESKTOP VERSION -->

        <!-- MOBILE VERSION (NEW STACKED) -->

<div class="mt-4 trans-scents-mobile">
  <div class="tss-mobile-stack">
    {% for block in section.blocks %}
      <div class="tss-mobile-card d-flex mb-4">
        <div class="tss-mobile-image">
  <picture>
    {% assign image = block.settings.blockImage %}
    {% assign mimage = block.settings.mBlockImage %}
    <source media="(min-width:769px)" srcset="{{ image | img_url: 'master'}}">
    <source media="(max-width:768px)" srcset="{{ mimage | img_url: 'master' }}">
    <img
      data-id="{{image.id}}"
      class="img-responsive w-100 h-auto lazy"
      src="{{ mimage | img_url: 'master'}}"
      width="120"
      height="120"
      alt="{{ image.alt }}"
    >
  </picture>
  {% if block.settings.tag != blank %}
    <div class="tss-mobile-tag font-lausanne">{{ block.settings.tag }}</div>
  {% endif %}
  
  <!-- Add popup trigger -->
  {% if block.settings.popup_summary != blank %}
  <span class="pf388-popup-detail-icon" 
    data-id="{{ forloop.index }}"
    data-title="{{ block.settings.popup_title }}"
    data-summary="{{ block.settings.popup_summary | default: block.settings.details }}"
    data-details="{{ block.settings.popup_details }}"
    data-image="{{ mimage | image_url: width: 1600 }}"
    data-tag="{{ block.settings.tag }}"
  >i</span>
  {% endif %}
</div>

        <div class="tss-mobile-content flex-grow-1 ps-3">
          <h3 class="tss-heading font-lausanne fw-400 mb-2">{{ block.settings.headingMobile }}</h3>
          <p class="tss-details black-text normal-text font-lausanne fw-200 mb-2">{{ block.settings.details }}</p>
        </div>
      </div>
    {% endfor %}
  </div>
</div>


        <!-- END: MOBILE VERSION -->
      </div>
    </div>
           {% if section.settings.addScrollBtn %}
    <div class="discoverBtmBtn">
      <span
          class="d-block text-center blue-starterkit-btn click-scroll m-auto common-btn-width"
          style="background-color: {{ section.settings.btn-color }}"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >{{ section.settings.btnLabel }}</span
      >
    </div>
    {% endif %}
  </div>

<!-- Popup functionality for pf388-kit -->
<div class="pf388-popup-wrapper display-none">
  <div class="pf388-popup-overlay"></div>
  <div class="pf388-detail-popup">
    <div class="pf388-inner-block-content">
      <div class="pf388-above-content">
        <div class="pf388-close-icon">✕</div>
        <h3 class="pf388-popup-title font-lausanne"></h3>
        <p class="pf388-popup-summary font-lausanne"></p>
        <div class="pf388-popup-image">
          <img src="" alt="" class="img-responsive w-100 h-auto">
          <span class="pf388-popup-saving-tag display-none font-lausanne"></span>
        </div>
      </div>
      <div class="pf388-popup-details">
        <div class="pf388-popup-desc font-lausanne"></div>
      </div>
    </div>
  </div>
</div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const pf388dtIcon = document.querySelectorAll('.pf388-popup-detail-icon');
  const pf388dtCloseIcon = document.querySelectorAll('.pf388-close-icon');

  pf388dtIcon.forEach(icon => {
    icon.addEventListener('click', (e) => {
      e.stopPropagation();
      
      // Clear previous content
      document.querySelector('.pf388-popup-title').innerHTML = '';
      document.querySelector('.pf388-popup-summary').innerHTML = '';
      document.querySelector('.pf388-popup-desc').innerHTML = '';
      document.querySelector('.pf388-popup-image img').setAttribute('src', '');
      document.querySelector('.pf388-popup-saving-tag').classList.add('display-none');
      
      // Set new content
      document.querySelector('.pf388-popup-title').innerHTML = icon.getAttribute('data-title');
      document.querySelector('.pf388-popup-summary').innerHTML = icon.getAttribute('data-summary');
      document.querySelector('.pf388-popup-desc').innerHTML = icon.getAttribute('data-details');
      document.querySelector('.pf388-popup-image img').setAttribute('src', icon.getAttribute('data-image'));
      document.querySelector('.pf388-popup-saving-tag').innerHTML = icon.getAttribute('data-tag');
      
      if(icon.getAttribute('data-tag')) {
        document.querySelector('.pf388-popup-saving-tag').classList.remove('display-none');
      }
      
      document.body.style.overflow = 'hidden';
      
      const popupBlock = document.querySelector('.pf388-popup-wrapper');
      if(popupBlock) {
        popupBlock.classList.remove('display-none');
      }
    });
  });

  pf388dtCloseIcon.forEach(closeIcon => {
    closeIcon.addEventListener('click', (e) => {
      e.stopPropagation();
      
      document.body.style.overflow = '';
      
      let closeWrapper = closeIcon.closest('.pf388-popup-wrapper');
      if (closeWrapper) {
        closeWrapper.classList.add('display-none');
      }
    });
  });

  const pf388popupWrapper = document.querySelector('.pf388-popup-wrapper');
  const pf388popupContent = document.querySelector('.pf388-detail-popup');
  
  // Close when clicking outside popup content
  if (pf388popupWrapper && pf388popupContent) {
    pf388popupWrapper.addEventListener('click', function (e) {
      if (!pf388popupContent.contains(e.target)) {
        pf388popupWrapper.classList.add('display-none');
        document.body.style.overflow = '';
      }
    });
  }
});
</script>

