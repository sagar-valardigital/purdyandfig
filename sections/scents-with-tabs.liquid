{% liquid
  assign tabs = section.settings.tabs
  assign class = section.settings.class
  assign plus = section.settings.plus
  assign style = section.settings.style
  assign button_label = section.settings.button_label
  assign button_color = section.settings.button_color
  assign button_bg = section.settings.button_bg
  assign button_target = section.settings.button_target
  assign background = section.settings.background
  assign tag_position = section.settings.tag_position
%}
<style>
  body.overflow-hidden{
    overflow:hidden;
  }
  #body .{{class}}  .custom-button{
      color : {{ button_color }} !important;
      background-color: {{ button_bg }} !important;
    }
    .pf-tab {
       padding: 16px 24px;
      cursor: pointer;
    }
  .tab-block.first-block {
    display: flex;
    align-items: end;
    justify-content: flex-end;
    padding: 15px;
    background-size: cover;
    border-radius: 4px;
    flex-direction: column;
    max-width:calc(50% - 8px);
  }
  .heading{
  display:flex;align-items:center;}
  .heading-3 {
    font-style: normal;
    font-weight: 400;
    line-height: 125%;
    padding:0 0 10px !important;
  }
  .sub-heading-3 {
    font-size: 16px;
    font-style: normal;
    font-weight: 200;
    line-height: 160%;
    color: #fff;
  }
  .heading__tag{
    font-size:16px;
    line-height:1.25;
    padding:2px 5px;
    background:#FBF1E8;
    border:1px solid #F2D4B9;
    border-radius:2px;
    {% if tag_position == 'on_image' %}
       position:absolute;
       right:5px;
       top:5px;
       margin:0 !important;
    {% endif %}
  }
  .id_{{ section.id }} img{border-radius:4px; vertical-align:top;}
  @media (max-width: 768px) {
    .heading__tag{font-size:10px;}
    .tab-block-content {
      font-size: 16px;
    }
    tab-block.first-block .heading-3 {
          font-size: 22px !important;
          line-height: 125%;
      }
  }
    .hiw-tag {
      position: absolute;
      top: 16px;
      left: 16px;
      font-family: "Lausanne";
      font-size: 14px;
      font-style: normal;
      font-weight: 400;
      line-height: 128%;
      border-radius: 4px;
      border: 1px solid var(--Secondary-200, #F2D4B9);
      background: var(--Secondary-50, #FBF1E8);
      padding: 2px 4px;
      align-items: center;
  }
  
    }
    

.id_{{ section.id }} .pf-tab-content {
    transition: all 0.5s ease;
}

.id_{{ section.id }} .pf-tab-content.tab_enabled:not(.active) {
    opacity: 0;
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    z-index: 0;
    pointer-events: none;
}

.id_{{ section.id }} .pf-tab-content.tab_enabled.active {
    opacity: 1;
    position: relative;
    z-index: 10;
}
.blend_details_scroll{
overflow-y:auto;
max-height:400px;
}
{% if tabs %}{% else %}
.signature-seasonal-tabs.always_show .pf-tab-content{
    opacity: 1 !important;
    position: relative !important;
    z-index: 10 !important;
}
{% endif %}
</style>
<div
  id="{{ class }}"
  class="id_{{ section.id }} signature-seasonal-tabs  {{ class }} {% if tabs %}{% else %}always_show{% endif %}"
  style="background-color:{{ background }}"
>
  <div class="container">
    {% if section.settings.heading != blank %}
      <div class=" mb-4  heading-2-wrapper">
        <h2 class="heading-2 blue-text-3 mt-0 text-center value-bold m-text-left">
          {{ section.settings.heading }}
        </h2>
      </div>
    {% endif %}
    {% if tabs %}
      <div class="pf-tabs-wrapper">
        <span
          class="pf-tab pf-tab-2 tab-heading-1 active"
          data-id="id_{{ section.id }}"
          data-label="{{ section.settings.tabone | handle }}"
          data-current="tab-heading-1"
          data-target="tab-1"
        >
          {{- section.settings.tabone -}}
        </span>
        <span
          class="pf-tab pf-tab-2 tab-heading-2"
          data-id="id_{{ section.id }}"
          data-label="{{ section.settings.tabtwo | handle }}"
          data-current="tab-heading-2"
          data-target="tab-2"
        >
          {{- section.settings.tabtwo -}}
        </span>
      </div>
    {% endif %}
    <div class="pf-tabs-content position-relative">
      <div id="tab-1" class="pf-tab-content {% if tabs %}tab_enabled{% endif %} tab-1 pf-tab-2-content active">
        <div class="tab-blocks-wrapper">
          {% for block in section.blocks %}
            {% if block.type == 'tab-one' %}
              {% if block.settings.first %}
                <div class="tab-block first-block" style="background-image:url({{ block.settings.image | img_url: '400x' }})">
                  {% if block.settings.tag != '' -%}
                    <span class="hiw-tag">{{ block.settings.tag }}</span>
                  {% endif %}
                  <div class="font-gtsuper heading-3 text-white white-text">{{ block.settings.heading }}</div>
                  <div>
                    <p class="fw-200 font-lausanne sub-heading-3">{{ block.settings.content }}</p>
                  </div>
                </div>
              {% else %}
                <div class="tab-block position-relative pb-30">
                  <div class="tab-image position-relative">
                    <picture>
                      <source media="(min-width:650px)" srcset="{{ block.settings.image | img_url: '400x' }}">
                      <source media="(min-width:320px)" srcset="{{ block.settings.mobile_image | img_url: '400x' }}">
                      <img
                        src="{{ block.settings.image | img_url: '400x' }}"
                        alt="{{ block.settings.image | img_url: '400x' }}"
                        class="w-100 h-auto"
                        width="300"
                        height="250"
                      >
                    </picture>
                    {% if tag_position == 'on_image' %}
                    {% if block.settings.tag != '' -%}
                          <span class="heading__tag mx-2">{{ block.settings.tag }}</span>
                        {% endif %}
                    {% endif %}
                  </div>
                  <div>
                    <div class="tab-block-content mt-2">
                      <div class="font-lausanne fw-400 heading">
                        {{ block.settings.heading }}
                        {% if tag_position == 'after_heading' %}
                        {% if block.settings.tag != '' -%}
                          <span class="heading__tag mx-2">{{ block.settings.tag }}</span>
                        {% endif %}{% endif %}
                      </div>
                      <p class="fw-200 font-lausanne content ">{{ block.settings.content }}</p>
                    </div>
                    {% if block.settings.blend != '' %}
                      <div class="tab-block-blend">
                        <input type="checkbox" id="{{ block.id }}">
                        <div class="">
                          <label
                            for="{{ block.id }}"
                            class="d-flex open-tab-blend-popup justify-content-between font-lausanne fw-400"
                          >
                            {{- block.settings.popup_label }}
                            {% if plus %}<img
                          src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/green-plus.svg?v=1722600268"
                          width="15"
                          height="15"
                          alt="icon"
                      >{% endif -%}
                          </label>
                        </div>
                        <div class="tab-blend-popup-wrapper">
                          <label for="{{ block.id }}" class="tab-popup-overlay close-tab-blend-popup"></label>
                          <div class="tab-blend-popup">
                            <label
                              class="tab-close-blend-popup close-tab-blend-popup d-block text-right px-2 pt-2"
                              for="{{ block.id }}"
                            >
                              <i style="font-size:18px;  font-style:normal;" class="">x</i>
                            </label>
                            <div class="overflow-auto_">
                              {% if block.settings.heading_before %}
                              <div class="tab-block-content">
                                <div class="font-lausanne fw-400 heading-3">{{ block.settings.heading }}</div>
                                <p class="fw-200 font-lausanne">
                                  {% if block.settings.popup_short_content != blank %}
                                  {{ block.settings.popup_short_content }}
                                  {% else %}
                                    {{ block.settings.content }}
                                  {% endif %}
                                </p>
                              </div>
                            {% endif %}
                              <div class="tab-image">
                                <img
                                  src="{{ block.settings.mobile_image | img_url: '300x' }}"
                                  class="w-100 h-auto"
                                  width="300"
                                  height="250"
                                  alt="image"
                                >
                                  {% if block.settings.heading_before %}
                              {% else %}
                              <div class="tab-block-content pt-3">
                                <div class="font-lausanne fw-400 heading-3">{{ block.settings.heading }}</div>
                                <p class="fw-200 font-lausanne">
                                  {% if block.settings.popup_short_content != blank %}
                                  {{ block.settings.popup_short_content }}
                                  {% else %}
                                    {{ block.settings.content }}
                                  {% endif %}
                                </p>
                              </div>
                            {% endif %}
                              </div>
                              

                              <div class="tab-blend-details blend_details_scroll">
                                <h3 class="font-lausanne fw-400">{{ block.settings.detail_heading }}</h3>
                                <div>{{ block.settings.blend }}</div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div id="tab-2" class="pf-tab-content {% if tabs %}tab_enabled{% endif %} tab-2 pf-tab-2-content">
        <div class="tab-blocks-wrapper">
          {% for block in section.blocks %}
            {% if block.type == 'tab-two' %}
              {% if block.settings.first %}
                <div class="tab-block first-block" style="background-image:url({{ block.settings.image | img_url: '400x' }})">
                  {% if block.settings.tag != '' -%}
                    <span class="hiw-tag">{{ block.settings.tag }}</span>
                  {% endif %}
                  <div class="font-gtsuper heading-3 text-white white-text">{{ block.settings.heading }}</div>
                  <div>
                    <p class="fw-200 font-lausanne sub-heading-3">{{ block.settings.content }}</p>
                  </div>
                </div>
              {% else %}
                <div class="tab-block position-relative pb-30">
                  <div class="tab-image position-relative">
                    <picture>
                      <source media="(min-width:650px)" srcset="{{ block.settings.image | img_url: '400x' }}">
                      <source media="(min-width:320px)" srcset="{{ block.settings.mobile_image | img_url: '400x' }}">
                      <img
                        src="{{ block.settings.image | img_url: '400x' }}"
                        alt="{{ block.settings.image | img_url: '400x' }}"
                        class="w-100 h-auto"
                        width="300"
                        height="250"
                      >
                    </picture>
                    {% if tag_position == 'on_image' %}
                    {% if block.settings.tag != '' -%}
                          <span class="heading__tag mx-2">{{ block.settings.tag }}</span>
                        {% endif %}
                    {% endif %}
                  </div>
                  <div>
                    <div class="tab-block-content mt-2">
                      <div class="font-lausanne fw-400 heading">{{ block.settings.heading }}
                        {% if tag_position == 'after_heading' %}
                        {% if block.settings.tag != '' -%}
                          <span class="heading__tag mx-2">{{ block.settings.tag }}</span>
                        {% endif %}{% endif %}
                      </div>
                      <p class="fw-200 font-lausanne content ">{{ block.settings.content }}</p>
                    </div>
                    {% if block.settings.blend != '' %}
                      <div class="tab-block-blend">
                        <input type="checkbox" id="{{ block.id }}">
                        <div class="">
                          <label
                            for="{{ block.id }}"
                            class="d-flex open-tab-blend-popup justify-content-between font-lausanne fw-400"
                          >
                            {{- block.settings.popup_label }}
                            {% if plus %}<img
                          src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/green-plus.svg?v=1722600268"
                          width="15"
                          height="15"
                          alt="icon"
                      >{% endif -%}
                          </label>
                        </div>
                        <div class="tab-blend-popup-wrapper">
                          <label for="{{ block.id }}" class="tab-popup-overlay close-tab-blend-popup"></label>
                          <div class="tab-blend-popup">
                            <label
                              class="tab-close-blend-popup close-tab-blend-popup d-block text-right px-2 pt-2"
                              for="{{ block.id }}"
                            >
                              <i style="font-size:18px; font-style:normal;" class="">x</i>
                            </label>
                            <div class="overflow-auto_">
                              {% if block.settings.heading_before %}
                              <div class="tab-block-content">
                                <div class="font-lausanne fw-400 heading-3">{{ block.settings.heading }}</div>
                                <p class="fw-200 font-lausanne">
                                  {% if block.settings.popup_short_content != blank %}
                                  {{ block.settings.popup_short_content }}
                                  {% else %}
                                    {{ block.settings.content }}
                                  {% endif %}
                                </p>
                              </div>
                            {% endif %}
                              <div class="tab-image">
                                <img
                                  src="{{ block.settings.mobile_image | img_url: '300x' }}"
                                  class="w-100 h-auto"
                                  width="300"
                                  height="250"
                                  alt="image"
                                >
                                   {% if block.settings.heading_before %}
                               {% else %}
                              <div class="tab-block-content pt-3">
                                <div class="font-lausanne fw-400 heading-3">{{ block.settings.heading }}</div>
                                <p class="fw-200 font-lausanne">
                                  {% if block.settings.popup_short_content != blank %}
                                  {{ block.settings.popup_short_content }}
                                  {% else %}
                                    {{ block.settings.content }}
                                  {% endif %}
                                </p>
                              </div>
                            {% endif %}
                              </div>
                              
                              <div class="tab-blend-details blend_details_scroll">
                                <h3 class="font-lausanne fw-400">{{ block.settings.detail_heading }}</h3>
                                <div>{{ block.settings.blend }}</div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
    {% if button_label != blank %}
      <div class="button-wrapper text-center">
        <span class="btn click-scroll custom-button" 
          {% if section.settings.dataTrack %}
                    {% render 'ga4-events' %}
                  {% endif %} data-target="{{ button_target }}" data-top="40">
          {{- button_label -}}
        </span>
      </div>
    {% endif %}
  </div>
</div>

{% if tabs %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('.pf-tab').forEach((tab) => {
        tab.addEventListener('click', function () {
          let targetClass = this.getAttribute('data-target');
          let tabClass = this.getAttribute('data-current');
          let sectionID = this.getAttribute('data-id');

          document.querySelectorAll('.pf-tab-content').forEach((content) => {
            content.classList.remove('active');
          });

          document.querySelectorAll('.' + targetClass).forEach((targetElement) => {
            targetElement.classList.add('active');
          });

          document.querySelectorAll('.pf-tab').forEach((content) => {
            content.classList.remove('active');
          });

          document.querySelectorAll('.' + tabClass).forEach((targetElement) => {
            targetElement.classList.add('active');
          });
        });
      });
    });
  </script>
{% endif %}
<script>
  document.addEventListener('change', function (e) {
    if (e.target.matches('.tab-block-blend input')) {
      const isAnyChecked = document.querySelectorAll('.tab-block-blend input:checked').length > 0;
      document.body.classList.toggle('is_popup_show', isAnyChecked);
    }
  });
</script>

<style>
  #{{ class }}{
      {{ style }}
  }
</style>

