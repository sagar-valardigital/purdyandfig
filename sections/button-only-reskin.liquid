{% assign product = section.settings.selectproduct %}
{% assign s_variant = product.selected_or_first_available_variant %}

{%  assign hasbtnlink = true %}

{% if section.settings.btnlink == '' %}
  {% assign hasbtnlink = false %}
{%  endif %}

<div class="button-only py-4" style="background-color:{{ section.settings.bgcolor }}" x-data="{qty:1}">
  <div class="container">
    <div class="product-buy-btn mt-0 mb-3 mx-auto">
      {%  if hasbtnlink %}
      {% else %}
      <form
        @submit.prevent="console.log('submitted')"
        x-ref="product_form_{{product.id}}"
        enctype="multipart/form-data"
        accept-charset="UTF-8"
        id="product_form_{{product.id}}"
        class="shopify-product-form"
        data-product-id="{{product.id}}"
        action="/cart/add"
      >
        <input type="hidden" name="id" value="{{ s_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        {% if section.settings.isSub %}
          <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
          <input
            type="hidden"
            name="selling_plan"
            value="{{s_variant.selling_plan_allocations.first.selling_plan.id}}"
          >
        {% endif %}
      </form>
      {%  endif %}
      <button
        {% if section.settings.dataTrack %}
          {% render 'ga4-events' %}
        {% endif %}
        class="btn theme-btn btn-loader {%  if hasbtnlink %}m-click-scroll{% endif %}" style="background:{{ section.settings.btnBG }};border-color:{{ section.settings.btnBG }}"
        {%  if hasbtnlink %}
          data-target="{{ section.settings.btnlink }}"
          data-top="{{ section.settings.top }}"
          data-m-top="{{ section.settings.mTop }}"
        {% else %}
        x-on:click="Purdy.PurdyCheckout($refs.product_form_{{ product.id }},'{{ section.settings.discount }}', $event)"
        {% endif %}
      >
        {{ section.settings.btnlabel }}
      </button>
    </div>
  </div>
</div>

{% schema %}
 {
   "name": "Button Only Reskin",
   "settings": [
       {
           "type": "color",
           "id": "bgcolor",
           "label": "Background Color"
         },
     {
           "type": "color",
           "id": "btnBG",
           "label": "Button Background Color"
         },
     {
           "type": "product",
           "id": "selectproduct",
           "label": "Select Product"
         },
     {
           "type": "checkbox",
           "id": "isSub",
           "label": "Product subscription",
            "default": true
         },
     {
           "type": "text",
           "id": "discount",
           "label": "Discount",
           "default": "Free"
         },
         {
           "type": "text",
           "id": "btnlabel",
           "label": "Button Label",
           "default": "Buy Now"
         },
         {
           "type": "text",
           "id": "btnlink",
           "label": "Element ID to scroll"
         },
        {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
      {
          "type": "text",
          "id": "mTop",
          "label": "On scroll mobile top position",
          "default": "0"
      },
       {
        "id": "dataTrack",
        "label":"Data Track",
        "type": "checkbox"
        },
        {
        "id": "targetUrl",
        "label":"Target Url",
        "type": "url"
        },
        {
        "id": "index",
        "label":"Index",
        "type": "number",
        "default" : 0
            },
            {
        "id": "funnel_stage",
        "label":"Funnel Stage",
        "type": "text",
         "default" : "landing_page"
            },
            {
        "id": "dataModule",
        "label":"Module",
        "type": "text",
         "default" : "announcement_bar"
            },
              {
        "id": "dataTitle",
        "label":"Event Label",
        "type": "text",
        "default": "get_your_offer"
            }
            ,
              {
        "id": "eventValue",
        "label":"Event Value",
        "type": "text",
        "default" : "shop_anchor"
            },
              {
        "id": "itemId",
        "label":"Item Id",
        "type": "text"
            }
            ,
              {
        "id": "optionIndex",
        "label":"Option Index",
        "type": "text"
            }
            ,
              {
        "id": "ItemName",
        "label":"Item Name",
        "type": "text"
            }

],

"presets": [
	{
		"name": "Button Only Reskin"
	}
]
 }
{% endschema %}
