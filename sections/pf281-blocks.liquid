<style>
  .main-block-section {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-gap: 30.7px;
  }
  .img-block-wrapper {
    /* width: 282px; */
    position: relative;
  }

  .image-wrapper-section {
    position: relative;
  }

  .main-block-section .heading-4 {
    font-family: "Lausanne";
    font-size: 24px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
  }

  .main-block-section p.theme-text {
    font-family: "Lausanne";
    font-size: 16px;
    font-weight: 200;
    font-style: normal;
  }

  .top-h2-heading {
    letter-spacing: 0px !important;
  }

  .top-p-heading {
    font-size: 18px;
    font-weight: 200;
    line-height: 150%;
    letter-spacing: 0px !important;
  }

  .new-block-btn {
    width: 343px;
    font-family: "Lausanne";
  }

  .block-variant-badge {
    position: absolute;
    top: 16px;
    right: 16px;
  }

  .new-block-badge {
    border-radius: 4px;
    background: #FBF1E8;
    color: #212121;
    font-size: 14px;
    padding: 2px 4px;
    font-style: normal;
    font-weight: 400;
    text-transform: capitalize;
    border: solid 1px #F2D4B9;
  }

  .mob-flex p.theme-text {
    margin-bottom: 0.5rem;
  }

  .new-tp-btn {
    padding-top: 40px;
  }

  @media (max-width: 768px) {
    .top-h2-heading,
    .top-p-heading {
      text-align: left;
    }
    .block-section.py-80 {
      padding-top: 32px;
      padding-bottom: 32px;
    }

    .main-block-section {
      margin-top: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .img-block-wrapper {
      width: 100%;
      display: flex;
      gap: 16px;
      align-items: baseline;
      flex-direction: row;
    }

    .image-wrapper-section {
      width: 97.40px;
    }

    .mob-flex {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      width: 230px;
    }

    .main-block-section .heading-4 {
      font-size: 16px;
    }

    .main-block-section p.theme-text {
      font-size: 12px;
      letter-spacing: 0.3px;
    }

    .new-block-btn {
      width: 100%;
    }

    .new-tp-btn {
      padding-top: 24px;
    }
  }
</style>

{% if section.settings.enable %}
  <div class="block-section py-80">
    <div class="container">
      <h2 class="heading-2 text-center theme-text mt-0  m-heading-2 top-h2-heading">{{ section.settings.heading }}</h2>
      {% if section.settings.subtext %}
        <p class="heading-4 theme-text text-center top-p-heading">{{ section.settings.subtext }}</p>
      {% endif %}
      <div class="main-block-section">
        {% for block in section.blocks %}
          <div class="img-block-wrapper">
            <div class="image-wrapper-section">
              <picture>
                <source media="(min-width:769px)" srcset="{{ block.settings.image | image_url }}">
                <img
                  class="img-responsive w-100 h-auto lazy"
                  src="{{ block.settings.image | image_url: width: 800, crop: 'center' }}"
                  width="282"
                  height="282"
                  alt="{{ block.settings.image.alt }}"
                >
              </picture>
              {% if block.settings.badge != blank %}
                <span class="block-variant-badge new-block-badge mobile-hide">{{ block.settings.badge }}</span>
              {% endif %}
            </div>
            <div class="mob-flex">
              <h4 class="heading-4 mt-3 mb-1">{{ block.settings.heading }}</h4>
              {% if block.settings.details %}
                <p class="theme-text font-lausanne fw-400">{{ block.settings.details }}</p>
              {% endif %}

              {% if block.settings.badge != blank %}
                <span class="new-block-badge desktop-hide">{{ block.settings.badge }}</span>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.buttontext != blank %}
        <div class="text-center new-tp-btn">
          <a
            href="javascript: void(0);"
            class="click-scroll btn green-btn new-block-btn"
            {% if section.settings.dataTrack %}
              {% render 'ga4-events' %}
            {% endif %}
            data-target="{{ section.settings.scrollto }}"
            style="{% if section.settings.buttonbg != blank %}background: {{ section.settings.buttonbg }};{% endif %} {% if section.settings.buttontxtcolor != blank %}color: {{ section.settings.buttontxtcolor }}{% endif %}"
          >
            {{ section.settings.buttontext }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
 {
   "name": "PF281 Image blocks",
   "settings": [
   	{
         "type": "checkbox",
         "id": "enable",
         "label": "Uncheck to hide the section",
         "default": true
       },
       {
         "type": "color",
         "id": "background",
         "label": "Background Color"
       },
       {
         "type": "color",
         "id": "textcolor",
         "label": "Text Color"
       },
       {
         "type": "text",
         "id": "heading",
         "label": "Heading"
       },
       {
         "type": "text",
         "id": "subtext",
         "label": "Text"
       },
       {
         "type": "text",
         "id": "buttontext",
         "label": "Button Label",
         "default": "GET YOUR OFFER"
       },
       {
         "type": "color",
         "id": "buttonbg",
         "label": "Button Background Color"
       },
       {
         "type": "color",
         "id": "buttontxtcolor",
         "label": "Button Text Color"
       },
       {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll To"
        },
     {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
],
"blocks": [
     {
       "type": "text",
       "name": "block",
       "settings": [
         {
             "type": "image_picker",
             "id": "image",
             "label": "Add Image"
         },
         {
             "type": "text",
             "id": "badge",
             "label": "Badge Label"
         },
         {
             "type": "text",
             "id": "heading",
             "label": "Heading"
         },
         {
             "type": "text",
             "id": "details",
             "label": "Detail Text"
         }
       ]
     }
],
"presets": [
	{
		"name": "PF281 Image blocks"
	}
]
 }
{% endschema %}
