<div class="powerfull-products-section section py-80">
  <div class="container">
    <div>
      <h2 class="heading-2 text-center blue-text value-bold mt-0 ">{{ section.settings.heading }}</h2>
    </div>
    <div class="mt-4">
      <div class="powerfull-product-wrapper">
        {% for block in section.blocks %}
          <div class="powerfull-product position-relative">
            <div class="pp-image">
              <img src="{{ block.settings.image | image_url  }}" alt="{{ block.settings.title }}" class="h-auto w-100" width="400" height="300" />
            </div>
            <div class="pp-content">
                <h3 class="heading-3 font-lausanne fw-400">{{ block.settings.title }}</h3>
                <p class="font-lausanne fw-200">{{ block.settings.content }}</p>
                <div class="pp-price font-lausanne">
                  <del>{{ block.settings.del }}</del>
                  <span>{{ block.settings.price }}</span>
                </div>
            </div>
          </div>
        {% endfor %}
      </div>
        {% if section.settings.addScrollBtn %}
    <div class="mt-4">
      <span
        class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >{{ section.settings.scrollBtnText }}</span
      >
    </div>
    {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Three Powerfull Products",
  "settings": [
    {
      "id": "heading",
      "label":"Heading",
      "type": "text"
      },
    {
          "type": "checkbox",
          "id": "addScrollBtn",
          "label": "Show Scroll to Btn",
          "default": false
        },{
          "type": "text",
          "id": "scrollBtnText",
          "label": "Scroll to Btn Text",
           "default": "GET YOUR OFFER"
        },
      {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      }
     ,
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
     {
      "id": "dataTrack",
      "label":"Data Track",
      "type": "checkbox"
      },
      {
      "id": "targetUrl",
      "label":"Target Url",
      "type": "url"
      },
      {
      "id": "index",
      "label":"Index",
      "type": "number",
      "default" : 0
          },
          {
      "id": "funnel_stage",
      "label":"Funnel Stage",
      "type": "text",
       "default" : "landing_page"
          },
          {
      "id": "dataModule",
      "label":"Module",
      "type": "text",
       "default" : "announcement_bar"
          },
            {
      "id": "dataTitle",
      "label":"Event Label",
      "type": "text",
      "default": "get_your_offer"
          }
          ,
            {
      "id": "eventValue",
      "label":"Event Value",
      "type": "text",
      "default" : "shop_anchor"
          },
            {
      "id": "itemId",
      "label":"Item Id",
      "type": "text"
          }
          ,
            {
      "id": "optionIndex",
      "label":"Option Index",
      "type": "text"
          }
          ,
            {
      "id": "ItemName",
      "label":"Item Name",
      "type": "text"
          }
  ],
  "blocks": [
      {
        "type": "image",
        "name": "accordion block",
        "settings": [
            {
      "type": "url",
      "id": "url",
      "label": "Add link"
    },
          {
      "type": "image_picker",
      "id": "image",
      "label": "Add Image"
    },

{
      "type": "text",
      "id": "title",
      "label": "Heading"
    }
          ,

{
      "type": "text",
      "id": "content",
      "label": "text"
    }          ,

{
      "type": "text",
      "id": "del",
      "label": "Crossover Price"
    },

{
      "type": "text",
      "id": "price",
      "label": "Price"
    }
        ]
      }
	],
  "presets": [
    {
      "name": "Three Powerfull Products"
    }
  ]
}
{% endschema %}
