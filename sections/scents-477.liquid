<style>
  .tss-block .tss-details {
    line-height: 1.6 !important;
    margin: 0 !important;
  }

  .tss-mobile-stack {
    width: 100%;
    padding: 0 16px;
  }

  .tss-mobile-card {
    align-items: flex-start;
  }

  .tss-mobile-card:last-child {
    margin-bottom: 0 !important;
  }

  .tss-mobile-image {
    flex-shrink: 0;
    width: 98px;
    height: 98px;
    border-radius: 4px;
    overflow: hidden;
  }

  .tss-mobile-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tss-mobile-content {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .tss-mobile-content .tss-heading {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5;
    margin-bottom: 4px !important;
    padding-top: 0;
    padding-bottom: 0;
    border-bottom: none;
    color: #212121;
  }

  .tss-mobile-content .tss-details {
    font-size: 12px !important;
    color: #212121;
    line-height: 1.6 !important;
    letter-spacing: 0.015em;
    margin-bottom: 12px;
    padding-top: 0;
    font-style: normal;
    font-weight: 200;
  }

  .tss-mobile-content .tss-mobile-tag {
      font-size: 14px;
      font-weight: 400;
      border-radius: 4px;
      padding: 2px 4px;
      border: 1px solid var(--Secondary-200, #f2d4b9);
      background: var(--Secondary-50, #fbf1e8);
      line-height: 128%;
      color: #212121;
      display: inline-block;
      white-space: nowrap;
      width: auto;
      max-width: fit-content;
  }

  .heading-2 {
    letter-spacing: 0px;
    color: #212121 !important;
  }
  .tss-tag {
    font-size: 14px;
    font-weight: 400;
    border-radius: 4px;
    right: 16px;
    top: 16px;
    padding: 2px 4px;
    border: 1px solid var(--Secondary-200, #f2d4b9);
    background: var(--Secondary-50, #fbf1e8);
    line-height: 128%;
    color: #212121;
  }
  .tss-details {
    font-size: 14px;
  }

  {% comment %} .pf388-scents .tss-block {
    padding: 15px 16px 0px 16px !important;
  } {% endcomment %}

  .pf388-scents .blue-starterkit-btn {
    margin-top: 40px !important;
    font-family: 'Lausanne';
    font-size: 16px;
      border: 0;
      font-weight: 400;
      border-radius: 4px;
      color: #fff;
      padding: 10px 15px;
  }

  .pf434 .heading-2 {
    line-height: 50px;
    letter-spacing: 0px;
  }
  .pf434 .tss-block .tss-details {
    line-height: 25.6px;
  }

  @media (min-width: 769px) {
    .trans-scents-desktop {
      display: block;
    }
    .trans-scents-mobile {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .trans-scents-desktop {
      display: none;
    }
    .trans-scents-mobile {
      display: block;
    }
    .common-btn-width {
      width: 100%;
    }
    .pf388-scents .blue-starterkit-btn {
      margin-top: 24px !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
      max-width: 100% !important;
      width: 100%;
    }
    .pf434 .heading-2 {
      line-height: 40px;
    }
    .pf434 .tss-mobile-content .tss-details {
      line-height: 18px;
      letter-spacing: 0.18px;
    }
    .pf434 .tss-mobile-content .tss-mobile-tag {
      font-size: 12px;
    }
  }
</style>

{% assign count = 0 %}
{% for block in section.blocks %}
  {% assign count = count | plus: 1 %}
{% endfor %}
<div id="{{ section.settings.sectionId }}">
  <div
    style="background-color:{{ section.settings.bgcolor }}"
    class="py-80  transformational-scents-section scents-reskins variant_{{ section.settings.linkVariant }} {{ section.settings.class }}"
  >
    <div class="container">
      <div
        {% if count < 2 %}
          class="d-flex align-items-center justify-content-between tss-one-block-wrapper"
        {% endif %}
      >
        <div class="tss-main-header">
          <h2 class="heading-2 text-center white-text font-gtsuper mt-0 ">{{ section.settings.heading }}</h2>
          {% if section.settings.subtext != blank %}
            <p style="color: #424242" class="normal-text font-lausanne fw-200 text-center">
              {{ section.settings.subtext }}
            </p>
          {% endif %}
        </div>
        <!-- DESKTOP VERSION -->
        <div class="mt-4 trans-scents-desktop">
          <div class="transformational-scents-slider {% if count > 2 %}tss-slider{% endif %}">
            {% for block in section.blocks %}
              <div class="tss-block">
                <div class="tss-image position-relative">
                  <picture>
                    {% assign image = block.settings.blockImage %}
                    {% assign mimage = block.settings.mBlockImage %}

                    <source media="(min-width:769px)" srcset="{{ image | img_url: 'master'}}">
                    <source media="(max-width:768px)" srcset="{{ mimage | img_url: 'master' }}">
                    <img
                      data-id="{{image.id}}"
                      class="img-responsive w-100 h-auto lazy"
                      src="{{ image | img_url: 'master'}}"
                      width="400"
                      height="300"
                      alt="{{ image.alt }}"
                    >
                  </picture>
                  {% if block.settings.tag != blank %}
                    <span class="tss-tag font-lausanne">{{ block.settings.tag }}</span>
                  {% endif %}
                </div>
                <div class="tss-content">
                  <h3 class="tss-heading  font-lausanne fw-400">{{ block.settings.heading }}</h3>
                  <p class="tss-details black-text normal-text font-lausanne fw-200">{{ block.settings.details }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
        <!-- END: DESKTOP VERSION -->

        <!-- MOBILE VERSION (NEW STACKED) -->

        <div class="mt-4 trans-scents-mobile">
          <div class="tss-mobile-stack">
            {% for block in section.blocks %}
              <div class="tss-mobile-card d-flex mb-4">
                <div class="tss-mobile-image">
                  <picture>
                    {% assign image = block.settings.blockImage %}
                    {% assign mimage = block.settings.mBlockImage %}
                    <source media="(min-width:769px)" srcset="{{ image | img_url: 'master'}}">
                    <source media="(max-width:768px)" srcset="{{ mimage | img_url: 'master' }}">
                    <img
                      data-id="{{image.id}}"
                      class="img-responsive w-100 h-auto lazy"
                      src="{{ mimage | img_url: 'master'}}"
                      width="120"
                      height="120"
                      alt="{{ image.alt }}"
                    >
                  </picture>
                </div>
                <div class="tss-mobile-content flex-grow-1 ps-3">
                  {% if block.settings.tag != blank %}
                    <div class="tss-mobile-tag font-lausanne">{{ block.settings.tag }}</div>
                  {% endif %}
                  <h3 class="tss-heading font-lausanne fw-400 mb-2">{{ block.settings.heading }}</h3>
                  <p class="tss-details black-text normal-text font-lausanne fw-200 mb-2">
                    {{ block.settings.details }}
                  </p>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- END: MOBILE VERSION -->
      </div>
    </div>
    {% if section.settings.addScrollBtn %}
      <div class="discoverBtmBtn">
        <span
          class="d-block text-center blue-starterkit-btn click-scroll m-auto common-btn-width"
          style="background-color: {{ section.settings.btn-color }}"
          data-target="{{ section.settings.scrollto }}"
          data-top="{{ section.settings.top }}"
          {% if section.settings.dataTrack %}
            {% render 'ga4-events' %}
          {% endif %}
        >
          {{- section.settings.btnLabel -}}
        </span>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Scents PF477",
  "settings": [
    {
      "type": "text",
      "id": "sectionId",
      "label": "Section ID"
    },
    {
      "type": "color",
      "id": "bgcolor",
      "label": "Background color"
    },
    {
      "type": "text",
      "id": "class",
      "label": "Section Class"
    },
    {
      "type": "text",
      "id": "linkVariant",
      "label": "Link variant number"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "html",
      "id": "subtext",
      "label": "Sub Heading"
    },
    {
      "type": "checkbox",
      "id": "addScrollBtn",
      "label": "Show Scroll to Btn",
      "default": false
    },
    {
      "type": "text",
      "id": "btnLabel",
      "label": "Button Label",
      "default": "GET YOUR OFFER"
    },
    {
      "type": "text",
      "id": "scrollto",
      "label": "Scroll to section id",
      "default": "javascript:void(0);"
    },
    {
      "type": "text",
      "id": "top",
      "label": "On scroll top position",
      "default": "0"
    },
    {
      "type": "color",
      "id": "btn-color",
      "label": "Button BG color",
      "default": "#11322c"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "landing_page"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "itemId",
      "label": "Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label": "Item Name",
      "type": "text"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Scent block",
      "settings": [
        {
          "type": "image_picker",
          "id": "blockImage",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mBlockImage",
          "label": "Mobile Image"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "details",
          "label": "text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scents PF477"
    }
  ]
}
{% endschema %}
