<section class="section section-relative " id="page-block-nv612p68z1" data-at="section">
  <div class="section-holder-border item-block item-absolute" data-at="section-border"></div>
  <div class="section-holder-overlay item-block item-absolute" data-at="section-overlay"></div>
  <div class="section-block">
    <div class="section-inner section-fit section-relative">
      <div class="widget item-absolute headline  " id="element-817" data-at="headline">
        <div class="contents">
          <h1>
            <span class="x_c3033fde x_40201d9b" style="text-align: center;">{{ section.settings.title }}</span>
          </h1>
        </div>
      </div>
      <div class="widget item-absolute paragraph hidden-mobile " id="element-818" data-at="paragraph">
        <div class="contents">
          <p class="x_190a7a83 x_7df451b3">{{ section.settings.subtitle }}</p>
        </div>
      </div>

      {% if section.blocks[0] %}
        <div class="widget item-absolute headline  " id="element-806" data-at="headline">
          <div class="contents">
            <h3>
              <span class="x_35a38d41 x_446dab97">{{ section.blocks[0].settings.heading }}</span
              ><span class="x_35a38d41 x_446dab97"><br></span>
            </h3>
          </div>
        </div>
        <div class="widget item-absolute " id="element-811">
          <div
            class="contents shape box figure"
            data-at="shape"
            data-src="{{ section.blocks[0].settings.image | img_url: '800x' }}"
            style="background-image: url({{ section.blocks[0].settings.image | img_url: '800x' }});"
          ></div>
        </div>
        <div class="widget item-absolute paragraph  " id="element-805" data-at="paragraph">
          <div class="contents">
            <br>
            <p class="x_8c071feb x_e6507cf2">{{ section.blocks[0].settings.info }}</p>
          </div>
        </div>
      {% endif %}

      {% if section.blocks[1] %}
        <div class="widget item-absolute " id="element-812">
          <div
            class="contents shape box figure"
            data-at="shape"
            data-src="{{ section.blocks[1].settings.image | img_url: '800x' }}"
            style="background-image: url({{ section.blocks[1].settings.image | img_url: '800x' }});"
          ></div>
        </div>
        <div class="widget item-absolute headline  " id="element-808" data-at="headline">
          <div class="contents">
            <h3>
              <span class="x_0def92d0 x_446dab97">{{ section.blocks[1].settings.heading }}</span>
            </h3>
          </div>
        </div>
        <div class="widget item-absolute paragraph  " id="element-807" data-at="paragraph">
          <div class="contents">
            <p class="x_695a2def x_e6507cf2">{{ section.blocks[1].settings.info }}</p>
          </div>
        </div>
      {% endif %}

      {% if section.settings['show-offer-btn'] %}
        <div class="widget item-absolute  " id="element-1195">
          <a
            href="javascript:void(0)"
            data-target="scroll-here-link-1"
            id="link-hbsntholi4n"
            class="onpage-link btn  click-scroll  item-block"
            data-at="button"
            data-link-hbsntholi4n=""
            {% if section.settings.dataTrack %}
              {% render 'ga4-events' %}
            {% endif %}
          >
            GET OFFER
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Instapage Info Blocks 2",
    "settings": [
      {
        "id": "title",
        "label": "Title",
        "type": "text"
      },
      {
        "id": "subtitle",
        "label": "Subtitle",
        "type": "text"
      },
      {
        "id": "show-offer-btn",
        "label": "Show Offer Button",
        "type": "checkbox"
      },
      {
        "type": "header",
        "content": "GA4"
      },
      {
        "id": "dataTrack",
        "label": "Data Track",
        "type": "checkbox"
      },
      {
        "id": "targetUrl",
        "label": "Target Url",
        "type": "url"
      },
      {
        "id": "index",
        "label": "Index",
        "type": "number",
        "default": 1
      },
      {
        "id": "funnel_stage",
        "label": "Funnel Stage",
        "type": "text",
        "default": "landing_page"
      },
      {
        "id": "dataModule",
        "label": "Module",
        "type": "text",
        "default": "announcement_bar"
      },
      {
        "id": "dataTitle",
        "label": "Event Label",
        "type": "text",
        "default": "get_your_offer"
      },
      {
        "id": "eventValue",
        "label": "Event Value",
        "type": "text",
        "default": "shop_anchor"
      },
      {
        "id": "itemId",
        "label": "Item Id",
        "type": "text"
      },
      {
        "id": "optionIndex",
        "label": "Option Index",
        "type": "text"
      },
      {
        "id": "ItemName",
        "label": "Item Name",
        "type": "text"
      }
    ],
    "max_blocks": 2,
    "blocks": [
      {
        "type": "text",
        "name": "block",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "text",
            "id": "info",
            "label": "Information"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Instapage Info Blocks 2"
      }
	]
  }
{% endschema %}
