<style>
  .citrus-desktop-hide {
    display: none;
  }
  .citrus-mobile-hide {
    display: block;
  }
  .citrus-section-381 {
    padding: 80px 112px;
    display: flex;
    gap: 32px;
    justify-content: center;
    align-items: flex-start;
    background: {{ section.settings.background_color }};
    flex-wrap: wrap;
    width: 100%;
  }
  .citrus-container {
    display: flex;
    gap: 104px;
    justify-content: center;
    align-items: flex-start;
    flex-wrap: wrap;
  }
  .citrus-product-box {
    order: 1;
    display: flex;
    flex-direction: column;
    width: calc(55% - 52px);;
    justify-content: center;
    align-items: flex-start;
    gap: 10px;
  }
  .citrus-product-box img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    cursor: pointer;
  }
  .prdetail-box {
    display: flex;
    padding: 0 8px;
    flex-direction: column;
    align-items: flex-start;
    align-self: stretch;
  }
  .citrus-product-title {
    font-family: "Lausanne";
    font-size: 18px;
    font-weight: 600;
    line-height: 27px;
    color: #212121;
    cursor: pointer;
  }
  .citrus-product-summary {
    font-family: "Lausanne";
    font-size: 14px;
    font-weight: 200;
    line-height: 21px;
    color: #424242;
  }
  .citrus-price {
    font-family: "Lausanne";
    font-size: 14px;
    font-weight: 400;
    line-height: 14px;
    color: #424242;
    letter-spacing: 0.35px;
  }
  .citrus-deleted-price {
    font-family: "Lausanne";
    font-size: 14px;
    font-weight: 400;
    line-height: 14px;
    color: #9E9E9E;
    letter-spacing: 0.35px;
    text-decoration: line-through;
  }
  .citrus-product-box form {
    width: 100%;
  }
  .citrus-product-box .checkout-starterkit-btn {
    font-size: 18px !important;
    width: 100%;
  }
  .citrus-heading-box {
    order: 2;
    width: calc(45% - 52px);
    /* height: 265px; */
    display: flex;
    align-self: center;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
    flex-shrink: 1;
  }
  .heading-brd {
    display: flex;
    padding: 16px 0;
    align-items: flex-start;
    border-top: 0.5px solid #003176;
    border-bottom: 0.5px solid #003176;
    width: 100%;
  }
  .citrus-heading {
    font-family: "GT Super" !important;
    font-size: 48px;
    font-weight: 400;
    line-height: 60px;
    color: #003176;
  }
  .citrus-heading .fi-lic {
    font-style: italic;
  }
  .citrus-summary {
    width: calc(90% - 30px);
    max-width: 416px;
    font-family: "Lausanne";
    font-size: 18px;
    font-weight: 200;
    line-height: 27px;
    color: #003176;
  }
  .citrus-summary .weight-extra {
    font-weight: 600;
  }
  .sc-btn-381 {
    display: flex;
    gap: 4px;
  }
  .sc-btn-del-price-381 {
    color: #9E9E9E;
    font-weight: 400;
  }
  .citrus-product-box {
    order: 2;
  }
  .citrus-heading-box {
    order: 1;
  }
  .atoz {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  @media (max-width: 768px) {
    .citrus-desktop-hide {
      display: block;
    }
    .citrus-mobile-hide {
      display: none;
    }
    
    .citrus-section-381 {
      padding: 32px 16px;
      gap: 24px;
    }

    .citrus-container {
      flex-direction: column;
      gap: 24px;
      align-items: flex-start;
      width: 100%;
    }

    .citrus-product-box {
      order: 2;
      width: 100%;
    }
    .citrus-product-box img {
      height: auto;
    }
    .citrus-product-title {
      font-size: 16px;
      line-height: 24px;
    }
    .citrus-product-summary {
      font-size: 12px;
      line-height: 18px;
      letter-spacing: 0.18px;
    }
    .citrus-product-box form {
      width: 100%;
    }
    .citrus-product-box .checkout-starterkit-btn {
      width: 100%;
    }
    
    .citrus-heading-box {
      order: 1;
      width: 100%;
      height: unset;
    }

    .heading-border-box {
      width: 100%;
    }
    .citrus-heading {
      font-size: 32px !important;
      line-height: 40px !important;
      /* max-width: 343px; */
    }
    .citrus-summary {
      width: 100%;
      font-size: 16px;
      line-height: 24px;
    }
    .deal-headings {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      text-align: center;
    }
    .mblcolor {
      color: #D89B39 !important;
    }
    .citrus-heading {
      font-size: 24px !important;
      line-height: 30px !important;
    }
    .citrus-summary {
      font-size: 14px;
      line-height: 21px;
    }
  }
</style>

{% assign product = section.settings.landing_product %}

<section class="citrus-section-381" x-data="{qty:1}">
  <div class="citrus-container">
    <div class="citrus-product-box" id="{{ section.settings.scroll_id }}">
      <div class="deal-headings desktop-hide">
        <span class="citrus-heading" style="color: #FFFFFF;">{{ section.settings.heading }}</span>
        <span class="citrus-summary" style="color: #FFFFFF;">{{ section.settings.summary }}</span>
      </div>
      <img
        loading="lazy"
        src="{{ section.settings.desktop_image | image_url: width: 3200 }}"
        width="592"
        height="592"
        class="citrus-image citrus-mobile-hide"
        alt="{{ section.settings.desktop_image.alt }}"
        onclick="firepopupblock(this);"
      >
      <img
        loading="lazy"
        src="{{ section.settings.mobile_image | image_url: width: 1200 }}"
        width="343"
        height="343"
        class="citrus-image citrus-desktop-hide image-main-381"
        alt="{{ section.settings.mobile_image.alt }}"
        onclick="firepopupblock(this);"
      >

      <span
        class="btn w-100 green-btn value-medium sc-btn-381 btn-main-381 atoz click-scroll"
        data-target="{{ section.settings.scroll_to }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
          data-tracked="true"
          data-page-url="{{ request.path }}"
          data-target-url="{{ section.settings.targetUrl }}"
          data-index="{{ section.settings.index }}"
          data-funnel-stage="{{ section.settings.funnel_stage }}"
          data-module="{{ section.settings.dataModule }}"
          data-event-label="{{ section.settings.dataTitle }}"
          data-event-value="{{ section.settings.eventValue }}"
          data-item-id="{{ section.settings.product_sku }}"
          data-option-index="{{ section.settings.optionIndex }}"
          data-item-name="{{ section.settings.ItemName }}"
          data-quantity="{{ section.settings.quantity }}"
        {% endif %}
        style="background: {{ section.settings.btn_bg_color }} !important; color: {{ section.settings.btn_text_color }} !important;"
      >
        {{ section.settings.btn_text }}
      </span>
    </div>
    <div class="citrus-heading-box mobile-hide">
      <div class="heading-brd">
        <div class="heading-border-box">
          <span class="citrus-heading" style="color: {{ section.settings.headingcolor }};">{{ section.settings.heading }}</span>
        </div>
      </div>
      <span class="citrus-summary" style="color: {{ section.settings.summarycolor }};">{{ section.settings.summary }}</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Deal of day",
  "settings": [
    {
      "type": "checkbox",
      "id": "out_of_stock",
      "label": "Out of stock"
    },
    {
      "type": "checkbox",
      "id": "isSub",
      "label": "Product subscription enable"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "text",
      "id": "scroll_id",
      "label": "Section scroll ID"
    },
    {
      "type": "color",
      "id": "headingcolor",
      "label": "Heading color"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "summarycolor",
      "label": "Summary color"
    },
    {
      "type": "html",
      "id": "summary",
      "label": "Summary"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button background"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text color"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button label"
    },
    {
      "type": "text",
      "id": "scroll_to",
      "label": "Scroll to"
    },
    {
      "type": "number",
      "id": "top",
      "label": "Scroll to position"
    },
    {
      "id": "dataTrack",
      "label":"Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label":"Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label":"Index",
      "type": "number",
      "default" : 0
    },
    {
      "id": "funnel_stage",
      "label":"Funnel Stage",
      "type": "text",
      "default" : "landing_page"
    },
    {
      "id": "dataModule",
      "label":"Module",
      "type": "text",
      "default" : "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label":"Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label":"Event Value",
      "type": "text",
      "default" : "shop_anchor"
    },
    {
      "id": "itemId",
      "label":"Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label":"Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label":"Item Name",
      "type": "text"
    }
  ],
  "presets": [
    {
      "name": "Deal of day"
    }
  ]
}
{% endschema %}
