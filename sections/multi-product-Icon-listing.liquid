<style>
   .details-listing-section li{
    background-image:url({{'list-icon.png' | asset_url}});
  }
</style>

<div data-section="{{ section.settings.related_product.title | handle }}" class="{{section.settings.background}} list-image-block {{ section.settings.className }}" >
        <div class="mobile-padding-y image-with-text">
            <div class="">
                <h2 class="heading-2 text-center theme-text mt-0 pt-5  m-heading-2">{{section.settings.heading}}</h2>
          {%if section.settings.subtext == ''%}
          <p class="heading-4 theme-text  text-center mb-5">{{section.settings.subtext}}</p>
          {%endif%}
              <div class="d-flex flex-wrap justify-content-between align-items-center list-image-block-inner">
                <div class="w-50 {% if section.settings.layout %} order-2 {%endif%}">
                    <div class="two-women">
                      {% if section.settings.image %}
                      	{% assign mImage = section.settings.image | img_url: '800x' %}
                        <img loading="lazy" src="{{mImage}}" width="800px" height="800px" class="img-responsive w-100 mobile-hide" alt="">
                      {% assign mImage = section.settings.mimage | img_url: '800x' %}
                        <img loading="lazy" src="{{mImage}}" width="800px" height="800px" class="img-responsive w-100 desktop-hide" alt="">
                  	  {%endif%}  
                  </div>
                </div>
                <div class="w-50  d-flex justify-content-center {% if section.settings.layout %} order-1 {%endif%} ">
                    <div class="two-women-details  pb-2 {{section.settings.width}}">
                        <div class="normal-text {{section.settings.textcolor}}">
                              {% if section.settings.details %}
                              	{{section.settings.details}}
                              {% endif %}
                              <ul class="details-listing-section">
                              {% for  block in section.blocks %}
                                  <li>{{ block.settings.details }}</li>
                              {% endfor %}
                              </ul>
                            </div>
                            <a class="{% if section.settings.enable-popup %} show-popup {%endif%}" {% if section.settings.enable-popup %} data-popup="section{{section.id}}"{%endif%} href="{% if section.settings.enable-popup %}javascript:void(0);{% else %}{{section.settings.link}} {%endif%}">
                          	{% if section.settings.link %}
                            <span  class="{{section.settings.textcolor}} font-pier {{section.settings.btntype}}">{{section.settings.btntext}}</span>
                          	{% endif %}
                        </a>
                    </div>
                </div>
              </div>
            </div>
        </div>
    </div>
{% if section.settings.enable-popup %}
<div id="section{{section.id}}" class="popup">
  <span class="popup-overlay"></span>
  <div class="popup-inner">
    <span class="close-popup">&#215;</span>
    <div class="theme-text normal-text popup-text">{{section.settings.popup-text}}</div>
   </div>
</div>
{%endif%}

{% schema %}
  {
    "name": "Multi Product icons list",
    "class": "product-icon-listing",
    "settings": [
	{
      "type": "product",
      "id": "related_product",
      "label": "Section for which product"
    },

      {
      "type": "text",
      "id": "className",
      "label": "Add Section Class"
    },
      
{
            "type": "select",
            "id": "textcolor",
            "label": "Select text color",
            "options": [
              {
                "value": "white-text",
                "label": "White color"
              },
              {
                "value": "theme-text",
                "label": "Theme color"
              }
            ],
            "default": "white-text"
          },
{
            "type": "select",
            "id": "background",
            "label": "Select background color",
            "options": [
              {
                "value": "theme-gradient",
                "label": "Blue & White"
              },
              {
                "value": "pf-mission ",
                "label": "Yellow & Orange"
              },
{				
                "value": "theme-bg ",
                "label": "Theme Color"
              },
              {
                "value": "white-bg",
                "label": "White Color"
              }
            ],
            "default": "theme-gradient"
          },
{
            "type": "select",
            "id": "width",
            "label": "Select text area width",
            "options": [
              {
                "value": "w-90",
                "label": "90%"
              },
              {
                "value": "w-80",
                "label": "80%"
              },
{				
                "value": "w-70",
                "label": "70%"
              },
              {
                "value": "w-60",
                "label": "60%"
              }
            ],
            "default": "w-80"
          },
{
            "type": "checkbox",
            "id": "layout",
            "label": "Image on right"
            
          },
{
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
{
      "type": "text",
      "id": "subtext",
      "label": "Text"
    },
{
      "type": "image_picker",
      "id": "image",
      "label": "Add Desktop Image"
    },
{
      "type": "image_picker",
      "id": "mimage",
      "label": "Add Mobile Image"
    },
{
      "type": "richtext",
      "id": "details",
      "label": "Detail Text"
    },
{
      "type": "url",
      "id": "link",
      "label": "Add link"
    },
{
      "type": "text",
      "id": "btntext",
      "label": "Button label"
    },
{
            "type": "select",
            "id": "btntype",
            "label": "Select button Type",
            "options": [
              {
                "value": "read-more-link",
                "label": "Link"
              },
              {
                "value": "btn",
                "label": "Button"
              } 
              
            ],
            "default": "read-more-link"
          },
{
      "type": "header",
      "content": "Mobile"
    },

{
            "type": "checkbox",
            "id": "heading-position",
            "label": "Heading After Image"
            
          }
	],
	"blocks": [
      {
        "type": "list",
        "name": "listing item",
        "settings": [ 
         
  {
            "type": "text",
            "id": "details",
            "label": "description"
          }

        ]
      }
	],
	"presets": [
		{
			"name": "Multi Product icons list"
		}
	]
  }
{% endschema %}


