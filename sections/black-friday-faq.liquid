<div class="bf-faq value-sans {{ section.settings.class }}" style="background-color: {{ section.settings.color_bg }}">
  <div class="bf-faq-inner mx-auto">
    <div class="faq-section-2-heading text-center">
      <h3 class="faq-heading value-bold blue-text">{{ section.settings.heading }}</h3>
    </div>
    <div class="faqBlockWrapper">
      {% for block in section.blocks %}
        <div class="faq">
          <details class="faq-acc-2"{% if block.settings.open %} open="true"{% endif %}>
            <summary class="faq-que-2 value-bold">{{ block.settings['faq-question'] }}</summary>
            <p class="mt-2 faq-ans-2">{{ block.settings['faq-ans'] }}</p>
          </details>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% style %}
  .bf-faq {
    display: flex;
  }

  .bf-faq .bf-faq-inner {
    padding: 80px 112px;
    width: 100%;
    max-width: 1440px;
  }
  
  .bf-faq .faq-section-2-heading .faq-heading {
    font-size: 36px;
    font-weight: 700;
    padding-bottom: 80px;
  }
  
  .bf-faq .faq-que-2 {
    font-family: "Value-Sans";
    font-size: 18px;
    font-weight: 600;
    color: #161718;
    list-style: none;
    position: relative;
    padding-right: 30px;
    cursor: pointer;
  }
  
  .bf-faq .faq-ans-2 {
    font-weight: 400;
  }
  
  .bf-faq .faq-que-2::-webkit-details-marker {
    display: none;
  }
  
  .bf-faq .faq-que-2:after {
    content: "";
    position: absolute;
    right: 0;
    width: 24px;
    height: 24px;
    background-image: url("https://cdn.shopify.com/s/files/1/0360/1347/3931/files/plus-circle.svg?v=1699259415");
    background-repeat: no-repeat;
    background-size: cover;
    top: 50%;
    transform: translateY(-50%);
  }
  
  .bf-faq .faq-acc-2[open] .faq-que-2:after {
    background-image: url("https://cdn.shopify.com/s/files/1/0360/1347/3931/files/minus-circle.svg?v=1699259415") !important;
  }
  
  .bf-faq .faq-acc-2 .faq-que-2 ~ * {
    font-family: "Value-Sans";
    color: #A0A1A7;
    font-size: 16px;
    line-height: 24px;
  }
  
  .bf-faq .bf-faq .faq {
    border-bottom: 0;
    border-top: 1px solid #EAEAEB;
  }
  
  .bf-faq .faq-acc-2 {
    margin: 24px 0 32px 0;
  }

  .bf-faq .blue-text {
    color: #3350B4 !important;
  }
  
  @media (max-width: 768px) {
    .bf-faq .bf-faq-inner {
      padding: 64px 16px;
    }
    
    .bf-faq .faq-section-2-heading .faq-heading {
      font-size: 30px;
      text-align: left !important;
      padding-bottom: 32px;
    }
    
    .bf-faq .faq-que-2 {
      font-size: 16px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Black Friday FAQ",
  "class": "faq-section",
  "settings": [
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background color",
      "default": "#fff"
    },
    {
      "type": "text",
      "id": "class",
      "label": "Section Class"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "faq",
      "settings": [
        {
          "type": "checkbox",
          "id": "open",
          "label": "Default Open",
          "default": false
        },
        {
          "type": "text",
          "id": "faq-question",
          "label": "FAQ QUE"
        },
        {
          "type": "richtext",
          "id": "faq-ans",
          "label": "FAQ ANS"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Black Friday FAQ"
    }
  ]
}
{% endschema %}
