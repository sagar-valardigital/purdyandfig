{% assign product = section.settings.landingproduct %}
{% assign s_variant = product.selected_or_first_available_variant %}

<style type="text/css">
  .custom-pf228-buybox .gp-5-points li span.fw-400,
  .custom-pf228-buybox .gp-5-points li span.market-place-currency {
    font-size: 16px;
  }
  .custom-pf228-buybox .heading-3 {
    font-weight: 600;
  }

.buy-box-currency {
  font-family: "GT Super";
}

.guarantee-text {
  font-size: 12px !important;
  font-weight: 600;
  line-height: 18px;
}

.g4-btn-wrapper {
  margin-top: 8px !important;
}

.reskin--buybox .bg-white.gp-4-details .gp-5-bottom .gp-5-price-points {
  padding-bottom: 0 !important;
}

.reskin--buybox .bg-white.gp-4-details .gp-5-bottom .gp-5-price-points > ul {
  padding: 16px 0 0 3px !important;
}

.reskin--buybox .bg-white.gp-4-details .gp-5-bottom .gp-5-points li {
  padding-left: 28px !important;
}

.gp-4-details .deleted-price {
  font-size: 24px;
  font-weight: 400;
  color: #616161;
}

span.gp-5-del-price:after {
  background: #616161 ;
  top: calc(60% - 2px);
}

.gp-5-sell-price {
  font-size: 26px;
  font-weight: 400;
  color: #212121;
  padding-left: 5px;
}
.slick-next svg path,
.slick-prev svg path {
  fill: #11322c !important;
}

.new-product-gallery-wrapper .slick-dots li.slick-active button:before {
  color: #11322c !important;
}


  @media (max-width: 768px) {
    .custom-pf228-buybox .gp-5-points li span.fw-400,
    .custom-pf228-buybox .gp-5-points li span.market-place-currency {
      font-size: 14px;
    }
    .custom-pf228-buybox .star-img {
      width: 12px;
      margin-right: 0px;
    }
    .custom-pf228-buybox .moneybackguarateetext {
      margin-top: 8px;
      margin-bottom: unset;
    }

  .gp-4-details .deleted-price {
  font-size: 21px;
}

.gp-5-sell-price {
  font-size: 22px;
}


    .reskin--buybox .gp-5-top, .reskin--buybox .gp-5-bottom {
        background-color: transparent !important;
    }
  .reskin--buybox .gp-5-bottom {
    padding-top: 0 !important;
  }

  .reskin--buybox .bg-white.gp-4-details .gp-5-bottom .gp-5-price-points > ul {
    padding-top: 8px !important;
  }

  }

  @media (max-width: 560px) {
    .custom-pf228-buybox .gp-5-price-points {
      margin-bottom: 8px !important;
    }
  }
</style>

<div
  class="{{ section.settings.className }} reskin--buybox global-product-5 py-80 custom-pf228-buybox"
  id="id_{{ section.id }}"
  style="background-color:{{section.settings.background}} !important;"
  x-data="{qty:1}"
>
  <div class="">
    <div class=" mb-4 container heading-2-wrapper">
      {% if section.settings.mainheading != '' %}
        <h2 class="heading-2 blue-text-3 mt-0 text-center font-gtsuper m-text-left">
          {{ section.settings.mainheading }}
        </h2>
      {% endif %}
    </div>
    {% if section.settings['before-mobile'] %}
      <div class="mb-3 container">
        <div class="gp-5-top  desktop-hide ">
          <h2 class="heading-3 font-lausanne fw-400  mb-0 mt-0">
            {{ section.settings.heading }}
          </h2>
          {% if section.settings.mainsubheading != '' -%}
            <p class="font-lausanne fw-200  mt-2 mb-2 gp-5-subheading">{{ section.settings.mainsubheading }}</p>
          {%- endif %}
          <div class="text-left mt-2 reviews-scroll-block">
