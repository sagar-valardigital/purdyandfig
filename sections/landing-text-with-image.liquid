{% if section.settings.enable%}
<div class="{{section.settings.background}} {{ section.settings.className }}">
        <div class="mobile-padding-y image-with-text">
            <div class="">
                <h2 class="heading-2  {{section.settings.textcolor}} {% if section.settings.heading-position%} mobile-hide {% endif %} desktop-hide mt-0 text-center">
                    {{section.settings.heading}}
                </h2>
              <div class="d-flex flex-wrap justify-content-between align-items-center">
                <div class="w-50 {% if section.settings.layout %} order-2 {%endif%}">
                    <div class="two-women">
                      {% if section.settings.image %}
                      	{% assign mImage = section.settings.image | img_url: '800x' %}
                        <img loading="lazy" src="{{mImage}}" width="800px" height="800px" class="img-responsive w-100" alt="">
                  	  {%endif%}  
                  </div>
                </div>
                <div class="w-50  d-flex justify-content-center {% if section.settings.layout %} order-1 {%endif%} ">
                    <div class="two-women-details  pb-2 {{section.settings.width}}">
                        
                            <h2 class="heading-2 {{section.settings.textcolor}} {% if section.settings.heading-position%} {% else %}mobile-hide{% endif %}">{{section.settings.heading}}
                            </h2>
                            <div class="normal-text {{section.settings.textcolor}}">
                              	{{section.settings.details}}
                            </div>
                            <a class="{% if section.settings.enable-popup %} show-popup {%endif%}" {% if section.settings.enable-popup %} data-popup="section{{section.id}}"{%endif%} href="{% if section.settings.enable-popup %}javascript:void(0);{% else %}{{section.settings.link}} {%endif%}">
                          	{% if section.settings.link %}
                            <span  class="{{section.settings.textcolor}} font-pier {{section.settings.btntype}}">{{section.settings.btntext}}</span>
                          	{% endif %}
                        </a>
                    </div>
                </div>
              </div>
            </div>
        </div>
    </div>
{% if section.settings.enable-popup %}
<div id="section{{section.id}}" class="popup">
  <span class="popup-overlay"></span>
  <div class="popup-inner">
    <span class="close-popup">&#215;</span>
    <div class="theme-text normal-text popup-text">{{section.settings.popup-text}}</div>
   </div>
</div>
{%endif%}
{% endif %}
{% schema %}
  {
    "name": "Landing Image with Text",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },
      {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
{
            "type": "select",
            "id": "textcolor",
            "label": "Select text color",
            "options": [
              {
                "value": "white-text",
                "label": "White color"
              },
              {
                "value": "theme-text",
                "label": "Theme color"
              }
            ],
            "default": "white-text"
          },
{
            "type": "select",
            "id": "background",
            "label": "Select background color",
            "options": [
              {
                "value": "theme-gradient",
                "label": "Blue & White"
              },
              {
                "value": "pf-mission ",
                "label": "Yellow & Orange"
              },
{				
                "value": "theme-bg ",
                "label": "Theme Color"
              },
              {
                "value": "white-bg",
                "label": "White Color"
              }
            ],
            "default": "theme-gradient"
          },
{
            "type": "select",
            "id": "width",
            "label": "Select text area width",
            "options": [
              {
                "value": "w-90",
                "label": "90%"
              },
              {
                "value": "w-80",
                "label": "80%"
              },
{				
                "value": "w-70",
                "label": "70%"
              },
              {
                "value": "w-60",
                "label": "60%"
              }
            ],
            "default": "w-80"
          },
{
            "type": "checkbox",
            "id": "layout",
            "label": "Image on right"
            
          },
{
      "type": "html",
      "id": "heading",
      "label": "Heading"
    },
{
      "type": "image_picker",
      "id": "image",
      "label": "Add Image"
    },

{
      "type": "richtext",
      "id": "details",
      "label": "Detail Text"
    },
{
      "type": "url",
      "id": "link",
      "label": "Add link"
    },
{
      "type": "text",
      "id": "btntext",
      "label": "Button label"
    },
{
            "type": "select",
            "id": "btntype",
            "label": "Select button Type",
            "options": [
              {
                "value": "read-more-link",
                "label": "Link"
              },
              {
                "value": "btn",
                "label": "Button"
              } 
              
            ],
            "default": "read-more-link"
          },
{
      "type": "header",
      "content": "Mobile"
    },

{
            "type": "checkbox",
            "id": "heading-position",
            "label": "Heading After Image"
            
          },
{
	"type": "header",
      "content": "Popup"
},
{
            "type": "checkbox",
            "id": "enable-popup",
            "label": "Enable popup"
            
          },
{
            "type": "text",
            "id": "popup-text",
            "label": "Popup Content"
            
          }
	],
	
	"presets": [
		{
			"name": "Landing Image With Text"
		}
	]
  }
{% endschema %}


