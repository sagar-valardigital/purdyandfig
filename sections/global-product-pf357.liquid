<script>
    document.addEventListener("DOMContentLoaded", function () {
        var sourceElement = document.querySelector(".link-to-section");
        if(sourceElement) {
            var sourceId = sourceElement.id;
            var targetElements = document.querySelectorAll(".set-buybox-id");
            targetElements.forEach(function (el) {
                el.id = sourceId;
            });
        }
    });
  
    /* function to add the product to cart */
    const additemstocart = (form, event) => {
        event.preventDefault();

        const targetBTN = $(event.target);
        targetBTN.addClass('loading');

        fetch('/cart.js')
        .then(response => response.json())
        .then(cart => {
            let allDiscounts = new Set();
            cart.items.forEach(item => {
                item.discounts.forEach(discountItem => {
                    allDiscounts.add(discountItem.title);
                });
            });
            let discountsString = Array.from(allDiscounts).join(',');
          
            const additemtocart = (data) => {
                return fetch('/cart/add.js', {
                    method: 'POST',
                    body: data
                }).then(response => response.json());
            }
    
            // Use form data directly for all variants - no bundling
            let formData = new FormData(form);
            let discount;
            
            // Handle discount logic
            const formDiscount = form.querySelector('input[name="discount"]') ? form.querySelector('input[name="discount"]').value : '';
            
            if(discountsString && formDiscount !== discountsString) {
                if(formDiscount) {
                    if(!discountsString.includes(formDiscount)) {
                        discountsString = formDiscount + ',' + discountsString;
                    }
                }
            } else if(formDiscount) {
                discountsString = formDiscount;
            }

            discount = discountsString;
          
            additemtocart(formData).then(response => {
                if(response.status === 'error') {
                  throw new Error(response.message);
                }
    
                targetBTN.removeClass('loading');

                if(discount) {
                    window.location.href = '/checkout?discount=' + encodeURIComponent(discount);
                } else {
                    window.location.href = '/checkout';
                }
            }).catch(error => {
                targetBTN.removeClass('loading');
                console.error("Error:", error);
            });
        });
    };
</script>

