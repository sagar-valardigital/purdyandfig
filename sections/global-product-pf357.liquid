<script>
    const clickID = document.querySelectorAll('.gp--product-variant');
    clickID.forEach((currentID, index) => {
        currentID.addEventListener('click', () => {
            const selectedVariant = currentID.getAttribute('data-variantclass');

            document.querySelectorAll('.pf-tab').forEach((scentTab, index) => {
                scentTab.classList.remove('active');
            });
          
            document.querySelectorAll('.pf-tab-content').forEach((tabContent, index) => {
                tabContent.classList.remove('active');
            });
          
            if(selectedVariant == 'variant_1') {
                document.querySelector('.tab-heading-1').classList.add('active');
                document.querySelector('.tab-1').classList.add('active');
            } else {
                document.querySelector('.tab-heading-2').classList.add('active');
                document.querySelector('.tab-2').classList.add('active');
            }
        });
    });
</script>

