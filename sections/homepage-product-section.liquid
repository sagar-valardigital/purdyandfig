            <div class="d-flex flex-wrap justify-content-between align-items-center container">
              <div class="w-50 {% if section.settings.layout %} order-2 {%endif%}">
                  <div class="two-women position-relative">
  {% if section.settings.tag !='' %} <span class="tag theme-text">{{ section.settings.tag }}</span> {% endif %}
                      <div class="product-gallery">
  {% assign product = section.settings.landingproduct %}
                  {% for image in product.images %}
                    	<div class="main-product-img">
                     <picture>
  <source media="(min-width:650px)" srcset="{{ image | img_url: '800x'}}">
  <source media="(max-width:650px)" srcset="{{ image | img_url: '500x'}}">
  <img  {% if forloop.index == 1 %} skip-lazy {% else %} loading="lazy" {% endif %}  data-id="{{image.id}}" class="img-responsive w-100 lazy"  src="{{ image | img_url: '800x'}}" width="800px" height="700px" alt="{{ image.alt }}">
</picture> 
                       </div>  
                  {% endfor %}
                </div>
                     
                </div>
              </div>
              <div class="w-50  d-flex justify-content-center {% if section.settings.layout %} order-1 {%endif%} ">
                  <div class="two-women-details  pb-2 {{section.settings.width}}">
                      
                          <h2 class="heading-3 lander-product-heading {{section.settings.textcolor}}">{{ product.title }}
                          </h2>
  <div class="text-left">
  <div class="font-pier theme-text mt-3 mb-2 stars-img-review mobile-hide">
