                      <span class="total-reviews ">6300+ Reviews</span></div></div>
                    <div class="theme-text text-left">
            <h2 class="heading-3">
£{{ section.settings.price }} {% if section.settings.delPrice != '' %}<small class="text-gray"><del>£{{ section.settings.delPrice }}</del></small> {% endif %} 
</h2>
          </div>
                          <div class="theme-text">
                            
              <h3 class="font-value mt-4 bb-points">{{ section.settings.subtext }}</h3>
              <ul class="lander-points">
                {% for block in section.blocks %}
                  {% if block.type == 'text' %}
                <li style="background-image:url({{ 'lander-check.png' | asset_img_url }})"  class="">{{ block.settings.listItem }}</li>
                    {% endif %}
                  {% endfor %}
                
              </ul>
          </div>
           
          <form @submit.prevent="console.log('submitted')"  x-ref="product_form"  enctype="multipart/form-data" accept-charset="UTF-8" id="product_form_{{product.id}}" class="shopify-product-form"  data-product-id="{{product.id}}" action="/cart/add">
            <input type="hidden" name="id" value={{ s_variant.id }}>
            <input type="hidden" name="quantity" value="1">
            <div class="selling_plan_wrapper d-none">
                     {% if  product.selling_plan_groups[0] %}
                     <select name="selling_plan" id="selling_plan">
                     {% for plan in product.selling_plan_groups[0].selling_plans %}
							<option value="{{plan.id}}">{{plan.name}}</option>
            
     				{% endfor %} 
                      </select>
                    {% endif %}
                       <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
                              </div>
          </form>
        <div class="text-left mt-3" style="max-width:400px">
          <span  class="btn w-100 theme-btn  checkout-lander-btn {% if section.settings.outOfStock %} bb-disable {% endif %}" x-on:click="Purdy.AddToCart($refs.product_form)" > {% if section.settings.outOfStock %} Out of Stock {% else %} Quick Buy {% endif %}</span><br>
            <small class="theme-text d-block text-center w-100">{{ section.settings.ctaDetails }}</small>
        </div>
                   
              </div>
            </div>
          </div>
      </div>
  </div>

{% endif %}


{% schema %}
{
  "name": "HomePage Product Section",
  "settings": [
  {
    "type": "checkbox",
    "id": "enable",
    "label": "Uncheck to hide the section",
    "default": true
  },
    {
    "type": "checkbox",
    "id": "outOfStock",
    "label": "Enable If product out Of Stock",
    "default": true
  },
    {
    "id": "isSub",
    "label": "Product subscription",
    "type": "checkbox",
    "default": false
  },
    {
    "id": "landingproduct",
    "label": "Choose the landing product",
    "type": "product"
  },
  {
      "type": "select",
      "id": "textcolor",
      "label": "Select text color",
      "options": [
        {
          "value": "white-text",
          "label": "White color"
        },
        {
          "value": "theme-text",
          "label": "Theme color"
        }
      ],
      "default": "white-text"
