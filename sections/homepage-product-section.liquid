              <h2 class="heading-2 theme-text mt-0 text-center ">
                  {{section.settings.mainheading}}
              </h2>
    {% endif %}
  {% if section.settings.mainsubheading != '' %}
  <p class="normal-text theme-text mt-0 text-center ">
                  {{section.settings.mainsubheading}}
              </p>
{% endif %}
          </div>
    <div class="text-center">
  <div class="font-pier theme-text mt-3 mb-2 stars-img-review desktop-hide">
