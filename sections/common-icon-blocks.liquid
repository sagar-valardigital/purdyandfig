{% if section.settings.show_hide_block %}
  {% assign image = section.settings.bgImage | img_url :'1000x' %}
<div class="block-section py-80 icon-blocks-2 {{ section.settings.class }}" {% if section.settings.bgImage %}style="background-image:url({{ image }}); background-size:cover; background-position: center bottom;" {% endif %}>
  <div class="container">
    <h2 class="heading-2 text-center m-text-left blue-text value-bold mt-0 ">
      {{ section.settings.heading }}
    </h2>
    <div class="d-flex flex-wrap justify-content-between  theme-text my-1 icon-blocks-2-wrapper">
      {% if section.blocks.size == 0 %}
      <div class="w-33 p-3 icon-block-2">
        <div class="text-center ">
          <h3 class="heading-4 value-bold blue-text my-3 ">Powerful</h3>
          <div class="block-img-wrappers mb-2">
            <img
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Frame_48096340_1.png?v=1699517603"
              width="57"
              height="56"
              alt="icon"
            >
          </div>

          <p class="value-sans normal-text">
            Super concentrated formulas that effortlessly clean and leave all surfaces gleaming and streak free
          </p>
        </div>
      </div>

      <div class="w-33 p-3 icon-block-2">
        <div class="text-center ">
          <h3 class="heading-4 value-bold blue-text my-3 ">Natural</h3>
          <div class="block-img-wrappers mb-2">
            <img
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Frame_48096340_3.png?v=1699517603"
              width="57"
              height="56"
              alt="icon"
            >
          </div>

          <p class="value-sans normal-text">
            Beautifully scented, plant-based refills arrive at your door every three months, ready to mix with tap water
          </p>
        </div>
      </div>

      <div class="w-33 p-3 icon-block-2">
        <div class="text-center ">
          <h3 class="heading-4 value-bold blue-text my-3 ">Reusable</h3>
          <div class="block-img-wrappers mb-2">
            <img
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Frame_48096340.png?v=1699517604"
              width="57"
              height="56"
              alt="icon"
            >
          </div>

          <p class="value-sans normal-text">
            Refillable glass bottles, fully recyclable packaging and zero single use plastic
          </p>
        </div>
      </div>
      {% else %}
        {% for block in section.blocks %}
        <div class="w-33 p-3 icon-block-2 ">
          <div class="text-center ">
            {% if block.settings.icon_block_title != blank %}
            <h3 class="heading-4 value-bold blue-text my-3 ">{{ block.settings.icon_block_title }}</h3>
            {% endif %}
            
            {% if block.settings.icon_block_image %}
            <div class="block-img-wrappers mb-2">
              <img
                src="{{ block.settings.icon_block_image | image_url }}"
                width="57"
                height="56"
                alt="icon"
              >
            </div>
            {% endif %}

            {% if block.settings.icon_block_description != blank %}
            <p class="value-sans normal-text">
              {{ block.settings.icon_block_description }}
            </p>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      {% endif %}   
    </div>
  </div>
</div>
{% endif %}

{% schema %}
 {
   "name": "Common Icon Blocks",
   "settings": [
      {
          "type": "text",
          "id" : "heading",
          "label": "Heading",
          "default": "You've never enjoyed cleaning this much"
      },
     {
          "type": "text",
          "id" : "class",
          "label": "Class"
      },
     {
          "type": "image_picker",
          "id" : "bgImage",
          "label": "Background Image"
      },
      {
          "type": "checkbox",
          "id": "show_hide_block",
          "label": "Show Icon Block",
          "default": true
      }
    ],
    "blocks": [
      {
          "type": "iconblocks",
          "name": "Icon Block",
          "limit": 3,
          "settings": [
              {
                "type": "text",
                "id": "icon_block_title",
                "label": "Title"
              },
              {
                "type": "textarea",
                "id": "icon_block_description",
                "label": "Description"
              },
              {
                "type": "image_picker",
                "id": "icon_block_image",
                "label": "Icon Image"
              }
          ]
      }
    ],
    "presets": [
      {
          "name": "Icon blocks 2"
      }
    ]
 }
{% endschema %}
