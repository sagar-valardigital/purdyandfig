<div class="block-section py-80 toggle-blocks-2" style="">
  <div class="container">
    <div class="text-center m-text-left">
      <h2 class="heading-2  blue-text value-bold mt-0 ">One non-toxic cleaner for all surfaces</h2>
      <p class="black-text value-medium normal-text m-text-left">
        Ultra-concentrated, naturally scented eco-friendly cleaning power. Dilute with tap water to clean all home
        surfaces.
      </p>
    </div>
    <div class="toggle-blocks-wrapper">
      <div class="toggle-blocks-options">
        {% for block in section.blocks %}
          <div
            class="toggle-option value-bold {% if forloop.first %} active {% endif %}"
            data-image="{{ block.settings.toggle_image }}"
          >
            {{ block.settings.toggle_text }}
          </div>
        {% endfor %}
      </div>
      <div class="toggle-block-img">
        {% for block in section.blocks %}
          {% if forloop.first %}
            <video class="toggle-image w-100 h-100" width="320" height="240" playsinline loop autoplay muted>
              <source src="{{ block.settings.toggle_image }}" type="video/mp4">
            </video>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div class="mt-4 desktop-hide">
      <span
        class="d-block text-center blue-starterkit-btn click-scroll m-auto"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >GET YOUR OFFER</span
      >
    </div>
  </div>
</div>

{% schema %}
 {
   "name": "Toggle Image Block",
   "settings": [
{
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      }
     ,
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
    {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
],
"blocks": [
      {
        "type": "text",
        "name": "block",
        "settings": [
          {
      "type": "text",
      "id": "toggle_image",
      "label": "Add Video URL"
    },

{
      "type": "text",
      "id": "toggle_text",
      "label": "Text"
    }
        ]
      }
	],
"presets": [
	{
		"name": "Toggle Image Block"
	}
]
 }
{% endschema %}
