                    <span class="total-reviews" style="color:{{ section.settings.titlecolor }}" > Over ({{settings.gloabalreviews}}+ reviews)</span>
                    </div>
                      <br>
                {% if section.settings.link %}
                  <div class="banner-btn-wrapper text-center">
                    <span class="font-pier my-1 d-inline-block desktop-hide" style="color:{{ section.settings.subtextcolor }};">{{section.settings.btnSubText}}</span>
                    
                      <a href="#{{section.settings.link}}" class="btn banner-btn w-100"><span>{{section.settings.btnText}}</span></a>
                      <br>
                      <span class="font-pier my-1 d-inline-block mobile-hide" style="color:{{ section.settings.subtextcolor }};">{{section.settings.btnSubText}}</span>
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
      </div>
  </div>

{% schema %}
{
  "name": "landing Page Banner",
  "settings": [
    {
      "id": "logoHide",
      "label": "Hide Mobile Banner Logo",
      "type": "checkbox",
      "default": false
	},
    {
      "id": "desktopimage",
      "label": "Desktop Image",
      "type": "image_picker"
    },
	{
      "id": "mobileimage",
      "label": "Mobile Image",
      "type": "image_picker"
    },
	{
      "id": "enablelink",
      "label": "Enable Banner Text",
      "type": "checkbox"
	},
	{
      "id": "title",
      "label": "Banner Title",
      "type": "text"
    },
    {
      "id": "titlecolor",
      "label": "Title text color",
      "type": "color",
      "default":"#ffffff"
	},
	{
      "id": "subtext",
      "label": "Banner Sub Text",
      "type": "html"
    },
    {
      "id": "subtextcolor",
      "label": "Sub Text color",
      "type": "color",
      "default":"#ffffff"
	},
{
      "id": "btnText",
      "label": "Button Label",
      "type": "text",
	  "default" : "SHOP NOW"
	},
	{
      "id": "link",
      "label": "Link",
      "type": "text"
	},
{
      "id": "textcolor",
      "label": "Button text color",
      "type": "color"
	},
{
      "id": "bgcolor",
      "label": "Button Background color",
      "type": "color"
	},
{
      "id": "btnSubText",
      "label": "Button Sub Text",
      "type": "text"
	}
  ],
  "presets": [
		{
			"name": "Landing Page Banner"
		}
	]
}
{% endschema %}


