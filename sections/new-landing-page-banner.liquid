<style>
  {%- assign DimageURL = section.settings.desktopimage | img_url:"2000x" -%}
  {%- assign MimageURL = section.settings.mobileimage | img_url:"768x" -%}
  .main-banner{background-image:url({{DimageURL}})}
  .banner-btn{color:{{section.settings.textcolor}};background-color:{{section.settings.bgcolor}};}
  @media(max-width:768px){
  .main-banner{background-image:url({{MimageURL}})}
    .landing-page .banner-text-wrapper {top:10px;height:calc(100% - 15px);}
  }
</style>
<div class="main-banner">
      <div class="banner-text-wrapper">
          <div class="container">
            {% if section.settings.enablelink %}
              <div class="banner-text">
                  
                  <div class="text-wrapper">
              <img loading="lazy"
                            class="img-responsive logo desktop-hide m-auto mb-2 {% if section.settings.logoHide %} mobile-hide{% endif %}"
                            width="35px"
                            height="35px"
                            alt="{{ section.settings.logo.alt | default: shop.name | escape }}" src="{{'Logo.svg' | asset_url}}">
                      <h1 class="heading-2 font-value m-0 mb-3" style="color:{{ section.settings.titlecolor }}">{{section.settings.title}}</h1>
                      <div class="font-pier mb-3" style="color:{{ section.settings.subtextcolor }}">{{section.settings.subtext}}</div>
                  </div>
                <div class="banner-review font-pier"><span class="star-img">
