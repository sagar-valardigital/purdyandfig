{% assign product = section.settings.landingproduct %}
{% assign s_variant = product.selected_or_first_available_variant %}
{% assign product2 = section.settings.landingproduct2 %}
{% assign s_variant2 = product2.selected_or_first_available_variant %}
<div
  class="{{ section.settings.className }} global-product-4 py-80"
  id="id_{{ section.id }}"
  style="background-color:{{section.settings.background}};"
  x-data="{qty:1}"
>
  <div class="">
    <div class=" mb-4 container">
      {% if section.settings.mainheading != '' %}
        <h2 class="heading-2 blue-text mt-0 text-center value-bold m-text-left">
          {{ section.settings.mainheading }}
        </h2>
      {% endif %}
    </div>

    <div class="d-flex product-block-4-wrapper flex-wrap justify-content-between align-items-start container">
      <div class="w-50 {% if section.settings.verticalThumbnails %}vertical-thumbnails-slider-wrapper{% endif %} {% if section.settings.layout %} order-2 {%endif%}">
        <div class="two-women position-relative">
          {% if section.settings.tag != '' %}
            <span class="tag theme-text value-sans">{{ section.settings.tag }}</span>
          {% endif %}
          {% assign mediacount = 0 %}
          <div class="gp-4-product-gallery  new-product-gallery-wrapper">
            {% for block in section.blocks %}
              {% if block.type == 'productImage' %}
                {% assign image = block.settings.image %}
                {% if block.settings.is_video %}
                  <div class="main-product-img">
                    <video
                      class=" w-100 lazy"
                      poster="{{ block.settings.poster | img_url : '800x'}}"
                      width="520"
                      height="520"
                      controls
                    >
                      <source src="{{ block.settings.videoURL }}" type="video/mp4">
                    </video>
                  </div>
                {% else %}
                  <div class="main-product-img">
                    <picture>
                      <source media="(min-width:650px)" srcset="{{ image | img_url: '800x'}}">
                      <source media="(max-width:650px)" srcset="{{ image | img_url: '400x'}}">
                      <img
                        {% if forloop.index == 1 %}
                          skip-lazy
                        {% else %}
                          loading="lazy"
                        {% endif %}
                        data-id="{{image.id}}"
                        class="img-responsive w-100 h-auto lazy"
                        src="{{ image | img_url: '800x'}}"
                        width="800"
                        height="700"
                        alt="{{ image.alt }}"
                      >
                    </picture>
                  </div>
                {% endif %}
              {% endif %}
              {% assign mediacount = mediacount | plus: '1' %}
            {% endfor %}
          </div>
          <div
            class="gp-4-product-gallery-thumb  new-product-gallery-wrapper {% if mediacount < 6 %} slider-transform-none {% endif %}"
          >
            {% for block in section.blocks %}
              {% if block.type == 'productImage' %}
                {% assign image = block.settings.image %}
                {% if block.settings.is_video %}
                  <div class="main-product-img position-relative">
                    <picture>
                      <source media="(min-width:650px)" srcset="{{ block.settings.poster  | img_url: '200x'}}">
                      <source media="(max-width:650px)" srcset="{{ block.settings.poster  | img_url: '200x'}}">
                      <img
                        {% if forloop.index == 1 %}
                          skip-lazy
                        {% else %}
                          loading="lazy"
                        {% endif %}
                        data-id="{{block.settings.poster.id}}"
                        class="img-responsive w-100 h-auto lazy"
                        src="{{ block.settings.poster  | img_url: '200x'}}"
                        width="200"
                        height="200"
                        alt="{{ image.alt }}"
                      >
                    </picture>
                    <img
                      src="{{ 'play-button.png' | asset_img_url : '20x20' }}"
                      width="20"
                      height="20"
                      class="pb-center"
                    >
                  </div>
                {% else %}
                  <div class="main-product-img">
                    <picture>
                      <source media="(min-width:650px)" srcset="{{ image | img_url: '200x'}}">
                      <source media="(max-width:650px)" srcset="{{ image | img_url: '200x'}}">
                      <img
                        {% if forloop.index == 1 %}
                          skip-lazy
                        {% else %}
                          loading="lazy"
                        {% endif %}
                        data-id="{{image.id}}"
                        class="img-responsive w-100 h-auto lazy"
                        src="{{ image | img_url: '200x'}}"
                        width="200"
                        height="200"
                        alt="{{ image.alt }}"
                      >
                    </picture>
                  </div>
                {% endif %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="w-50  d-flex justify-content-center">
        <div class="w-90  pb-2 bg-white gp-4-details" id="{{ section.settings.p_id }}">
          <div class="text-left">
            <div class="value-sans theme-text mt-0 mb-2 stars-img-review ">
              <span class="star-img">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 509.9 488.54">
                  <defs><style>.cls-1{fill:#3350B4;}</style></defs><g id="Layer_2" data-name="Layer 2"><g id="Layer_1-2" data-name="Layer 1"><path class="cls-1" d="M509.9,199c-6.46,16.14-21.36,24.42-33.37,35.23-27.73,25-56,49.36-84.17,73.87-2.35,2-2.78,3.81-2.1,6.79q15.89,69.25,31.52,138.58c2.72,12-.07,22.26-10.1,29.59s-20.66,7-31.22.67q-60.6-36.27-121.16-72.59c-3.1-1.86-5.3-2-8.46-.07-40.2,24.19-80.62,48-120.7,72.38C111.86,494.6,92.75,484.81,88.22,469a30,30,0,0,1-.17-15.23q15.61-68.55,31.32-137.09c1-4.18.37-6.76-3-9.72C81,276.22,45.92,245.29,10.7,214.48c-9.28-8.11-13-18-9.23-29.85,3.64-11.34,12-17.61,23.9-18.72q36.64-3.42,73.3-6.73c23.12-2.1,46.24-4.23,69.37-6.18,3.5-.29,4.63-2.29,5.8-5Q201.4,83.29,229,18.63C234,6.94,242.31-.07,255.18,0,267.83.07,276,7.06,280.89,18.54c18.16,42.68,36.54,85.27,54.51,128,2.11,5,5,6.28,9.9,6.71Q415.17,159.42,485,166c12.87,1.22,20.67,8.4,24.11,20.92.11.43.53.77.8,1.15Z"/></g></g>
                </svg>
