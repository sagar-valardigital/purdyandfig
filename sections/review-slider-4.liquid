            <span class="total-reviews gray-text value-sans">4.9</span>
          </div>
          <h2 class="heading-3 blue-text value-bold">Small acts, big impact: cleaning routines transformed</h2>
          <div class="rs-3-arrows hide-below-991">
            <span class="rs-left">
              <img
                alt="arrow"
                width="51"
                height="51"
                src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/arrow_circle_left.png?v=1699594069"
              >
            </span>
            <span class="rs-right ml-2">
              <img
                alt="arrow"
                width="51"
                height="51"
                src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/arrow_circle_right-1.png?v=1699594069"
              >
            </span>
          </div>
        </div>
        <div class="mt-4 hide-below-991">
          <span
            class="d-block text-center blue-starterkit-btn click-scroll"
            style="max-width:100%"
            data-target="{{ section.settings.scrollto }}"
            {% if section.settings.dataTrack %}
              data-tracked="true"
              data-title="{{ section.settings.dataTitle }}"
              data-module="{{ section.settings.dataModule }}"
              data-page="{{ page.url }}"
            {% endif %}
            >GET YOUR OFFER</span
          >
        </div>
      </div>
      <div class="w-75 pr-0">
        <div class="review-slider-3">
          {% for block in section.blocks %}
            <div class="rs-3-slide">
              <div class="d-grid">
                <div class="rs-3-user-wrapper">
                  <div class="rs-3-user">
                    <div class="hide-below-9911">
                      <h4 class="heading-4 black-text value-medium">{{ block.settings.heading }}</h4>
                      <p class=" value-sans rs3-review">{{ block.settings.review }}</p>
                      <span class="value-medium rs3-user-name">{{ block.settings.userName }}</span>
                    </div>
                  </div>
                </div>
                <div class=" position-relative">
                  <video
                    class="img-responsive w-100"
                    loading="lazy"
                    id="video_{{ block.id }}"
                    poster="{{ block.settings.poster | img_url : '400x' }}"
                    playsinline
                    {% if block.settings.autoplay %}
                      autoplay muted loop
                    {% endif %}
                  >
                    <source src="{{ block.settings.videoURL }}" type="video/mp4">
                  </video>
                  {% if block.settings.videoURL %}
                    <div class="video-pp-icon d-none">
                      <img
                        width="50"
                        height="50"
                        src="{{ 'play-button.png' | asset_img_url }}"
                        data-target="video_{{ block.id }}"
                        class="t-video-play"
                        alt="video"
                      >
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="w-100 hide-above-991">
        <div class="rs-3-arrows">
          <span class="rs-left">
            <img
              alt="arrow"
              width="48"
              height="48"
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/arrow_circle_left.png?v=1699594069"
            >
          </span>
          <span class="rs-right ml-2">
            <img
              alt="arrow"
              width="48"
              height="48"
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/arrow_circle_right-1.png?v=1699594069"
            >
          </span>
        </div>
        <div class="mt-4">
          <span
            class="d-block text-center blue-starterkit-btn click-scroll m-auto"
            style="max-width:100%"
            data-target="{{ section.settings.scrollto }}"
            {% if section.settings.dataTrack %}
              data-tracked="true"
              data-title="{{ section.settings.dataTitle }}"
              data-module="{{ section.settings.dataModule }}"
              data-page="{{ page.url }}"
            {% endif %}
            >GET YOUR OFFER</span
          >
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
 {
   "name": "Reviews Slider 4",
   "class": "review-slider-3-section",
   "settings": [
     {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      },
   {
     "type": "text",
     "id": "className",
     "label": "Section Class"
   },

     {
     "type": "color",
     "id": "bgColor",
     "label": "Background Color"
   }
     ,
    {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
      {
"id": "dataTitle",
"label":"Data Title",
"type": "text"
    }
    ,
    {
"id": "dataModule",
"label":"Data Module",
"type": "text"
    }
],
"blocks": [
     {
       "type": "text",
       "name": "Review",
       "settings": [

         {
     "type": "text",
     "id": "heading",
     "label": "Review Heading"
   },
         {
     "type": "text",
     "id": "review",
     "label": "Review"
   },
         {
     "type": "text",
     "id": "userName",
     "label": "User Name"
   }, {
      "type": "image_picker",
      "id": "poster",
      "label": "Add Image"
    },

{
      "type": "url",
      "id": "videoURL",
      "label": "Video URL"
    },
         {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Video autoplay"
    }
       ]
     }
],
"presets": [
	{
		"name": "Review Slider 4"
	}
]
 }
{% endschema %}
