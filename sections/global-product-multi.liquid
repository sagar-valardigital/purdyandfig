    },
    {
      "type": "text",
      "id": "className",
      "label": "Section Class"
    },
    {
      "type": "html",
      "id": "mainheading",
      "label": "Main Heading"
    },
    {
      "type": "html",
      "id": "mainsubheading",
      "label": "Sub Heading"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Product Title"
    },
    {
      "id": "subtext",
      "label": "Banner Sub Text",
      "type": "html"
    },
    {
      "id": "price",
      "label": "Price",
      "type": "text"
    },
    {
      "id": "delPrice",
      "label": "Compare Price",
      "type": "text"
    },
    {
      "id": "btnText",
      "label": "Button label",
