          "label": "Add list Class",
          "default": "1 show",
          "info": "add number 1, 2, 3 according to related variant number"
        },
        {
          "type": "text",
          "id": "listItem",
          "label": "Add Item"
        }
      ]
    },
    {
      "type": "productImage",
      "name": "Product Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Add Product Image"
        },
        {
          "type": "image_picker",
          "id": "mimage",
          "label": "Mobile Product Image"
        },
        {
          "type": "checkbox",
          "id": "is_video",
          "label": "Check if video added"
        },
        {
          "type": "url",
          "id": "videoURL",
          "label": "Add Video url"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Add Video poster"
        }
      ]
    },
    {
      "type": "aboutproduct",
      "name": "About Product",
      "settings": [
        {
          "type": "text",
          "id": "text-heading",
          "label": "Heading"
        },
        {
          "type": "color",
          "id": "heading-color",
          "label": "Heading Color"
        },
        {
          "type": "text",
          "id": "text-detail",
