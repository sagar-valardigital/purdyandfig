<!--
  This buy box is used for adding two products to the cart.
  Originally created for PF145
-->

{% assign product = section.settings.landingproduct %}
{% assign s_variant = product.selected_or_first_available_variant %}

{% assign product2 = section.settings.landingproduct2 %}

<script>
  const addProductsToCart = (form, event) => {
  event.preventDefault();
  $(event.target).addClass("loading");

  // First product form data
  const formData1 = new FormData(form);
  let discount1 = formData1.get("discount");

  if (formData1.get("purchase_type") === "subscription") {
    $(form).attr("data-discount") && (discount1 = $(form).attr("data-discount"));
  } else {
    formData1.delete("selling_plan");
  }

  // Function to add product to cart
  const addProductToCart = (data) => {
    return fetch("/cart/add.js", {
      method: "POST",
      body: data
    }).then(response => response.json());
  };

  // Add first product
  addProductToCart(formData1).then(response => {
      if (response.status === 'error') {
        throw new Error(response.message);
      }
      console.log('First product added:', response);

      // Prepare second product form data
      const formData2 = new FormData();
      formData2.append("id", document.getElementById('second_product_id').value);
      formData2.append("quantity", document.getElementById('second_product_quantity').value);

      const discount2 = document.getElementById('second_product_discount').value;
      if (discount2) {
        formData2.append("discount", discount2);
      }

      const purchaseType2 = document.getElementById('second_product_purchase_type')?.value;
      if (purchaseType2 === "subscription") {
        formData2.append("purchase_type", purchaseType2);
        formData2.append("selling_plan", document.getElementById('second_product_selling_plan').value);
      }

      // Add second product
      return addProductToCart(formData2);
    }).then(response => {
      if (response.status === 'error') {
        throw new Error(response.message);
      }
      console.log('Second product added:', response);
      $(form).removeClass("loading");

      const finalDiscount = discount1 || discount2;
      const redirectUrl = finalDiscount ? `/discount/${finalDiscount}?redirect=%2Fcheckout?discount=${finalDiscount}` : "/checkout/";
      window.location.href = redirectUrl;
    })
    .catch(error => {
      $(form).removeClass("loading");
      console.error("Error:", error);
      alert('There was an error adding the products to the cart. Please try again.');
    });
}
</script>

