    },
    {
      "id": "ctaDetails",
      "label": "Button Details Text",
      "type": "html"
    },
    {
      "id": "shopbtnLabel",
      "label": "Shop Button label",
      "type": "text"
    },
    {
      "id": "shopbtnLink",
      "label": "Shop Button link",
      "type": "url"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "checkbox",
      "id": "heading-position",
      "label": "Heading After Image"
    },
    {
      "type": "checkbox",
      "id": "before-mobile",
      "label": "Heading before Image"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "landing_page"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
