    },
    {
      "id": "isSub",
      "label": "Product subscription",
      "type": "checkbox",
      "default": false
    },
    {
      "id": "isCheckout",
      "label": "Go to Checkout",
      "type": "checkbox",
      "default": false
    },
    {
      "id": "scrollto",
      "label": "Review Scroll to",
      "type": "text"
    },
    {
      "id": "background",
      "label": "Background color",
      "type": "color"
    },
    {
      "id": "p_id",
      "label": "Product Section Scroll ID",
      "type": "text"
    },
    {
      "id": "landingproduct",
      "label": "Choose the landing product",
      "type": "product"
    },
    {
      "type": "text",
      "id": "varaiantid",
      "label": "Variant ID"
    },
    {
      "type": "text",
      "id": "sellingid",
      "label": "Selling ID"
    },
    {
      "type": "text",
      "id": "sku",
      "label": "SKU"
    },
    {
      "id": "landingproduct2",
      "label": "Choose a Secondary Product",
      "type": "product"
    },
    {
      "type": "text",
      "id": "varaiantid2",
      "label": "Secondary Product Variant ID"
    },
    {
      "type": "text",
      "id": "sellingid2",
      "label": "Secondary Product Selling ID"
    },
    {
      "type": "text",
      "id": "sku2",
      "label": "SKU 2"
    },
    {
      "type": "text",
      "id": "discount",
      "label": "Discount Code"
    },
    {
      "type": "text",
      "id": "combinedSKU",
      "label": "Combined SKU"
    },
    {
      "type": "text",
      "id": "guarantee",
