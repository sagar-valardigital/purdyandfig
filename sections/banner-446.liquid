<style>
  .banner-section-381 {
    width: 100%;
    height: 400px;
    padding: 80px 184px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    background: linear-gradient(263deg, rgba(27, 34, 6, 0.00) 14.27%, rgba(27, 34, 6, 0.60) 100%), 
      url('{{ section.settings.desktop_image | image_url: width: 3200 }}');
    background-color: lightgray;
    background-size: cover;
    background-position: top center;
  }

  .banner-image-381 {
    display: none;
  }

  .banner-heading-381 h2 {
    font-family: "GT Super";
    font-size: 48px;
    font-style: normal;
    font-weight: 400;
    line-height: 60px;
    color: {{ section.settings.heading_color }};
  }

  .banner-446-subheading {
    color: {{ section.settings.sub_heading_color }};
    font-family: "Lausanne";
    font-size: 18px;
    font-style: normal;
    font-weight: 200;
    line-height: 27px;
  }

  @media (max-width: 767px) {
    .banner-section-381 {
      height: 280px;
      padding: 32px 16px;
      background: linear-gradient(180deg, rgba(27, 34, 6, 0.00) 29.61%, rgba(27, 34, 6, 0.80) 100%), 
        url('{{ section.settings.mobile_image | image_url: width: 1200 }}');
      background-size: cover;
      background-position: top center;
    }

    .banner-heading-381 h2 {
      font-size: 36px;
      line-height: 45px;
    }

    .banner-446-subheading {
      color: #FFEDE4;
      font-size: 16px;
      line-height: 24px;
    }
  }
</style>

<section class="banner-section-381 position-relative">
  <div class="banner-heading-381">
    <h2>{{ section.settings.heading }}</h2>
    <div class="banner-446-subheading">{{ section.settings.subheading }}</div>
  </div>
</section>

{% schema %}
  {
    "name": "Banner 446",
    "settings": [
      {
        "type": "image_picker",
        "id": "desktop_image",
        "label": "Desktop image"
      },
      {
        "type": "image_picker",
        "id": "mobile_image",
        "label": "Mobile image"
      },
      {
        "type": "color",
        "id": "heading_color",
        "label": "Heading color"
      },
      {
        "type": "html",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "color",
        "id": "sub_heading_color",
        "label": "Sub-heading color"
      },
      {
        "type": "html",
        "id": "subheading",
        "label": "Sub-heading"
      }
    ],
    "presets": [
      {
        "name": "Banner 446"
      }
    ]
  }
{% endschema %}