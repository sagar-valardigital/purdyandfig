<style>
  .cln-container {
    padding: 80px 112px;
    background: #FCFAF6;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    gap: 40px;
    display: flex;
    width: 100%;
  }
  .cln-heading-block {
    align-self: stretch;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    gap: 12px;
    display: flex;
  }
  .cln-heading-content {
    justify-content: flex-start;
    align-items: center;
    gap: 12px;
    display: flex;
    flex-direction: column;
  }
  .cln-heading {
    text-align: center;
    color: {{ section.settings.heading_color }};
    font-size: 40px;
    font-family: "GT Super";
    font-weight: 400;
    line-height: 50px;
    word-wrap: break-word;
    letter-spacing: 0px;
  }
  .cln-image-block {
    align-self: stretch;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    gap: 32px;
    display: flex;
  }
  .cln-image-content {
    align-self: stretch;
    justify-content: flex-start;
    align-items: center;
    gap: 36px;
    display: inline-flex;
  }
  .cln-image-content img {
    width: calc(50% - 18px);
    border-radius: 4px;
    order: 1
  }
  .cln-text-block {
    width: calc(50% - 18px);
    flex: 1 1 0;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    gap: 16px;
    display: inline-flex;
    order: 2;
  }
  .cln-image-content.cln-right img {
    order: 2;
  }
  .cln-image-content.cln-right .cln-text-block {
    order: 1;
  }
  .cln-blockheading-block {
    align-self: stretch;
    justify-content: flex-start;
    align-items: flex-start;
    display: inline-flex;
  }
  .cln-block-heading {
    justify-content: center;
    display: flex;
    flex-direction: column;
    color: {{ section.settings.block_heading_color }};
    font-size: 24px;
    font-family: "Lausanne";
    font-weight: 400;
    line-height: 36px;
    word-wrap: break-word;
  }
  .cln-sub-block {
    align-self: stretch;
    justify-content: center;
    align-items: center;
    display: inline-flex;
  }
  .cln-subheading {
    flex: 1 1 0;
    justify-content: center;
    display: flex;
    flex-direction: column;
    color: {{ section.settings.block_text_color }};
    font-size: 18px;
    font-family: "Lausanne";
    font-weight: 200;
    line-height: 27px;
    word-wrap: break-word;
  }
  .cln-mainsubheading {
    color: {{ section.settings.subheading_color }};
    font-size: 20px;
    font-family: "GT Super";
    font-weight: 300;
    line-height: 35px;
    word-wrap: break-word;
    text-align: center;
  }
  .cln-cta {
    width: 343px;
  }
  .desk_image {
    display: block;
  }
  .mob_image {
    display: none;
  }
  @media (max-width: 767px) {
    .cln-container {
      padding: 32px 16px;
      gap: 32px;
    }
    .cln-image-block {
      gap: 24px;
    }
    .cln-heading {
      text-align: left;
      font-size: 32px;
      line-height: 40px;
    }
    .cln-image-content {
      flex-direction: column;
      gap: 16px;
    }
    .cln-text-block {
      gap: 4px;
    }
    .cln-block-heading {
      font-size: 20px;
      line-height: 30px;
    }
    .cln-subheading {
      font-size: 16px;
      line-height: 24px;
    }
    .cln-image-content img, .cln-image-content.cln-right img {
      order: 1;
      width: 100%;
    }
    .cln-image-content .cln-text-block, .cln-image-content.cln-right .cln-text-block {
      order: 2;
      width: 100%;
    }
    .cln-mainsubheading {
      display: none;
      font-size: 16px;
      line-height: 24px;
      text-align: left;
    }
    .cln-mainsubheading.clnshow {
      display: block;
    }
    .cln-cta {
      width: 100%;
    }
  }
</style>

<div class="cln-container">
  <div class="cln-heading-block">
    <div class="cln-heading-content">
      <div class="cln-heading">{{ section.settings.main_heading }}</div>
      {% if section.settings.main_subheading != blank %}
      <div class="cln-mainsubheading {% if section.settings.showsubheading %}clnshow{% endif %}">{{ section.settings.main_subheading }}</div>
      {% endif %}
    </div>
  </div>
  <div class="cln-image-block">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <div class="cln-image-content {% if block.settings.showright %}cln-right{% endif %}">
          <img src="{{ block.settings.desk_image | image_url: width: 1600, crop: 'center' }}" class="desk_image img-responsive h-auto" width="" height="" />
          <img src="{{ block.settings.mob_image | image_url: width: 800, crop: 'center' }}" class="mob_image img-responsive h-auto" width="" height="" />
          <div class="cln-text-block">
            <div class="cln-blockheading-block">
              <div class="cln-block-heading">{{ block.settings.heading }}</div>
            </div>
            <div class="cln-sub-block">
              <div class="cln-subheading">{{ block.settings.summary }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
  {% if section.settings.addScrollBtn %}
    <div class="cln-cta">
      <span
        class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto common-btn-width"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
          {% render 'ga4-events' %}
        {% endif %}
      >
        {{- section.settings.btnLabel -}}
      </span>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Image with text optimized",
  "settings": [
    {
      "type": "checkbox",
      "id": "addScrollBtn",
      "label": "Show Scroll to Btn",
      "default": false
    },
    {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Select background color"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color"
    },
    {
      "type": "color",
      "id": "block_heading_color",
      "label": "Blocks heading color"
    },
    {
      "type": "color",
      "id": "block_text_color",
      "label": "Blocks text color"
    },
    {
      "type": "html",
      "id": "main_heading",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "showsubheading",
      "label": "Show sub-heading - Mobile"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Sub-heading color"
    },
    {
      "type": "html",
      "id": "main_subheading",
      "label": "Sub-heading"
    },
    {
      "type": "text",
      "id": "btnLabel",
      "label": "Button Label",
      "default": "GET YOUR OFFER"
    },
    {
      "type": "text",
      "id": "scrollto",
      "label": "Scroll to section id",
      "default": "javascript:void(0);"
    },
    {
      "type": "text",
      "id": "top",
      "label": "On scroll top position",
      "default": "0"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "landing_page"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "itemId",
      "label": "Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label": "Item Name",
      "type": "text"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "block",
      "settings": [
        {
          "type": "checkbox",
          "id": "showright",
          "label": "Image on right"
        },
        {
          "type": "html",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "html",
          "id": "summary",
          "label": "Summary"
        },
        {
          "type": "image_picker",
          "id": "desk_image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mob_image",
          "label": "Mobile image"
        }
      ]
    },
  ],
  "presets": [
    {
      "name": "Image with text optimized"
    }
  ]
}
{% endschema %}
