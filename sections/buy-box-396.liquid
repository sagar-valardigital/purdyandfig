<style>
    .link-to-variant,.link-to-plan {
        height: 0;
        overflow: hidden;
        position: relative;
    }

    .link-to-variant.show ,.link-to-plan.show {
        display: block !important;
        height: auto;
        margin-top: 4px;
        margin-bottom: 4px;
        overflow: visible;
    }
  .scent-tag{
    position:absolute;
    border:1px solid #eee;
    font-weight:400;
    font-size:12px;
    border-radius:4px;
    padding:4px 8px;
    line-height:1.2;
    left:38px;
    top:-13px;
    border-color:#708480;
    background-color:#708480;
    color:#fff;
  }
  .mbestvalue {
    background: #E55829;
  }
  .mbestplan {
    border-top-color: #E55829 !important;
  }
  .buy--plan input:checked + label, .ms-buy--plan input:checked + label {
    background-color: #fff;
    border: 1.5px solid #11322c !important;
  }
  .include-starterkit {
    font-size: 14px !important;
    font-weight: 400;
  }
  .checkout-starterkit-btn {
    gap: 4px;
  }
  @media (max-width: 768px) {
    .ms-plan-wrapper .points > span {
      font-size: 12px;
    }
    .include-starterkit {
      font-size: 12px !important;
      margin: 8px 0 6px -28px;
    }
  }
</style>

<div
  class="{{ section.settings.className }} multi-step-product-section gp--product-wrapper py-80"
  id="id_{{ section.id }}"
  style="background-color:{{section.settings.background}};"
  x-data="{qty:1}"
>
  <div class="position-relative">
    <div class=" mb-4 container heading-2-wrapper">
      {% if section.settings.sectionheading != '' %}
        <h2 style="color:#212121" class="heading-2 font-gtsuper fw-400 mt-0 text-center">
          {{ section.settings.sectionheading }}
        </h2>
      {% endif %}
    </div>

    <div class="d-flex product-block-4-wrapper flex-wrap justify-content-between align-items-start container">
      <div class="w-50 gp--product-gallery" id="{{ section.settings.scrollId }}">
        <div class="position-relative step step-1 step-gallery">
          {% assign mediacount = 0 %}
          <div class="link-to-variant variant_1 show position-relative">
            <div class="gp-5-product-gallery  new-product-gallery-wrapper">
              {% for block in section.blocks %}
                {% if block.type == 'productImage' %}
                  {% assign image = block.settings.image %}
                  {% assign mimage = block.settings.mimage %}
                  {% if block.settings.is_video %}
                    <div class="main-product-img">
                      <video
                        class=" w-100 lazy"
                        poster="{{ block.settings.poster | img_url : '800x'}}"
                        width="520"
                        height="520"
                        controls
                      >
                        <source src="{{ block.settings.videoURL }}" type="video/mp4">
                      </video>
                    </div>
                  {% else %}
                    <div class="main-product-img ">
                      <picture>
                        <source media="(min-width:650px)" srcset="{{ image | img_url: '2000x'}}">
                        <source media="(max-width:650px)" srcset="{{ mimage | img_url: '2000x' }}">
                        <img
                          {% if forloop.index == 1 %}
                            skip-lazy
                          {% else %}
                            loading="lazy"
                          {% endif %}
                          data-id="{{image.id}}"
                          class="img-responsive w-100 h-auto lazy"
                          src="{{ image | img_url: '2000x'}}"
                          width="800"
                          height="700"
                          alt="{{ image }}"
                        >
                      </picture>
                    </div>
                  {% endif %}
                {% endif %}
                {% assign mediacount = mediacount | plus: '1' %}
              {% endfor %}
            </div>
          </div>
          <div class="link-to-variant variant_2 position-relative">
            <div class="gp-5-product-gallery  new-product-gallery-wrapper">
              {% for block in section.blocks %}
                {% if block.type == 'productImage2' %}
                  {% assign image = block.settings.image_2 %}
                  {% assign mimage = block.settings.mimage_2 %}
                  {% if block.settings.is_video_2 %}
                    <div class="main-product-img">
                      <video
                        class=" w-100 lazy"
                        poster="{{ block.settings.poster_2 | img_url : '800x'}}"
                        width="520"
                        height="520"
                        controls
                      >
                        <source src="{{ block.settings.videoURL_2 }}" type="video/mp4">
                      </video>
                    </div>
                  {% else %}
                    <div class="main-product-img ">
                      <picture>
                        <source media="(min-width:650px)" srcset="{{ image | img_url: '2000x'}}">
                        <source media="(max-width:650px)" srcset="{{ mimage | img_url: '2000x'}}">
                        <img
                          {% if forloop.index == 1 %}
                            skip-lazy
                          {% else %}
                            loading="lazy"
                          {% endif %}
                          data-id="{{image.id}}"
                          class="img-responsive w-100 h-auto lazy"
                          src="{{ image | img_url: '2000x'}}"
                          width="800"
                          height="700"
                          alt="{{ image }}"
                        >
                      </picture>
                    </div>
                  {% endif %}
                {% endif %}
                {% assign mediacount = mediacount | plus: '1' %}
              {% endfor %}
            </div>
          </div>
        </div>
        <div class="position-relative step-gallery step step-2 height-0">
          <div class="link-to-plan g_variant_1 show position-relative">
            <div class="gp-5-product-gallery_  new-product-gallery-wrapper">
              {% assign image-1 = section.settings['plan-image-1'] | image_url %}
              {% assign mimage-1 = section.settings['plan-mimage-1'] | image_url %}
              <div class="main-product-img ">
                <picture>
                  <source media="(min-width:650px)" srcset="{{ image-1 | img_url: '2000x'}}">
                  <source media="(max-width:650px)" srcset="{{ mimage-1 | img_url: '2000x' }}">
                  <img
                    data-id="{{image-1.id}}"
                    class="img-responsive w-100 h-auto lazy"
                    src="{{ image-1 | img_url: '2000x'}}"
                    width="800"
                    height="700"
                    alt="{{ image }}"
                  >
                </picture>
              </div>
            </div>
          </div>
          <div class="link-to-plan g_variant_2  position-relative">
            <div class="gp-5-product-gallery_  new-product-gallery-wrapper">
              {% assign image-2 = section.settings['plan-image-2'] | image_url %}
              {% assign mimage-2 = section.settings['plan-mimage-2'] | image_url %}
              <div class="main-product-img ">
                <picture>
                  <source media="(min-width:650px)" srcset="{{ image-2 | img_url: '2000x'}}">
                  <source media="(max-width:650px)" srcset="{{ mimage-2 | img_url: '2000x' }}">
                  <img
                    data-id="{{image-2.id}}"
                    class="img-responsive w-100 h-auto lazy"
                    src="{{ image-2 | img_url: '2000x'}}"
                    width="800"
                    height="700"
                    alt="{{ image }}"
                  >
                </picture>
              </div>
            </div>
          </div>
          <div class="link-to-plan g_variant_4  position-relative">
            <div class="gp-5-product-gallery_  new-product-gallery-wrapper">
              {% assign image-4 = section.settings['plan-image-4'] | image_url %}
              {% assign mimage-4 = section.settings['plan-mimage-4'] | image_url %}
              <div class="main-product-img ">
                <picture>
                  <source media="(min-width:650px)" srcset="{{ image-4 | img_url: '2000x'}}">
                  <source media="(max-width:650px)" srcset="{{ mimage-4 | img_url: '2000x' }}">
                  <img
                    data-id="{{image-4.id}}"
                    class="img-responsive w-100 h-auto lazy"
                    src="{{ image-4 | img_url: '2000x'}}"
                    width="800"
                    height="700"
                    alt="{{ image }}"
                  >
                </picture>
              </div>
            </div>
          </div>
          <div class="link-to-plan g_variant_5  position-relative">
            <div class="gp-5-product-gallery_  new-product-gallery-wrapper">
              {% assign image-5 = section.settings['plan-image-5'] | image_url %}
              {% assign mimage-5 = section.settings['plan-mimage-5'] | image_url %}
              <div class="main-product-img ">
                <picture>
                  <source media="(min-width:650px)" srcset="{{ image-5 | img_url: '2000x'}}">
                  <source media="(max-width:650px)" srcset="{{ mimage-5 | img_url: '2000x' }}">
                  <img
                    data-id="{{image-5.id}}"
                    class="img-responsive w-100 h-auto lazy"
                    src="{{ image-5 | img_url: '2000x'}}"
                    width="800"
                    height="700"
                    alt="{{ image }}"
                  >
                </picture>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="w-50  d-flex justify-content-center">
        <div class="w-90   bg-white">
          <div class="gp-5-top desktop-hide mt-3">
            <h2 class="heading-2 font-gtsuper fw-400 mt-0 text-center" style="color:#212121">
              {{ section.settings.sectionheading }}
            </h2>
          </div>

          <div class="gp-5-bottom link-variants-wrapper scents-plan-wrapper">
            <div class="step step-1 select-scents">
              <h4 class="text-center font-lausanne fw-600 ">CHOOSE YOUR SCENT</h4>
              <div class="step-count-wrapper">
                <span></span>
                <div class="progress-bar pw-50"></div>
                <span class="font-lausanne"><span class="fw-600">1</span> of <b class="fw-600">2</b></span>
              </div>
              <div class="ms-scents-wrapper">
                <div class="ms-scent-block ">
                  <input
                    autocomplete="off"
                    class="scent-selector-radio gp--product-variant"
                    type="radio"
                    name="scent"
                    id="{{ section.settings.scent1-heading | handle }}"
                    checked
                    data-plan="variant_1"
                    data-gallery="variant_1"
                    data-image="{{ section.settings.plan-image-1 | image_url }}"
                    data-variantclass="variant_1"

                    data-tracked="true"
                    data-page-url="{{ request.path }}"
                    data-target-url=""
                    data-index="{{ section.settings.index }}"
                    data-funnel-stage="{{ section.settings.funnel_stage }}"
                    data-module="{{ section.settings.dataModule }}"
                    data-event-label="{{ section.settings.scent1-heading | handle }}"
                    data-event-value="product_toggle"
                    data-item-id=""
                    data-option-index="1"
                    data-item-name="{{ section.settings.scent1-heading }}"
                  >
                  <label for="{{ section.settings.scent1-heading | handle }}" class="position-relative">
                    {% if section.settings.tag_1 != blank %}
                      <span class="scent-tag">{{ section.settings.tag_1 }}</span>
                    {% endif %}
                    <div class="scent-header">
                      <h4 class="font-lausanne fw-600">{{ section.settings['scent1-heading'] }}</h4>
                      <div class="scent-price">
                        <del class="font-lausanne fw-500">{{- localization.country.currency.symbol -}}{{- section.settings['scent1-delprice'] -}}</del>
                        <span class="font-lausanne fw-500">{{- localization.country.currency.symbol -}}{{- section.settings['scent1-price'] -}}</span>
                      </div>
                    </div>
                    <p class="m-0 font-lausanne fw-200">{{ section.settings['scent1-details'] }}</p>
                  </label>
                </div>
                <div class="ms-scent-block">
                  <input
                    autocomplete="off"
                    class="scent-selector-radio gp--product-variant"
                    type="radio"
                    name="scent"
                    id="{{ section.settings.scent2-heading | handle }}"

                    data-plan="variant_4"
                    data-gallery="variant_2"
                    data-image="{{ section.settings.plan-image-4 | image_url }}"
                    data-variantclass="variant_2"
                    data-tracked="true"
                    data-page-url="{{ request.path }}"
                    data-target-url=""
                    data-index="{{ section.settings.index }}"
                    data-funnel-stage="{{ section.settings.funnel_stage }}"
                    data-module="{{ section.settings.dataModule }}"
                    data-event-label="{{ section.settings.scent2-heading | handle }}"
                    data-event-value="product_toggle"
                    data-item-id=""
                    data-option-index="2"
                    data-item-name="{{ section.settings.scent2-heading }}"
                  >
                  <label for="{{ section.settings.scent2-heading | handle }}" class="position-relative">
                    {% if section.settings.tag_2 != blank %}
                      <span class="scent-tag">{{ section.settings.tag_2 }}</span>
                    {% endif %}
                    <div class="scent-header">
                      <h4 class="font-lausanne fw-600">{{ section.settings['scent2-heading'] }}</h4>
                      <div class="scent-price">
                        <del class="font-lausanne fw-500">{{- localization.country.currency.symbol -}}{{- section.settings['scent2-delprice'] -}}</del>
                        <span class="font-lausanne fw-500">{{- localization.country.currency.symbol -}}{{- section.settings['scent2-price'] -}}</span>
                      </div>
                    </div>
                    <p class="m-0 font-lausanne fw-200">{{ section.settings['scent2-details'] }}</p>
                  </label>
                </div>
                <div class="mt-4">
                  <span
                    data-tracked="true"
                    data-page-url="{{ request.path }}"
                    data-target-url=""
                    data-index="{{ section.settings.index }}"
                    data-funnel-stage="{{ section.settings.funnel_stage }}"
                    data-module="multi_step_buybox"
                    data-event-label="next"
                    data-event-value="click"
                    class="btn w-100  value-medium next-step-btn"
                    style="background-color:#11322c; color:#fff; width:100%;"
                  >
                    NEXT
                  </span>
                </div>
              </div>
            </div>

            <div class="step step-2 select-Plan height-0">
              <h4 class="text-center font-lausanne fw-500 mt-0">CHOOSE YOUR PLAN</h4>
              <div class="step-count-wrapper">
                <span
                  data-tracked="true"
                  data-page-url="{{ request.path }}"
                  data-target-url=""
                  data-index="{{ section.settings.index }}"
                  data-funnel-stage="{{ section.settings.funnel_stage }}"
                  data-module="multi_step_buybox"
                  data-event-label="back"
                  data-event-value="click"
                  class="back-btn"
                  style="cursor:pointer;"
                >
                  <img
                    src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/arrow-right-f.png?v=1739882042"
                    width="13"
                    height="14"
                    alt="back"
                  >
                </span>
                <div class="progress-bar pw-100"></div>
                <span class="font-lausanne"><span class="fw-600">2</span> of <b class="fw-600">2</b></span>
              </div>
              <div class="ms-plan-wrapper">
                <div class="link-to-variant variant_1 show">
                  <form
                    name="shopify-product-form"
                    autocomplete="off"
                    @submit.prevent="console.log('submitted')"
                    x-ref="product_form_{{ section.index}}"
                    enctype="multipart/form-data"
                    accept-charset="UTF-8"
                    id="product_form_{{ section.index}}"
                    class="shopify-product-form form_s1"
                    data-product-id="{{product.id}}"
                    action="/cart/add"
                  >
                    {% if section.settings['plan-heading-1'] != blank %}
                      <div class="gp--paln-1 ms-buy--plan position-relative mt-1">
                        <input
                          autocomplete="off"
                          type="radio"
                          checked
                          data-gallery="variant_1"

                          data-scent-type="s1"
                          data-index-order="1"
                          id="buyplan_1_{{ section.id }}"
                          name="buyplan_{{ section.id }}"
                          class="buy_plan_radio_ buy_plan_radio_1"
                          data-plantype="subscription"
                          data-section="id_{{ section.id }}"
                          data-form="product_form_{{ section.index}}"
                          data-planid="{{ section.settings.selling_plan_1 }}"
                          data-discount="{{ section.settings.discountPlan_1 }}"
                          data-variantid="{{ section.settings.variant_id_1 }}"
                          data-sku="{{ section.settings.sku_1 }}"
                          data-price="{{ localization.country.currency.symbol }}{{- section.settings.scent1-price -}}"
                          data-deleted-price="{{ localization.country.currency.symbol }}{{- section.settings.scent1-delprice -}}"
                          data-tracked="true"
                          data-page-url="{{ request.path }}"
                          data-target-url=""
                          data-index="{{ section.settings.index }}"
                          data-funnel-stage="{{ section.settings.funnel_stage }}"
                          data-module="{{ section.settings.dataModule }}"
                          data-event-label="{{ section.settings.plan-heading-1 | handle }}"
                          data-event-value="plan_selector"
                          data-item-id="{{ section.settings.sku_1 }}"
                          data-option-index="1"
                          data-item-name="{{ section.settings.plan-product-1  }}"
                          data-id="{{ section.settings.variant_id_1 }}"
                          data-item-type="subscription"
                        >
                        <label for="buyplan_1_{{ section.id }}" class=" ">
                          <div class="d-flex justify-content-between buy-block-text mt-0 mb-1">
                            <span class="font-lausanne fw-500">{{ section.settings['plan-heading-1'] }}</span>
                            <span class="d-flex justify-content-end">
                              <span
                                class="text-decoration-line-through font-lausanne fw-400  gp-5-del-price"
                              >
                                {{ localization.country.currency.symbol }}{{- section.settings['scent1-delprice'] -}}
                              </span>
                              <span class="gp-5-sell-price font-lausanne fw-500 ">
                                {{ localization.country.currency.symbol -}}{{- section.settings['scent1-price'] -}}
                              </span>
                            </span>
                          </div>

                          <div
                            class="d-flex points"
                            style="flex-direction: column; {% if section.settings.flipPoints %}margin-top: 6px;{% endif %}"
                          >
                            {% for block in section.blocks %}
                              {% if block.type == 'text' %}
                                <span
                                  class="font-lausanne fw-400"
                                >
                                  {{ block.settings.listItem }}
                                </span>
                              {% endif %}
                            {% endfor %}
                          </div>
                        </label>
                      </div>
                    {% endif %}
                    {% if section.settings['plan-heading-2'] != blank %}
                      <div class="gp--paln-2  ms-buy--plan position-relative ">
                        <input
                          autocomplete="off"
                          type="radio"
                          data-gallery="variant_2"
                          data-scent-type="s1"
                          data-index-order="2"
                          id="buyplan_2_{{ section.id }}"
                          name="buyplan_{{ section.id }}"
                          class="buy_plan_radio_ "
                          data-section="id_{{ section.id }}"
                          data-form="product_form_{{ section.index}}"
                          data-plantype="subscription"
                          data-planid="{{ section.settings.selling_plan_2 }}"
                          data-discount="{{ section.settings.discountPlan_2 }}"
                          data-variantid="{{ section.settings.variant_id_2 }}"
                          data-sku="{{ section.settings.sku_2 }}"
                          data-price="{{ localization.country.currency.symbol }}{{- section.settings.price_2 -}}"
                          data-deleted-price="{{ localization.country.currency.symbol }}{{- section.settings.deleted_price_2 -}}"
                          data-tracked="true"
                          data-page-url="{{ request.path }}"
                          data-target-url=""
                          data-index="{{ section.settings.index }}"
                          data-funnel-stage="{{ section.settings.funnel_stage }}"
                          data-module="{{ section.settings.dataModule }}"
                          data-event-label="{{ section.settings.plan-heading-2 | handle }}"
                          data-event-value="plan_selector"
                          data-item-id="{{ section.settings.sku2 }}"
                          data-option-index="2"
                          data-item-name="{{ section.settings.plan-product-2  }}"
                          data-id="{{ section.settings.variant_id_2 }}"
                          data-item-type="subscription"
                          data-discount-price=""
                        >
                        <label for="buyplan_2_{{ section.id }}" class="best-value-plan mbestplan">
                          {% if section.settings['plan-2-tag'] != blank %}
                            <div class="label-bestValue font-lausanne fw-400 mbestvalue">{{ section.settings['plan-2-tag'] }}</div>
                          {% endif %}
                          <div class="d-flex justify-content-between buy-block-text">
                            <span class="font-lausanne fw-500">{{ section.settings['plan-heading-2'] }}</span>
                            <span class="d-flex justify-content-end">
                              <span
                                class="text-decoration-line-through font-lausanne fw-400  gp-5-del-price"
                              >
                                {{ localization.country.currency.symbol }}{{- section.settings.deleted_price_2 -}}
                              </span>
                              <span class="gp-5-sell-price font-lausanne fw-500">
                                {{ localization.country.currency.symbol -}}{{- section.settings.price_2 -}}
                              </span>
                            </span>
                          </div>
                          <div
                            class="d-flex points"
                            style="flex-direction: column; {% if section.settings.flipPoints %}margin-top: 6px;{% endif %}"
                          >
                            <p class="font-lausanne fw-300 include-starterkit">
                              Includes everything in a Counter Clean Plan, PLUS:
                            </p>
                            {% for block in section.blocks %}
                              {% if block.type == 'point3' %}
                                <span
                                  class="font-lausanne fw-400"
                                >
                                  {{ block.settings.listItem }}
                                </span>
                              {% endif %}
                            {% endfor %}
                          </div>
                        </label>
                      </div>
                    {% endif %}
                    <input
                      autocomplete="off"
                      type="hidden"
                      name="id"
                      class="input_variant_id"
                      value="{{ section.settings.variant_id_1 }}"
                    >
                    <input
                      autocomplete="off"
                      type="hidden"
                      class="discout_input"
                      name="discount"
                      value="{{ section.settings.discountPlan_1 }}"
                    >
                    <input autocomplete="off" type="hidden" name="quantity" value="1">

                    <input
                      autocomplete="off"
                      type="checkbox"
                      name="purchase_type"
                      value="subscription"
                      checked
                      class="d-none gp--buyoption-input"
                    >
                    <input
                      autocomplete="off"
                      class="input_selling_plan"
                      type="hidden"
                      name="selling_plan"
                      value="{{ section.settings.selling_plan_1 }}"
                    >
                    <div class="text-left  g4-btn-wrapper m-auto">
                      <span
                        x-on:click="Purdy.CheckoutLandingV2($refs.product_form_{{ section.index}}, event)"
                        class="btn w-100 green-btn mt-4 value-medium btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                        style="background-color:#2D469E"
                        {% if section.settings.dataTrack %}
                          data-checkout="true"
                          data-add-to-cart="true" data-page-url="{{ request.path }}"
                          data-target-url="{{ section.settings.targetUrl }}"
                          data-index="{{ section.settings.index }}"
                          data-funnel-stage="{{ section.settings.funnel_stage }}"
                          data-module="{{ section.settings.dataModule }}"
                          data-event-label="{{ section.settings.dataTitle }}"
                          data-event-value="{{ section.settings.eventValue }}"
                          data-item-id="{{ section.settings.sku_1 }}"
                          data-option-index="{{ section.settings.optionIndex }}"
                          data-item-name="{{ section.settings.plan-product-1  }}"
                          data-quantity="{{ section.settings.quantity }}"
                          data-price="{{ localization.country.currency.symbol }}{{ section.settings.scent1-price  }}"
                          data-item-type="subscription"
                        {% endif %}
                      >
                        {% if section.settings.outOfStock %}
                          Out of Stock
                        {% else %}
                          <span class="buy-text">TRY IT RISK FREE</span> |
                          <span
                            class="deleted-price font-lausanne fw-400 text-decoration-line-through  gp--del-price"
                            style="color:#bdbdbd;margin-right:0;"
                          >
                            {{ localization.country.currency.symbol }}{{- section.settings['scent1-delprice'] -}}
                          </span>
                          <span class="font-lausanne fw-500 white-text gp--sell-price">
                            {{- localization.country.currency.symbol -}}{{- section.settings['scent1-price'] }}
                          </span>
                        {% endif -%}
                      </span>
                    </div>
                    <div
                      class="text-center theme-text mt-2 guarantee-text fw-600"
                      style="font-size:12px; color:#212121; line-height: 18px;"
                    >
                      {{ section.settings.guarantee }}
                      {% if section.settings['guarantee-sub-text'] != blank -%}
                        <span class="guarantee-sub-text d-block">{{ section.settings['guarantee-sub-text'] }}</span>
                      {%- endif %}
                    </div>
                  </form>
                </div>

                <!-- scent 2 -->
                <div class="link-to-variant variant_2">
                  <form
                    name="shopify-product-form"
                    autocomplete="off"
