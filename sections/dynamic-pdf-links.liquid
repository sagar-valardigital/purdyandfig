<div class="dynamic-pdf-links-container">
 <div id="pdf-section" 
     data-pdf-items='[
       {% for block in section.blocks %}
         {
           "product_name": "{{ block.settings.product_name | escape }}",
           "product_handle": "{{ block.settings.product_handle | escape }}",
           "sds_url": "{{ block.settings.sds_url | escape }}",
           "caid_url": "{{ block.settings.caid_url | escape }}"
         }{% unless forloop.last %},{% endunless %}
       {% endfor %}
     ]'>
</div>
</div>

<script>
{% comment %} document.addEventListener("DOMContentLoaded", function() {
  // Get URL params
  const params = new URLSearchParams(window.location.search);
  const productHandle = params.get('product');
  const docType = params.get('type'); // expected values: "sds" or "caid"

  const pdfSection = document.getElementById("pdf-section");
  if (!pdfSection) return;

  // Get the block data from Liquid
  let pdfItems = [];
  try {
    pdfItems = JSON.parse(pdfSection.dataset.pdfItems);
  } catch (e) {
    console.error("Invalid JSON in data-pdf-items", e);
    return;
  }

  // Find matching product block
  const match = pdfItems.find(item =>
    item.product_handle.toLowerCase() === (productHandle || "").toLowerCase()
  );

  if (!match) {
    pdfSection.innerHTML += "<p>No matching product found.</p>";
    return;
  }

  // Determine which PDF URL to use
  let pdfUrl = "";
  if (docType && docType.toLowerCase() === "sds") {
    pdfUrl = match.sds_url;
  } else if (docType && docType.toLowerCase() === "caid") {
    pdfUrl = match.caid_url;
  }

  if (pdfUrl) {
    const iframe = document.createElement("iframe");
    iframe.src = pdfUrl;
    iframe.style.width = "100%";
    iframe.style.height = "800px";
    iframe.setAttribute("frameborder", "0");
    pdfSection.appendChild(iframe);
  } else {
    pdfSection.innerHTML += "<p>No document found for this type.</p>";
  }
}); {% endcomment %}

</script>
<script>
document.addEventListener("DOMContentLoaded", function() {
  const params = new URLSearchParams(window.location.search);
  const productHandle = params.get('product');
  const docType = params.get('type');

  const pdfSection = document.getElementById("pdf-section");
  if (!pdfSection) return;

  let pdfItems = [];
  try {
    pdfItems = JSON.parse(pdfSection.dataset.pdfItems);
  } catch (e) {
    console.error("Invalid JSON in data-pdf-items", e);
    return;
  }

  const match = pdfItems.find(item =>
    item.product_handle.toLowerCase() === (productHandle || "").toLowerCase()
  );

  if (!match) {
    pdfSection.innerHTML += "<p>No matching product found.</p>";
    return;
  }

  let pdfUrl = "";
  if (docType && docType.toLowerCase() === "sds") {
    pdfUrl = match.sds_url;
  } else if (docType && docType.toLowerCase() === "caid") {
    pdfUrl = match.caid_url;
  }

  if (!pdfUrl) {
    pdfSection.innerHTML += "<p>No document found for this type.</p>";
    return;
  }

  const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
  
  if (isMobile) {
    // Use Google Docs viewer as fallback
    const gviewUrl = "https://docs.google.com/viewer?url=" + encodeURIComponent(pdfUrl) + "&embedded=true";
    pdfSection.innerHTML = `
      <iframe src="${gviewUrl}" style="width:100%; height:800px;" frameborder="0"></iframe>
    `;
  } else {
    // Desktop: use native iframe
    pdfSection.innerHTML = `
      <iframe src="${pdfUrl}" style="width:100%; height:800px;" frameborder="0"></iframe>
    `;
  }
});
</script>




{% schema %}
{
  "name": "Dynamic PDF Links",
  "tag": "section",
  "class": "section-dynamic-pdf-links",
  "settings": [],
  "blocks": [
    {
      "type": "pdf-link",
      "name": "PDF Link",
      "settings": [
        {
          "type": "text",
          "id": "product_name",
          "label": "Product Name",
          "info": "e.g., Uplifting Citrus"
        },
        {
          "type": "text",
          "id": "product_handle",
          "label": "Product Handle",
          "info": "The URL handle of the product, e.g., 'uplifting-citrus'. Must match the URL parameter."
        },
        {
          "type": "url",
          "id": "sds_url",
          "label": "Safety Data Sheet URL",
          "info": "Paste the file URL from Content > Files"
        },
        {
          "type": "url",
          "id": "caid_url",
          "label": "CA Ingredient Disclosure URL",
          "info": "Paste the file URL from Content > Files"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dynamic PDF Links",
      "category": "Custom",
      "blocks": [
        {
          "type": "pdf-link"
        }
      ]
    }
  ]
}
{% endschema %}