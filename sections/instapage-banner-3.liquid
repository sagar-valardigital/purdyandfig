      {
        "id": "eventValue",
        "label": "Event Value",
        "type": "text",
        "default": "shop_anchor"
      },
      {
        "id": "itemId",
        "label": "Item Id",
        "type": "text"
      },
      {
        "id": "optionIndex",
        "label": "Option Index",
        "type": "text"
      },
      {
        "id": "ItemName",
        "label": "Item Name",
        "type": "text"
