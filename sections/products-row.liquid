<style>

  #body  .section-header  .heading-2 {
  color: var(--Primary-800, #0c231f);
  font-family: "Lausanne" !important;
  font-size: 20px !important;
  font-style: normal;
  font-weight: 200 !important;
  line-height: 150% !important; 
  margin-bottom: 14px;
  padding-left: 10px;
}
.rpb-pricing {
  padding-bottom: 8px;
}

  .rpb-product-details .heading-3  {
    color: var(--Neutral-900, #212121);
    
    /* Desktop/Body Large/Semi Bold */
    font-family: "Lausanne" !important;
    font-size: 18px !important;
    font-style: normal;
    font-weight: 600;
    line-height: 150%; /* 27px */
    margin-top: 8px;
    min-height: 54px;
  }

  .py-20 {
    padding-top: 20px;
    padding-bottom: 20px;
}
  
.btn-christmas-btn{font-size:14px !important}


  
.reskin-product-blocks-wrapper {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.reskin-product-block {
  width: 25%; /* 4 cards per row by default */
  box-sizing: border-box;
}
  .reskin-product-block{
    margin:0 !important;
  }

@media (max-width: 430px) { /* Very small mobile view: 2 cards per row */
  .reskin-product-block {
    width: 50%;
  }
}

  @media (max-width: 768px) {
  #body  .section-header  .heading-2 {
        font-size: 20px !important;
        margin-bottom: 12px !important;
    }

     .rpb-product-details .heading-3  {
      font-size: 16px !important;
     }
}
 
</style>
<div id="product-blocks-section" class="product-blocks-section py-20" x-data="{qty:1}" style="background-color:{{ section.settings.bg }}">
  <div class="container">
    <div class="section-header ">
      {% if section.settings.heading != blank %}
      <h2 class="heading-2 font-gtsuper">{{ section.settings.heading }}</h2>
      {% endif %}
     {% if section.settings.subheading != blank %}
      <p class="font-lausanne fw-300">{{ section.settings.subheading }}</p>
     {% endif %}
    </div>
    <div class="reskin-product-blocks-wrapper ">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        <div class="reskin-product-block">
            <div class="rpb-image position-relative">{% if block.settings.product_image %}
              <img src="{{ block.settings.product_image | img_url : 'master' }}" width="300" height="300" class="img-responsive h-auto">
              {% else %}
<img src="{{ product.featured_image | img_url : 'master' }}" width="300" height="300" class="img-responsive h-auto">
              {% endif %}
             {% if block.settings.saving != blank %} <span class="saving-tag font-lausanne fw-400">{{ block.settings.saving }}</span>{% endif %}
            </div>
            <div class="rpb-product-details">
              <h3 class="heading-3 font-lausanne fw-400">{{ block.settings.title }}</h3>
              {% if block.settings.showRating %}
              {% render 'okendo-reviews-product-rating-summary', product: product %}
              {% endif %}
              <div class="rpb-pricing">
                <span>{{ localization.country.currency.symbol }}{{ block.settings.price }}</span>
                <del>{{ localization.country.currency.symbol }}{{ block.settings.crossprice }}</del>
              </div>
              <div>
                <form name="shopify-product-form" autocomplete="off" @submit.prevent="console.log('submitted')"
                        x-ref="product_form_{{ forloop.index}}" enctype="multipart/form-data" accept-charset="UTF-8"
                        id="product_form_{{ forloop.index}}" class="shopify-product-form form_s1 link-to-variant variant_1 show"
                        data-product-id="{{product.id}}" action="/cart/add">
              
                <input autocomplete="off" type="hidden" name="id" class="input_variant_id_"
                                value="{{ block.settings.variant_id }}">
                            
                            <input autocomplete="off" type="hidden" name="quantity" value="1">
{% if block.settings.isSub %}
                            <input autocomplete="off" type="checkbox" name="purchase_type" value="subscription" checked
                                class="d-none gp--buyoption-input">
  {% endif %}
                            <input autocomplete="off" class="input_selling_plan_" type="hidden" name="selling_plan"
                                value="{{ block.settings.sealing_plan}}">
                  <input autocomplete="off" type="hidden" class="" name="discount"
                                value="{{ block.settings.discount }}">
                <button 
                 {% if section.settings.toast %}
                  x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_{{ forloop.index}}, false, false, $event)"
                  {% else %}
                  x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_{{ forloop.index}}, true, false, $event)"
                  {% endif %}
                  class="btn btn-christmas-btn btn-loader green-btn"
                  {% if block.settings.dataTrack %}
                      data-add-to-cart="true"
                      data-page-url="{{ request.path }}"
                      data-target-url="{{ block.settings.targetUrl }}"
                      data-index="{{ section.index }}"
                      data-funnel-stage="{{ block.settings.funnel_stage }}"
                      data-module="{{ block.settings.dataModule }}"
                      data-event-label="{{ block.settings.dataTitle }}"
                      data-event-value="{{ block.settings.eventValue }}"
                      data-item-id="{{ block.settings.sku }}"
                      data-option-index="{{ block.settings.optionIndex }}"
                      data-item-name="{{ block.settings.title }}"
                      data-quantity="{{ block.settings.quantity }}"
                      data-price="{{ localization.country.currency.symbol }}{{ block.settings.price }}"
                      data-item-type="{% if block.settings.sealing_plan != blank %}subscription{% else %}PAYG{% endif %}"
                    {% endif %}
                  >{{ block.settings.buttonLabel }}</button>
                </form>
              </div>
            </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>


{% schema %}
  {
    "name": "Products Row",
    "settings": [
         {
            "type": "color",
            "id": "bg",
            "label": "Section Background Color"
          },  
          {
            "type": "checkbox",
            "id": "toast",
            "label": "Enable Toast",
            "default": false
          },
         {
            "type": "text",
            "id": "heading",
            "label": "Section Heading"
          },
         {
            "type": "text",
            "id": "subheading",
            "label": "Section Sub Heading"
          },
    ],
    "blocks": [
      {
        "type": "product",
        "name": "Product",
        "settings": [ 
          {
            "type": "product",
            "id": "product",
            "label": "Choose Product"
          },
          {
            "type": "text",
            "id": "variant_id",
            "label": "Variant ID"
          },
         {
           "type": "text",
           "id": "sku",
           "label": "SKU"
         },
          {
            "type": "text",
            "id": "sealing_plan",
            "label": "Sealing Plan"
          },
          {
            "type": "text",
            "id": "discount",
            "label": "Discount Code"
          },
          {
            "type": "image_picker",
            "id": "product_image",
            "label": "Choose Product Image"
          },
          {
            "type": "checkbox",
            "id": "isSub",
            "label": "Product subscription enable"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Product Title"
          },
          {
            "type": "checkbox",
            "id": "showRating",
            "label": "Show Rating"
          },
          {
            "type": "text",
            "id": "saving",
            "label": "Product Saving %",
            "default": "Saving 20%"
          },
          {
            "type": "text",
            "id": "price",
            "label": "Product Price"
          },
          {
            "type": "text",
            "id": "crossprice",
            "label": "Product Cross Price"
          },
          {
            "type": "text",
            "id": "buttonLabel",
            "label": "Button Label",
            "default" : "ADD TO CART"
          },
          {
            "type": "header",
            "content": "GA4"
          },
          {
            "id": "dataTrack",
            "label":"Data Track",
            "type": "checkbox"
          },
          {
            "id": "targetUrl",
            "label":"Target Url",
            "type": "url"
          },
          {
            "id": "index",
            "label":"Index",
            "type": "number",
            "default" : 0
          },
          {
            "id": "funnel_stage",
            "label":"Funnel Stage",
            "type": "text",
            "default" : "landing_page"
          },
          {
            "id": "dataModule",
            "label":"Module",
            "type": "text",
            "default" : "announcement_bar"
          },
          {
            "id": "dataTitle",
            "label":"Event Label",
            "type": "text",
            "default": "get_your_offer"
          },
          {
            "id": "eventValue",
            "label":"Event Value",
            "type": "text",
            "default" : "shop_anchor"
          },
          {
            "id": "optionIndex",
            "label":"Option Index",
            "type": "text"
          },
          {
            "id": "quantity",
            "label":"Item Quantity",
            "type": "number",
            "default" : 1
          }
        ]
      }
	],
    "presets": [
    	{
    		"name": "Products Row"
    	}
    ]
  }
  
{% endschema %}