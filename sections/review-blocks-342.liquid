<style>
  .review-section-342{
    padding:80px 0;
  }
  .review-section-342 .review-blocks-wrapper{
    display:grid;
    grid-template-columns:repeat(4 , 1fr);
    grid-gap:15px;
  }
  .rs-3-slide .d-grid{
    grid-template-columns:1fr;
  }
@media(max-width:768px){
  .review-section-342{
    padding:32px 0;
  }
  .review-section-3-wrapper .heading-2{
    text-align:left !important;
  }
  .review-section-342 .review-blocks-wrapper{
    display:grid;
    grid-template-columns:repeat(2 , 1fr);
    grid-gap:15px;
  }


}
</style>

<div
  class="review-section-342 review-slider-reskin {{ section.settings.className }}"
  style="background-color:{{ section.settings.bgColor }}"
>
  <div class="container">
    <div class=" review-section-3-wrapper">
      <div>
      <h2 class="heading-2 text-center blue-text font-gtsuper fw-400 mt-0">{{ section.settings.heading }}</h2>
    </div>
      <div class="w-100 pr-0">
        <div class="review-blocks-wrapper">
          {% for block in section.blocks %}
            <div class="rs-3-slide">
              <div class="d-grid">
                <div class="">
                  <div class="rs-3-user">
                    <img
                      src="{{ block.settings.image | img_url : '400x400' }}"
                      width="200"
                      height="200"
                      alt="{{ block.settings.image.alt }}"
                      class="img-responsive h-auto w-100"
                    >
                    <div class="mt-2">
            {% if block.settings.heading != blank %}
                      <h4 class="heading-4 black-text font-lausanne fw-400">{{ block.settings.heading }}</h4> 
              {% endif %}
                      <p class=" font-lausanne fw-200 rs3-review">{{ block.settings.review }}</p>
                      <span class="font-lausanne fw-400 rs3-user-name">{{ block.settings.userName }}</span>
                    </div>
                  </div>
                </div>
                
              </div>
              
            </div>
          {% endfor %}
        </div>
      </div>
      {%  if section.settings.btn_text != blank %}
      <div class="w-100">
        
        <div class="mt-4">
          <span
            class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto"
            style="max-width:100%"
            data-target="{{ section.settings.scrollto }}"
            data-top="{{ section.settings.top }}"
            {% if section.settings.dataTrack %}
              {% render 'ga4-events' %}
            {% endif %}
            >{{ section.settings.btn_text }}</span
          >
        </div>
      </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
 {
   "name": "Review Blocks 342",
   "class": "review-block-342",
   "settings": [
     {
     "type": "html",
      "id" : "heading",
      "label": "Heading"
    },
     {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      },
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
   {
     "type": "text",
     "id": "className",
     "label": "Section Class"
   },

     {
     "type": "color",
     "id": "bgColor",
     "label": "Background Color"
   },
     {
     "type": "text",
     "id": "btn_text",
     "label": "Button Label",
       "default": "GET MY FREE SCENT"
   },
   {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
     {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
     {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
],
"blocks": [
     {
       "type": "text",
       "name": "Review",
       "settings": [
	{
           "type": "image_picker",
           "id": "image",
           "label": "User Image"
         },
         {
     "type": "text",
     "id": "heading",
     "label": "Review Heading"
   },
         {
     "type": "text",
     "id": "review",
     "label": "Review"
   },
         {
     "type": "text",
     "id": "userName",
     "label": "User Name"
   }
       ]
     }
],
"presets": [
	{
		"name": "Review Blocks 342"
	}
]
 }
{% endschema %}