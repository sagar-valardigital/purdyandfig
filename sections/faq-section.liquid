{% if section.settings.enable%}
  <div class="faq-section-wrapper py-5 {{ section.settings.class }}" style="background-color:{{ section.settings.color_bg }}">
    <div class="container">
      <div class="faq-section-headings text-center pb-4">
          <h3 class="heading-2 theme-text">{{section.settings.heading}}</h3>
      </div>
        <div class="faqBlockWrapper">
      {% for block in section.blocks %}
      <div class="faq">
          <details class="faq-acc theme-text">
            <summary class="faq-que font-peir">{{block.settings.faq-question}}</summary>
            <p class="mt-2">{{block.settings.faq-ans}}</p>
          </details>
      </div>
      {% endfor %}
        </div>
    </div>
  </div>
{%endif%}

{% schema %}
 {
    "name": "FAQ's",
    "class": "faq-section",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },	{
          "type": "color",
          "id": "color_bg",
          "label": "Background color",
          "default": "#fff"
        },
      {
          "type": "text",
          "id": "class",
          "label": "Section Class"
        },
{
          "type": "text",
          "id": "heading",
          "label": "Heading"
        }
	],
	"blocks": [
      {
        "type": "text",
        "name": "faq",
        "settings": [ 
		
{
            "type": "text",
            "id": "faq-question",
            "label": "FAQ QUE"
          },
{
            "type": "richtext",
            "id": "faq-ans",
            "label": "FAQ ANS"
          }
        ]
      }
	],
	"presets": [
		{
			"name": "FAQ's"
		}
	]
  }
{% endschema %}

