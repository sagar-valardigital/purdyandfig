<div class="annoucment-bar py-2 font-pier" style="background-color:{{section.settings.bg-color}}">
  <div class="container text-center" style="color:{{section.settings.text-color}}">
    <a
      {% if section.settings.dataTrack %}
        {% render 'ga4-events' %}
      {% endif %}
      {% if section.settings.scrollto != 'blank' %}
        {% if template.name == 'index' %}
          href="javascript:void(0);"
          class="click-scroll" data-target="{{ section.settings.scrollto }}"
        {% else %}
        href="/pages/homepage-new/#{{ section.settings.scrollto }}"
        {% endif %}
        
      {% else %}
        href="{{ section.settings.annuLink }}"
      {% endif %}
      style="color:{{section.settings.text-color}}"
    >
      {{ section.settings.text }}
    </a>
  </div>
</div>

{% schema %}
  {
    "name": "PF119 Announcement Bar",
    "settings": [
      {
        "type": "text",
        "id": "text",
        "default": "Welcome to our store",
        "label": "Text"
      },
      {
        "type": "color",
        "id": "bg-color",
        "default": "#CB3C8E",
        "label": "Background Colour"
      },
      {
        "type": "color",
        "id": "text-color",
        "default": "#fff",
        "label": "text Colour"
      },
      {
        "type": "url",
        "id": "annuLink",
        "label": "Link"
      },
      {
        "type": "text",
        "id": "scrollto",
        "label": "Scroll to"
      },
      {
        "type": "header",
        "content": "GA4"
      },
      {
        "id": "dataTrack",
        "label": "Data Track",
        "type": "checkbox"
      },
      {
        "id": "targetUrl",
        "label": "Target Url",
        "type": "url"
      },
      {
        "id": "index",
        "label": "Index",
        "type": "number",
        "default": 0
      },
      {
        "id": "funnel_stage",
        "label": "Funnel Stage",
        "type": "text",
        "default": "hp"
      },
      {
        "id": "dataModule",
        "label": "Module",
        "type": "text",
        "default": "announcement_bar"
      },
      {
        "id": "dataTitle",
        "label": "Event Label",
        "type": "text",
        "default": "get_your_offer"
      },
      {
        "id": "eventValue",
        "label": "Event Value",
        "type": "text",
        "default": "shop_anchor"
      },
      {
        "id": "itemId",
        "label": "Item Id",
        "type": "text"
      },
      {
        "id": "optionIndex",
        "label": "Option Index",
        "type": "text"
      },
      {
        "id": "ItemName",
        "label": "Item Name",
        "type": "text"
      }
    ],
    "presets": [
      {
        "name": "PF119 Announcement Bar"
      }
    ]
  }
{% endschema %}