<style>
  .faq--reskin {
    padding: 80px 0;
  }
  .faqbtncta {
    padding-top: 80px;
  }
  .faq-acc-2 .faq-que-2 ~ * {
    font-family: 'Lausanne';
    color: #212121;
    font-size: 18px;
    line-height: 1.5;
    font-weight: 200;
  }
  .faq--reskin .blue-starterkit-btn {
    font-size: 16px;
  }
  @media (max-width: 768px) {
    .faq--reskin {
      padding: 32px 0;
    }
    .faq-acc-2 p {
        font-size: 16px !important;
    }
    .faq--reskin .blue-starterkit-btn {
      font-size: 16px;
    }
    .faqbtncta {
      padding-top: 32px;
    }
  }
</style>

{% if section.settings.enable %}
  <div
    class="faq--reskin {{ section.settings.class }}"
    style="background-color:{{ section.settings.color_bg }}"
  >
    <div class="container">
      <div class="faq-section-2-heading text-center">
        <h3 class="heading-2 font-gtsuper">{{ section.settings.heading }}</h3>
      </div>
      <div class="faqBlockWrapper">
        {% for block in section.blocks %}
          <div class="faq">
            <details
              class="faq-acc faq-acc-2"
              {% if block.settings.open %}
                open="true"
              {% endif %}
            >
              <summary class="faq-que-2 font-lausanne fw-400 ">{{ block.settings['faq-question'] }}</summary>
              <p class="mt-2 font-lausanne fw-200 ">{{ block.settings['faq-ans'] }}</p>
            </details>
          </div>
        {% endfor %}
      </div>
      {% if section.settings.addScrollBtn %}
    <div class="faqbtncta">
      <span
        class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >{% if section.settings.reviews_button_text %} 
              {{ section.settings.reviews_button_text }} 
            {% else %}
              GET YOUR OFFER
            {% endif %}</span
      >
    </div>
    {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
 {
    "name": "FAQ section Reskin 212",
    "class": "faq-section",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },	{
          "type": "color",
          "id": "color_bg",
          "label": "Background color",
          "default": "#fff"
        },
      {
          "type": "text",
          "id": "class",
          "label": "Section Class"
        },
{
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
      {
          "type": "checkbox",
          "id": "addScrollBtn",
          "label": "Show Scroll to Btn",
          "default": false
        },
      {
       "type": "text",
       "id": "reviews_button_text",
       "label": "Get offer label",
       "default": "GET YOUR OFFER"
     },
      {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      }
     ,
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
    {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
	],
	"blocks": [
      {
        "type": "text",
        "name": "faq",
        "settings": [

{
            "type": "checkbox",
            "id": "open",
            "label": "Default Open",
            "default": false
          },
{
            "type": "text",
            "id": "faq-question",
            "label": "FAQ QUE"
          },
{
            "type": "richtext",
            "id": "faq-ans",
            "label": "FAQ ANS"
          }
        ]
      }
	],
	"presets": [
		{
			"name": "FAQ section Reskin 212"
		}
	]
  }
{% endschema %}
