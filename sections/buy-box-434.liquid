<style>
  .cart-toast{
    position:fixed;
    left:0;
    right:0;
    top:-100px;
    background-color:#11322c;
    padding:15px 10px;
    text-align:center;
    color:#fff;
    font-size:14px;
    transition:all 0.3s ease;
    z-index:9999;
  }
  .cart-toast.show{
    top:0;
  }
  .global-product-19-wrapper .gp-4-details .gp-5-bottom .gp-5-price-points .gp-5-points li {
    color: #424242 !important;
  }
  .reskin--buybox
  .bg-white.gp-4-details
  .gp-5-bottom
  .gp-5-price-points
