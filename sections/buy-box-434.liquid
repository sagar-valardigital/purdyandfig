                <span class="star-img">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 509.9 488.54">
                    <defs><style>.cls-1{{ section.id }}{fill:#F3C419;}</style></defs><g id="Layer_2" data-name="Layer 2"><g id="Layer_1-2" data-name="Layer 1"><path class="cls-1{{ section.id }}" d="M509.9,199c-6.46,16.14-21.36,24.42-33.37,35.23-27.73,25-56,49.36-84.17,73.87-2.35,2-2.78,3.81-2.1,6.79q15.89,69.25,31.52,138.58c2.72,12-.07,22.26-10.1,29.59s-20.66,7-31.22.67q-60.6-36.27-121.16-72.59c-3.1-1.86-5.3-2-8.46-.07-40.2,24.19-80.62,48-120.7,72.38C111.86,494.6,92.75,484.81,88.22,469a30,30,0,0,1-.17-15.23q15.61-68.55,31.32-137.09c1-4.18.37-6.76-3-9.72C81,276.22,45.92,245.29,10.7,214.48c-9.28-8.11-13-18-9.23-29.85,3.64-11.34,12-17.61,23.9-18.72q36.64-3.42,73.3-6.73c23.12-2.1,46.24-4.23,69.37-6.18,3.5-.29,4.63-2.29,5.8-5Q201.4,83.29,229,18.63C234,6.94,242.31-.07,255.18,0,267.83.07,276,7.06,280.89,18.54c18.16,42.68,36.54,85.27,54.51,128,2.11,5,5,6.28,9.9,6.71Q415.17,159.42,485,166c12.87,1.22,20.67,8.4,24.11,20.92.11.43.53.77.8,1.15Z"/></g></g>
                  </svg>
                </span>

                <span class="font-lausanne fw-400 glbreviews" style="color: {{ section.settings.review_text_color }} !important;">
                  {{ settings.gloabalreviews }} verified 5-star reviews</span
                >
              </div>
            </div>

            <h2 class="heading-3 font-lausanne  fw-600 mb-0 mt-0">
              {{ section.settings.heading }}
            </h2>
            {% if section.settings.mainsubheading != '' -%}
              <p class="font-lausanne fw-200 mt-2 mb-2 gp-5-subheading">{{ section.settings.mainsubheading }}</p>
            {%- endif %}
          </div>
          <div class="gp-5-bottom">
            <div class="black-text  product-box-border    gp-5-price-points ">
              <div class="d-flex justify-content-between font-lausanne gp-5-var">
                <div class="gp-5-price">
                  <del style="color:#707279; font-size:16px;" class="gp-5-del-price">
                    {{- section.settings.delPrice -}}</del
                  >&nbsp;<span style="color:#A94442; font-size:16px;" class="font-lausanne fw-500 gp-5-sell-price">
                    {{- section.settings.price -}}
                  </span>
                </div>
                <div style="color:#434448;">Subscribe & Save 50%</div>
              </div>
              {% if section.settings.tab_description_1 != blank %}
                <div
                  style="color:#11322C;"
                  class="tbdesc font-lausanne gp-19-var-short-desc fw-400 gp-5-var gp-5-var-ab link-to-variant variant_1 show"
                >
                  {{ section.settings.tab_description_1 }}
                </div>
              {% endif %}

              {% if section.settings.tab_description_2 != blank %}
                <div
                  style="color:#434448;"
                  class="tbdesc font-lausanne fw-400 gp-5-var gp-5-var-ab link-to-variant variant_2 "
                >
                  {{ section.settings.tab_description_2 }}
                </div>
              {% endif %}
              <ul class="gp-5-points text-left">
                {% for block in section.blocks %}
                  {% if block.type == 'text' %}
                    <li class="font-lausanne fw-200 gray-text link-to-variant variant_{{ block.settings.listClass }} ">
                      {{ block.settings.listItem }}
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>

            <form
              @submit.prevent="console.log('submitted')"
              x-ref="product_form_{{ section.index}}"
              enctype="multipart/form-data"
              accept-charset="UTF-8"
              id="product_form_{{ section.index}}"
              class="shopify-product-form"
              data-product-id="{{product.id}}"
              action="/cart/add"
            >
              <input type="hidden" name="id" class="input_variant_id" value="{{ section.settings.varaiantid }}">
              <input type="hidden" class="discout_input" name="discount" value="{{ section.settings.discount }}">
              {% assign discount_titles = '' %}

              {% for item in cart.items %}
                {% for discount in item.discounts %}
                  {% if discount_titles != '' %}
                    {% assign discount_titles = discount_titles | append: ',' %}
                  {% endif %}
                  {% assign discount_titles = discount_titles | append: discount.title %}
                {% endfor %}
              {% endfor %}

              <input type="hidden" name="already_discount" value="{{ discount_titles }}">
              <input type="hidden" name="quantity" value="1">
              {% if section.settings.isSub %}
                <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
                <input
                  class="input_selling_plan"
                  type="hidden"
                  name="selling_plan"
                  value="{{section.settings.sellingid}}"
                >
              {% else %}
                <input type="checkbox" name="purchase_type" value="PAYG" checked class="d-none">
              {% endif %}
            </form>

            <div class="text-left  g4-btn-wrapper m-auto">
              {% if section.settings.redirectLink %}
                <a
                  class="btn w-100 green-btn font-lausanne fw-400 btn-loader checkout-starterkit-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                  href="{{ section.settings.redirectLink }}"
                >
                  {% if section.settings.outOfStock %}
                    Out of Stock
                  {% else %}
                    {{ section.settings.btnText }}
                  {% endif -%}
                </a>
              {% else %}
                {% if section.settings.isCheckout %}
                  <span
                    {% if section.settings.toast %}
                      x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_{{ section.index}}, false, false, $event)"
                    {% else %}
                      x-on:click="Purdy.CheckoutLandingV2($refs.product_form_{{ section.index}}, $event)"
                    {% endif %}

                    class="btn w-100 green-btn font-lausanne fw-400 btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"

                    data-add-to-cart="true"
                    data-page-url="{{ request.path }}"
                    data-target-url="{{ section.settings.targetUrl }}"
                    data-index="{{ section.settings.index }}"
                    data-funnel-stage="{{ section.settings.funnel_stage }}"
                    data-module="{{ section.settings.dataModule }}"
                    data-event-label="{{ section.settings.dataTitle }}"
                    data-event-value="{{ section.settings.eventValue }}"
                    data-item-id="{{ section.settings.sku }}"
                    data-option-index="{{ section.settings.optionIndex }}"
                    data-item-name="{{ product.title }}"
                    data-quantity="{{ section.settings.quantity }}"
                    data-price="{{ localization.country.currency.symbol }}{{ section.settings.price }}"
                    data-checkout="true"
                    {% if section.settings.sellingid != blank %}
                      data-item-type="subscription"
                    {% else %}
                      data-item-type="PAYG"
                    {% endif %}
                  >
                    {% if section.settings.outOfStock %}
                      Out of Stock
                    {% else %}
                      <span class="buy-text font-lausanne fw-400">{{ section.settings.btnText }}</span> |
                      <span class="deleted-price font-lausanne fw-400 font-16 white-text gp-5-del-price">
                        {{ localization.country.currency.symbol }}
                        {{- section.settings.delPrice -}}
                      </span>
                      <span class="font-lausanne fw-400 white-text gp-5-sell-price">
                        {{- localization.country.currency.symbol -}}
                        {{- section.settings.price }}
                      </span>
                    {% endif -%}
                  </span>
                {% else %}
                  <span
                    class="btn w-100 green-btn font-lausanne fw-400 btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                    {% if section.settings.toast %}
                      x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_{{ section.index}}, false, false, $event)"
                    {% else %}
                      x-on:click="Purdy.AddToCart($refs.product_form_{{ section.index}}, true, false, $event)"
                    {% endif %}
                    {% if section.settings.dataTrack %}
                      data-add-to-cart="true"
                      data-page-url="{{ request.path }}"
                      data-target-url="{{ section.settings.targetUrl }}"
                      data-index="{{ section.index }}"
                      data-funnel-stage="{{ section.settings.funnel_stage }}"
                      data-module="{{ section.settings.dataModule }}"
                      data-event-label="{{ section.settings.dataTitle }}"
                      data-event-value="{{ section.settings.eventValue }}"
                      data-item-id="{{ section.settings.sku }}"
                      data-option-index="{{ section.settings.optionIndex }}"
                      data-item-name="{{ product.title }}"
                      data-quantity="{{ section.settings.quantity }}"
                      data-price="{{ localization.country.currency.symbol }}{{ section.settings.price }}"
                      {% if section.settings.sellingid != blank %}
                        data-item-type="subscription"
                      {% else %}
                        data-item-type="PAYG"
                      {% endif %}
                    {% endif %}
                  >
                    {% if section.settings.outOfStock %}
                      Out of Stock
                    {% else %}
                      <span class="buy-text">{{ section.settings.btnText }} </span> |
                      <span class="deleted-price font-lausanne fw-400 font-16 white-text gp-5-del-price">
                        {{ localization.country.currency.symbol }}
                        {{- section.settings.delPrice -}}
                      </span>
                      <span class="font-lausanne fw-400 white-text gp-5-sell-price">
                        {{- localization.country.currency.symbol -}}
                        {{- section.settings.price }}
                      </span>
                    {% endif -%}
                  </span>
                {% endif %}
              {% endif -%}
              {% if section.settings.guaranteeText %}
                <div
                  class="text-center font-lausanne fw-400 theme-text mt-2 guarantee-text"
                  style="font-size: 15.5px; color: {{ section.settings.guaranteeTextColor }}"
                >
                  {{ section.settings.guaranteeDescription }}
                </div>
              {% endif %}
            </div>
            <p class="moneybackguarateetext text-center fw-600 font-lausanne mt-12">{{ section.settings.moneyback }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Buy box 434",
  "settings": [
    {
      "type": "text",
      "id": "moneyback",
      "label": "30-day money-back guarantee",
      "default": "30-day money-back guarantee"
    },
    {
      "type": "checkbox",
      "id": "toast",
      "label": "Enable Toast",
      "default": false
    },
    {
      "type": "text",
      "id": "reviewCount",
      "label": "Review Count",
      "default": "9,500+"
    },
    {
      "type": "checkbox",
      "id": "outOfStock",
      "label": "Enable If product out Of Stock",
      "default": true
    },
    {
      "id": "isSub",
      "label": "Product subscription",
      "type": "checkbox",
      "default": false
    },
    {
      "id": "isCheckout",
      "label": "Go to Checkout",
      "type": "checkbox",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "guaranteeText",
      "label": "Show Guarantee Text",
      "default": false
    },
    {
      "type": "text",
      "id": "guaranteeDescription",
      "label": "Guarantee Description"
    },
    {
      "type": "color",
      "id": "guaranteeTextColor",
      "label": "Guarantee Text Color",
      "default": "#434448"
    },
    {
      "id": "scrollto",
      "label": "Review Scroll to",
      "type": "text"
    },
    {
      "type": "color",
      "id": "review_text_color",
      "label": "Reviews text color"
    },
    {
      "id": "background",
      "label": "Background color",
      "type": "color"
    },
    {
      "id": "p_id",
      "label": "Product Section Scroll ID",
      "type": "text"
    },
    {
      "id": "landingproduct",
      "label": "Choose the landing product",
      "type": "product"
    },
    {
      "type": "text",
      "id": "varaiantid",
      "label": "Variant ID"
    },
    {
      "type": "text",
      "id": "sellingid",
      "label": "Selling ID"
    },
    {
      "type": "text",
      "id": "sku",
      "label": "SKU"
    },
    {
      "type": "text",
      "id": "discount",
      "label": "Discount Code"
    },
    {
      "id": "tab_description_1",
      "label": "Tab 1 Description",
      "default": "Transform your home with new natural scents each season",
      "type": "text"
    },
    {
      "type": "text",
      "id": "className",
      "label": "Section Class"
    },
    {
      "type": "html",
      "id": "mainheading",
      "label": "Main Heading"
    },
    {
      "type": "html",
      "id": "mainsubheading",
      "label": "Sub Heading"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Product Title"
    },
    {
      "id": "subtext",
      "label": "Banner Sub Text",
      "type": "html"
    },
    {
      "id": "price",
      "label": "Price",
      "type": "text"
    },
    {
      "id": "delPrice",
      "label": "Compare Price",
      "type": "text"
    },
    {
      "id": "btnText",
      "label": "Button label",
      "type": "text",
      "default": "BUY NOW"
    },
    {
      "id": "redirectLink",
      "label": "Button Link",
      "type": "url"
    },
    {
      "id": "ctaDetails",
      "label": "Button Details Text",
      "type": "html"
    },
    {
      "id": "shopbtnLabel",
      "label": "Shop Button label",
      "type": "text"
    },
    {
      "id": "shopbtnLink",
      "label": "Shop Button link",
      "type": "url"
    },
    {
      "type": "header",
      "content": "Mobile"
    },

    {
      "type": "checkbox",
      "id": "heading-position",
      "label": "Heading After Image"
    },
    {
      "type": "checkbox",
      "id": "before-mobile",
      "label": "Heading before Image"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },

    {
      "id": "index",
