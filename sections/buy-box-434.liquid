        <div class="two-women position-relative">
          {% if section.settings.tag != '' %}
            <span class="tag theme-text value-sans">{{ section.settings.tag }}</span>
          {% endif %}
          {% assign mediacount = 0 %}
          <div class="gp-19-gallery-block link-to-variant variant_1 show position-relative">
            <div class="product-gallery-341-1 new-product-gallery-wrapper">
              {% for block in section.blocks %}
                {% if block.type == 'productImage' %}
                  {% assign image = block.settings.image %}
                  {% assign mimage = block.settings.mimage %}
                  {% if block.settings.is_video %}
                    <div class="main-product-img">
                      <video
                        class=" w-100"
                        poster="{{ block.settings.poster | img_url : '800x'}}"
                        width="520"
                        height="520"
                        controls
                      >
                        <source src="{{ block.settings.videoURL }}" type="video/mp4">
                      </video>
                    </div>
                  {% else %}
                    <div class="main-product-img ">
                      <picture>
                        <source media="(min-width:650px)" srcset="{{ image | image_url: width: 1200, crop: 'center' }}">
                        <source media="(max-width:650px)" srcset="{{ mimage | image_url: width: 800, crop: 'center' }}">
                        <img
                          data-id="{{image.id}}"
                          class="img-responsive w-100 h-auto"
                          src="{{ image | image_url: width: 800, crop: 'center' }}"
                          width="800"
                          height="700"
                          alt="{{ image.alt }}"
                        >
                      </picture>
                    </div>
                  {% endif %}
                {% endif %}
                {% assign mediacount = mediacount | plus: '1' %}
              {% endfor %}
