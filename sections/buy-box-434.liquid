  	background: #11322C !important;
  	gap: 4px;
  }
  .gp-4-product-gallery-thumb .slick-track{transform: none !important;}

  .gp-354-del-price {
    text-decoration: none !important;
    position: relative;
    color: #9E9E9E;
  }
  .gp-354-del-price:after {
    content: '';
    position: absolute;
    width: 100%;
    height: 1px;
    background: #9E9E9E !important;
    top: calc(50% + 1px);
    left: 0;
  }
  .black-text {
    color: #212121;
  }
  .product-box-border {
    padding-top:16px;
  }
  .black-text.product-box-border.gp-5-price-points {
    padding-inline: 0;
  }

  .new-product-gallery-wrapper-thumb {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
