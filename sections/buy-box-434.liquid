    background-image: url(https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Checkmark.svg?v=1753917568);
    background-size: 20px 24px;
  }
  .gp-5-price-points {
    border: 0 !important;
    box-shadow: none;
    background-color: transparent;
  }
  .gp-4-product-gallery-thumb .main-product-img {
    width: 64px !important;
  }
  .slick-slider .slick-track {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .new-product-gallery-wrapper .slick-arrow {
    display: none !important;
  }
  .pricebullets del {
    color: #9E9E9E;
    font-weight: 400;
  }
  .cls-1template--25758333370748__buy_box_434_c7gCXk {
    fill: #D89B39 !important;
  }
  .reskin--buybox .bg-white.gp-4-details .gp-5-bottom .gp-5-price-points > ul li.gray-text {
    background-image: url(https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Checkmark_ac46f69d-8f3d-4fc8-a29a-066f82a69be5.svg?v=1762440011) !important;
