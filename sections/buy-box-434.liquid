{% assign product = section.settings.landingproduct %}
{% assign s_variant = product.selected_or_first_available_variant %}

{% if section.settings.toast %}
<script>
  window.addEventListener('product:added', function (event) {
    const cartToast = document.getElementById('cart-toast');
    const cartData = event.detail; // Access the passed data here
    if (cartToast) {
      cartToast.classList.add('show');
      setTimeout(() => {
        cartToast.classList.remove('show');
      }, 1500);
    }
  });
</script>
<div id="cart-toast" class="cart-toast font-lausanne fw-400">Great choice, that's in your cart!</div>
{% endif %}

