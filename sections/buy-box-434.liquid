                      <video
                        class=" w-100"
                        poster="{{ block.settings.poster_2 | img_url : '100x'}}"
                        width="48"
                        height="48"
                        controls
                      >
                        <source src="{{ block.settings.videoURL_2 }}" type="video/mp4">
                      </video>
                    </div>
                  {% else %}
                    <div class="main-product-img">
                      <picture class="position-relative">
                        <source media="(min-width:650px)" srcset="{{ image | image_url: width: 100, crop: 'center' }}">
                        <source media="(max-width:650px)" srcset="{{ image | image_url: width: 100, crop: 'center' }}">
                        <img
                          data-id="{{image.id}}"
                          class="img-responsive w-100 h-auto"
                          src="{{ image | image_url: width: 100 }}"
                          width="48"
                          height="48"
                          alt="{{ image.alt }}"
                        >
                        <div class="imglay"></div>
                      </picture>
                    </div>
                  {% endif %}
                {% endif %}
                {% assign mediacount = mediacount | plus: '1' %}
              {% endfor %}
            </div>
          </div>
        </div>
      </div>

      <div class="w-50  d-flex justify-content-center">
        <div class="w-90   bg-white gp-4-details">
          <div
            class="gp-5-top {% if section.settings.before-mobile %} mobile-hide {% endif %}"
          >
            <div class="text-left mt-2 mb-2 reviews-scroll-block">
              <div
                class="value-sans theme-text mt-0  stars-img-review click-scroll"
                data-target="{{ section.settings.scrollto }}"
              >
                <span class="star-img">
