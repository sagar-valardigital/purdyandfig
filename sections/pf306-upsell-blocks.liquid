<style>
  .btn-christmas-btn{font-size:14px !important}

  .upsell-blocks-wrapper .upsell-product-blocks {
    display: flex !important;
    align-items: flex-start;
    gap: 32px;
    align-self: stretch;
    padding-top: 40px;
    align-items: center;
    width: 100%;
  }
  .upsell-blocks-wrapper .upsell-product-blocks .slick-track {
    display: flex !important;
  }
  .upsell-blocks-wrapper .upsell-product-blocks .slick-slide {
    height: auto !important;
  }
  .upsell-blocks-wrapper .upsell-product-block {
    display: flex !important;
    width: 282px;
    padding: 10px;
    flex-direction: column;
    gap: 16px;
    align-self: stretch;
    border-radius: 4px;
    border: 1px solid #E7EBEA;
    background: #FFFFFF;
    justify-content: space-between;
  }
  .upsell-blocks-wrapper .rpb-slider-black-friday .slick-track .upsell-product-block {
    margin-right: 32px;
  }
  .upsell-blocks-wrapper .upsell-product-image {
    display: flex !important;
    /* width: 262px;
    height: 262px; */
    flex-direction: column;
    align-items: flex-end;
  }
  .upsell-blocks-wrapper .upsell-title-price-block {
    display: flex !important;
    flex-direction: column;
    justify-content: flex-end;
    flex: 1 0 0;
  }
  .upsell-blocks-wrapper .upsell-title {
    color: #212121;
    font-family: "Lausanne";
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
  }
  .upsell-blocks-wrapper .upsell-price {
    color: #212121;
    font-family: "Lausanne";
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 100%;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }
  .upsell-blocks-wrapper .upsell-cross-price {
    color: #BDBDBD;
  }
  .upsell-blocks-wrapper .upsell-cta {
    display: flex !important;
    height: 40px;
    padding: 9px 14px;
    justify-content: center;
    align-items: center;
    gap: 10px;
    flex: 1 0 0;
    border-radius: 4px;
    background: #11322C;
    color: #FFFFFF;
  }

  .upsell-saving-tag {
    position: absolute;
    color: #212121;
    background-color: #FBF1E8;
    padding: 2px 4px;
    border: solid 1px #F2D4B9;
    border-radius: 4px;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 128%;
    top: 0px;
    right: 8px;
  }
  .popup-detail-icon {
    position: absolute;
    color: #11322C;
    background-color: #FFFFFF;
    width: 24px;
    height: 24px;
    border: solid 1px #11322C;
    border-radius: 50%;
    text-align: center;
    font-family: "Lausanne";
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
    bottom: 8px;
    right: 8px;
    cursor: pointer;
  }

  .upsell-popup-wrapper {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    transition: all 0.3s ease;
    z-index: 9999999;
  }

  .display-none {
    right: -100vw;
  }

  .upsell-popup-overlay {
    display: block;
    width: 100%;
    height: 100%;
    background-color: #ffffff20;
    backdrop-filter: blur(2px);
  }

  .upsell-detail-popup {
    width: 360px;
    max-width: calc(100% - 30px);
    height: calc(100vh - 30px);
    position: absolute;
    right: 15px;
    top: 15px;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 0 4px #ccc;
    overflow: hidden;
  }
  .upsell-close-icon {
    display: flex;
    height: 32px;
    flex-direction: column;
    justify-content: center;
    align-self: stretch;
    color: var(--Neutral-900, #212121);
    leading-trim: both;
    text-edge: cap;
    font-family: "Font Awesome 6 Pro";
    font-size: 24px;
    font-style: normal;
    font-weight: 300;
    line-height: 150%;
    letter-spacing: -0.48px;
    align-items: flex-end;
  }
  .inner-block-content {
    display: flex;
    /* padding: 8px 8px 24px 8px; */
    padding: 8px 0px 24px 0px;
    justify-content: flex-end;
    align-items: flex-start;
    align-self: stretch;
    flex-direction: column;
  }
  .upsell-above-content {
    display: flex;
    padding: 0px 8px 0px 8px;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    flex: 1 0 0;
  }
  .upsell-popup-image {
    display: flex;
    width: 247px;
    /* padding: 8px; */
    flex-direction: column;
    align-items: flex-end;
    /* aspect-ratio: 1 / 1; */
  }
  .upsell-popup-title {
    color: var(--Neutral-900, #212121);
    text-align: center;
    font-family: "Lausanne";
    font-size: 24px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
    padding: 5px 32px;
  }
  .upsell-popup-summary {
    color: var(--Neutral-800, #424242);
    text-align: center;
    font-family: "Lausanne" !important;
    font-size: 16px;
    font-style: normal;
    font-weight: 200;
    line-height: 160%;
    padding: 5px 32px;
  }
  .upsell-popup-details {
    display: flex;
    padding: 24px 16px 0px;
    flex-direction: column;
    align-items: flex-start;
    align-self: stretch;
    border-radius: 0px 0px 16px 16px;
    border-top: 1px solid var(--opaque-dark-black-10, rgba(0, 0, 0, 0.10));
  }
  .upsell-popup-details h3 {
    color: var(--Neutral-900, #212121);
    font-family: "Lausanne" !important;
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
  }
  .upsell-popup-desc {
    color: var(--Neutral-800, #424242);
    font-family: "Lausanne";
    font-size: 16px;
    font-style: normal;
    font-weight: 200;
    line-height: 160%;
  }
  .popup-saving-tag {
    top: 4px;
  }

  @media (max-width: 768px) {
    .upsell-blocks-wrapper.py-80 {
      padding-top: 32px;
      padding-bottom: 32px;
    }
    .upsell-blocks-wrapper .upsell-product-blocks {
      padding-top: 32px;
    }
    .upsell-blocks-wrapper .upsell-product-block {
      width: 273px;
    }
    .upsell-blocks-wrapper .upsell-product-image {
      /* width: 253px;
      height: 253px; */
    }
    .upsell-blocks-wrapper .rpb-slider-black-friday .slick-track .upsell-product-block {
      margin-right: 16px;
    }
    .upsell-blocks-wrapper .rpb-slider-black-friday .slick-track .upsell-product-block:last {
      margin-right: 16px;
    }
    .upsell-popup-title {
      font-size: 20px;
      padding-left: 50px;
      padding-right: 50px;
    }
    .upsell-popup-summary,
    .upsell-popup-desc {
      font-size: 14px;
    }
    .upsell-popup-summary {
      padding: 5px 50px;
    }
    .upsell-popup-details h3 {
      font-size: 16px;
    }
    .upsell-detail-popup {
      width: 100%;
    }
  }
</style>
<div class="upsell-blocks-wrapper py-80" x-data="{qty:1}" style="background-color:{{ section.settings.bg }}">
  <div class="container">
    <div class="section-header text-center">
      {% if section.settings.heading != blank %}
        <h2 class="heading-2 font-gtsuper">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="font-lausanne fw-300">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="upsell-product-blocks position-relative rpb-slider-black-friday">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        <div class="upsell-product-block position-relative" id="upsell-product-block-{{ forloop.index }}">
          <div class="upsell-product-image position-relative">
            {% if block.settings.product_image %}
              <img
                src="{{ block.settings.product_image | img_url : 'master' }}"
                width="300"
                height="300"
                class="img-responsive h-auto"
              >
            {% else %}
              <img
                src="{{ product.featured_image | img_url : 'master' }}"
                width="300"
                height="300"
                class="img-responsive h-auto"
              >
            {% endif %}

            {% if block.settings.saving != blank %}
              <span class="upsell-saving-tag font-lausanne fw-400">{{ block.settings.saving }}</span>
            {%- endif %}

            <span class="popup-detail-icon" 
              data-id="{{ forloop.index }}"
              data-title="{{ block.settings.title }}"
              data-summary="{{ block.settings.summary }}"
              data-details="{{ block.settings.details }}"
              {% if block.settings.product_image %}
              data-image="{{ block.settings.product_image | image_url: width: 1600 }}"
              {% else %}
              data-image="{{ product.featured_image | image_url: width: 1600 }}"
              {% endif %}
              data-tag="{{ block.settings.saving }}"
            >i</span>
          </div>
          <div class="upsell-title-price-block">
            <h3 class="upsell-title">{{ block.settings.title }}</h3>
            <div class="upsell-price">
              <span class="upsell-sale-price">
                {{- localization.country.currency.symbol -}}
                {{- block.settings.price -}}
              </span>
              <del class="upsell-cross-price">
                {{- localization.country.currency.symbol -}}
                {{- block.settings.crossprice -}}
              </del>
            </div>
          </div>
          
          <form
            name="shopify-product-form"
            autocomplete="off"
            @submit.prevent="console.log('submitted')"
            x-ref="product_form_{{ forloop.index}}"
            enctype="multipart/form-data"
            accept-charset="UTF-8"
            id="product_form_{{ forloop.index}}"
            class="shopify-product-form form_s1 link-to-variant variant_1 show"
            data-product-id="{{product.id}}"
            action="/cart/add"
          >
            <input
              autocomplete="off"
              type="hidden"
              name="id"
              class="input_variant_id_"
              value="{{ block.settings.variant_id }}"
            >

            <input autocomplete="off" type="hidden" name="quantity" value="1">
            {% if block.settings.isSub %}
              <input
                autocomplete="off"
                type="checkbox"
                name="purchase_type"
                value="subscription"
                checked
                class="d-none gp--buyoption-input"
              >
            {% endif %}
            <input
              autocomplete="off"
              class="input_selling_plan_"
              type="hidden"
              name="selling_plan"
              value="{{ block.settings.sealing_plan}}"
            >
            <input
              autocomplete="off"
              type="hidden"
              class=""
              name="discount"
              value="{{ block.settings.discount }}"
            >
            <button
              data-add-to-cart="true"
              data-page-url="{{ request.path }}"
              data-target-url="{{ section.settings.targetUrl }}"
              data-index="4"
              data-funnel-stage="landing_page"
              data-module="{{ section.settings.module }}"
              data-event-label="add_to_cart"
              data-event-value="add_to_cart"
              data-item-id="{{ block.settings.sku }}"
              data-item-name="{{ block.settings.title }}"
              data-quantity="1"
              data-price="{{ localization.country.currency.symbol }}{{ block.settings.price }}"
              data-item-type="{% if block.settings.sealing_plan != blank %}subscription{% else %}PAYG{% endif %}"
              {% if section.settings.toast %}
                x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_{{ forloop.index}}, false, false, $event)"
              {% else %}
                x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_{{ forloop.index}}, true, false, $event)"
              {% endif %}
              class="btn btn-loader upsell-cta"
            >
              {{ block.settings.buttonLabel }}
            </button>
          </form>
        </div>
      {% endfor %}
    </div>
  </div>

  <!-- upsell popup starts here -->
  {%- render 'upsell-details-popup' -%}
  <!-- upsell popup ends here -->
</div>

<script>
  const dtIcon = document.querySelectorAll('.popup-detail-icon');
  const dtCloseIcon = document.querySelectorAll('.upsell-close-icon');

  dtIcon.forEach(icon => {
    icon.addEventListener('click', (e) => {
      e.stopPropagation();
      
      const popupContent = document.querySelector('.upsell-blocks-wrapper');
      if (popupContent) {
        popupContent.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }

      document.querySelector('.upsell-popup-title').innerHTML = '';
      document.querySelector('.upsell-popup-summary').innerHTML = '';
      document.querySelector('.upsell-popup-desc').innerHTML = '';
      document.querySelector('.upsell-popup-image img').setAttribute('src', '');
      document.querySelector('.popup-saving-tag').classList.add('display-none');
      
      document.querySelector('.upsell-popup-title').innerHTML = icon.getAttribute('data-title');
      document.querySelector('.upsell-popup-summary').innerHTML = icon.getAttribute('data-summary');
      document.querySelector('.upsell-popup-desc').innerHTML = icon.getAttribute('data-details');
      document.querySelector('.upsell-popup-image img').setAttribute('src', icon.getAttribute('data-image'));
      document.querySelector('.popup-saving-tag').innerHTML = icon.getAttribute('data-tag');
      if(icon.getAttribute('data-tag')) {
        document.querySelector('.popup-saving-tag').classList.remove('display-none');
      }
      
      document.body.style.overflow = 'hidden';
      
      const popupBlock = document.querySelector(`.upsell-popup-wrapper`);
      if(popupBlock) {
        popupBlock.classList.remove('display-none');
      }
    });
  });

  dtCloseIcon.forEach(closeIcon => {
    closeIcon.addEventListener('click', (e) => {
      e.stopPropagation();
      
      document.body.style.overflow = '';
      
      let closeWrapper = closeIcon.closest('.upsell-popup-wrapper');
      if (closeWrapper) {
        closeWrapper.classList.add('display-none');
      }
    });
  });

  const popupWrapper = document.querySelector('.upsell-popup-wrapper');
  const popupContent = document.querySelector('.upsell-detail-popup');
  
  // Close when clicking outside popup content
  if (popupWrapper && popupContent) {
    popupWrapper.addEventListener('click', function (e) {
      if (!popupContent.contains(e.target)) {
        popupWrapper.classList.add('display-none');
        document.body.style.overflow = '';
      }
    });
  }
</script>

