<style>
	#body .two-women-wrapper-2 .heading-2 {
		margin-bottom: unset !important;
	}
	.women-v2 {
		display: flex;
    align-items: center;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 48px;
	}
	.women-v2 h2 {
		height: unset !important;
	}
	.women-v2 p {
		margin-bottom: unset !important;
		text-align: center;
		font-family: "Lausanne";
		font-size: 18px;
		font-style: normal;
		font-weight: 200;
		line-height: 27px;
		width: max(343px, 100%);
  	max-width: 800px;
	}
	.two-women-details.h-100 .normal-text {
		line-height: 27px;
	}
	.two-women video, .video-pp-icon img {
		border-radius: 4px;
	}
	.des-hid {
		display: none;
	}
	.mob-hid {
		display: block;
	}
	@media(max-width: 768px) {
		.women-v2 {
			align-items: flex-start;
			margin-bottom: 32px;
		}
		.women-v2 p {
			text-align: left;
			font-size: 16px;
			line-height: 24px;
			max-width: 343px;
		}
		.two-women-details.h-100 {
			padding-left: unset !important;
			padding-right: unset !important;
			margin-top: 16px !important;
		}
		.two-women-details.h-100 .normal-text {
			display: flex;
			flex-direction: column;
			gap: 4px;
			font-size: 16px !important;
			line-height: 24px;
		}
		.two-women-details.h-100 .normal-text .fw-400 {
			margin-bottom: unset !important;
		}
		.two-women-details.h-100 .normal-text .fw-300 {
			font-weight: 200 !important;
		}
		.des-hid {
			display: block;
		}
		.mob-hid {
			display: none;
		}
	}
</style>

<div
  style="background-color:{{section.settings.background}};"
  class="{{ section.settings.className }} py-80 two-women-wrapper-2"
>
  <div class="container">
    <div class="">
      <div class="text-center m-text-left women-v2">
        <h2 class="heading-2 value-bold">
          {{ section.settings.main_heading }}
        </h2>
        {% if section.settings.sub_heading != blank %}
          <p class="font-lausanne gray-text">{{ section.settings.sub_heading }}</p>
        {% endif %}
      </div>
      <div class="d-flex flex-wrap justify-content-between ">
        <div class="w-50 {% if section.settings.layout %} order-2 {%endif%}">
          <div class="two-women position-relative">
            <video
              poster="{{ section.settings.poster | image_url }}"
              id="video_{{ section.id }}"
              class=" w-100 h-100"
              width="320"
              height="240"
              playsinline
              loop
              {% if section.settings.autoplay %}
                autoplay
                muted
              {% endif %}
            >
              <source src="{{ section.settings.video }}" type="video/mp4">
            </video>
            <div class="video-pp-icon">
              <img
                src="{{ 'play-button.png' | asset_img_url }}"
                data-target="video_{{ section.id }}"
                class="intro-video-play"
                alt="video"
                width="50"
                height="50"
              >
            </div>
          </div>
        </div>
        <div class="w-50  d-flex justify-content-center mob-hid {% if section.settings.layout %} order-1 {%endif%} ">
          <div class="two-women-details h-100 w-90">
            <div class="p-3">
              <div class="normal-text font-lausanne {{section.settings.textcolor}} m-text-left">
                {{ section.settings.details }}
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="manufactured mt-5">
				<div class="w-50 d-flex justify-content-center des-hid {% if section.settings.layout %} order-1 {%endif%} ">
          <div class="two-women-details h-100 w-90">
						<div class="normal-text font-lausanne {{section.settings.textcolor}} m-text-left">
							{{ section.settings.details }}
						</div>
          </div>
        </div>
        <div class="manufactured-inner">
          <h2 class="heading-2 blue-text font-lausanne mt-0 text-center d-flex align-items-center justify-content-center">
            <span class="font-lausanne"> Manufactured in the UK &nbsp;</span>
            <img
              width="40"
              height="40"
              alt="gb"
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/GB.png?v=1699590423"
            >
          </h2>
          <p class="value-sans gray-text mt-4 m-text-left">
            <span class="font-lausanne fw-400" style="color:#212121">{{ section.settings.man_details_1 }}</span>
            <br>
            <br>
            <span class="font-lausanne fw-200" style="color:#212121 !important">
              {{- section.settings.man_details_2 -}}
            </span>
          </p>
        </div>
        {% if section.settings.addScrollBtn %}
          <div class="mt-4">
            <span
              class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto common-btn-width"
              data-target="{{ section.settings.scrollto }}"
              data-top="{{ section.settings.top }}"
              {% if section.settings.dataTrack %}
                {% render 'ga4-events' %}
              {% endif %}
            >
              {{- section.settings.btnLabel -}}
            </span>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Two Women V2",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable AutoPlay",
      "default": true
    },
    {
      "type": "text",
      "id": "video",
      "label": "Add Video link",
      "default": "https://cdn.shopify.com/videos/c/o/v/5c5e343bbf94401b8aa54d7f61e796ac.mp4"
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Add Video Poster"
    },
    {
      "type": "checkbox",
      "id": "addScrollBtn",
      "label": "Show Scroll to Btn",
      "default": false
    },
    {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Select background color"
    },
    {
      "type": "checkbox",
      "id": "layout",
      "label": "Image on right"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Heading"
    },
    {
      "type": "html",
      "id": "sub_heading",
      "label": "Heading Sub text"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Add Image"
    },
    {
      "type": "html",
      "id": "details",
      "label": "Detail Text"
    },
    {
      "type": "html",
      "id": "man_details_1",
      "label": "Manufacturing Details 1",
      "default": "We manufacture Purdy & Figg concentrates in the UK, where we are subject to stringent health regulations."
    },
    {
      "type": "html",
      "id": "man_details_2",
      "label": "Manufacturing Details 2",
      "default": "Every Purdy & Figg refill is produced and packaged at our factory in Hertfordshire, where our dedicated team keep our customers’ safety in mind every step of the way"
    },
    {
      "type": "text",
      "id": "btnLabel",
      "label": "Button Label",
      "default": "GET YOUR OFFER"
    },
    {
      "type": "text",
      "id": "scrollto",
      "label": "Scroll to section id",
      "default": "javascript:void(0);"
    },
    {
      "type": "text",
      "id": "top",
      "label": "On scroll top position",
      "default": "0"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "landing_page"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "itemId",
      "label": "Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label": "Item Name",
      "type": "text"
    }
  ],
  "presets": [
    {
      "name": "Two Women V2"
    }
  ]
}
{% endschema %}
