          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "m_image_only",
          "label": "Mobile image"
        },
        {
          "type": "text",
          "id": "badge_heading",
          "label": "Badge heading"
        },
        {
          "type": "textarea",
          "id": "badge_subheading",
          "label": "Badge sub heading"
        }
      ]
    },
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "checkbox",
          "id": "out_of_stock",
          "label": "Out of stock"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Choose Product"
        },
        {
          "type": "text",
          "id": "variant_number",
          "label": "Variant number"
        },
        {
          "type": "text",
          "id": "variant_id",
          "label": "Variant ID"
        },
        {
          "type": "text",
          "id": "sku",
          "label": "SKU"
        },
        {
          "type": "text",
          "id": "sealing_plan",
          "label": "Sealing Plan"
        },
        {
          "type": "text",
          "id": "discount",
          "label": "Discount Code"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Choose Product Image"
        },
        {
          "type": "checkbox",
          "id": "isSub",
          "label": "Product subscription enable"
        },
        {
          "type": "color",
          "id": "productheadingcolor",
          "label": "Product Heading Color",
          "default" : "#212121"
        },
        {
          "type": "color",
          "id": "productsummarycolor",
          "label": "Product Summary Color",
          "default" : "#424242"
        },
        {
          "type": "color",
          "id": "ctabgcolor",
          "label": "CTA BG Color",
          "default" : "#11322C"
        },
        {
          "type": "color",
          "id": "ctatextcolor",
          "label": "CTA Text Color",
          "default" : "#FFFFFF"
        },
        {
          "type": "html",
          "id": "title",
          "label": "Product Title"
        },
        {
          "type": "html",
          "id": "summary",
          "label": "Short summary"
        },
        {
          "type": "text",
          "id": "saving",
          "label": "Product Saving %",
          "default": "Saving 20%"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Product Price"
        },
        {
