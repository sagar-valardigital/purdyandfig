{% assign blockcount = 0 %}
{% for block in section.blocks %}
  {% if block.type == 'product' %}
    {% assign blockcount = blockcount | plus: 1 %}
  {% endif %}
{% endfor %}

{% if section.settings.showdivider %}
  <div class="show-divider-m"></div>
{% endif %}

<div
  id="product-blocks-section"
  class="product-blocks-section"
  x-data="{qty:1}"
  style="background-color:{{ section.settings.bg }}"
>
  <div class="container" id="{{ section.settings.scroll_id }}" style="scroll-margin-top: {{ section.settings.scroll_margin }}px;">
    <div class="section-header">
      {% if section.settings.heading != blank %}
        <h2 class="heading-2 font-gtsuper" style="color: {{ section.settings.headingcolor }} !important">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="font-lausanne fw-300 subheading" style="color: {{ section.settings.subheadingcolor }} !important">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="reskin-product-blocks-wrapper {% if section.settings.paddingfix %}has-note-padding{% endif %}" 
     {% if section.settings.lastblock %}style="border-bottom: 0"{% endif %}>
      {% for block in section.blocks %}
        {% if block.type == 'image' %}
          <div class="reskin-product-block image-only-block position-relative {% if blockcount == 2 %}take-two{% endif %}">
            <img
              src="{{ block.settings.d_image_only | image_url: width: 600 }}"
              alt="{{ block.settings.d_image_only.alt }}"
              width="280"
              height="431"
              class="img-responsive h-auto"
            >
            <div class="image-only-badge">
              <span class="badge-head">{{ block.settings.badge_heading }}</span>
              <span class="badge-subhead">{{ block.settings.badge_subheading }}</span>
            </div>
          </div>
        {% else %}
          {% assign product = block.settings.product %}
          <div class="reskin-product-block {% if blockcount == 2 %}update-order{% endif %}">
            <div class="rpb-image position-relative">
              {% if block.settings.product_image %}
                <img
                  src="{{ block.settings.product_image | image_url: width: 600 }}"
                  alt="{{ block.settings.product_image.alt }}"
                  width="280"
                  height="280"
                  class="img-responsive h-auto image-main-381"
                  onclick="firepopupblock(this);"
                >
              {% else %}
                <img
                  src="{{ product.featured_image | image_url : width: 600 }}"
                  alt="{{ product.featured_image.alt }}"
                  width="280"
                  height="280"
                  class="img-responsive h-auto image-main-381"
                  onclick="firepopupblock(this);"
                >
              {% endif %}
              {% if block.settings.saving != blank %}
                <span class="saving-tag font-lausanne fw-400">{{ block.settings.saving }}</span>
              {%- endif %}
            </div>
            <div class="rpb-product-details">
              <h3 class="heading-3 font-lausanne fw-400 title-main-381" style="color: {{ block.settings.productheadingcolor }} !important" onclick="firepopupblock(this);">
                {{ block.settings.title }}
              </h3>
              <div class="pr-short-desc" style="color: {{ block.settings.productsummarycolor }} !important">{{ block.settings.summary }}</div>
              <div class="rpb-pricing" style="color: {{ block.settings.productsummarycolor }} !important">
                <span style="color: {{ block.settings.productsummarycolor }} !important">
                  {{- localization.country.currency.symbol -}}
                  {{- block.settings.price -}}
                </span>
                <del style="{% if block.settings.crossprice == blank %}display: none;{% endif %}">
                  {{- localization.country.currency.symbol -}}
                  {{- block.settings.crossprice -}}
                </del>
              </div>
            </div>
            <div class="rpb-btn-box">
              <input type="hidden" class="toast-sub" data-pop-sub="{{ block.settings.isSub }}">

              <div class="bulletpoints1" style="display: none;">{{ block.settings.bulletpoints1 }}</div>
              <div class="bulletpoints2" style="display: none;">{{ block.settings.bulletpoints2 }}</div>
              <div class="bulletpoints3" style="display: none;">{{ block.settings.bulletpoints3 }}</div>
              <div class="bulletpoints4" style="display: none;">{{ block.settings.bulletpoints4 }}</div>
              <div class="bulletpoints5" style="display: none;">{{ block.settings.bulletpoints5 }}</div>
              <div class="bulletpoints6" style="display: none;">{{ block.settings.bulletpoints6 }}</div>
              <div class="bulletpoints7" style="display: none;">{{ block.settings.bulletpoints7 }}</div>
              <div class="bulletpoints8" style="display: none;">{{ block.settings.bulletpoints8 }}</div>
              <div class="popup-title" style="display: none;">{{ block.settings.popuptitle }}</div>
              <div class="popup-summary" style="display: none;">{{ block.settings.popupsummary }}</div>
              <div class="pop-bullet-heading" style="display: none;">
                {% if block.settings.bulletlabel != blank -%}
                  {{- block.settings.bulletlabel -}}
                {%- else -%}
                  Pack includes:
                {%- endif %}
              </div>
              <div class="out-of-stock" style="display: none;">{{ block.settings.out_of_stock }}</div>

              <form
                name="shopify-product-form"
                autocomplete="off"
                @submit.prevent="console.log('submitted')"
                x-ref="product_form_{{ block.settings.variant_number }}"
                enctype="multipart/form-data"
                accept-charset="UTF-8"
                id="product_form_{{ block.settings.variant_number }}"
                class="shopify-product-form form_s1 link-to-variant variant_1 show"
                data-product-id="{{product.id}}"
                action="/cart/add"
              >
                <input
                  autocomplete="off"
                  type="hidden"
                  name="id"
                  class="input_variant_id_"
                  value="{{ block.settings.variant_id }}"
                >

                <input autocomplete="off" type="hidden" name="quantity" value="1">
                {% if block.settings.isSub %}
                  <input
                    autocomplete="off"
                    type="checkbox"
                    name="purchase_type"
                    value="subscription"
                    checked
                    class="d-none gp--buyoption-input purc_type"
                  >
                {% else %}
                  <input
                    autocomplete="off"
                    type="checkbox"
                    name="purchase_type"
                    value="payg"
                    checked
                    class="d-none gp--buyoption-input purc_type"
                  >
                {% endif %}
                <input
                  autocomplete="off"
                  class="input_selling_plan_"
                  type="hidden"
                  name="selling_plan"
                  value="{{ block.settings.sealing_plan}}"
                >
                <input
                  autocomplete="off"
                  type="hidden"
                  class="disc"
                  name="discount"
                  value="{{ block.settings.discount }}"
                >
                {% if block.settings.out_of_stock %}
                <button
                  class="btn btn-christmas-btn btn-loader cta-381 btn-main-381"
                  disabled="disabled"
                  style="opacity: 0.6; background: {{ block.settings.ctabgcolor }} !important; color: {{ block.settings.ctatextcolor }} !important"
                  {% if block.settings.dataTrack %}
                    {% comment %} data-add-to-cart="true" {% endcomment %}
                    data-page-url="{{ request.path }}"
                    data-target-url="{{ block.settings.targetUrl }}"
                    data-index="{{ block.settings.index }}"
                    data-funnel-stage="{{ block.settings.funnel_stage }}"
                    data-module="{{ block.settings.dataModule }}"
                    data-event-label="{{ block.settings.dataTitle }}"
                    data-event-value="{{ block.settings.eventValue }}"
                    data-item-id="{{ block.settings.sku }}"
                    data-option-index="{{ block.settings.optionIndex }}"
                    data-item-name="{{ block.settings.gaitemName }}"
                    data-quantity="{{ block.settings.quantity }}"
                    data-price="{{ localization.country.currency.symbol }}{{ block.settings.price }}"
                    data-cross-price="{{ localization.country.currency.symbol }}{{ block.settings.crossprice }}"
                    data-item-type="{% if block.settings.isSub %}subscription{% else %}PAYG{% endif %}"
                  {% endif %}
                >
                  <span class="cl-btn-txt-381">OUT OF STOCK</span>
                  <!--
                    <del class="cl-btn-del-price-381">{{ localization.country.currency.symbol }}{{ block.settings.crossprice }}</del>
                    <span class="cl-btn-price-381">{{ localization.country.currency.symbol }}{{ block.settings.price }}</span>
                  -->
                </button>
                {% else %}
                <button
                  {% if section.settings.toast %}
                    x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_{{ block.settings.variant_number }}, false, false, $event)"
                  {% else %}
                    x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_{{ block.settings.variant_number }}, false, false, $event)"
                  {% endif %}
                  class="btn btn-christmas-btn btn-loader cta-381 btn-main-381"
                  style="background: {{ block.settings.ctabgcolor }} !important; color: {{ block.settings.ctatextcolor }} !important"
                  {% if block.settings.dataTrack %}
                    data-add-to-cart="true"
                    data-page-url="{{ request.path }}"
                    data-target-url="{{ block.settings.targetUrl }}"
                    data-index="{{ block.settings.index }}"
                    data-funnel-stage="{{ block.settings.funnel_stage }}"
                    data-module="{{ block.settings.dataModule }}"
                    data-event-label="{{ block.settings.dataTitle }}"
                    data-event-value="{{ block.settings.eventValue }}"
                    data-item-id="{{ block.settings.sku }}"
                    data-option-index="{{ block.settings.optionIndex }}"
                    data-item-name="{{ block.settings.gaitemName }}"
                    data-quantity="{{ block.settings.quantity }}"
                    data-price="{{ localization.country.currency.symbol }}{{ block.settings.price }}"
                    data-cross-price="{{ localization.country.currency.symbol }}{{ block.settings.crossprice }}"
                    data-item-type="{% if block.settings.isSub %}subscription{% else %}PAYG{% endif %}"
                  {% endif %}
                >
                  <span class="cl-btn-txt-381">{{ block.settings.buttonLabel }}</span>
                  <!--
                    <del class="cl-btn-del-price-381">{{ localization.country.currency.symbol }}{{ block.settings.crossprice }}</del>
                    <span class="cl-btn-price-381">{{ localization.country.currency.symbol }}{{ block.settings.price }}</span>
                  -->
                </button>
                {% endif %}
              </form>
              <div class="note-under-button" style="color: {{ block.settings.productsummarycolor }} !important; {% if block.settings.buttonNote == blank %}display: none;{% endif %}">{{ block.settings.buttonNote }}</div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.shownote %}
      <div class="alert-note" style="color: {{ section.settings.notecolor }}">Discount valid on maximum of 5 products</div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Collections 430",
  "class": "collections-381",
  "settings": [
    {
      "type": "text",
      "id": "className",
      "label": "Add section class"
    },
    {
      "type": "checkbox",
      "id": "showdivider",
      "label": "Show divider"
    },
    {
      "type": "checkbox",
      "id": "lastblock",
      "label": "Last block (hide divider)"
    },
    {
      "type": "checkbox",
      "id": "paddingfix",
      "label": "Adjust padding (for note)"
    },
    {
      "type": "checkbox",
      "id": "shownote",
      "label": "Show bottom note"
    },
    {
      "type": "color",
      "id": "notecolor",
      "label": "Note Text Color",
      "default" : "#212121"
    },
    {
      "type": "checkbox",
      "id": "toast",
      "label": "Enable toast"
    },
    {
      "type": "color",
      "id": "bg",
      "label": "Section Background Color"
    },
    {
      "type": "color",
      "id": "headingcolor",
      "label": "Heading Color",
      "default" : "#0A1E1A"
    },
    {
      "type": "color",
      "id": "subheadingcolor",
      "label": "Sub Heading Color",
      "default" : "#0A1E1A"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Section Heading"
    },
    {
      "type": "html",
      "id": "subheading",
      "label": "Section Subheading"
    },
    {
      "id": "scroll_id",
      "label": "Section Scroll ID",
      "type": "text"
    },
    {
      "id": "scroll_margin",
      "label": "Section margin",
      "type": "text"
    },
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
