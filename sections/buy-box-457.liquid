			font-size: 24px !important;
		}
	}
</style>

<script>
// Create AB object
var AB = AB || {};

AB.checkoutBundle = function(formdata, event) {
    event.preventDefault();
    $(event.target).addClass('loading');
    
    // Get variant IDs from the input field
    let variantIdsValue = $(formdata).find('.input_variant_id').val();
    let variantIds = variantIdsValue ? variantIdsValue.split(',').map(id => id.trim()).filter(id => id) : [];

    // Get selling plans from the input field
    let sellingPlansValue = $(formdata).find('.input_selling_plan').val();
    let sellingPlans = sellingPlansValue ? sellingPlansValue.split(',').map(plan => plan.trim()).filter(plan => plan) : [];

    // Get discount from the input field
    let discount = $(formdata).find('.discout_input').val() || '';

    // Get quantity
    let quantity = parseInt($(formdata).find('input[name="quantity"]').val()) || 1;

    // Check if subscription is selected
    let isSubscription = $(formdata).find('.gp--buyoption-input').is(':checked');

    // Check if button has data-discount attribute
    if (isSubscription && $(event.target).attr('data-discount')) {
      discount = $(event.target).attr('data-discount');
    }

    // Validate we have variant IDs
    if (variantIds.length === 0) {
      $(event.target).removeClass('loading');
      console.error('No variant IDs found');
      return;
    }

    // Fetch discount information from cart.js
    fetch(window.Shopify.routes.root + 'cart.js')
      .then(response => response.json())
      .then(cart => {
        // Initialize a set to hold all unique discount titles
        let allDiscounts = new Set();

        // Loop through each item and add their discounts to the set
        cart.items.forEach(item => {
          item.discounts.forEach(discountItem => {
            allDiscounts.add(discountItem.title);
          });
        });

        // Convert the set of discounts to a comma-separated string
        let discountsString = Array.from(allDiscounts).join(',');

        // Update 'discount' if different
        if (discountsString && discount !== discountsString) {
          if (discount) {
            discount = discount + ',' + discountsString;
          } else {
            discount = discountsString;
          }
        }

        // Function to add items sequentially
        const addItemsSequentially = async () => {
          for (let i = 0; i < variantIds.length; i++) {
            const variantId = variantIds[i];
            const formData = new FormData();
            
            formData.append('id', variantId);
            formData.append('quantity', quantity);
            
            // Add selling plan if subscription is checked and plan exists for this variant
            if (isSubscription && sellingPlans[i]) {
              formData.append('selling_plan', sellingPlans[i]);
            }

            try {
              const response = await fetch(window.Shopify.routes.root + 'cart/add.js', {
                method: 'POST',
                body: formData
              });
              
              const result = await response.json();
              
              if (!response.ok) {
                throw new Error(result.description || 'Failed to add item');
              }
            } catch (error) {
              $(event.target).removeClass('loading');
              console.error('Error adding item to cart:', error);
              return;
            }
          }
          
          // All items added successfully, redirect to checkout
          $(event.target).removeClass('loading');
          if (discount != '') {
            window.location.href = window.Shopify.routes.root + 'checkout?discount=' + discount;
          } else {
            window.location.href = window.Shopify.routes.root + 'checkout/';
          }
        };

        // Start adding items
        addItemsSequentially();
      })
      .catch((error) => {
        $(event.target).removeClass('loading');
        console.error('Failed to fetch cart data:', error);
      });
  };
</script>

