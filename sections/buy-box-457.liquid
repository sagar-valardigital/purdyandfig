                      </p>
                      {% endif %}
                      {% for block in section.blocks %}
                        {% if block.type == 'point' %}
                          <span
                            class="link-to-variant font-lausanne fw-300  variant_{{ block.settings.listClass2 }}"
                          >
                            {{ block.settings.listItem2 }}
                          </span>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </label>
                </div>
              </div>
              <input
                autocomplete="off"
                type="hidden"
                name="id"
                class="input_variant_id"
                value="{{ section.settings.variant_id_1 }}"
              >
              <input
                autocomplete="off"
                type="hidden"
                class="discout_input"
                name="discount"
                value="{{ section.settings.discountPlan_1 }}"
              >
              <input autocomplete="off" type="hidden" name="quantity" value="1">

              <input
                autocomplete="off"
                type="checkbox"
                name="purchase_type"
                value="subscription"
                checked
                class="d-none gp--buyoption-input"
              >
              <input
                autocomplete="off"
                class="input_selling_plan"
                type="hidden"
                name="selling_plan"
                value="{{ section.settings.selling_plan_1 }}"
              >
              <div class="text-left  g4-btn-wrapper m-auto">
                {% if section.settings.redirectLink %}
                  <a
                    class="btn w-100 green-btn font-lausanne fw-400 btn-loader checkout-starterkit-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                    href="{{ section.settings.redirectLink }}"
                  >
                    {% if section.settings.outOfStock %}
                      Out of Stock
                    {% else %}
                      {{ section.settings.btnText }}
                    {% endif -%}
                  </a>
                {% else %}
                  {% if section.settings.isCheckout %}
                    <span
                      x-on:click="AB.checkoutBundle($refs.product_form_{{ section.index}}, event)"
                      class="btn w-100 value-medium btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                      style="background-color:#2D469E"
                      {% if section.settings.dataTrack %}
                        data-checkout="true"
                        data-add-to-cart="true" data-page-url="{{ request.path }}"
                        data-target-url="{{ section.settings.targetUrl }}"
                        data-index="{{ section.settings.index }}"
                        data-funnel-stage="{{ section.settings.funnel_stage }}"
                        data-module="{{ section.settings.dataModule }}"
                        data-event-label="{{ section.settings.dataTitle }}"
                        data-event-value="{{ section.settings.eventValue }}"
                        data-item-id="{{ section.settings.sku_1 }}"
                        data-option-index="{{ section.settings.optionIndex }}"
                        data-item-name="Counter Clean 90-day plan" data-quantity="{{ section.settings.quantity }}"
                        data-price="{{ localization.country.currency.symbol }}{{- section.settings.price_1 -}}"
                        data-item-type="subscription"
                      {% endif %}
                    >
                      {% if section.settings.outOfStock %}
                        Out of Stock
                      {% else %}
                        <span class="buy-text">{{ section.settings.btnText }} </span>|
                        <span
                          class="deleted-price font-lausanne fw-400 text-decoration-line-through  gp--del-price"
                          style="color:#bdbdbd;margin-right:0;"
                        >
                          {{- localization.country.currency.symbol }}{{- section.settings.deleted_price_1 -}}
                        </span>
                        <span class="font-lausanne fw-500 white-text gp--sell-price">
                          {{- localization.country.currency.symbol -}}{{- section.settings.price_1 -}}
                        </span>
                      {% endif -%}
                    </span>
                  {% endif %}
                {% endif -%}

                {% if section.settings.showMoneyBackLabel %}
                  <div
                    class="text-center theme-text mt-2 guarantee-text fw-600"
                    style="font-size:12px; color:#212121; line-height: 18px;"
                  >
                    90-day plan, cancel any time<br>
                    30-day money-back guarantee
                  </div>
                {% endif %}
              </div>
            </form>

            
          </div>
        </div>
      </div>
    </div>
  </div>
</div>


