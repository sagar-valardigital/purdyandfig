<style>
  .banner-section-381 {
    width: 100%;
    height: 400px;
    padding: 80px 184px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    background: linear-gradient(263deg, rgba(27, 34, 6, 0.00) 14.27%, rgba(27, 34, 6, 0.60) 100%),
      url('{{ section.settings.desktop_image | image_url: width: 3200 }}');
    background-color: lightgray;
    background-size: cover;
    background-position: top center;
  }

  .banner-image-381 {
    display: none;
  }

  .banner-heading-381 h2 {
    font-family: "GT Super";
    font-size: 48px;
    font-style: normal;
    font-weight: 400;
    line-height: 60px;
    color: {{ section.settings.text_color }};
  }

  .breadcrumbs {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .breadcrumb-inner, .breadcrumb-inner.active a {
    font-size: 14px;
    font-style: normal;
    line-height: 21px;
    color: #FFF;
    font-family: "Lausanne";
  }

  .breadcrumb-inner.active a {
    color: #EEE !important;
    font-weight: 200;
  }

  .breadcrumb-inner {
    font-weight: 400;
  }

  .breadcrumb-inner.bread-icon {
    font-weight: 200;
  }

  @media (max-width: 767px) {
    .banner-section-381 {
      height: 280px;
      padding: 32px 16px;
      background: linear-gradient(180deg, rgba(27, 34, 6, 0.00) 29.61%, rgba(27, 34, 6, 0.80) 100%),
        url('{{ section.settings.mobile_image | image_url: width: 1200 }}');
      background-size: cover;
      background-position: top center;
    }

    .banner-heading-381 h2 {
      font-size: 36px;
      line-height: 45px;
    }

    .breadcrumb-inner, .breadcrumb-inner.active a {
      font-size: 12px;
      line-height: 18px;
      letter-spacing: 0.18px;
    }
  }
</style>

<section class="banner-section-381 position-relative">
  <div class="banner-heading-381">
    <h2>{{ section.settings.heading }}</h2>

    {% if section.blocks.size > 0 %}
    <div class="breadcrumbs">
      {% for block in section.blocks %}
        {% if block.settings.link != blank %}
          <div class="breadcrumb-inner active">
            <a href="{{ block.settings.link }}">{{ block.settings.breadcrumb }}</a>
          </div>
        {% else %}
          <div class="breadcrumb-inner">{{ block.settings.breadcrumb }}</div>
        {% endif %}

        {% if forloop.index < section.blocks.size %}
        <div class="breadcrumb-inner bread-icon">&#x3E;</div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Banner 461",
  "settings": [
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Add breadcrumbs",
      "settings": [
        {
          "type": "text",
          "id": "breadcrumb",
          "label": "Breadcrumb"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Breadcurmb link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner 461"
    }
  ]
}
{% endschema %}
