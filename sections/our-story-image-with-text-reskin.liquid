{% if section.settings.enable %}
  <div class="{{section.settings.background}} {{ section.settings.className }} {% if template.suffix == 'Our Story' %}our-story-imagewithtext{% endif %}">
    <div class="image-with-text">
      <div class="">
        <div class="d-flex flex-wrap justify-content-between align-items-center common-flex">
          <div class="w-45 {% if section.settings.layout %} order-2 {%endif%}">
            <div class="two-women">
              {% if section.settings.image %}
                {% assign mImage = section.settings.image | img_url: '800x' %}
                <img loading="lazy" src="{{mImage}}" width="800px" height="800px" class="img-responsive w-100" alt="{{ section.settings.image.alt }}">
              {% endif %}
            </div>
          </div>
          <div class="w-45 d-flex {% if section.settings.layout %} order-1 {%endif%} ">
            <div class="two-women-details  pb-2 {{section.settings.width}}">
              <h2 class="heading-2 {{section.settings.textcolor}} {% if section.settings.heading-position%} {% endif %}">
                {{ section.settings.heading }}
              </h2>
              <div class="normal-text {{section.settings.textcolor}}">
                {{ section.settings.details }}
              </div>
              {% if section.settings.scrollID != blank %}
                <a href="javascript:void(0);"  >
                  <span  class="{{section.settings.textcolor}} font-pier {{section.settings.btntype}} click-scroll" data-top="{{ section.settings.top }}" data-target="{{ section.settings.scrollID  }}" {% if section.settings.dataTrack %} {% render 'ga4-events' %} {% endif %}>{{section.settings.btntext}}</span>
                </a>
              {% else %}
                <a
                  class="{% if section.settings.enable-popup %} show-popup {%endif%}"
                  {% if section.settings['enable-popup'] %}
                    data-popup="section{{section.id}}"
                  {% endif %}
                  href="{% if section.settings.enable-popup %}javascript:void(0);{% else %}{{section.settings.link}} {%endif%}"
                  {% if section.settings.dataTrack %}
                    {% render 'ga4-events' %}
                  {% endif %}
                >
                  {% if section.settings.link %}
                    <span class="{{section.settings.textcolor}} font-pier {{section.settings.btntype}}">
                      {{- section.settings.btntext -}}
                    </span>
                  {% endif %}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  {% if section.settings['enable-popup'] %}
    <div id="section{{section.id}}" class="popup">
      <span class="popup-overlay"></span>
      <div class="popup-inner">
        <span class="close-popup">&#215;</span>
        <div class="theme-text normal-text popup-text">{{ section.settings['popup-text'] }}</div>
      </div>
    </div>
  {% endif %}
{% endif %}

{% schema %}
  {
    "name": "Our story image with text",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
