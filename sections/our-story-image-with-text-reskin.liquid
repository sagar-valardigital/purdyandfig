      {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
{
            "type": "select",
            "id": "textcolor",
            "label": "Select text color",
            "options": [
              {
                "value": "white-text",
                "label": "White color"
              },
              {
                "value": "theme-text",
                "label": "Theme color"
              }
            ],
            "default": "white-text"
          },
{
            "type": "select",
            "id": "background",
            "label": "Select background color",
            "options": [
              {
                "value": "theme-gradient",
                "label": "Blue & White"
              },
              {
                "value": "pf-mission ",
                "label": "Yellow & Orange"
              },
{
                "value": "theme-bg ",
                "label": "Theme Color"
              },
              {
                "value": "white-bg",
                "label": "White Color"
              }
            ],
            "default": "theme-gradient"
          },
{
            "type": "select",
            "id": "width",
            "label": "Select text area width",
            "options": [
              {
                "value": "w-90",
                "label": "90%"
              },
              {
                "value": "w-80",
                "label": "80%"
              },
{
                "value": "w-70",
                "label": "70%"
              },
              {
                "value": "w-60",
                "label": "60%"
              }
            ],
            "default": "w-80"
          },
{
            "type": "checkbox",
            "id": "layout",
            "label": "Image on right"

          },
{
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
{
      "type": "image_picker",
      "id": "image",
      "label": "Add Image"
    },

{
      "type": "richtext",
      "id": "details",
      "label": "Detail Text"
    },
{
      "type": "url",
      "id": "link",
      "label": "Add link"
    },
{
      "type": "text",
      "id": "btntext",
      "label": "Button label"
    },
    {
      "type": "text",
      "id": "scrollID",
      "label": "Button Scroll to"
    },
      {
          "type": "text",
          "id": "top",
          "label": "Scroll Position"
        },
{
            "type": "select",
            "id": "btntype",
            "label": "Select button Type",
            "options": [
              {
                "value": "read-more-link",
                "label": "Link"
              },
              {
                "value": "btn",
                "label": "Button"
              }

            ],
            "default": "read-more-link"
          },
{
      "type": "header",
      "content": "Mobile"
    },

{
            "type": "checkbox",
            "id": "heading-position",
            "label": "Heading After Image"

          },
{
	"type": "header",
      "content": "Popup"
},
{
            "type": "checkbox",
            "id": "enable-popup",
            "label": "Enable popup"

          },
{
            "type": "text",
            "id": "popup-text",
            "label": "Popup Content"

          },
  {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
	],

	"presets": [
		{
			"name": "Our story image with text"
		}
	]
  }
{% endschema %}
