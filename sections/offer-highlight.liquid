
  <style>
    .join-btn {
        letter-spacing: 0.4px;
        text-decoration-line: underline;
        text-underline-position: from-font;
        text-transform: uppercase;
    }
    .join_us_link, .banner-sub-heading {
      text-align: center;
    }
    .member-benifit-heading-381{
          color:  #0A1E1A;

      }

      .py-40 {
        padding-block:40px;
      }

       @media (min-width: 767px) {
      .banner-sub-heading {
         font-size: 18px;
      }
    }

     @media (max-width: 767px) {
      .join_us_link, .banner-sub-heading {
        text-align: left;
      }

      .heading-2
      {
          font-size: 32px !important;
          margin-bottom: 16px !important;
      }

      .member-benifit-heading-381{
          font-size: 32px !important;
          margin-bottom: 16px !important;
          color:  #0A1E1A;

      }

       .py-40 {
        padding-block:32px;
      }

    }

   
    
  }
    </style>
  <div
    class="block-section py-40 icon-blocks-2 icon-blocks-reskin member-benifit-381 {{ section.settings.class }}"
    style="background-color:{{ section.settings.bg }}"
  >
    <div class="container">
      <h2 class="heading-2 text-center m-text-left blue-text font-gtsuper fw-400 mt-0 member-benifit-heading-381" >
        {{ section.settings.heading }}
      </h2>
      <p class="banner-sub-heading font-lausanne fw-200 ">
         {{ section.settings.sub_heading }}
      </p>
      {% if section.settings.showbtn %}
        <div class=" mt-3 join_us_link">
          <a
            {% if section.settings.dataTrack %}
              {% render 'ga4-events' %}
            {% endif %}
            href="{{ section.settings.btnlink }}"
            data-target="{{ section.settings.scrollto }}"
            data-top="{{ section.settings.top }}"
            class="click-scroll join-btn"
            style="background: {{ section.settings.btnbgcolor }} !important; color: {{ section.settings.btntxtcolor }} !important;"
          >
            {{- section.settings.btntext -}}
          </a>
        </div>
      {% endif %}
    </div>
  </div>


{% schema %}
{
  "name": "Offer Highlight",
  "settings": [
    {
       "type": "text",
       "id" : "class",
       "label": "Section Class"
     },
     {
       "type": "color",
       "id" : "bg",
       "label": "Background Colour",
       "default": "#ffffff"
     },
     {
       "type": "text",
       "id" : "heading",
       "label": "Heading"
     },
     {
       "type": "html",
       "id" : "sub_heading",
       "label": "Sub Heading"
     },
     {
       "type": "checkbox",
       "id": "showbtn",
       "label": "Show button",
       "default": false
     },
     {
       "type": "color",
       "id": "btnbgcolor",
       "label": "Button background"
     },
     {
       "type": "color",
       "id": "btntxtcolor",
       "label": "Button text color"
     },
     {
       "type": "text",
       "id": "btntext",
       "label": "Button label"
     },
     {
       "type": "text",
       "id" : "btnlink",
       "label": "Button Link"
     },
     {
       "type": "text",
       "id": "scrollto",
       "label": "Scroll to"
     },
     {
       "type": "text",
       "id": "top",
       "label": "Scroll position"
     },
     {
        "id": "dataTrack",
        "label":"Data Track",
        "type": "checkbox"
      },
      {
        "id": "targetUrl",
        "label":"Target Url",
        "type": "url"
      },
      {
        "id": "index",
        "label":"Index",
        "type": "number",
        "default" : 0
      },
      {
        "id": "funnel_stage",
        "label":"Funnel Stage",
        "type": "text",
        "default" : "landing_page"
      },
      {
        "id": "dataModule",
        "label":"Module",
        "type": "text",
        "default" : "announcement_bar"
      },
      {
        "id": "dataTitle",
        "label":"Event Label",
        "type": "text",
        "default": "get_your_offer"
      },
      {
        "id": "eventValue",
        "label":"Event Value",
        "type": "text",
        "default" : "shop_anchor"
      },
      {
        "id": "itemId",
        "label":"Item Id",
        "type": "text"
      },
      {
        "id": "optionIndex",
        "label":"Option Index",
        "type": "text"
      },
      {
        "id": "ItemName",
        "label":"Item Name",
        "type": "text"
      }
   ],
   "presets": [
     {
       "name": "Offer Highlight"
     }
   ]
}
{% endschema %}
