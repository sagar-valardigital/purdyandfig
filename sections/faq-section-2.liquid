{% if section.settings.enable %}
  <div
    class="faq-section-wrapper-2 {{ section.settings.class }}"
    style="background-color:{{ section.settings.color_bg }}"
  >
    <div class="container">
      <div class="faq-section-2-heading text-center">
        <h3 class="heading-2 font-value blue-text">{{ section.settings.heading }}</h3>
      </div>
      <div class="faqBlockWrapper">
        {% for block in section.blocks %}
          <div class="faq">
            <details
              class="faq-acc faq-acc-2"
              {% if block.settings.open %}
                open="true"
              {% endif %}
            >
              <summary class="faq-que-2 value-medium ">{{ block.settings['faq-question'] }}</summary>
              <p class="mt-2 ">{{ block.settings['faq-ans'] }}</p>
            </details>
          </div>
        {% endfor %}
      </div>
      {% if section.settings.bottomText != blank %}
        <div class="mt-5">
          <p class="font-lausanne text-center m-0 faq-bottom-text fw-200">{{ section.settings.bottomText }}</p>
        </div>
      {% endif %}
      {% if section.settings.addScrollBtn %}
        <div class="mt-4">
          <span
            class="d-block text-center blue-starterkit-btn click-scroll m-auto custom-button"
            data-target="{{ section.settings.scrollto }}"
            data-top="{{ section.settings.top }}"
            {% if section.settings.dataTrack %}
              {% render 'ga4-events' %}
            {% endif %}
            >{{ section.settings.bottom_label }}</span
          >
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "FAQ section 2",
  "class": "faq-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background color",
      "default": "#fff"
    },
    {
      "type": "text",
      "id": "class",
      "label": "Section Class"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "addScrollBtn",
      "label": "Show Scroll to Btn",
      "default": false
    },
    {
      "type": "text",
      "id": "bottom_label",
      "label": "Button label",
      "default": "GET YOUR OFFER"
    },
    {
      "type": "text",
      "id": "scrollto",
      "label": "Scroll to section id",
      "default": "javascript:void(0);",
      "visible_if": "{{ section.settings.addScrollBtn }}"
    },
    {
      "type": "text",
      "id": "top",
      "label": "On scroll top position",
      "default": "0",
      "visible_if": "{{ section.settings.addScrollBtn }}"
    },
    {
      "type": "html",
      "id": "bottomText",
      "label": "FAQ Bottom Text"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "landing_page"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "itemId",
      "label": "Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label": "Item Name",
      "type": "text"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "faq",
      "settings": [
        {
          "type": "checkbox",
          "id": "open",
          "label": "Default Open",
          "default": false
        },
        {
          "type": "text",
          "id": "faq-question",
          "label": "FAQ QUE"
        },
        {
          "type": "richtext",
          "id": "faq-ans",
          "label": "FAQ ANS"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ section 2"
    }
  ]
}
{% endschema %}
