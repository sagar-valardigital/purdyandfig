{% if section.settings.enable%}
<style>
  #{{section.id}}_image{
    {%if section.settings.bgImage %}
  background-image:url("{{section.settings.bgImage | img_url : '2000x'}}");
    {% endif %}
      color:{{section.settings.textcolor}};
    background-position:center center;
    background-size:cover;
    background-repeat:no-repeat;
  }
  #{{section.id}}{
    
      padding-top:{{section.settings.sp}}rem;
      padding-bottom:{{section.settings.sp}}rem;
  }
  @media(min-width:769px){
  .text-over-image  img{display:none !important;;}
  }
  @media(max-width:768px){
    {% if section.settings.mobileimage%}
    	{% if section.settings.bgmImage %}
  			#{{section.id}}_image{
   				 background-image:url("{{section.settings.bgmImage | img_url : '768x'}}");
 			 }
            
    	{%endif%} 
    {%else%}
  	#{{section.id}}_image{
    	background-color:{{section.settings.bgcolor }};
      background-image: none;
 	 }
    {%endif%}
    #{{section.id}}{color:#3D5065;}
    #{{section.id}}.mobile-bottom{
      padding-bottom:{{section.settings.spacem}}px !important;
      background-position:center bottom;
      padding-top:0px !important;
    }
    #{{section.id}}.mobile-top{
      padding-bottom:0px !important;
    	padding-top:{{section.settings.spacem}}px !important;
      background-position:center top;
    }
  }
</style>
<div class="py-4" id='{{section.id}}_image'>
  <div class="container">
    <div>
      {% if section.settings.mainheading %}
      <h2 class="heading-2 font-value text-center textover-main-heading  mb-4">{{section.settings.mainheading}}</h2>
      {%endif%}
    </div>
    <div id='{{section.id}}' class="text-over-image  {% if section.settings.mobileimage %} {{section.settings.space}} {%endif%}">
    <div class="d-flex {{section.settings.alignment}}  ">
      <div class="{{section.settings.width}} {{section.settings.Textalignment}} m-text-center">
        {% if section.settings.heading%}
        <h3 class="heading-2 font-value  {% if section.settings.headingAfterImage %} hide {% endif %}">{{section.settings.heading}}</h3>
        {% endif %}
        {% assign image =  section.settings.bgmImage | img_url : '768x'%}
        {% if section.settings.mobileimage %}
        <img loading="lazy" width="100%" height="400px" class="img-responsive w-100  {% if section.settings.mobileimage%}d-none {%endif%}" src="{{image}}">
        {% endif %}
        {% if section.settings.heading%}
        {% if section.settings.headingAfterImage %}
        <h3 class="heading-2 font-value  mobile-heading my-3">{{section.settings.heading}}</h3>
        {% endif %}
        {% endif %}
        <div class="{% if section.settings.mobileShow %} mobile-hide{% endif %}">{{section.settings.details}}</div>
        {% if section.settings.btn%}
        <a class="btn text-over-btn mt-3 checkout-au-btn" style="background:{{ section.settings.btnColor }}; border-color:{{ section.settings.btnColor }};
          color:{{ section.settings.btnTextColor }};" href="javascript:void(0);">{{section.settings.btntext}}</a>
        {% endif %}
      </div>
    </div>
  </div>
    </div>
    </div>
{% endif %}
{% schema %}
  {
    "name": "Landing Text over Image",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },
     {
      "type": "image_picker",
      "id": "bgImage",
      "label": "Add Desktop Image"
    },
{
      "type": "checkbox",
      "id": "mobileimage",
      "label": "Mobile Image as a background",
      "default": true
    },
{
      "type": "image_picker",
      "id": "bgmImage",
      "label": "Add Mobile Image"
    },
{
      "type": "checkbox",
      "id": "headingAfterImage",
      "label": "Heading after Image"
    },

{
      "type": "color",
      "id": "bgcolor",
      "label": "Mobile background Color"
    },
{
            "type": "select",
            "id": "width",
            "label": "Select text area width",
            "options": [
              {
                "value": "w-90",
                "label": "90%"
              },
              {
                "value": "w-80",
                "label": "80%"
              },
{				
                "value": "w-70",
                "label": "70%"
              },
              {
                "value": "w-60",
                "label": "60%"
              },
              {
                "value": "w-50",
                "label": "50%"
              },
              {
                "value": "w-40",
                "label": "40%"
              }
            ],
            "default": "w-80"
          },
{
  "type": "range",
  "id": "sp",
  "min": 1,
  "max": 10,
  "step": 1,
  "unit": "rem",
  "label": "Top Bottom Spacing",
  "default": 3
},
{
            "type": "select",
            "id": "alignment",
            "label": "Select alignment",
            "options": [
              {
                "value": "justify-content-center",
                "label": "Center"
              },
              {
                "value": "justify-content-end",
                "label": "Right"
              },
              {
                "value": "justify-content-start",
                "label": "Left"
              }
            ],
            "default": "justify-content-start"
          },
{
            "type": "select",
            "id": "Textalignment",
            "label": "Select Text alignment",
            "options": [
              {
                "value": "text-center",
                "label": "Center"
              },
              {
                "value": "text-right",
                "label": "Right"
              },
              {
                "value": "text-left",
                "label": "Left"
              }
            ],
            "default": "text-left"
          },
{
            "type": "select",
            "id": "space",
            "label": "Mobile image alignment",
            "options": [
              {
                "value": "mobile-bottom",
                "label": "Bottom"
              },
              {
                "value": "mobile-top",
                "label": "Top"
              }
            ],
            "default": "mobile-top"
          },

{
      "type": "text",
      "id": "spacem",
      "label": "Space Value",
	"default" : "150"
    },
{
      "type": "text",
      "id": "mainheading",
      "label": "Main Heading"
    },
{
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },


{
      "type": "richtext",
      "id": "details",
      "label": "Detail Text"
    },
    {
      "type": "checkbox",
      "id": "mobileShow",
      "label": "mobile hide",
      "default": false
    },
{
      "type": "color",
      "id": "textcolor",
      "label": "Text Color"
    },
{
      "type": "text",
      "id": "btntext",
      "label": "Button label"
    }
,
{
      "type": "text",
      "id": "btn",
      "label": "Button Link"
    },
{
      "type": "color",
      "id": "btnColor",
      "label": "Button Color"
    }
      ,
{
      "type": "color",
      "id": "btnTextColor",
      "label": "Button Text Color"
    }
	],
	
	"presets": [
		{
			"name": "Landing Text Over Image"
		}
	]
  }
{% endschema %}