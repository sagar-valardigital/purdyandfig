<style>
.image-with-listing .image-listing li{
  background-image:url({{ section.settings.icon | image_url }});
}
</style>
<div style="background-image:url({{ section.settings.bgImage| image_url }})" class="py-80 image-with-listing">
  <div class="container">
    <div class="desktop-hide">
      <h2 class="heading-2 font-gtsuper" style="color:#0A1E1A !important">{{ section.settings.heading }}</h2>
    </div>
    <div class="d-grid image-listing-wrapper justify-content-between mt-4">
      <div class="image-listing-image">
        <img src="{{ section.settings.image | image_url }}" alt="image" width="400" height="400" class="h-auto w-100">
      </div>
      <div class="image-listing-text">
          <div class="mobile-hide">
            <h2 class="heading-2 font-gtsuper" style="color:#0A1E1A !important">{{ section.settings.heading }}</h2>
          </div>
        <ul class="image-listing">
          {% for block in section.blocks %}
            <li class="fw-200 font-lausanne">{{ block.settings.heading }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>
    {% if section.settings.addScrollBtn %}
    <div class="mt-5">
      <span
        class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >{{ section.settings.scrollBtnText }}</span
      >
    </div>
    {% endif %}
  </div>
</div>

{% schema %}
  {
    "name": "Image with list PF357",
    "settings": [
      {
        "type" : "image_picker",
        "id": "bgImage",
        "label" : "Choose Background Image"
      },
      {
        "type": "html",
        "id": "heading",
        "label" : "Heading"
      },
     {
        "type" : "image_picker",
        "id": "image",
        "label" : "Choose Image"
      },
      {
        "type" : "image_picker",
        "id": "icon",
        "label" : "Choose Listing Icon"
      },
       {
          "type": "checkbox",
          "id": "addScrollBtn",
          "label": "Show Scroll to Btn",
          "default": false
        },{
          "type": "text",
          "id": "scrollBtnText",
          "label": "Scroll to Btn Text",
           "default": "GET YOUR OFFER"
        },
      {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      }
     ,
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
    {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
    ],
    "blocks": [
      {
        "type": "text",
        "name": "block",
        "settings": [
          {
        "type" : "text",
        "id": "heading",
        "label" : "Heading"
      }
        ]
      }
    ], 
	"presets": [
		{
			"name": "Image with list PF357"
		}
	]
  }
{% endschema %}