<style>
	.link-to-variant,.link-to-plan {
		height: 0;
		overflow: hidden;
		position: relative;
	}

	.link-to-variant.show ,.link-to-plan.show {
		display: block !important;
		height: auto;
		margin-top: 4px;
		margin-bottom: 4px;
		overflow: visible;
	}
	.scent-tag{
		position:absolute;
		border:1px solid #eee;
		font-weight:400;
		font-size:12px;
		border-radius:4px;
		padding:4px 8px;
		line-height:1.2;
		{%if section.settings.tag_position == 'left' %}
		left:38px;
		{% elsif section.settings.tag_position == "right" %}
		right: 15px;
		{%endif %}
		top:-13px;
		border-color:{{section.settings.tag_bg_color | default :' #708480'}};
		background-color:{{section.settings.tag_bg_color | default :' #708480'}};
		color:{{section.settings.tag_text_color | default : '#ffffff '}};
	}
  .new-product-gallery-wrapper{
    border-radius:4px;
    overflow:hidden;
  }
	.new-product-gallery-wrapper-thumb{
		position: absolute;
		bottom: 10px;
		left: 50%;
		transform: translateX(-50%);
		max-width: 288px;
		width:80%;
	}
	.new-product-gallery-wrapper-thumb .main-product-img{
		padding:5px;
	}
	.new-product-gallery-wrapper-thumb .main-product-img img{
		border-radius:4px;
		border:2px solid transparent;
	}
	.new-product-gallery-wrapper-thumb .main-product-img.slick-current{position:relative;}
	.new-product-gallery-wrapper-thumb .main-product-img.slick-current:after{
		content:'';
		position:absolute;
		width:calc(100% - 10px);
		height:calc(100% - 10px);
		top:5px;
		left:5px;
		border-radius:4px;
		overflow:hidden;
		background:#00000040;
	}
	.new-product-gallery-wrapper-thumb .main-product-img.slick-current img{
		border:2px solid #0F2D28;
	}
  .bestvaluelabel {
    display: flex;
    justify-content: space-between;
  }
  span.inrlabel, span.lpo {
    margin: 4px 0 5px 0px;
    font-size: 16px;
  }
  span.tagtop {
    display: flex;
    gap: 8px;
    height: 24px;
    justify-content: center;
    align-items: center;
    margin: 4px 0 5px 0px;
  }
  .bestvaluestag {
    background: #FBE27C;
    font-size: 12px;
    padding: 6px 4px;
    border-radius: 24px;
    letter-spacing: 0.4px;
    color: #000000 !important;
  }
  .sc-head {
    font-size: 16px;
    line-height: 160%;
    color: #11322C;
  }
  .ms-scent-block label:before {
    top: 18px;
  }
  .scent-header {
    align-items: flex-start;
  }
  @media(max-width:768px){
    .new-product-gallery-wrapper-thumb .main-product-img{
			width:42px !important;height:42px;
		}
  	.new-product-gallery-wrapper-thumb .slick-track{display:flex; justify-content:center;}
  	.scent-tag{font-size:10px;}
  	#body .multi-step-product-section .heading-2{margin-bottom:12px !important;}

    span.inrlabel {
      max-width: 220px;
      font-size: 14px;
    }
    span.lpo {
      font-size: 14px;
    }
    .bestvaluestag {
      font-size: 10px;
      width: 70px;
    }
    .sc-head {
      font-size: 14px;
      line-height: 150%;
    }
    .ms-scent-block label:before {
      top: 18px;
    }
  }

  .multi-gallery-slider:not(.slick-initialized) .main-product-img:not(:first-child) img,
  .multi-gallery-slider-thumbnail:not(.slick-initialized) .main-product-img:not(:first-child) img{display:none;}

	p.include-starterkit {
		margin: 4px 0 5px 0px;
		font-size: 16px;
	}

	.rol-price .text-decoration-line-through {
		margin-right: 4px !important;
	}
	.rol-btn {
		gap: 4px;
	}

  .ammend-weight del {
    font-weight: 400 !important;
  }
</style>

<div
  class="{{ section.settings.className }} multi-step-product-section gp--product-wrapper py-80"
  id="id_{{ section.id }}"
  style="background-color:{{section.settings.background}};"
  x-data="{qty:1}"
>
  <div class="position-relative">
    <div class=" mb-4 container  heading-2-wrapper">
      {% if section.settings.sectionheading != '' %}
        <h2 style="color:#212121" class="heading-2 font-gtsuper  fw-400 mt-0 text-center">
          {{ section.settings.sectionheading }}
        </h2>
      {% endif %}
    </div>
    <span id="{{ section.settings.scrollId }}"></span>
    <div class="d-flex product-block-4-wrapper flex-wrap justify-content-between align-items-start container">
      <div class="w-50 gp--product-gallery">
        <div class="position-relative step step-1 step-gallery">
          {% assign mediacount = 0 %}
          <div class="link-to-variant variant_1 show position-relative">
            <div class="slider__block">
              <div class="multi-gallery-slider  new-product-gallery-wrapper">
                {% for block in section.blocks %}
                  {% if block.type == 'productImage' %}
                    {% assign image = block.settings.image %}
                    {% assign mimage = block.settings.mimage %}
                    {% if block.settings.is_video %}
                      <div class="main-product-img">
                        <video
                          class=" w-100  "
                          poster="{{ block.settings.poster | img_url : '800x'}}"
                          width="520"
                          height="520"
                          controls
                        >
                          <source src="{{ block.settings.videoURL }}" type="video/mp4">
                        </video>
                      </div>
                    {% else %}
                      <div class="main-product-img ">
                        <picture>
                          <source media="(min-width:650px)" srcset="{{ image | img_url: '800x'}}">
                          <source media="(max-width:650px)" srcset="{{ mimage | img_url: '800x' }}">
                          <img
                            {% if forloop.index == 1 %}
                              skip-
                            {% else %}
                              loading=" "
                            {% endif %}
                            data-id="{{image.id}}"
                            class="img-responsive w-100 h-auto  "
                            src="{{ image | img_url: '800x'}}"
                            width="800"
                            height="700"
                            alt="{{ image.alt }}"
                          >
                        </picture>
                      </div>
                    {% endif %}
                  {% endif %}
                  {% assign mediacount = mediacount | plus: '1' %}
                {% endfor %}
              </div>
              <div class="multi-gallery-slider-thumbnail  new-product-gallery-wrapper-thumb">
