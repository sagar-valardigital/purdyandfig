<script>
    document.addEventListener('DOMContentLoaded', function () {
      // Next step button click handler
      document.querySelectorAll('.next-step-btn').forEach((btn) => {
        btn.addEventListener('click', function () {
          // Check which form/variant is currently selected before moving to step 2
          let selectedForm;
          const seasonalForm = document.querySelector('.form_s1');
          const signatureForm = document.querySelector('.form_s2');

          // Check if seasonal variant is visible and has a checked input
          const seasonalVariant = document.querySelector('.variant_1');
          if (seasonalVariant && seasonalVariant.classList.contains('show')) {
            selectedForm = seasonalForm;
          } else {
            // Otherwise use signature form
            selectedForm = signatureForm;
          }

          // Get the gallery value from the checked input in the selected form
          let galleryValue;
          if (selectedForm) {
            const checkedInput = selectedForm.querySelector('input:checked');
            if (checkedInput) {
              galleryValue = checkedInput.getAttribute('data-gallery');
            }
          }

          // Show step 2, hide step 1
          document.querySelectorAll('.step-1').forEach((el) => el.classList.add('height-0'));
          document.querySelectorAll('.step-2').forEach((el) => el.classList.remove('height-0'));

          // Update the gallery after changing steps
          if (galleryValue) {
            updateGallery(galleryValue);
          }
        });
      });

      // Back button click handler - simple version without gallery updates
      document.querySelectorAll('.back-btn').forEach((btn) => {
        btn.addEventListener('click', function () {
          document.querySelectorAll('.step-2').forEach((el) => el.classList.add('height-0'));
          document.querySelectorAll('.step-1').forEach((el) => el.classList.remove('height-0'));
        });
      });

      // Function to update gallery based on variant
      function updateGallery(galleryClass) {
        // Remove 'show' class from all variants
        document.querySelectorAll('.step-gallery .link-to-plan').forEach(function (el) {
          el.classList.remove('show');
        });

        // Add 'show' class to the matching variant
        if (galleryClass) {
          const targetElement = document.querySelector('.step-gallery .g_' + galleryClass);
          if (targetElement) {
            targetElement.classList.add('show');
          }
        }
      }

      // Input change handler for all buy plan radios
      document.querySelectorAll('.buy_plan_radio').forEach(function (input) {
        input.addEventListener('change', function () {
          updateGallery(this.getAttribute('data-gallery'));
        });
      });

      document.querySelectorAll('.ms-buy--plan input').forEach(function (input) {
        input.addEventListener('change', function () {
          const dataFormSelector = input.getAttribute('data-form');
          const itemType = input.getAttribute('data-item-type');

          if (itemType === 'PAYG') {
            const guaranteeText = document.querySelector('#' + dataFormSelector + ' ' + ' .guarantee-sub-text');
            if (guaranteeText) {
              guaranteeText.style.display = 'none';
            }
          } else {
            const guaranteeText = document.querySelector('#' + dataFormSelector + ' ' + '.guarantee-sub-text');
            if (guaranteeText) {
              guaranteeText.style.display = 'block';
            }
          }
        });
      });
    });

    {%if section.settings.tab_switch %}
  document.querySelectorAll('input.scent-selector-radio').forEach(input => {
    input.addEventListener('change', function() {
      let tabValue = this.dataset.tab;

      document.querySelectorAll('.pf-tab').forEach(tab => {
        if (tab.dataset.target === tabValue) {
          tab.click(); // Fire click event
        }
      });
    });
  });

    {%endif %}
</script>

