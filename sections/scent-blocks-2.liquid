<div class="bf-scents" style="background-color: {{ section.settings.bg_color }}">
   <div class=" mx-auto  image-with-text image-with-text-2">   
    <div class="bf-scents-inner bf-scents-heading text-center">
      <h2 class="section-heading blue-text value-bold mt-0">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
      <p class="section-subheading value-sans">{{ section.settings.subheading }}</p>
        {% endif %}
    </div>
 
      <div class="scent-accordion-blocks">
        {% for block in section.blocks %}

           <div class="container block-container">
            <h2 class="heading-2 blue-text mt-0 desktop-hide">
              {{ block.settings.scent_heading }}
            </h2>
        <div class="d-flex flex-wrap justify-content-between align-items-center">
        <div class="w-50  {% if block.settings.layout %} order-2 {%endif%}" style="align-self: flex-start;">
          <div class="two-women">
            {% if block.settings.image %}
              {% assign mImage = block.settings.image | img_url: '800x' %}
              {% assign mmImage = block.settings.mimage | img_url: '800x' %}
              <img
                loading="lazy"
                src="{{mImage}}"
                width="800px"
                height="800px"
                class="img-responsive w-100 h-auto mobile-hide"
                alt="image"
              >
              <img
                loading="lazy"
                src="{{mmImage}}"
                width="800px"
                height="800px"
                class="img-responsive w-100 h-auto desktop-hide"
                alt="image"
              >
            {% endif %}
          </div>
        </div>
        <div class="w-50 d-flex justify-content-start {% if block.settings.layout %} order-1 {%endif%} ">
          <div class="two-women-details  pb-2 {{block.settings.width}} {% if block.settings.layout == false %} text-on-right {% endif %}}">
            <h2 class="heading-2 value-bold blue-text mobile-hide">
              {{ block.settings.scent_heading }}
            </h2>
            <div class="normal-text">
              {{ block.settings.scent_details }}
            </div>
            
            {% if block.settings.infoHeading != blank %}
              <div class="scent-accordion-block value-sans">
                <details  class="scent-accordion">
                  <summary class="scent-heading value blue-text">{{ block.settings.infoHeading }}</summary>
                  <div class="scent-accordion-details">
                    {{ block.settings.infoDetails }}
                  </div>
                </details>
              </div>
            {% endif %}
          </div>
        </div>
        
      </div>
    </div>
          
        {% endfor %}
      </div>
  
     
   </div>
</div>

{% style %}


  .bf-scents  {
     padding-bottom: 80px !important;
  }

 

   .bf-scents-heading {
      padding-top: 80px !important;
      padding-bottom: 0px !important;
    }

   .bf-scents .section-heading {
    font-size: 36px;
    font-weight: 700;
    line-height: 44px;
    margin-bottom: 0px;
  }

  .bf-scents .section-subheading {
    font-size: 18px;
    line-height: 28px;
    margin-bottom: 0px;
  }

  .bf-scents .block-container {
    padding-top: 32px !important;
  }

  .bf-scents .two-women-details .heading-2 {
    font-family: 'Value-Medium';
    font-size: 24px;
}
  .bf-scents .two-women-details .normal-text {
    font-family: 'Value-Sans';
    color: #434448;
}
    .text-on-right
    {
        padding-left: 32px;
    }

  .bf-scents .scent-accordion-block {
    border-bottom: 0;
    border-top: 1px solid #EAEAEB;
    padding-top: 16px;
    margin-top: 16px;
  }

  .bf-scents .scent-accordion-block .scent-heading {
     padding-bottom: 16px;
    cursor: pointer;
  }
  
  .bf-scents .scent-accordion-details {
    background: #F4F6FC;
    padding: 16px;
    border-radius: 8px;
  }

  .bf-scents .scent-accordion-block .scent-heading:after {
    content: "";
    position: absolute;
    right: 0;
    width: 24px;
    height: 24px;
    background-image: url(https://cdn.shopify.com/s/files/1/0360/1347/3931/files/plus-circle-bule.svg?v=1699552425);
    background-repeat: no-repeat;
    background-size: cover;
}

  .bf-scents .scent-accordion-block .scent-accordion[open] .scent-heading:after {
    background-image: url(https://cdn.shopify.com/s/files/1/0360/1347/3931/files/minus-circle-bule.svg?v=1699552425);
    background-repeat: no-repeat;
  }


  @media (max-width: 768px) {
     .bf-scents .container > div {
      padding: 16px;
      background: #FCFCFD;
      box-shadow: 0px 1px 2px 0px rgba(16, 24, 40, 0.06), 0px 1px 3px 0px rgba(16, 24, 40, 0.10);
    }

    .bf-scents .container .heading-2 {
    font-family: 'Value-Medium';
    font-size: 20px !important;
    color: #3350B4;
}
    .bf-scents .scent-accordion-details {
      font-size:14px;
      background: #FCFCFD;
    }
  }



    @media (max-width: 565px) {

      .bf-scents .bf-scents-inner {
    padding: 32px 16px !important;
}
      
      .bf-scents .section-heading {
      font-size: 30px;
      margin-bottom: 16px;
      line-height: 38px;
    }

    .bf-scents .section-subheading {
      font-size: 16px;
      line-height: 24px;
      margin-bottom: 32px;
    }
      
    .bf-scents .section-heading, .bf-scents p {
      text-align: left;
    }
    }

{% endstyle %}

{% schema %}
  {
    "name": "Scent Blocks 2",
    "settings": [
      {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fff"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Sub Heading"
      }
    ],
    "blocks": [
    {
      "type": "image",
      "name": "Scent Block",
      "settings": [
        {
            "type": "select",
            "id": "width",
            "label": "Select text area width",
            "options": [
              {
                "value": "w-90",
                "label": "90%"
              },
              {
                "value": "w-80",
                "label": "80%"
              },
              {
                "value": "w-70",
                "label": "70%"
              },
              {
                "value": "w-60",
                "label": "60%"
              }
            ],
            "default": "w-80"
          },
        {
            "type": "checkbox",
            "id": "layout",
            "label": "Image on right",
           "default": false

        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Add Desktop Image"
        },
          {
          "type": "image_picker",
          "id": "mimage",
          "label": "Add Mobile Image"
        },
        {
          "type": "text",
          "id": "scent_heading",
          "label": "Heading"
        },
        {
            "type": "checkbox",
            "id": "heading-position",
            "label": "Heading After Image"

        },
        {
          "type": "html",
          "id": "scent_details",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "infoHeading",
          "label": "Info Heading"
        },
        {
          "type": "html",
          "id": "infoDetails",
          "label": "Info Detail Text"
        }
      ]
    }
  ],
    "presets": [
      {
        "name": "Scent Blocks 2"
      }
    ]
  }
{% endschema %}