                </h3>
                {% if block.settings.link %}
                  <a href="{{block.settings.link}}" class="theme-text read-more-link">{{ block.settings.btntext }}</a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
      {% if section.settings.btnLabel != '' %}
        <div class="mt-4 px-4 text-center">
          <a
            class="btn text-over-btn mt-3 checkout-au-btn"
            style="
              background:{{ section.settings.btnColor }}; border-color:{{ section.settings.btnColor }};
              color:{{ section.settings.btnTextColor }};
            "
            href="javascript:void(0);"
          >
            {{- section.settings.btnLabel -}}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}
{% schema %}
  {
    "name": "Lander Reviews",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },
       {
      "type": "checkbox",
      "id": "reviewenable",
      "label": "Enable Heading Review",
      "default": true
    },
    {
      "type": "text",
      "id": "className",
      "label": "Section Class"
    },
      {
      "type": "text",
      "id": "Review-Count",
      "label": "Review Count"
    },
      {
      "type": "color",
      "id": "bgColor",
      "label": "Background Color"
    },
{
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },{
      "type": "text",
      "id": "btnLabel",
      "label": "Button label"
    }
,
{
      "type": "text",
      "id": "btn",
      "label": "Button Link"
    },
{
      "type": "color",
      "id": "btnColor",
      "label": "Button Color"
    }
      ,
{
      "type": "color",
      "id": "btnTextColor",
      "label": "Button Text Color"
    }
	],
	"blocks": [
      {
        "type": "text",
        "name": "Review",
        "settings": [
          {
      "type": "checkbox",
      "id": "starafter",
      "label": "Stars after review",
      "default": false
    },
          {
            "type": "text",
            "id": "username",
            "label": "User Name"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
		{
            "type": "image_picker",
            "id": "image",
            "label": "User Image"
          },
{
      "type": "text",
      "id": "review",
      "label": "Review"
    },

{
      "type": "url",
      "id": "link",
      "label": "Add link"
    },
{
      "type": "text",
      "id": "btntext",
      "label": "Button Label"
    }
        ]
      }
	],
