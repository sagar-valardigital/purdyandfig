{% if section.settings.enable %}
  <div
    class="review-section py-5 {{ section.settings.className }}"
    style="background-color:{{ section.settings.bgColor }}"
  >
    <div class="container">
      {% if section.settings.heading != '' %}
        <h2 class="heading-2 text-center theme-text mt-0 mb-3 value-pro">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.reviewenable %}
        <div class="text-center">
          <div class="font-pier theme-text mt-0 mb-3 stars-img-review">
            <span class="total-reviews value-sans">{{ section.settings['Review-Count'] }}</span>
          </div>
        </div>
      {%- endif %}
    </div>
    <div class="container">
      <div class="lander-reviews-slider">
        {% for block in section.blocks %}
          <div class="review p-2 ">
            <div class="d-flex flex-wrap p-2 align-items-center height-100">
              {% if block.settings.image %}
                <div class="review-user-img">
                  {% assign userimage = block.settings.image | img_url: '400x' %}
                  <img
                    width="130px"
                    height="130px"
                    loading="lazy"
                    src="{{userimage}}"
                    width=""
                    height=""
                    class="img-responsive w-100"
                    alt=""
                  >
                </div>
              {% endif %}
              <div class="review-detail theme-text font-pier position-relative height-100">
                {% if block.settings.starafter %}
                {% else %}
                  <div class="stars mt-2">
                    <span class="star-img">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 509.9 488.54">
