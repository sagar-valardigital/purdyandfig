            {% endif %}
            <form autocomplete="off">
              <ul class="list-unstyle  gp--product-variants  var_{{ product.variants | size  }} ">
                {% assign checked = true %}
                {% for block in section.blocks %}
                  {% if block.type == 'variant' %}
                    <li
                      data-title="{{block.settings.text_heading | downcase }}"
                      class=" {% if block.settings.outofstock %}disabled var-out-of-stock{% endif %}"
                    >
                      <input
                        autocomplete="off"
                        class="gp--product-variant form_s{{ forloop.index }} {{ section.settings.className }} {{ block.settings.class }}"
                        data-planid="{{block.settings.selling_plan}}"
                        data-plantype="payg"
                        data-variantid="{{block.settings.variant_id}}"
                        data-sku="{{ block.settings.sku }}"
                        data-discount="{{ block.settings.discount }}"
                        data-name="{{block.settings.text_heading | handle}}"
                        {% if forloop.first %}
                          data-gallery="variant_1"
                        {% else %}
                          data-gallery="variant_4"
                        {% endif %}
                        data-price="{{ localization.country.currency.symbol }}{{- block.settings.sellPrice -}}"
                        data-deleted-price="{{ localization.country.currency.symbol }}{{- block.settings.delPrice -}}"
                        value="{{block.settings.variant_id }}"
                        data-productid="{{product_v.id}}"
                        data-variantclass="variant_{{ block.settings.varCount }}"
                        type="radio"
                        name="id_{{ section.id }}"
                        {% if block.settings.dataTrack %}
                          data-tracked="true"
                          data-page-url="{{ request.path }}"
                          data-target-url="{{ block.settings.targetUrl }}"
                          data-index="{{ block.settings.index }}"
                          data-funnel-stage="{{ block.settings.funnel_stage }}"
                          data-module="{{ block.settings.dataModule }}"
                          data-event-label="{{ block.settings.dataTitle }}"
                          data-event-value="{{ block.settings.eventValue }}"
                          data-item-id="{{ block.settings.sku }}"
                          data-option-index="{{ block.settings.optionIndex }}"
                          data-item-name="{{block.settings.text_heading }}"
                        {% endif %}
                        data-section="id_{{ section.id }}"
                        id="id_{{ section.id }}_{{block.settings.text_heading | escape }}"
                        {% if forloop.first %}
                          checked {% assign checked = false -%}
                        {% else %}

                        {% endif %}
                      >

                      <label
                        class="font-lausanne fw-500 var_bg_{{ block.settings.text_heading | handle }} "
                        for="id_{{ section.id }}_{{block.settings.text_heading | escape}}"
                        data-include="{{variant.metafields.metadata.includes}}"
                        data-value="{{block.settings.text_heading}}"
                      >
                        {{- block.settings.text_heading -}}
                      </label>
                    </li>
                  {% endif %}
                {% endfor %}
