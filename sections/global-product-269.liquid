<style>
    .link-to-variant {
        height: 0;
        overflow: hidden;
        position: relative;
    }

    .link-to-variant.show {
        display: block !important;
        height: auto;
        margin-top: 4px;
        margin-bottom: 4px;
        overflow: visible;
    }
  @media(max-width:768px){
  .gp-5-del-price,.gp-5-sell-price,.plan-heading-label{
    font-size:14px;
  }
    .label-bestValue{font-size:12px;}
  }

  .cart-toast{
    position: fixed;
    left: 0;
    right: 0;
    padding: 15px 10px;
    text-align: center;
    color: #fff;
    font-size: 14px;
    transition: all 0.3s ease;
    z-index: 9999;
  }
  .toast-cart {
    top: -100px;
    background-color: #11322c;
  }
  .toast-cart.show{
    top:0;
  }
  .cart-button {
    bottom: -100px;
    background-color: #0A1E1A;
  }
  .cart-button.show {
    bottom: 0px;
  }
  @media(max-width:768px){
    font-size:12px;
  }
</style>
{% if section.settings.toast %}
  <script>
    window.addEventListener('product:added', function(event) {
        const cartToast = document.getElementById('cart-toast');
        const cartData = event.detail; // Access the passed data here

        // const cartBTN = document.getElementById('cart-button');
        if (cartToast) {
            cartToast.classList.add('show');
            // cartBTN.classList.add('show');
            setTimeout(() => {
                cartToast.classList.remove('show');
                // cartBTN.classList.remove('show');
            }, 1500);
        }
    });
  </script>
  <div id="cart-toast" class="cart-toast toast-cart font-lausanne fw-400">Great choice, that's in your cart!</div>
{% endif %}
