<script>
  document.querySelectorAll('.buy--plan input[type="radio"].buy_plan_radio').forEach(function(radio) {
      radio.addEventListener('change', function() {
          setTimeout(function() {
              const itemName = radio.getAttribute('data-item-name');
              const scentType = radio.getAttribute('data-scent-type');
              console.log(itemName);

              document.querySelector('.gp--del-price').style.display = 'block';

              const scentForm = document.querySelector('.form_' + scentType);
              if (scentForm) {
                  const checkoutButton = scentForm.querySelector('.ga4-checkout-btn');
                  if (checkoutButton) {
                      checkoutButton.setAttribute('data-item-name', itemName);
                  }
              }
          }, 10);
      });
  });
</script>

