<div class="bundle-sticky-bar w-100">
  <div class="bundle-sticky-bar-header py-1">
    <div class="container bundle-count-bar">
      <div>
      <p class="mb-0" x-show="tabIndex == 0">
        <span x-text="getItemsCountByTab('tab1')"></span> of 3 Selected
    </p>

    <p class="mb-0" x-show="tabIndex == 1">
        <span x-text="getItemsCountByTab('tab2')"></span> Selected
    </p>
    <p class="mb-0" x-show="tabIndex == 2">
        <span x-text="getItemsCountByTab('tab3')"></span> Selected
    </p>
    <p class="mb-0" x-show="tabIndex == 3">
        <span x-text="getItemsCountByTab('tab4')"></span> Selected
    </p>
    <p class="mb-0" x-show="tabIndex == 4">
        <span x-text="getItemsCountByTab('tab5')"></span> Selected
    </p>
    </div>
    <span id="bundle-down-arrow" class="bundle-down-arrow {% if section.settings.show %}open{% endif %}"></span>
    </div>
    <div>
    <div class="container">
   <div class="bundle-card-body row mx-0 align-items-center justify-content-start bundle-added-products-section {% if section.settings.show %}show{% endif %}" id="bundle-added-products-section">
  <template x-for="(item, index) in getItemsByTab(activeTab)">
    <template x-for="count in item.quantity">
      <div class="col col-4 px-0">
        <div class="d-flex align-items-center justify-content-center position-relative bundle-img-wrapper">
          <span class="bundle-remove-icon" @click="removeFromBundle(index)"><img src="{{ 'remove-white.png' | asset_img_url }}" /></span>
          <img :src="item.image" class="img-responsive">
        </div>
        <span class="value-sans white-text" x-text="item.productTitle.replace(/-/g, ' ')"></span>
      </div>
    </template>
  </template>
  <template x-if="getItemsCountByTab(activeTab) < maxCounts[activeTab] && ( activeTab == 'tab1' || activeTab == 'tab2' || activeTab == 'tab4' )">
    <template x-for="index in maxCounts[activeTab] - getItemsCountByTab(activeTab)">
      <div class="col col-4 px-0 empty-bundle-count-sticky">
        <div class="d-flex align-items-center justify-content-center empty-bundle-count" x-text="getItemsCountByTab(activeTab) + index"></div>
        <span class="value-sans white-text">Scent <span x-text="getItemsCountByTab(activeTab) + index"></span></span>
      </div>
    </template>
  </template>

  <template x-if="getItemsCountByTab(activeTab) < maxCounts[activeTab] && ( activeTab == 'tab3' || activeTab == 'tab5' )">
    <template x-for="index in 1">
      <div class="col col-4 px-0 empty-bundle-count-sticky">
        <div class="d-flex align-items-center justify-content-center empty-bundle-count" x-text="getItemsCountByTab(activeTab) + index"></div>
        <span class="value-sans white-text">Scent <span x-text="getItemsCountByTab(activeTab) + index"></span></span>
      </div>
    </template>
  </template>
  
</div>
    </div>
    </div>
  </div>
  <div class="container pt-3 pb-4 d-flex align-items-center justify-content-between bundle-sticky-bar-footer">
    <div>
      <h3 class="m-0 value-sans">Total <span x-text="formatCurrency(calculateTotalPrice())"></span> <span class="text-green">(<span x-text="formatCurrency(totalSavedPrice())"></span> Saved)</span></span></h3>
    </div>
    <div class="sticky-bundle-btn">
    <template x-if="tabIndex > 0">
    <span class="prev-wizar" @click="tabIndex = (tabIndex - 1) % tabs.length; activeTab = tabs[tabIndex];">&#10142;</span>
    </template>
    <template x-if="tabIndex < 4">
    <button id="next_btn" :class="{'first_btn':tabIndex == 0, 'light-blue': getItemsCountByTab(activeTab) < 1}" class="col-6 col-md-4 next-without" type="button" @click="tabIndex = (tabIndex + 1) % tabs.length; activeTab = tabs[tabIndex];"><span x-show="tabIndex == 0 || getItemsCountByTab(activeTab) > 0">NEXT</span><span x-show="tabIndex > 0 && tabIndex < 4 && getItemsCountByTab(activeTab) == 0">SKIP</span></button>
    </template>
    <template x-if="activeTab == 'tab5'">
    <button :class="{'light-blue': getItemsCountByTab(activeTab) < 1 && tabIndex != 4 }" id="next_btn" class="col-6 col-md-4 " type="button" @click="addBundleToCart();">FINISH</button>
    </template>
    </div>
    </div>
</div>
</div>

