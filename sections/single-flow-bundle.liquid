<div class="single-flow-bundle-section"  x-init="{bundleItems:JSON.parse(localStorage.getItem('sbundleItems')) || []},updateBundleItems();"
 x-data="{
  activeTab:'tab1',
  tabs: ['tab1', 'tab2', 'tab3', 'tab4', 'tab5'],
  tabIndex:0,
  minCounts: {
    tab1: 0, // Update with the minimum count for tab1
    tab2: 0, // Update with the minimum count for tab2
    tab3: 0, // Update with the minimum count for tab3
    tab4: 0,
    tab5: 0,
  },
  autonext: {
    tab1: false,
    tab2: true,
    tab3: false, 
    tab4: true,
    tab5: false,
  },
  maxCounts: {
    tab1: 3,
    tab2: 1,
    tab3: 3,
    tab4: 1,
    tab5: 3,
  },
  bundleItems: JSON.parse(localStorage.getItem('sbundleItems')) || [],
  totalCount:6,
  isAddingToCart: false,
  updateBundleItems() {
    const currentTime = new Date().getTime();
    const updatedItems = this.bundleItems.filter(item => (currentTime - item.timestamp) < (60 * 60 * 1000));
    this.bundleItems = updatedItems;
    this.saveToLocalStorage();
  },
  addToBundle(productId, productTitle, quantity, price, image, compareprice, sku, pid, sid, tab) {
        const newItem = {'id': productId, 'productTitle': productTitle, 'quantity': quantity, 'price':price, 'image':image, 'compareprice':compareprice, 'sku':sku, 'pid':pid, 'sid':sid, 'tab':tab, 'timestamp':new Date().getTime()};
       // const existingItem = this.bundleItems.find(item => item.id === productId);
       // const totalQuantity = this.calculateTotalQuantity();
       /* if (existingItem) {
            if (totalQuantity+1 <= this.totalCount) {
                existingItem.quantity += quantity;
                this.saveToLocalStorage();
            } else {
            }
        } else {
            if (totalQuantity+1 <= this.totalCount) {
                this.bundleItems.unshift(newItem);
                this.saveToLocalStorage();
            } else {
            }
        } */
        this.bundleItems.unshift(newItem);
         this.saveToLocalStorage();
        if(this.autonext[this.activeTab]){
              this.switchToNextTabWithDelay();
        }
    },
    getScentsBreakdown() {
  let breakdown = [];
  const tab1Items = this.getItemsByTab('tab1');
  tab1Items.forEach(item => {
    breakdown.unshift(item.quantity + 'x ' + this.formatString(item.productTitle));
  });
  return breakdown.join(' + ');
},
  switchToNextTabWithDelay() {
    setTimeout(() => {
      const currentIndex = this.tabs.indexOf(this.activeTab);
      const nextIndex = currentIndex + 1;
      
      if (nextIndex < this.tabs.length) {
        this.activeTab = this.tabs[nextIndex];
        this.tabIndex = nextIndex;
        console.log(this.activeTab);
        console.log(this.tabIndex);
      }
    }, 500);
  },
getBundleBreakdown() {
  let breakdown = [];
  const tab1Items = this.getItemsByTab('tab1');
  tab1Items.forEach(item => {
    breakdown.unshift(item.quantity + 'x' + item.sku);
  });
  return breakdown.join('+');
},
  formatCurrency(amountPence) {
        const amountInCurrency = (amountPence / 100).toFixed(2); // Convert pence to currency
        return '£'+amountInCurrency;
    },
 calculateTotalPrice() {
  let totalPrice = 0;
  let tab1Price = 0;
  let tab1ProductCount = 0;

  this.bundleItems.forEach(item => {
    totalPrice += item.price * item.quantity;

    if (item.tab === 'tab1') {
      tab1Price = item.price;
      tab1ProductCount += item.quantity;
    }
  });

  if (tab1ProductCount > 0) {
    totalPrice -= (tab1Price * (tab1ProductCount - 1));
  }
  if(totalPrice == 0) {
    return 1500
  }
  return totalPrice;
},

totalSavedPrice() {
  let totalSaved = 0;
  let tab1Price = 0;
  let tab1ComparePrice = 0;
  let tab1ProductCount = 0;

  this.bundleItems.forEach(item => {
    const savedPerItem = (item.compareprice - item.price) * item.quantity;
    totalSaved += savedPerItem;

    if (item.tab === 'tab1') {
      tab1Price = item.price;
      tab1ComparePrice = item.compareprice;
      tab1ProductCount += item.quantity;
    }
  });

  if (tab1ProductCount > 0) {
    totalSaved -= ((tab1ComparePrice - tab1Price) * (tab1ProductCount - 1));
  }

  if(totalSaved == 0) {
    return 1500
  }

  return totalSaved;
},

 removeFromBundle(index) {
            if (index >= 0 && index < this.bundleItems.length) {
                const item = this.bundleItems[index];
                if (item.quantity > 1) {
                    item.quantity -= 1;
                } else {
                    this.bundleItems.splice(index, 1);
                }
                this.saveToLocalStorage();
            }
        },
  getItemQuantity(productId) {
  const items = this.bundleItems.filter(item => item.id === productId);
  let totalQuantity = 0;
  items.forEach(item => {
    totalQuantity += item.quantity;
  });
  return totalQuantity;
},
  getItemsByTab(tab) {
  return this.bundleItems.filter(item => item.tab === tab);
},
  getItemsCountByTab(tab) {
    const items = this.bundleItems.filter(item => item.tab === tab);
    return items.reduce((total, item) => total + item.quantity, 0);
},
  calculateTotalQuantity() {
            let totalQuantity = 0;
            this.bundleItems.forEach(item => {
                totalQuantity += item.quantity;
            });
            return totalQuantity;
  },
increaseQuantity(productId) {
/*             const index = this.bundleItems.findIndex(item => item.id === productId);
            if (index >= 0) {
                const item = this.bundleItems[index];
                const totalQuantity = this.calculateTotalQuantity();
                if (totalQuantity + 1 <= this.totalCount) {
                    item.quantity += 1;
                } else {
                    alert('The maximum total quantity for all items in the bundle is '+this.totalCount);
                }
                this.saveToLocalStorage();
            } */
            const index = this.bundleItems.findIndex(item => item.id === productId);
            if (index >= 0) {
              const item = this.bundleItems[index];
              item.quantity += 1;
              this.saveToLocalStorage();
            }
            
        },
decreaseQuantity(productId) {
            const index = this.bundleItems.findIndex(item => item.id === productId);
            if (index >= 0) {
                const item = this.bundleItems[index];
                if (item.quantity > 1) {
                    item.quantity -= 1;
                } else {
                    this.bundleItems.splice(index, 1);
                }
                this.saveToLocalStorage();
            }
 },
  saveToLocalStorage() {
        localStorage.setItem('sbundleItems', JSON.stringify(this.bundleItems));
  },
  bundleToAddCount() {
    return this.totalCount - this.calculateTotalQuantity();
  },
  isItemAdded(productId) {
            return this.bundleItems.some(item => item.id === productId);
    },
  isbundleCompleted() {
    return this.calculateTotalQuantity() >= this.totalCount;
  },
 formatString(str) {
  // Replace hyphens with spaces
  var formattedStr = str.replace(/-/g, ' ');

 // Capitalize the first letter of each word
  formattedStr = formattedStr.replace(/\b\w/g, function(match) {
    return match.toUpperCase();
  });

  return formattedStr;
  },
  openTab(target) {
      $('.tab-button').removeClass('active');
      $(this).addClass('active');
      $('.tab-pane').removeClass('active');
      $('#'+target).addClass('active');
  },
 addBundleToCart() {
  this.isAddingToCart = true;
  var bundleItems = this.bundleItems;
  var lineItems = [];
  
  const tab1Items = this.getItemsByTab('tab1');
  if (tab1Items.length === 0) {
    lineItems.push({
      quantity: 1,
      id: 43836262056163,
      properties: {
        '_is_bundle': 'Yes',
        '_breakdown': '1xFG1030+1xFG1029+1xFG1031',
        '_single_flow':'Yes',
        'scents': '1x Balancing Floral + 1x Original Citrus + 1x Grounding Vetiver'
      },
      selling_plan: 3313041635
    });
  }

  this.bundleItems.forEach(item => {
    var lineItem = {
      quantity: item.quantity,
      id: item.pid,
      properties: {}
    };

    if (item.tab === 'tab1') {
      lineItem.selling_plan = item.sid;
      lineItem.properties = {
        '_is_bundle': 'Yes',
        '_single_flow':'Yes',
        '_breakdown': this.getBundleBreakdown(item),
        'scents': this.getScentsBreakdown(item),
      };
    } else if (item.tab === 'tab5') {
      lineItem.properties = {
      };
    } else {
      lineItem.selling_plan = item.sid;
      lineItem.properties = {
      };
    }

    // Check if a line item with the same product ID (pid) is already added
    const existingLineItemIndex = lineItems.findIndex(lineItem => lineItem.id === item.pid);
    if (existingLineItemIndex === -1) {
      lineItems.push(lineItem);
    }
  });

  fetch('/cart/add.js', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ items: lineItems })
  })
    .then(response => {
      if (response.ok) {
        console.log('Bundle added to cart');
        this.isAddingToCart = false;
        window.location.href = '/checkout/';
      } else {
        console.error('Failed to add bundle to cart:', response);
      }
    })
    .catch(error => {
      console.error('Error adding bundle to cart:', error);
    });
}

}" >
