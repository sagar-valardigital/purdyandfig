{% if section.settings.show_hide_block %}
  <div
    class="block-section py-80 icon-blocks-2 icon-blocks-reskin  {{ section.settings.class }}"
    style="background-color:{{ section.settings.bg }}"
  >
    <div class="container">
      <h2 class="heading-2 text-center m-text-left blue-text font-gtsuper fw-400 mt-0" style="color:{{ section.settings.textcolor }} !important">
        {{ section.settings.heading }}
      </h2>
      <div class="d-flex flex-wrap justify-content-between  theme-text my-1 icon-blocks-2-wrapper">
        {% for block in section.blocks %}
          <div class="w-33 p-3 icon-block-2">
            <div class="text-center ">
              {% if block.settings.icon_block_image %}
                <div class="block-img-wrappers mb-1">
                  <img
                    src="{{ block.settings.icon_block_image | image_url }}"
                    width="57"
                    height="56"
                    alt="{{ block.settings.icon_block_image.alt }}"
                  >
                </div>
              {% endif %}
              <div>
                {% if block.settings.icon_block_title != blank %}
                  <h3 class="heading-4 font-lausanne fw-400 mb-2" style="color:{{ section.settings.textcolor }}">
                    {{ block.settings.icon_block_title }}
                  </h3>
                {% endif %}

                {% if block.settings.icon_block_description != blank %}
                  <p class="font-lausanne fw-200 normal-text m-0" style="color:{{ section.settings.textcolor }}">
                    {{ block.settings.icon_block_description }}
                  </p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
      {% if section.settings.showbtn %}
        <div class="text-center mt-3">
          <span
            {% if section.settings.dataTrack %}
              {% render 'ga4-events' %}
            {% endif %}
            data-target="{{ section.settings.scrollto }}"
            data-top="{{ section.settings.top }}"
            class="btn click-scroll"
            style="background: {{ section.settings.btnbgcolor }}; color: {{ section.settings.btntxtcolor }};"
          >
            {{- section.settings.btntext -}}
          </span>
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Icon blocks Reskin 290",
  "settings": [
    {
         "type": "text",
         "id" : "class",
         "label": "Section Class"
     },
    {
         "type": "color",
         "id" : "bg",
         "label": "Background Colour",
         "default": "#ffffff"
     },
    {
         "type": "color",
         "id" : "textcolor",
         "label": "TextColour",
         "default": "#212121"
     },
     {
         "type": "text",
         "id" : "heading",
         "label": "Heading",
         "default": "You've never enjoyed cleaning this much"
     },
     {
         "type": "checkbox",
         "id": "show_hide_block",
         "label": "Show Icon Block",
         "default": true
     },
     {
         "type": "checkbox",
         "id": "showbtn",
         "label": "Show button",
         "default": false
     },
     {
         "type": "color",
         "id": "btnbgcolor",
         "label": "Button background"
     },
     {
         "type": "color",
         "id": "btntxtcolor",
         "label": "Button text color"
     },
     {
         "type": "text",
         "id": "btntext",
         "label": "Button label"
     },
     {
         "type": "text",
         "id": "scrollto",
         "label": "Scroll to"
     },
    {
         "type": "text",
         "id": "top",
         "label": "Scroll position"
     },
     {
      "id": "dataTrack",
      "label":"Data Track",
      "type": "checkbox"
      },
      {
      "id": "targetUrl",
      "label":"Target Url",
      "type": "url"
      },
      {
      "id": "index",
      "label":"Index",
      "type": "number",
      "default" : 0
          },
          {
      "id": "funnel_stage",
      "label":"Funnel Stage",
      "type": "text",
       "default" : "landing_page"
          },
          {
      "id": "dataModule",
      "label":"Module",
      "type": "text",
       "default" : "announcement_bar"
          },
            {
      "id": "dataTitle",
      "label":"Event Label",
      "type": "text",
      "default": "get_your_offer"
          }
          ,
            {
      "id": "eventValue",
      "label":"Event Value",
      "type": "text",
      "default" : "shop_anchor"
          },
            {
      "id": "itemId",
      "label":"Item Id",
      "type": "text"
          }
          ,
            {
      "id": "optionIndex",
      "label":"Option Index",
      "type": "text"
          }
          ,
            {
      "id": "ItemName",
      "label":"Item Name",
      "type": "text"
          }
   ],
   "blocks": [
     {
         "type": "iconblocks",
         "name": "Icon Block",
         "limit": 3,
         "settings": [
             {
               "type": "text",
               "id": "icon_block_title",
               "label": "Title"
             },
             {
               "type": "textarea",
               "id": "icon_block_description",
               "label": "Description"
             },
             {
               "type": "image_picker",
               "id": "icon_block_image",
               "label": "Icon Image"
             }
         ]
     }
   ],
   "presets": [
     {
         "name": "Icon blocks Reskin 290"
     }
   ]
}
{% endschema %}
