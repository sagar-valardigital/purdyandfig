{% assign image = section.settings.bannerimage | img_url : '1900x400'%}
<div class="banner-setion " style="background-image:url({{image}})">
     <div class="container position-relative">
            <div class="faq-banner-text position-absolute">
                 <h3 class="heading-3 theme-text">{{ page_title}}</h3>
              <div class="faq-filters d-flex flex-wrap">
                {% for block in section.blocks %}
                {% if block.type == 'filter'%}
                <a class="faq-filter theme-text" href="#{{block.settings.id}}">{{block.settings.title}}</a>
                {%endif%}
                {%endfor%}
              </div>
            </div>
        </div>   
</div>
<div class="my-5 theme-text">
        <div class="container">
          <div class="inner-container">
          	{% for block in section.blocks %}
          {% if block.type == 'text'%}
          	{% if block.settings.heading-section %}
            <div class="faq-section-heading" id="{{block.settings.sectionid}}">
                <h3 class="heading-2">{{block.settings.heading}}</h3>
            </div>
          {%else%}
          
          <div class="faq">
          <details class="faq-acc">
  <summary class="faq-que font-value">{{block.settings.faq-question}}</summary>
  <p>{{block.settings.faq-ans}}</p>
</details>
          </div>
          {%endif%}{%endif%}
          {%endfor%}
        </div></div>
    </div>
{% schema %}
  {
    "name": "FAQ",
    "settings": [
	{
      "type": "image_picker",
      "id": "bannerimage",
      "label": "Page Bannner"
    }
	],
	"blocks": [
      {
        "type": "text",
        "name": "faq",
        "settings": [ 
          {
            "type": "checkbox",
            "id": "heading-section",
            "label": "Heading"
          },
{
            "type": "text",
            "id": "heading",
            "label": "FAQ Heading"
          },
		{
            "type": "text",
            "id": "sectionid",
            "label": "Section ID"
          },
{
            "type": "text",
            "id": "faq-question",
            "label": "FAQ QUE"
          },
{
            "type": "richtext",
            "id": "faq-ans",
            "label": "FAQ ANS"
          }
        ]
      },
{
        "type": "filter",
        "name": "Filters",
		"settings" : [
		{
            "type": "text",
            "id": "title",
            "label": "Filter title"
          },
{
            "type": "text",
            "id": "id",
            "label": "Id"
          }
]
}
	]
  }
{% endschema %}

