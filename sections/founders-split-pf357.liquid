{% comment %} Use modern image_url filter instead of deprecated img_url {% endcomment %}
{% assign mimage = section.settings.image | image_url: width: 800 %}

<style>
.{{ section.settings.className }}{
  {% if section.settings.backgroundImage %}
    background-image: url("{{ section.settings.backgroundImage | image_url }}");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  {% else %}
    background-color: {{ section.settings.background }};
  {% endif %}
}

.{{ section.settings.className }}:after{
  content: '';
  width: 45%;
  height: 100%;
  {% if section.settings.image %}
    background-image: url("{{ mimage }}");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  {% endif %}
  position: absolute;
  top: 0;
  {% if section.settings.layout %}
    right: 0;
  {% else %}
    left: 0;
  {% endif %}
}

.fi-image { opacity: 0; }

.heading-2 {
  margin-bottom: 12px !important;
}

.normal-text {
  line-height: 1.5 !important;
  color: #424242 !important;
}

@media(max-width: 768px){
  .fi-image { opacity: 1; }
  .{{ section.settings.className }}:after { display: none; }
  .{{ section.settings.className }} .image-with-text-2 {
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }
  .{{ section.settings.className }} .image-with-text-2 .fi-image {
    margin-left: -15px;
    margin-right: -15px;
    width: calc(100% + 30px);
    margin-bottom: 0;
  }

.pf357-meet-text .heading-2 {
        font-size: 32px !important;
}

  .pf357-meet-text {
    margin: 22px 0 32px;
  }
}
</style>

<div class="{{ section.settings.className }} position-relative">
  <div class="py-80 image-with-text image-with-text-2">
    <div class="container">
      <div class="d-flex flex-wrap justify-content-between align-items-center">
        <div class="w-40 {% if section.settings.layout %} order-2 {% endif %}">
          <div class="position-relative">
            {% if section.settings.image %}
              <img 
                src="{{ mimage }}" 
                class="w-100 h-auto fi-image" 
                width="700" 
                height="500" 
                alt="{{ section.settings.heading | escape }}"
                loading="lazy"
              >
            {% endif %}
          </div>
        </div>
        <div class="w-50 pf357-meet-text d-flex justify-content-start {% if section.settings.layout %} order-1 {% endif %} image-txt">
          <div>
            <h2 class="heading-2 font-gtsuper" style="color: #0A1E1A !important;">
              {{ section.settings.heading }}
            </h2>
            <div class="normal-text font-lausanne fw-200" style="color: {{ section.settings.textcolor }};">
              {{ section.settings.details }}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Founders Split PF357",
  "settings": [
    {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name",
      "default": "full-width-image-text"
    },
    {
      "type": "color",
      "id": "textcolor",
      "label": "Select text color",
      "default": "#212121"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Select background color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "backgroundImage",
      "label": "Select background Image"
    },
    {
      "type": "checkbox",
      "id": "layout",
      "label": "Image on right"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Poster"
    },
    {
      "type": "html",
      "id": "details",
      "label": "Detail Text"
    }
  ],
  "presets": [
    {
      "name": "Founders Split PF357"
    }
  ]
}
{% endschema %}