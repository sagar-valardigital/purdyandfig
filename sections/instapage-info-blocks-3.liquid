<section class="section section-relative " id="page-block-g0oz7m6y6y" data-at="section">
  <div class="section-holder-border item-block item-absolute" data-at="section-border"></div>
  <div class="section-holder-overlay item-block item-absolute" data-at="section-overlay"></div>
  <div class="section-block">
    <div class="section-inner section-fit section-relative">
      <div class="widget item-absolute headline  " id="element-1408" data-at="headline">
        <div class="contents">
          <h1>
            <span class="x_f0b77de1 x_d47fa885">{{ section.settings.title }}</span>
          </h1>
        </div>
      </div>
      <div class="widget item-absolute headline  " id="element-1402" data-at="headline">
        <div class="contents">
          <h3>
            <span class="x_35a38d41 x_446dab97">{{ section.blocks[0].settings.heading }}</span>
          </h3>
        </div>
      </div>
      <div class="widget item-absolute " id="element-1405">
        <div
          class="contents shape box figure"
          data-at="shape"
          data-src="{{ section.blocks[0].settings.image | img_url: '800x' }}"
          style="background-image: url({{ section.blocks[0].settings.image | img_url: '800x' }});"
        ></div>
      </div>
      <div class="widget item-absolute paragraph  " id="element-1401" data-at="paragraph">
        <div class="contents">
          <p class="x_8c071feb x_e6507cf2">{{ section.blocks[0].settings.info }}</p>
          <p class="x_8c071feb x_e6507cf2">&nbsp;</p>
        </div>
      </div>
      <div class="widget item-absolute headline  " id="element-1409" data-at="headline">
        <div class="contents">
          <h3>
            <span class="x_35a38d41 x_26296864">{{ section.blocks[1].settings.heading }}</span>
          </h3>
        </div>
      </div>
      <div class="widget item-absolute " id="element-1406">
        <div
          class="contents shape box figure"
          data-at="shape"
          data-src="{{ section.blocks[1].settings.image | img_url: '800x' }}"
          style="background-image: url({{ section.blocks[1].settings.image | img_url: '800x' }});"
        ></div>
      </div>
      <div class="widget item-absolute paragraph  " id="element-1403" data-at="paragraph">
        <div class="contents">
          <p class="x_695a2def x_e6507cf2">{{ section.blocks[1].settings.info }}</p>
          <br>
          <br>
          <br>
        </div>
      </div>
      <div class="widget item-absolute " id="element-1407">
        <div
          class="contents shape box figure"
          data-at="shape"
          data-src="{{ section.blocks[2].settings.image | img_url: '800x' }}"
          style="background-image: url({{ section.blocks[2].settings.image | img_url: '800x' }});"
        ></div>
      </div>
      <div class="widget item-absolute headline  " id="element-1410" data-at="headline">
        <div class="contents">
          <h3>
            <span class="x_35a38d41 x_26296864">{{ section.blocks[2].settings.heading }}</span>
          </h3>
        </div>
      </div>
      <div class="widget item-absolute paragraph  " id="element-1404" data-at="paragraph">
        <div class="contents">
          <p class="x_8c071feb x_e6507cf2">{{ section.blocks[2].settings.info }}</p>
          <br>
          <br>
        </div>
      </div>
      {% if section.settings['show-offer-btn'] %}
        <div class="widget item-absolute  " id="element-1411">
          <a
            href="javascript:void(0)"
            data-target="scroll-here-link-1"
            id="link-jadetka08um"
            class="onpage-link btn  click-scroll  item-block"
            data-at="button"
            data-link-jadetka08um=""
            {% if section.settings.dataTrack %}
              {% render 'ga4-events' %}
            {% endif %}
          >
            GET OFFER
          </a>
        </div>
      {% endif %}
      {% if section.settings.discount != '' %}
        <div class="widget item-absolute headline  " id="element-1412" data-at="headline">
          <div class="contents">
            <h1>
              <span class="x_c610ae00 x_52f6981f"
                ><span class="x_7b2817bf">*USE CODE {{ section.settings.discount }}</span></span
              >
            </h1>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  {% if section.settings.discount == '' %}
    @media screen and (min-width: 768px) {
      #page-block-g0oz7m6y6y {
        height: 83.5rem;
      }
    }
  {% endif %}
</style>

{% schema %}
  {
    "name": "Instapage Info Blocks 3",
    "settings": [
      {
        "id": "title",
        "label": "Title",
        "type": "text"
      },
      {
        "id": "subtitle",
        "label": "Subtitle",
        "type": "text"
      },
      {
        "id": "show-offer-btn",
        "label": "Show Offer Button",
        "type": "checkbox"
      },
      {
        "id": "discount",
        "label": "Discount Code",
        "type": "text"
      },
      {
        "type": "header",
        "content": "GA4"
      },
      {
        "id": "dataTrack",
        "label": "Data Track",
        "type": "checkbox"
      },
      {
        "id": "targetUrl",
        "label": "Target Url",
        "type": "url"
      },
      {
        "id": "index",
        "label": "Index",
        "type": "number",
        "default": 1
      },
      {
        "id": "funnel_stage",
        "label": "Funnel Stage",
        "type": "text",
        "default": "landing_page"
      },
      {
        "id": "dataModule",
        "label": "Module",
        "type": "text",
        "default": "announcement_bar"
      },
      {
        "id": "dataTitle",
        "label": "Event Label",
        "type": "text",
        "default": "get_your_offer"
      },
      {
        "id": "eventValue",
        "label": "Event Value",
        "type": "text",
        "default": "shop_anchor"
      },
      {
        "id": "itemId",
        "label": "Item Id",
        "type": "text"
      },
      {
        "id": "optionIndex",
        "label": "Option Index",
        "type": "text"
      },
      {
        "id": "ItemName",
        "label": "Item Name",
        "type": "text"
      }
    ],
    "max_blocks": 3,
    "blocks": [
      {
        "type": "text",
        "name": "block",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "text",
            "id": "info",
            "label": "Information"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Instapage Info Blocks 3"
      }
	]
  }
{% endschema %}
