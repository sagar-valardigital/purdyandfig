                  </svg>
                </span>
                <span class="star-img">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 509.9 488.54">
                    <defs><style>.cls-1{fill:#3D5065;}</style></defs><g id="Layer_2" data-name="Layer 2"><g id="Layer_1-2" data-name="Layer 1"><path class="cls-1" d="M509.9,199c-6.46,16.14-21.36,24.42-33.37,35.23-27.73,25-56,49.36-84.17,73.87-2.35,2-2.78,3.81-2.1,6.79q15.89,69.25,31.52,138.58c2.72,12-.07,22.26-10.1,29.59s-20.66,7-31.22.67q-60.6-36.27-121.16-72.59c-3.1-1.86-5.3-2-8.46-.07-40.2,24.19-80.62,48-120.7,72.38C111.86,494.6,92.75,484.81,88.22,469a30,30,0,0,1-.17-15.23q15.61-68.55,31.32-137.09c1-4.18.37-6.76-3-9.72C81,276.22,45.92,245.29,10.7,214.48c-9.28-8.11-13-18-9.23-29.85,3.64-11.34,12-17.61,23.9-18.72q36.64-3.42,73.3-6.73c23.12-2.1,46.24-4.23,69.37-6.18,3.5-.29,4.63-2.29,5.8-5Q201.4,83.29,229,18.63C234,6.94,242.31-.07,255.18,0,267.83.07,276,7.06,280.89,18.54c18.16,42.68,36.54,85.27,54.51,128,2.11,5,5,6.28,9.9,6.71Q415.17,159.42,485,166c12.87,1.22,20.67,8.4,24.11,20.92.11.43.53.77.8,1.15Z"/></g></g>
                  </svg>
                </span>
                <span class="total-reviews value-sans">{{- settings.gloabalreviews }} Reviews</span>
              </div>
            </div>

            <div class="theme-text">
              {% if section.settings.subtext != '' -%}
                <h3 class="font-value mt-4 bb-points">{{ section.settings.subtext }}</h3>
              {%- endif %}
              <ul class="lander-points text-center">
                {% for block in section.blocks %}
                  {% if block.type == 'text' %}
                    <li style="padding-left:0;" class="value-sans">
                      {{ block.settings.listItem }}
                    </li>
                    <br>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>

            <form
              @submit.prevent="console.log('submitted')"
              x-ref="product_form"
              enctype="multipart/form-data"
              accept-charset="UTF-8"
              id="product_form_{{ section.id }}"
              class="shopify-product-form"
              data-product-id="{{product.id}}"
              action="/cart/add"
            >
              <input type="hidden" name="id" value="{{ s_variant.id }}">
              <input type="hidden" name="quantity" value="1">
              {% if section.settings.isSub %}
                <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
                <input
                  type="hidden"
                  name="selling_plan"
                  value="{{s_variant.selling_plan_allocations.first.selling_plan.id}}"
                >
              {% endif %}
            </form>
            <div class="text-left mt-3 m-auto" style="max-width:400px">
              {% if section.settings.ctaDetails != '' %}
                <div class="text-center value-sans theme-text">{{ section.settings.ctaDetails }}</div>
              {% endif %}
              {% if section.settings.redirectLink %}
                <a
                  class="btn w-100 theme-btn value-sans btn-loader checkout-lander-btn checkout-lander-product-btn{% if section.settings.outOfStock %} bb-disable {% endif %}"
                  href="{{ section.settings.redirectLink }}"
                >
                  {% if section.settings.outOfStock %}
                    Out of Stock
                  {% else %}
                    {{ section.settings.btnText }} | £{{ section.settings.price }}
                    {% if section.settings.delPrice != '' -%}
                      <small class="text-white"
                        ><del>£{{ section.settings.delPrice }}</del></small
                      >
                    {% endif %}
                  {% endif -%}
                </a>
              {% else %}
                {% if section.settings.isCheckout %}
                  <span
                    class="btn w-100 theme-btn value-sans btn-loader checkout-lander-btn checkout-lander-product-btn{% if section.settings.outOfStock %} bb-disable {% endif %}"
                    x-on:click="Purdy.PurdyCheckout($refs.product_form, '{{ section.settings.discount }}', $event)"
                  >
                    {% if section.settings.outOfStock %}
                      Out of Stock
                    {% else %}
                      {{ section.settings.btnText }} |
                      {% if section.settings.delPrice != '' -%}
                        <del class="text-white">£{{ section.settings.delPrice }}</del>
                      {% endif %}
                      £{{ section.settings.price }}
                    {% endif -%}
                  </span>
                {% else %}
                  <span
                    class="btn w-100 theme-btn value-sans btn-loader checkout-lander-btn checkout-lander-product-btn{% if section.settings.outOfStock %} bb-disable {% endif %}"
                    x-on:click="Purdy.AddToCart($refs.product_form, true, false, $event)"
                  >
                    {% if section.settings.outOfStock %}
                      Out of Stock
                    {% else %}
                      {{ section.settings.btnText }} |
                      {% if section.settings.delPrice != '' -%}
                        <del class="text-white">£{{ section.settings.delPrice }}</del>
                      {% endif %}
                      £{{ section.settings.price }}
                    {% endif -%}
                  </span>
                {% endif %}
              {% endif -%}
              <br>
              {% if section.settings.shopbtnLink %}
                <a
                  class="btn w-100 mt-3 blue-border-btn value-sans btn-loader"
                  href="{{ section.settings.shopbtnLink }}"
                >
                  {{ section.settings.shopbtnLabel }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Global Product 3",
  "settings": [
  {
    "type": "checkbox",
    "id": "enable",
    "label": "Uncheck to hide the section",
    "default": true
  },
    {
    "type": "checkbox",
    "id": "verticalThumbnails",
    "label": "Thumbnail vertical slider",
    "default": false
  },
    {
    "type": "checkbox",
    "id": "outOfStock",
    "label": "Enable If product out Of Stock",
    "default": true
  },
    {
    "id": "isSub",
    "label": "Product subscription",
    "type": "checkbox",
    "default": false
  },
      {
    "id": "isCheckout",
    "label": "Go to Checkout",
    "type": "checkbox",
    "default": false
  },
    {
    "id": "p_id",
    "label": "Product Section Scroll ID",
    "type": "text"
  },
    {
    "id": "tag",
    "label": "Product Tag",
    "type": "text"
  }, {
      "id": "landingproduct",
      "label": "Choose the landing product",
      "type": "product"
    },
    {
    "type": "text",
    "id": "discount",
    "label": "Discount Code"
  },
  {
      "type": "select",
      "id": "textcolor",
      "label": "Select text color",
      "options": [
        {
          "value": "white-text",
          "label": "White color"
        },
        {
          "value": "theme-text",
          "label": "Theme color"
        }
      ],
      "default": "white-text"
        },

        {
          "type": "select",
          "id": "width",
          "label": "Select text area width",
          "options": [
            {
              "value": "w-90",
              "label": "90%"
            },
            {
              "value": "w-80",
              "label": "80%"
            },
{
              "value": "w-70",
              "label": "70%"
            },
            {
              "value": "w-60",
              "label": "60%"
            }
          ],
          "default": "w-80"
        },
{
          "type": "checkbox",
          "id": "layout",
          "label": "Image on right"

        },
{
    "type": "text",
    "id": "className",
    "label": "Section Class"
  },
    {
    "type": "html",
    "id": "mainheading",
    "label": "Main Heading"
  },
    {
    "type": "html",
    "id": "mainsubheading",
    "label": "Sub Heading"
  },
   {
    "type": "html",
    "id": "heading",
    "label": "Product Title"
  },
    {
    "id": "subtext",
    "label": "Banner Sub Text",
    "type": "html"
  },
    {
    "id": "price",
    "label": "Price",
    "type": "text"
  },
  {
    "id": "delPrice",
    "label": "Compare Price",
    "type": "text"
  },
    {
"id": "btnText",
"label":"Button label",
"type": "text",
      "default" : "BUY NOW"
    },
    {
"id": "redirectLink",
"label":"Button Link",
"type": "url"
    },
    {
"id": "ctaDetails",
"label":"Button Details Text",
"type": "html"
    },
    {
"id": "shopbtnLabel",
"label":"Shop Button label",
"type": "text"
    },
    {
"id": "shopbtnLink",
"label":"Shop Button link",
"type": "url"
    },
{
    "type": "header",
    "content": "Mobile"
  },

{
          "type": "checkbox",
          "id": "heading-position",
          "label": "Heading After Image"

        }
  ],
      "blocks": [
    {
      "type": "text",
      "name": "block",
      "settings": [

            {
    "type": "text",
    "id": "listItem",
    "label": "Add Item"
  }

      ]
    },

        {
      "type": "productImage",
      "name": "Product Image",
      "settings": [
            {
    "type": "image_picker",
    "id": "image",
    "label": "Add Product Image"
  }

      ]
    },{
      "type": "aboutproduct",
      "name": "About Product",
      "settings": [
            {
              "type": "text",
              "id": "text-heading",
              "label": "Heading"
            },
            {
              "type": "color",
              "id": "heading-color",
              "label": "Heading Color"
            },
            {
              "type": "text",
              "id": "text-detail",
              "label": "About Text"
            }

      ]
    }
  ],
  "presets": [
      {
          "name": "Global Product 3"
      }
  ]
}
{% endschema %}
