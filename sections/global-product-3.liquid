{% if section.settings.enable %}
  {% assign product = section.settings.landingproduct %}
  {% assign s_variant = product.selected_or_first_available_variant %}
  <div
    class="{{ section.settings.className }} lander-product-section"
    id="{{ section.settings.p_id }}"
    style="background-color:{{section.settings.background}};"
    x-data="{qty:1}"
  >
    <div class="mobile-padding-y image-with-text">
      <div class=" mb-4">
        {% if section.settings.mainheading != '' %}
          <h2 class="heading-2 theme-text mt-0 text-center value-pro">
            {{ section.settings.mainheading }}
          </h2>
        {% endif %}
        {% if section.settings.mainsubheading != '' %}
          <p class="normal-text theme-text mt-0 text-center value-sans">
            {{ section.settings.mainsubheading }}
          </p>
        {% endif %}
      </div>

      <div class="d-flex flex-wrap justify-content-between align-items-center container">
        <div class="w-50 {% if section.settings.verticalThumbnails %}vertical-thumbnails-slider-wrapper{% endif %} {% if section.settings.layout %} order-2 {%endif%}">
          <div class="two-women position-relative">
            {% if section.settings.tag != '' %}
              <span class="tag theme-text value-sans">{{ section.settings.tag }}</span>
            {% endif %}
            <div class="product-gallery global-product-3-gallery">
              {% for block in section.blocks %}
                {% if block.type == 'productImage' %}
                  {% assign image = block.settings.image %}
                  <div class="main-product-img">
                    <picture>
                      <source media="(min-width:650px)" srcset="{{ image | img_url: '800x'}}">
                      <source media="(max-width:650px)" srcset="{{ image | img_url: '500x'}}">
                      <img
                        {% if forloop.index == 1 %}
                          skip-lazy
                        {% else %}
                          loading="lazy"
                        {% endif %}
                        data-id="{{image.id}}"
                        class="img-responsive w-100 lazy"
                        src="{{ image | img_url: '800x'}}"
                        width="800px"
                        height="700px"
                        alt="{{ image.alt }}"
                      >
                    </picture>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
        <div class="w-50  d-flex justify-content-center {% if section.settings.layout %} order-1 {%endif%} ">
          <div class="two-women-details  pb-2 {{section.settings.width}}">
            <h2 class="heading-3 lander-product-heading {{section.settings.textcolor}} value-sans__ text-center">
              {{ section.settings.heading }}
            </h2>
            <div class="text-center">
              <div class="font-pier theme-text mt-3 mb-2 stars-img-review ">
                <span class="star-img">
