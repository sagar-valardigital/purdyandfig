<style>
    .wrapper {
    display: flex;
    background: #161616;
    padding-block: 8px;
     width: 100%;
        overflow: hidden; /* Hides content outside the container */
        white-space: nowrap; /* Prevents content from wrapping */
    
    }
    .text {
    padding-right:85px; 
    color: #fafafa;
    text-align: center;
    font-family: "GT Super" !important;
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%; /* 27px */
    letter-spacing: 0.45px;
    text-transform: uppercase;
    }

    .italic-text {
     font-family: "GT Super" !important;
     color: #D89B39; 
     font-style: italic;
    }

    .marquee-content {
        display: inline-block; /* Allows content to be on one line */
        animation: scroll-left 60s linear infinite; /* Adjust duration for speed */
    }

    @keyframes scroll-left {
        0% {
            transform: translateX(0%);
        }
        100% {
            transform: translateX(-30%); /* Moves content halfway out of view */
        }
    }

    @media (max-width: 768px) {
      .text {
        padding-right:10px; 
      }
    }
    </style>

<div class="wrapper">
    <div class="marquee-content">
    <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
    <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
    <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
    <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
    <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
    <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
    <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
    <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
    <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
    <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
    <span class="text">LIMITED STOCK <span class="italic-text">SHOP NOW</span></span>
    </div>
</div>

