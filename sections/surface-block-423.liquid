{% liquid
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign heading = section.settings.heading
  assign text = section.settings.text
  assign position = section.settings.position
  assign desktop_image = section.settings.desktop_image | image_url: width: 800, height: 800
  assign mobile_image = section.settings.mobile_image | image_url: width: 500, height: 500
  assign poster = section.settings.poster | image_url: width: 800, height: 800
  assign video = section.settings.video
  assign multiple_media = section.settings.multiple_media
  assign button_label = section.settings.button_label
  assign button_color = section.settings.button_color
  assign button_bg = section.settings.button_bg
  assign button_target = section.settings.button_target
  assign autoplay = section.settings.auto_play
  assign full_width = section.settings.full_width
%}
<style>
  #media_{{ section.id }}{
    background-color: {{ bg_color }};
  }
  #media_{{ section.id }} .text-color{
    color : {{ text_color }} !important;
  }
  #media_{{ section.id }} .custom-button{
    color : {{ button_color }} !important;
    background-color: {{ button_bg }} !important;
  }
  {% if  multiple_media %}
  @media(min-width:768px){
    #media_{{ section.id }} .mwt-media{
      opacity:0;
    }
    #media_{{ section.id }}{
      background-image:url("{{ desktop_image }}");
      background-size: 47% auto;
      background-position:left bottom;
      background-repeat:no-repeat;
    }
  }
  {% endif %}

  {% if full_width %}
  @media(max-width:768px){
    #media_{{ section.id }} .mwt-media-wrapper{
      width:calc(100% + 30px);
      margin-left:-15px;
      margin-right:-15px;
    }
  }
  {% endif %}
</style>

<div id="media_{{ section.id }}" class="py-80 m-py-32 media-with-text-section">
  <div class="container">
    {% if heading != blank %}
      <div class="section-heading desktop-hide mb-4">
        <h2 class="heading-2 font-gtsuper text-color">{{ heading }}</h2>
        {% if text != blank %}
          <p class="normal-text  font-lausanne desktop-hide fw-200 text-color">{{ text }}</p>
        {% endif %}
      </div>
    {% endif %}
    <div class="d-grid grid-2 m-grid-1 gap-4 align-items-center">
      {% comment %} Media wrapper {% endcomment %}
      <div class="mwt-media {% if position == 'left' %}{% else %}d-order-2{% endif %}">
        <div class="mwt-media-wrapper position-relative">
          {% if video %}
            <video
              id="video_{{ section.id }}"
              class=" w-100 h-100"
              width="320"
              height="180"
              playsinline
              {% if autoplay %}
                loop
                muted
                autoplay
              {% endif %}
              poster="{{ poster }}"
            >
              <source src="{{ video }}" type="video/mp4">
            </video>
            {% if autoplay %}
            {% else %}
              <div class="video-pp-icon">
                <i class="fas fa-play"></i>
              </div>
            {% endif %}
          {% else %}
            {% if desktop_image %}
              <picture>
                <source media="(min-width:769px)" srcset="{{ desktop_image }}">
                <source
                  media="(max-width:768px)"
                  srcset="{% if mobile_image %}{{ mobileImage }}{%else %}{{ desktop_image }}{% endif %}"
                >
                <img
                  src="{{ desktop_image }}"
                  alt="{{ desktop_image.alt}}"
                  width="600"
                  height="600"
                  class="img-responsive"
                >
              </picture>
            {% endif %}
          {% endif %}
        </div>
      </div>
      {% comment %} Content wrapper {% endcomment %}
      <div class="mwt-text {% if position == 'left' %}{% else %}d-order-1{% endif %}">
        {% if heading != blank %}
          <h2 class="heading-2 font-gtsuper mobile-hide text-color">{{ heading }}</h2>
        {% endif %}
        {% if text != blank %}
          <p class="normal-text  font-lausanne mobile-hide fw-200 text-color">{{ text }}</p>
        {% endif %}
        {% if button_label != blank %}
          <div class="mt-4">
            <span
              class="btn click-scroll custom-button"
              {% if section.settings.dataTrack %}
                {% render 'ga4-events' %}
              {% endif %}
              data-target="{{ button_target }}"
              data-top="{{ section.settings.top }}"
            >
              {{- button_label -}}
            </span>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Surface block 423",
  "settings": [
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "html",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label"
    },
    {
      "type": "text",
      "id": "button_target",
      "label": "Button Target ID"
    },
    {
      "type": "text",
      "id": "top",
      "label": "Scroll to Position",
      "default": "40"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background color"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "checkbox",
      "id": "multiple_media",
      "label": "Outside Container Media",
      "default": false
    },
    {
      "type": "select",
      "id": "position",
      "label": "Media Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Mobile Image : Full Width"
    },
    {
      "type": "checkbox",
      "id": "add_video",
      "label": "Add Video"
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster",
      "visible_if": "{{ section.settings.add_video}}"
    },
    {
      "type": "url",
      "id": "video",
      "label": "Video",
      "visible_if": "{{ section.settings.add_video}}"
    },
    {
      "type": "checkbox",
      "id": "auto_play",
      "label": "Auto Play",
      "default": true,
      "visible_if": "{{ section.settings.add_video}}"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "landing_page"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "itemId",
      "label": "Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label": "Item Name",
      "type": "text"
    }
  ],
  "presets": [
    {
      "name": "Surface block 423",
      "category": "Media & Text"
    }
  ]
}
{% endschema %}
