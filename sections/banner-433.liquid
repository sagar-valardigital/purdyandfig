{% assign desktop_image = section.settings.desktop_img | img_url: '3200x' %}
{% assign mobile_image = section.settings.mobile_img | img_url: '1200x' %}
<style>
  .section_{{ section.id }}.banner-section.banner-10{
    background-image:url({{desktop_image}});
  }
  @media(max-width:768px){
    .section_{{ section.id }}.banner-section.banner-10{
      background-image:url({{mobile_image}});
    }
  }

@media (max-width: 460px) {
  #body .banner-section.banner-10 {
    background-position: top center;
    height: 590px;
  }
}

@media (max-width: 390px) {
  #body .banner-section.banner-10 {
    background-position: top center;
    height: 560px;
  }
}
</style>
<section class="banner-section banner-10 position-relative section_{{ section.id }}">
  <picture>
    <source media="(min-width:768px)" srcset="{{ desktop_image }}">
    <source media="(max-width:767px)" srcset="{{ mobile_image }}">
    <img
      class="w-100 h-auto banner-10-image"
      src="{{ desktop_image }}"
      width="2000"
      height="660"
      style="vertical-align:top;"
    >
  </picture>
  <div class="banner-10-content position-absolute">
    <div class="text-center">
      <h2 class="banner-heading heading-1 font-gtsuper" style="color: {{ section.settings.txt-color }} !important;">
        {{ section.settings.heading }}
      </h2>
      <p class="banner-sub-heading font-lausanne fw-200" style="color:{{ section.settings.txt-color }} !important;">
        {{ section.settings.sub_heading }}
      </p>
      <a
        {% if section.settings.dataTrack %}
          {% render 'ga4-events' %}
        {% endif %}
        href="javascript:void(0);"
        class="click-scroll btn banner-10-btn"
        style="background-color:{{ section.settings.btn-bg }}; color:{{ section.settings.btn-txt-color }}"
        data-top="{{ section.settings.top }}"
        data-target="{{ section.settings.button_link }}"
      >
        {{- section.settings.button_label -}}
      </a>
      {% if section.settings.showreview %}
        <div class="banner-10-reviews">
          <div class="reviews-images">
            <img
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Avatar.png?v=1721733107"
              style="width:144px; height:auto;"
            >
          </div>
          <div class="text-left">
            <div class="font-pier theme-text mt-0 stars-img-review">
              <span class="star-img">
