<style>
/* Custom styling for Icon Blocks PF357 */

.icon-blocks-2-wrapper {
    box-shadow: none !important;
  }

.pf427-icon-blocks {
  padding: 80px 40px !important;
}

/* .pf-357-icon-block .icon-blocks-2-wrapper .icon-block-2 {
  border-color: #F0E8D3 !important;
}*/

.icon-block-2 .normal-text {
  font-size: 16px !important;
}

.icon-block-2 .heading-4 {
font-size: 20px !important;
}

.icon-block-2 .block-img-wrappers {
    margin-bottom: 24px !important;
}

.pf-357-icon-block .block-img-wrappers img {
    height: 54px !important;
    width: auto !important;
  }
  
.green-btn {
  width: 343px;
  padding: 12px 16px;
  margin-top: 40px;
}
.heading-2 {
  letter-spacing: 0px;
}

  span.line-break {
    display: inline !important;
    font-family: "GT Super" !important;
  }

.icon-blocks-2 .heading-2 {
    margin-bottom: 40px!important;
}

.icon-blocks-2-wrapper .icon-block-2 {
padding: 32px 16px;
border-bottom: 0;
}

.icon-blocks-2-wrapper .icon-block-2:not(:last-child) {
  border-right: 1px solid;
}


  
@media (max-width: 768px) {
  
  .pf-357-icon-block.icon-blocks-reskin.py-80
    .icon-blocks-2-wrapper
    .icon-block-2 {
    padding: 16px 0 0 44px !important;
  }

  .pf-357-icon-block .block-img-wrappers {
    position: relative;
  }
      
  .pf-357-icon-block .block-img-wrappers img {
    height: 54px !important;
    width: auto !important;
    position: absolute;
    left: -39px;
    top: 1px;
  }

.icon-blocks-2-wrapper .icon-block-2 .normal-text {
  font-size: 14px !important;
}
  
  .green-btn {
    margin-top: unset;
    width: 100% !important;
    max-width: 100% !important;
  }

.pf427-icon-blocks {
  padding: 32px 16px !important;
}

.pf427-icon-blocks .icon-blocks-2 .heading-427 {
  font-size: 32px !important;
}
  
.pf-357-icon-block .heading-4 {
    color: #212121 !important;
  }

.icon-blocks-2-wrapper .icon-block-2 {
    border-right: 0 !important;
  }

.icon-blocks-2-wrapper .icon-block-2:not(:last-child) {
  border-bottom: 1px solid !important;
}

.pf-357-icon-block .text-center {
    text-align: left !important;
  }

.pf-357-icon-block  .icon-blocks-2-wrapper {
    margin-top: 24px !important;
  }

  span.line-break {
    display: block !important;
    font-family: "GT Super" !important;
  }

.icon-blocks-2 .heading-2 {
    margin-bottom: 24px!important;
}

.icon-blocks-2 .heading-427 {
    font-size: 32px !important;
}
  
}

</style>

{% if section.settings.show_hide_block %}
  <div
    class="block-section icon-blocks-2 icon-blocks-reskin  {{ section.settings.class }}"
    style="background-color:{{ section.settings.bg }}"
  >
    <div class="container">
      <h2 class="heading-2 heading-427 text-center m-text-left blue-text font-gtsuper fw-400 mt-0" style="color:{{ section.settings.headingcolor }}!important">
        {{ section.settings.heading }}
      </h2>
      <div class="d-flex flex-wrap justify-content-between  theme-text my-1 icon-blocks-2-wrapper">
        {% for block in section.blocks %}
          <div class="w-33 icon-block-2" style="border-color: {{ section.settings.linecolor }}!important">
            <div class="text-center ">
              {% if block.settings.icon_block_image %}
                <div class="block-img-wrappers">
                  <img
                    src="{{ block.settings.icon_block_image | image_url }}"
                    width="54"
                    height="54"
                    alt="{{ block.settings.icon_block_image.alt }}"
                  >
                </div>
              {% endif %}
              <div>
                {% if block.settings.icon_block_title != blank %}
                  <h3 class="heading-4 font-lausanne fw-400 mb-2" style="color:{{ section.settings.textcolor }}">
                    {{ block.settings.icon_block_title }}
                  </h3>
                {% endif %}

                {% if block.settings.icon_block_description != blank %}
                  <p class="font-lausanne fw-200 normal-text m-0" style="color:{{ section.settings.detailtextcolor }}">
                    {{ block.settings.icon_block_description }}
                  </p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
      {% if section.settings.showbtn %}
        <div class="text-center mt-3">
          <span
            {% if section.settings.dataTrack %}
              {% render 'ga4-events' %}
            {% endif %}
            data-target="{{ section.settings.scrollto }}"
            data-top="{{ section.settings.top }}"
            class="btn click-scroll green-btn"
            style="background: {{ section.settings.btnbgcolor }} !important; color: {{ section.settings.btntxtcolor }} !important;"
          >
            {{- section.settings.btntext -}}
          </span>
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Icon blocks 427",
  "settings": [
    {
         "type": "text",
         "id" : "class",
         "label": "Section Class"
     },
    {
         "type": "color",
         "id" : "bg",
         "label": "Background Colour",
         "default": "#ffffff"
     },
    {
         "type": "color",
         "id" : "linecolor",
         "label": "Dividing line Colour",
         "default": "#212121"
     },
    {
         "type": "color",
         "id" : "headingcolor",
         "label": "Heading Text Colour",
         "default": "#FFFFFF"
     },
    {
         "type": "color",
         "id" : "textcolor",
         "label": "Item Text Colour",
         "default": "#212121"
     },
    {
         "type": "color",
         "id" : "detailtextcolor",
         "label": "Detail Text Colour",
         "default": "#424242"
     },
     {
         "type": "html",
         "id" : "heading",
         "label": "Heading",
         "default": "You've never enjoyed cleaning this much"
     },
     {
         "type": "checkbox",
         "id": "show_hide_block",
         "label": "Show Icon Block",
         "default": true
     },
     {
         "type": "checkbox",
         "id": "showbtn",
         "label": "Show button",
         "default": false
     },
     {
         "type": "color",
         "id": "btnbgcolor",
         "label": "Button background"
     },
     {
         "type": "color",
         "id": "btntxtcolor",
         "label": "Button text color"
     },
     {
         "type": "text",
         "id": "btntext",
         "label": "Button label"
     },
     {
         "type": "text",
         "id": "scrollto",
         "label": "Scroll to"
     },
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
     {
      "id": "dataTrack",
      "label":"Data Track",
      "type": "checkbox"
      },
      {
      "id": "targetUrl",
      "label":"Target Url",
      "type": "url"
      },
      {
      "id": "index",
      "label":"Index",
      "type": "number",
      "default" : 0
          },
          {
      "id": "funnel_stage",
      "label":"Funnel Stage",
      "type": "text",
       "default" : "landing_page"
          },
          {
      "id": "dataModule",
      "label":"Module",
      "type": "text",
       "default" : "announcement_bar"
          },
            {
      "id": "dataTitle",
      "label":"Event Label",
      "type": "text",
      "default": "get_your_offer"
          }
          ,
            {
      "id": "eventValue",
      "label":"Event Value",
      "type": "text",
      "default" : "shop_anchor"
          },
            {
      "id": "itemId",
      "label":"Item Id",
      "type": "text"
          }
          ,
            {
      "id": "optionIndex",
      "label":"Option Index",
      "type": "text"
          }
          ,
            {
      "id": "ItemName",
      "label":"Item Name",
      "type": "text"
          }
   ],
   "blocks": [
     {
         "type": "iconblocks",
         "name": "Icon Block",
         "limit": 3,
         "settings": [
             {
               "type": "text",
               "id": "icon_block_title",
               "label": "Title"
             },
             {
               "type": "textarea",
               "id": "icon_block_description",
               "label": "Description"
             },
             {
               "type": "image_picker",
               "id": "icon_block_image",
               "label": "Icon Image"
             }
         ]
     }
   ],
   "presets": [
     {
         "name": "Icon blocks 427"
     }
   ]
}
{% endschema %}
