<style>
.blocks-reskin .insta-post .heading-4 {
  font-size: 18px!important;
}

  .insta-2-details {
  margin-bottom: 40px!important;
}

@media (max-width: 768px) {

  .blocks-reskin {
  padding: 32px 0!important;
  }

  .blocks-reskin .heading-2 {
  padding-bottom: 12px!important;
  margin-bottom: 0!important;
}

  .mobile-vertical-container {
    display: flex !important;
    flex-direction: column !important;
    width: 100% !important;
    transform: none !important;
    transition: none !important;
  }
  
  .mobile-vertical-item {
    padding: 0!important;
    width: 100% !important;
    display: block !important;
    opacity: 1 !important;
    transform: none !important;
    position: relative !important;
  }
  
  .mobile-vertical-post {
    display: flex !important;
    align-items: center;
    gap: 12px;
    background: transparent;
    margin: 8px 0;
  }

.mobile-vertical-item:first-child .mobile-vertical-post {
  margin-top: 0!important;
}

.mobile-vertical-item:last-child .mobile-vertical-post {
  margin-bottom: 0!important;
}
  
  .mobile-vertical-img {
    flex-shrink: 0;
    width: 146px;
    height: 112px;
  }
  
  .mobile-vertical-img img {
    width: 100%;
    height: 100%;
    border-radius: 4px;
  }
  
  .mobile-vertical-content {
    flex: 1;
  }

  .insta-2-details {
  font-size: 16px;
  margin-bottom: 32px!important;
}

.blocks-reskin .text-center {
  text-align: left;
}
  
  .mobile-vertical-content .heading-4 {
    font-size: 16px!important;
    font-weight: 400!important;
    margin-bottom: 4px !important;
  }
  
  .mobile-vertical-content .detail-text {
    font-size: 14px!important;
    font-weight: 200!important;
    margin: 0 !important;
  }
  
  /* Hide desktop elements on mobile */
  .insta-blocks.insta-blocks-2 {
    display: none !important;
  }
}

/* Show mobile layout  */
@media (min-width: 769px) {
  .mobile-vertical-container {
    display: none !important;
  }
}
</style>

{% if section.settings.enable %}
  <div
    class="instagram-wrapper py-80  blocks-reskin {{ section.settings.className }}"
    style="background-color:{{ section.settings.bgColor }}"
  >
    <div class="container">
      {% if section.settings.heading != '' %}
        <h2 class="heading-2 text-center theme-text mt-0  font-gtsuper" style="color: #0A1E1A!important; margin-bottom: 0!important">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.details != '' %}
        <div class="normal-text text-center theme-text mt-0 font-lausanne fw-400  col-12 col-md-8 col-lg-6 m-auto  insta-2-details" style="color: #424242; font-weight: 200!important">
          {{ section.settings.details }}
        </div>
      {% endif %}
    </div>
    <div class="container">
      <!-- Desktop Layout (Original) -->
      <div class="insta-blocks insta-blocks-2 custom-dots w-100 justify-content-center">
        {% for block in section.blocks %}
          <div class="insta-item py-1 px-3">
            <div class="insta-post bg-transparent d-block" >
              <div class="insta-img position-relative">
                <picture>
                  {% assign desktop_image = block.settings.desktop_image %}
                  {% assign mobile_image = block.settings.mobile_image %}

                  <source media="(min-width:769px)" srcset="{{ desktop_image | img_url: '600x', crop: 'center' }}">
                  <source media="(max-width:768px)" srcset="{% if mobile_image %}{{ mobile_image | img_url: '600x', crop: 'center' }}{% else %}{{ desktop_image | img_url: '600x', crop: 'center' }}{% endif %}">
                  <img
                    class="w-100 img-responsive"
                    src="{{ desktop_image | img_url: '600x', crop: 'center' }}"
                    alt="{{ desktop_image.alt }}"
                  >
                </picture>
              </div>
              {% if block.settings.ig_username != '' %}
                <div class="pt-3">                                   
                  <div class="insta-post-username">
                    <p class="m-0  heading-4 font-lausanne fw-400" style="color:#212121">
                      {{ block.settings.ig_username }}
                    </p>
                    <p class="mt-2 detail-text font-lausanne fw-200" style="color:#424242">{{ block.settings.subtext }}</p>
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Mobile Layout (Separate container with new classes) -->
      <div class="mobile-vertical-container">
        {% for block in section.blocks %}
          <div class="mobile-vertical-item">
            <div class="mobile-vertical-post">
              <div class="mobile-vertical-img">
                {% assign mobile_image = block.settings.mobile_image %}
                {% assign desktop_image = block.settings.desktop_image %}
                <img
                  src="{% if mobile_image %}{{ mobile_image | img_url: '160x160', crop: 'center' }}{% else %}{{ desktop_image | img_url: '160x160', crop: 'center' }}{% endif %}"
                  alt="{% if mobile_image %}{{ mobile_image.alt }}{% else %}{{ desktop_image.alt }}{% endif %}"
                >
              </div>
              {% if block.settings.ig_username != '' %}
                <div class="mobile-vertical-content">
                  <p class="m-0 heading-4 font-lausanne fw-400" style="color:#212121">
                    {{ block.settings.ig_username }}
                  </p>
                  <p class="mt-1 detail-text font-lausanne fw-200" style="color:#424242">{{ block.settings.subtext }}</p>
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
      {% if section.settings.followLink %}
        <div class="text-center mt-5">                   
          <a href="{{ section.settings.followLink }}" target="_blank" class="btn theme-border-btn">
            {{- section.settings.followText -}}
          </a>               
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Blocks Reskin 408",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },
    {
      "type":"text",
      "id":"className",
      "label": "Section Class"
    },
    {
      "type": "color",
      "id": "bgColor",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "textColor",
      "label": "Text Color",
      "default": "#212121"
    },
    {
      "type":"html",
      "id":"heading",
      "label": "Section Heading"
    },
    {
      "type":"html",
      "id":"details",
      "label": "Section detail text"
    },
    {
      "type":"text",
      "id":"followText",
      "label": "Button text"
    },
    {
      "type":"url",
      "id":"followLink",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type":"igblock",
      "name":"block",
      "settings":[
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image (Optional - falls back to desktop image if not set)"
        },
        {
          "type": "html",
          "id": "ig_username",
          "label": "Heading"
        },
        {
          "type": "html",
          "id": "subtext",
          "label": "Sub Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blocks Reskin 408"
    }
  ]
}
{% endschema %}