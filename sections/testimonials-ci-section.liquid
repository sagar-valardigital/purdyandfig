<section class="testimonial-section">
  <div class="page-width">
    <h2>{{ section.settings.heading }}</h2>
    <p class="testimonial-text">{{ section.settings.testimonial }}</p>
    <p class="testimonial-author">
      — {{ section.settings.author }}
      <span>-test</span>
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Testimonial",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "textarea",
      "id": "testimonial",
      "label": "Testimonial",
      "default": "This product is amazing!"
    },
    {
      "type": "text",
      "id": "author",
      "label": "Author",
      "default": "Happy Customer"
    }
  ],
  "presets": [
    {
      "name": "Testimonial"
    }
  ]
}
{% endschema %}
