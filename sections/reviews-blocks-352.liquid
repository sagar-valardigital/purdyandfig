<style>
    /* General Setup and Font Import */


  /* Testimonials Section Styling */
  .testimonials {

      color: #f3f3f3; /* Off-white text color */
      padding: 60px 20px;
      text-align: center;
  }

  .testimonials .container {
      max-width: 1200px;
      margin: 0 auto;

  }

  .testimonials h2 {
      color: var(--Neutral-White, #FFF);

      /* Mobile/H2/Regular */
      font-family: "GT Super";
      font-size: 40px;
      font-style: normal;
      font-weight: 400;
      line-height: 125%; /* 40px */
      margin-bottom: 40px;
  }

  /* Grid Layout for Testimonials */
  .testimonial-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr); /* 4 columns on desktop */
      gap: 18px; /* Space between cards */
  }

  .testimonial-card {
      text-align: left;
  }

  .testimonial-card img {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1; /* Makes images square */
      object-fit: cover; /* Prevents image stretching */
      border-radius: 5px; /* Slightly rounded corners */
      margin-bottom: 15px;
  }

  .testimonial-card .quote {
      color: var(--Neutral-White, #FFF);

      /* Desktop/Body Large/Light */
      font-family: "TWK Lausanne";
      font-size: 18px;
      font-style: normal;
      font-weight: 200;
      line-height: 150%; /* 27px */
  }

  .testimonial-card .author {
      color: var(--Neutral-500, #9E9E9E);

      /* Desktop/Body Medium/Regular */
      font-family: "TWK Lausanne";
      font-size: 16px;
      font-style: normal;
      font-weight: 400;
      line-height: 160%; /* 25.6px */
  }

  /* Responsive Design for Tablets */
  @media (max-width: 992px) {
      .testimonial-grid {
          grid-template-columns: repeat(2, 1fr); /* 2 columns on tablets */
      }
      .testimonials h2 {
          /* font-size: 2rem; */
      }
     .testimonial-card .quote {
          font-size: 16px;
      }
    .testimonial-card .author {
      font-size: 14px;
    }
  }

  /* MODIFIED: Responsive Design for Mobile */
  @media (max-width: 576px) {
    .testimonials {
      padding: 0px 16px 32px 16px;
      margin-top: -1px;
    }
      .testimonial-grid {
          /* This line is changed from 1fr to show 2 columns */
          grid-template-columns: repeat(2, 1fr);
          gap: 15px; /* Reduced gap for smaller screens */
          row-gap: 32px;
      }
      .testimonials h2 {
          font-size: 32px;
          text-align: left;
          margin-bottom: 32px;
      }
      .testimonial-card .quote {
          font-size: 16px;
      }
    .testimonial-card .author {
      font-size: 14px;
      margin-bottom: 0;
    }
  }
</style>

<div class="testimonials" style=" background-color: {{ section.settings.bgColor }}">
  <div class="container" style="padding: 0 0 !important;">
    <h2>{{ section.settings.heading }}</h2>
    <div class="testimonial-grid">
      {% for block in section.blocks %}
        <div class="testimonial-card">
          <img
            src="{{ block.settings.image | img_url : '200x200' }}"
            width="200"
            height="200"
            alt="{{ block.settings.image.alt }}"
          >
          <p class="quote">{{ block.settings.review }}</p>
          <p class="author">{{ block.settings.userName }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

