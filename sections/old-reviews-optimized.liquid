<style>
  .rev-container {
    padding: 80px 16px;
		background: {{ section.settings.background }};
		flex-direction: column;
		justify-content: flex-start;
		align-items: center;
		gap: 40px;
		display: flex;
  }
	.rev-heading-block {
		flex-direction: column;
		justify-content: flex-start;
		align-items: center;
		gap: 8px;
		display: flex;
	}
	.rev-heading {
		text-align: center;
		color: {{ section.settings.heading_color }};
		font-size: 40px;
		font-family: "GT Super";
		font-weight: 400;
		line-height: 50px;
		word-wrap: break-word;
	}
	.rev-block-main {
		padding-left: 112px;
		padding-right: 112px;
		display: flex;
		justify-content: space-between;
		align-items: stretch;
		gap: 24px;
	}
	.rev-blocks {
		width: 30%;
		background: white;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		align-items: center;
		gap: 16px;
	}
	.rev-block-content {
		padding: 16px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		flex-grow: 1;
		text-align: center;
		gap: 24px;
	}
	.rev-summary {
		align-self: stretch;
		text-align: center;
		justify-content: center;
		display: flex;
		flex-direction: column;
		color: {{ section.settings.block_text_color }};
		font-size: 20px;
		font-family: "GT Super";
		font-weight: 300;
		line-height: 30px;
		word-wrap: break-word;
	}
	.rev-author-block {
		align-self: stretch;
		flex-direction: column;
		justify-content: flex-start;
		align-items: center;
		gap: 8px;
		display: flex;
	}
	.rev-author-block img {
		border-radius: 4px;
	}
	.rev-author {
		align-self: stretch;
		text-align: center;
		justify-content: center;
		display: flex;
		flex-direction: column;
		color: {{ section.settings.block_heading_color }};
		font-size: 16px;
		font-family: "Lausanne";
		font-weight: 400;
		line-height: 25.60px;
		word-wrap: break-word;
	}
	.rev-spacer {
		align-self: stretch;
		height: 1px;
		outline: 1px #EEEEEE solid;
		outline-offset: -0.50px;
		margin-top: auto;
		width: 100%;
	}

	@media (max-width: 767px) {
		.rev-container {
    	padding: 32px 16px;
			gap: 32px;
		}
		.rev-heading-block {
			flex-direction: column;
			justify-content: flex-start;
			align-items: center;
			gap: 8px;
			display: flex;
		}
		.rev-heading {
			text-align: left;
			font-size: 32px;
			line-height: 40px;
		}
		.rev-block-main {
			flex-direction: column;
			padding-left: 0px;
			padding-right: 0px;
		}
		.rev-blocks {
			width: 100%;
			padding-left: 0px;
			padding-right: 0px;
		}
		.rev-author {
			font-size: 14px;
			line-height: 21px;
		}
		.rev-blocks:last-child .rev-spacer {
			display: none;
		}
	}
</style>

<div class="rev-container">
  <div class="rev-heading-block">
    <div class="rev-heading">{{ section.settings.main_heading }}</div>
  </div>
	{% if section.blocks.size > 0 %}
  <div class="rev-block-main">
		{% for block in section.blocks %}
			<div class="rev-blocks">
				<div class="rev-block-content">
					<div class="rev-summary">{{ block.settings.summary }}</div>
					<div class="rev-author-block">
						<img src="{{ block.settings.desk_image | image_url: width: 300, crop: 'center' }}" width="60" height="60">
						<div class="rev-author">{{ block.settings.heading }}</div>
					</div>
				</div>
				<div class="rev-spacer"></div>
			</div>
		{% endfor %}
  </div>
	{% endif %}
</div>

{% schema %}
{
  "name": "Old reviews optimized",
  "settings": [
    {
      "type": "checkbox",
      "id": "addScrollBtn",
      "label": "Show Scroll to Btn",
      "default": false
    },
    {
      "type": "text",
      "id": "className",
      "label": "Add Section class Name"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Select background color"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color"
    },
    {
      "type": "color",
      "id": "block_heading_color",
      "label": "Blocks heading color"
    },
    {
      "type": "color",
      "id": "block_text_color",
      "label": "Blocks text color"
    },
    {
      "type": "html",
      "id": "main_heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "btnLabel",
      "label": "Button Label",
      "default": "GET YOUR OFFER"
    },
    {
      "type": "text",
      "id": "scrollto",
      "label": "Scroll to section id",
      "default": "javascript:void(0);"
    },
    {
      "type": "text",
      "id": "top",
      "label": "On scroll top position",
      "default": "0"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "landing_page"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "itemId",
      "label": "Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label": "Item Name",
      "type": "text"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "block",
			"limit": 3,
      "settings": [
        {
          "type": "html",
          "id": "heading",
          "label": "Author"
        },
        {
          "type": "html",
          "id": "summary",
          "label": "Summary"
        },
        {
          "type": "image_picker",
          "id": "desk_image",
          "label": "Author image"
        },
      ]
    },
  ],
  "presets": [
    {
      "name": "Old reviews optimized"
    }
  ]
}
{% endschema %}
