<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Find the first element with class 'global-product-5'
    let productElement = document.querySelector('.global-product-5');

    if(productElement) {
      // Create a new div element with id 'buy-now'
      let buyNowDiv = document.createElement('div');
      buyNowDiv.id = 'buy-now';
  
      // Insert the new div before the product element
      productElement.parentNode.insertBefore(buyNowDiv, productElement);
    }
  });

  let discountCode = "";
  document.addEventListener("DOMContentLoaded", function() {
    let mainElement = document.getElementById("starterkit-page");
    if(mainElement) { discountCode = mainElement.dataset.discount; }
  
    // Function to close the popup
    function closePopup(popup) {
        if (popup) {
            popup.style.display = 'none';
            // Additional code for closing the popup can be added here
        }
    }
    // Select all elements with the 'popup-link' class
    var popupLinks = document.querySelectorAll('.popup-link');
    popupLinks.forEach(function(link) {
        link.addEventListener('click', function(event) {
            // Prevent the default action
            event.preventDefault();
            // Extract the unique part of the ID from the link
            var idPart = this.id.replace('link-', '');
            // Find the corresponding popup
            var popup = document.getElementById('popup-' + idPart);
            // Display the popup
            if (popup) {
                popup.style.display = 'block';
                // Additional code to properly show the popup can be added here
            }
        });
    });
    // Close popup when clicking on lightbox-dim but not on lightbox-content
    document.addEventListener('click', function(event) {
        if (event.target.classList.contains('lightbox-dim') && !event.target.closest('.lightbox-content')) {
            closePopup(event.target.closest('.popup'));
        }
    });
    // Close popup when clicking on lightbox-close
    document.querySelectorAll('.lightbox-close').forEach(function(closeButton) {
        closeButton.addEventListener('click', function() {
            closePopup(this.closest('.popup'));
        });
    });
    // Function to set the margin-top of page-block-u7mmwsnnmra
    function adjustMarginTop() {
        var sourceElement = document.getElementById('page-block-hbeipyb748f');
        var targetElement = document.getElementById('page-block-u7mmwsnnmra');
        if (sourceElement && targetElement) {
            var height = sourceElement.offsetHeight;
            targetElement.style.marginTop = height + 'px';
        }
    }
    // Call the function on page load and window resize
    {% if page.handle != 'starterkit-offer' and page.handle != 'starterkit-offer-1' and page.handle != 'starterkit-offer-2' %}
    adjustMarginTop();
    window.addEventListener('resize', adjustMarginTop);
    {% endif %}
  });

  const checkout = () => {
    let mainElement = document.getElementById("starterkit-page");
    if(mainElement) { discountCode = mainElement.dataset.discount; }
    
    items = [
      {
        quantity: 1,
        id: 42467940991203,
        selling_plan:3088842979
      },
      {
        quantity: 1,
        id: 42468003250403,
      }
    ];
    
    data = {
      'items': items
    };
    
    var xhr = new XMLHttpRequest();
    xhr.onreadystatechange = function() {
      if (xhr.readyState === 4) {
        window.location.href = `/discount/${discountCode}?redirect=%2Fcheckout?discount=${discountCode}`;
      }
    };
    
    xhr.open('POST', '/cart/add.js');
    xhr.setRequestHeader('Content-Type', 'application/json');
    xhr.send(JSON.stringify(data));
  }
</script>

