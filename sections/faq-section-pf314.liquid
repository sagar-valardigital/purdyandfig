<style>
  
.faq-section-wrapper-2 .faq {
  border-top: 1px solid #9E9E9E;
}
  
.faq-section-wrapper-2 .faq:first-child {
  border-top: 0;
}

.faq-section-2-heading .heading-2 {
  padding-bottom:48px;
}

.faq-acc-2{
  margin:32px 0;
}

.faq-que-2.value-medium {
  font-weight: 400 !important;
}
  
</style>

{% if section.settings.enable %}
  <div
    class="faq-section-wrapper-2 {{ section.settings.class }}"
    style="background-color:{{ section.settings.color_bg }}"
  >
    <div class="container">
      <div class="faq-section-2-heading text-center">
        <h3 class="heading-2 font-value blue-text">{{ section.settings.heading }}</h3>
      </div>
      <div class="faqBlockWrapper">
        {% for block in section.blocks %}
          <div class="faq">
            <details
              class="faq-acc faq-acc-2"
              {% if block.settings.open %}
                open="true"
              {% endif %}
            >
              <summary class="faq-que-2 value-medium ">{{ block.settings['faq-question'] }}</summary>
              <p class="mt-2 ">{{ block.settings['faq-ans'] }}</p>
            </details>
          </div>
        {% endfor %}
      </div>
      {% if section.settings.addScrollBtn %}
    <div class="mt-4">
      <span
        class="d-block text-center blue-starterkit-btn click-scroll m-auto"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >GET YOUR OFFER</span
      >
    </div>
    {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
 {
    "name": "FAQ section FP314",
    "class": "faq-section",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },	{
          "type": "color",
          "id": "color_bg",
          "label": "Background color",
          "default": "#fff"
        },
      {
          "type": "text",
          "id": "class",
          "label": "Section Class"
        },
{
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
      {
          "type": "checkbox",
          "id": "addScrollBtn",
          "label": "Show Scroll to Btn",
          "default": false
        },
      {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      }
     ,
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
    {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
	],
	"blocks": [
      {
        "type": "text",
        "name": "faq",
        "settings": [

{
            "type": "checkbox",
            "id": "open",
            "label": "Default Open",
            "default": false
          },
{
            "type": "text",
            "id": "faq-question",
            "label": "FAQ QUE"
          },
{
            "type": "richtext",
            "id": "faq-ans",
            "label": "FAQ ANS"
          }
        ]
      }
	],
	"presets": [
		{
			"name": "FAQ section FP314"
		}
	]
  }
{% endschema %}
