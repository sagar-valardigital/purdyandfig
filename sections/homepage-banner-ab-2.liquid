              </svg>
            </span>
            <span class="total-reviews" style="color:{{ section.settings.titlecolor }}">
              Over ({{ settings.gloabalreviews }}+ reviews)</span
            >
          </div>

         
          {% if section.settings.link %}
            <div class="banner-btn-wrapper text-center">
              {% if section.settings.linkText != '' %}
                <span class="click-scroll btn banner-btn theme-btn w-100 " 
                  data-target="{{section.settings.linkText}}"
                  {% if section.settings.dataTrack %}
                    data-tracked="true"
                    data-page-url="{{ request.path }}"
                    data-target-url="{{ section.settings.targetUrl }}"
                    data-index="{{ section.settings.index }}"
                    data-funnel-stage="{{ section.settings.funnel_stage }}"
                    data-module="{{ section.settings.dataModule }}"
                    data-event-label="{{ section.settings.eventLabel }}"
                    data-event-value="{{ section.settings.eventValue }}"
                    data-item-id="{{ section.settings.itemId }}"
                    data-option-index="{{ section.settings.optionIndex }}"
                    data-item-name="{{ section.settings.ItemName }}"
                  {% endif %}
                  ><span>{{ section.settings.btnText }}</span></span
                >
              {% else %}
                <a href="{{ section.settings.link }}" class="btn banner-btn theme-btn w-100 btn-loader"
                  ><span>{{ section.settings.btnText }}</span></a
                >
              {% endif %}
              {% if settings.freeshipping %}
                <br>
                <small class="font-pier my-1 d-inline-block theme-text"
                  ><img
                    width="25px"
                    height="25px"
                    style="margin-right:15px; display:inline-block; vertical-align:middle;"
                    src="{{ 'delivery-2.png' | asset_url }}"
                  >
                  <span style="display:inline-block; vertical-align:middle;" class="theme-text">
                    {{- section.settings.btnSubText -}}
                  </span></small
                >
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>       
</div>

<div class="banner-2-usps d-flex mobile-hide">
      <div class="d-flex justify-content-center column">
        <span class="d-flex align-items-center me-2"><img src="{{'icon-delivery.svg' | asset_url}}" width="21px" height="20px" alt=""></span>
        <span class="ms-2">Free delivery with orders over £40</span>
      </div>
      <div class="d-flex justify-content-center column">
        <span class="d-flex align-items-center me-2"><img src="{{'icon-money.svg' | asset_url}}" width="21px" height="20px" alt=""></span>
        <span class="ms-2">Money Back Guarantee</span>
      </div>
      <div class="d-flex justify-content-center column">
        <span class="d-flex align-items-center me-2"><img src="{{'icon-cube.svg' | asset_url}}" width="21px" height="20px" alt=""></span>
        <span class="ms-2">Eco Packaging</span>
      </div>
</div>
<style>
  {%- assign DimageURL = section.settings.desktopimage | img_url:"2400x" -%}
  {%- assign MimageURL = section.settings.mobileimage | img_url:"768x" -%}

  .main-banner{{ section.id }} {
    background-image:url({{DimageURL}})
  }
      
  .banner-btn {
      color:{{section.settings.textcolor}};
      background-color:{{section.settings.bgcolor}}; 
      border-color:{{section.settings.bgcolor}};
  }

  .banner-2 .heading-1{
    font-size:44px;
  }
  
  .banner-2 {
    background-size: cover;
    background-position: center;
  }
  
  .banner-2 .banner-text-wrapper {
    position: absolute;
    top: calc(19% + 5px);
    left: 0;
    right: 0;
  }
  
  .banner-2 .banner-button-wrapper {
    position: absolute;
    top: auto;
    bottom: 20px;
    left: 0;
    right: 0;
  }
  
  .banner-2-usps {
    margin-top: 16px;
    margin-bottom: 16px;
    font-size: 12px;
  }
  
  .banner-2-usps .column {
    flex: 1;
    text-align: center;
  }
  
  @media(max-width:768px) {
    .main-banner{{ section.id }} {
      background-image:url({{MimageURL}})
    }
    
    .banner-2 .banner-text-wrapper {
      height: calc(100% - 80px);
      position: absolute;
      top: calc(12% + 5px);
      left: 0;
      right: 0;
    }
    
    .banner-2 .heading-1{
      font-size: 35px !important;
    }
    
    .main-banner.banner-2.img-top .banner-text{
      position: absolute;
      left: 45%;
      transform: translateX(-50%);
      max-width: 90%;
      bottom: 50px;
    }
    
    .main-banner.banner-2.img-top .banner-text .banner-btn-wrapper,
    .main-banner.banner-2.img-bottom .banner-text .banner-btn-wrapper {
        position: relative;
        bottom: 0;
        max-width: 90%;
        width: 400px;
    }
  }
</style>
                  
{% schema %}
{
  "name": "Homepage Banner A/B Var 2",
  "settings": [
    {
      "id": "class",
      "label": "Section class",
      "type": "text"
    },
    {
      "id": "desktopimage",
      "label": "Desktop Image",
      "type": "image_picker"
    },
    {
      "id": "mobileimage",
      "label": "Mobile Image",
      "type": "image_picker"
    },
    {
      "type": "select",
      "id": "mobileImgLoc",
      "label": "Mobile Image position",
      "options": [
        {
          "value": "img-top",
          "label": "Top image"
        },
        {
          "value": "img-center",
          "label": "Middle Image "
        },
        {
          "value": "img-bottom",
          "label": "Bottom Image "
        }
      ],
      "default": "img-center"
    },
    {
      "id": "enablelink",
      "label": "Enable Banner Text",
      "type": "checkbox"
    },
    {
      "id": "reviewShow",
      "label": "Hide Banner Review Mobile",
      "type": "checkbox",
      "default": false
    },
    {
      "id": "title",
      "label": "Banner Title",
      "type": "text"
    },
    {
      "id": "titlecolor",
      "label": "Title text color",
      "type": "color",
      "default": "#ffffff"
    },
    {
      "id": "subtext",
      "label": "Banner Sub Text",
      "type": "textarea"
    },
    {
      "id": "subtextcolor",
      "label": "Sub Text color",
      "type": "color",
      "default": "#ffffff"
    },
    {
      "id": "btnText",
      "label": "Button Label",
      "type": "text",
      "default": "SHOP NOW"
    },
    {
      "id": "link",
      "label": "Link",
      "type": "url"
    },
    {
      "id": "linkText",
      "label": "Scroll to Section",
      "type": "text"
    },
    {
      "id": "textcolor",
      "label": "Button text color",
      "type": "color"
    },
    {
      "id": "bgcolor",
      "label": "Button Background color",
      "type": "color"
    },
    {
      "id": "btnSubText",
      "label": "Button Sub Text",
      "type": "text"
    },
    {
      "type": "header",
      "content": "GA4"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },
    {
      "id": "targetUrl",
      "label": "Target Url",
      "type": "url"
    },
    {
      "id": "targetUrl2",
      "label": "Target Url 2",
      "type": "url"
    },
    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "hp"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "hero"
    },
    {
      "id": "eventLabel",
      "label": "Event Label",
      "type": "text",
      "default": "get_started"
    },
    {
      "id": "eventLabel2",
      "label": "Event Label 2",
      "type": "text",
      "default": "shop_all"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "eventValue2",
      "label": "Event Value 2",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "id": "itemId",
      "label": "Item Id",
      "type": "text"
    },
    {
      "id": "optionIndex",
      "label": "Option Index",
      "type": "text"
    },
    {
      "id": "ItemName",
      "label": "Item Name",
      "type": "text"
    }
  ],
  "presets": [
    {
      "name": "Homepage Banner AB Var 2"
    }
  ]
}
{% endschema %}