<div class="main-banner home-page-banner-1 main-banner{{ section.id }} banner-2 {{ section.settings.mobileImgLoc }} {{ section.settings.class }}">
   <div class="banner-text-wrapper"> 
  <div class="container d-flex align-items-center justify-content-center">
       <div class="text-wrapper text-center">
          
            <h1 class="heading-1 font-value m-0 " style="color:{{ section.settings.titlecolor }}">
              {{ section.settings.title }}
            </h1>
           {% if section.settings.subtext %}
              <p class="font-pier" style="color:{{ section.settings.subtextcolor }}">{{ section.settings.subtext }}</p>
            {% endif %}
          </div>
    </div>
   </div>
