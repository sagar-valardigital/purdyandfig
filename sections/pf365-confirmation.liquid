font-weight: 400;
line-height: 150%; /* 18px */
letter-spacing: 0.18px;
display: flex;
width: 100%;
height: 37px;
padding: 8px 0px;
flex-direction: row;
justify-content: center;
align-items: end;
flex-shrink: 0;
