  height: 50vh;
  background-position: center;
  background-repeat: no-repeat;
  background-size: cover;  
}

.coming-bar {
  display: block;
  width: 100%;
  color: var(--Primary-500, #11322C);
text-align: center;
/* Mobile/Body Small/Regular */
font-size: 12px;
