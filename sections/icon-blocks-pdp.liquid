<style>
  .icon-block-2 {
    padding: 32px 16px;
  }

  .icon-block-2 .block-img-wrappers {
    margin-bottom: 24px !important;
  }
  
  .icon-blocks-2 .heading-4 {
    margin-top: 0px !important;
  }

  @media (max-width: 768px) {
    .subheading {
      text-align: left;
    }

    .bathroom-bliss-page .block-section .heading-4 {
      font-size: 16px;
      text-decoration: none;
    }
  }
</style>

{% if section.settings.show_hide_block %}
<div class="block-section py-80 icon-blocks-2 icon-blocks-reskin" style="background-color:{{ section.settings.bg }}">
  <div class="container">
    <h2 class="heading-2 text-center m-text-left blue-text font-gtsuper fw-400 mt-0 mb-0">
      {{ section.settings.heading }}
    </h2>

    {% if section.settings.subheading %}
      <div style="margin-top: 12px;">
        <p class="subheading text-center fw-200" style="color:{{ section.settings.textcolor }}">
          {{ section.settings.subheading }}
        </p>
      </div>
    {% endif %}
      
    <div class="d-flex flex-wrap justify-content-between  theme-text my-1 icon-blocks-2-wrapper" style="margin-top: 40px !important;">
    
        {% for block in section.blocks %}
        <div class="w-25 icon-block-2">
          <div class="text-center ">
            {% if block.settings.icon_block_image %}
            <div class="block-img-wrappers mb-3">
              <img
                src="{{ block.settings.icon_block_image | image_url }}"
                width="57"
                height="56"
                alt="icon"
              >
            </div>
            {% endif %}
            
            {% if block.settings.icon_block_title != blank %}
            <h3 class="heading-4 font-lausanne fw-400 mb-2" style="color:{{ section.settings.textcolor }}">{{ block.settings.icon_block_title }}</h3>
            {% endif %}
            
            

            {% if block.settings.icon_block_description != blank %}
            <p class="font-lausanne fw-200 normal-text m-0" style="color:{{ section.settings.textcolor }}">
              {{ block.settings.icon_block_description }}
            </p>
            {% endif %}
          </div>
        </div>
        {% endfor %}  
    </div>
  </div>
</div>
{% endif %}

{% schema %}
 {
   "name": "Icon Blocks PDP",
   "settings": [
     {
          "type": "color",
          "id" : "bg",
          "label": "Background Colour",
          "default": "#ffffff"
      },
     {
          "type": "color",
          "id" : "textcolor",
          "label": "TextColour",
          "default": "#212121"
      },
      {
          "type": "text",
          "id" : "heading",
          "label": "Heading",
          "default": "You've never enjoyed cleaning this much"
      },
       {
          "type": "text",
          "id" : "subheading",
          "label": "Subheading"
      },
      {
          "type": "checkbox",
          "id": "show_hide_block",
          "label": "Show Icon Block",
          "default": true
      }
    ],
    "blocks": [
      {
          "type": "iconblocks",
          "name": "Icon Block",
          "limit": 4,
          "settings": [
              {
                "type": "text",
                "id": "icon_block_title",
                "label": "Title"
              },
              {
                "type": "textarea",
                "id": "icon_block_description",
                "label": "Description"
              },
              {
                "type": "image_picker",
                "id": "icon_block_image",
                "label": "Icon Image"
              }
          ]
      }
    ],
    "presets": [
      {
          "name": "Icon Blocks PDP"
      }
    ]
 }
{% endschema %}
