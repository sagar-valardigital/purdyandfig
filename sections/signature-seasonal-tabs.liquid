<style>
body.overflow-hidden{
  overflow:hidden;
}
</style>
<div class="signature-seasonal-tabs">
  <div class="container"> 
    </div>
    <div class="pf-tabs-wrapper">
        <span class="pf-tab active" data-label="{{ section.settings.tabone | handle }}" data-target="tab-1">{{ section.settings.tabone }}</span>
        <span class="pf-tab" data-label="{{ section.settings.tabtwo | handle }}"  data-target="tab-2">{{ section.settings.tabtwo }}</span>
    </div>
    <div class="pf-tabs-content position-relative">
      <div id="tab-1" class="pf-tab-content active">
        <div class="tab-blocks-wrapper">
          {% for block in section.blocks %}
            {% if block.type == "tab-one" %}
              {% if block.settings.first %}
              <div class="tab-block first-block" style="background-image:url({{ block.settings.image | image_url }})">
                <h3 class="font-gtsuper heading-3 text-white white-text">{{ block.settings.heading }}</h3>
              </div>
              {% else %}
              <div class="tab-block position-relative">
                <div class="tab-image">
                  <picture>
  <source media="(min-width:650px)" srcset="{{ block.settings.image | image_url }}">
  <source media="(min-width:320px)" srcset="{{ block.settings.mobile_image | image_url }}">
  <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image | image_url }}" class="w-100 h-auto" width="300" height="250">
</picture>
                  
                </div>
                <div class="tab-block-content mt-2">
                  <h3 class="font-lausanne fw-400 heading-3">{{ block.settings.heading }}</h3>
                  <p class="fw-200 font-lausanne">{{ block.settings.content }}</p>
                </div>
            
                <div class="tab-block-blend">
                  <input type="checkbox" id="{{ block.id }}">
                  <div class="">
                    <label for="{{ block.id }}" class="d-flex open-tab-blend-popup justify-content-between font-lausanne fw-400">BLEND DETAILS <img src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/green-plus.svg?v=1722600268"  width="15" height="15" alt="icon"></label> 
                    
                  </div>
                  <div class="tab-blend-popup-wrapper">
                    <label for="{{ block.id }}" class="tab-popup-overlay close-tab-blend-popup"></label>
                    <div class="tab-blend-popup">
                      <label class="tab-close-blend-popup close-tab-blend-popup d-block text-right px-2 pt-2" for="{{ block.id }}">
                        <img src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/close.png?v=1736092528" width="32" height="32" alt="close">
                      </label>
                      <div class="overflow-auto">
                      <div class="tab-block-content">
                        <h3 class="font-lausanne fw-400 heading-3">{{ block.settings.heading }}</h3>
                        <p class="fw-200 font-lausanne">{{ block.settings.content }}</p>
                      </div>
                      <div class="tab-image">
                        <img src="{{ block.settings.mobile_image | image_url }}" class="w-100 h-auto" width="300" height="250" alt="image">
                      </div>
                      
                      <div class="tab-blend-details">
                        <h3 class="font-lausanne fw-400">Blend Details</h3>
                        <div>{{ block.settings.blend }}</div>
                      </div>
                     
                      </div>
                    </div>
                  </div>
                </div>
              
              </div>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div id="tab-2" class="pf-tab-content">
        <div class="tab-blocks-wrapper">
          {% for block in section.blocks %}
            {% if block.type == "tab-two" %}
              {% if block.settings.first %}
              <div class="tab-block first-block" style="background-image:url({{ block.settings.image | image_url }})">
                <h3 class="font-gtsuper heading-3 text-white white-text">{{ block.settings.heading }}</h3>
              </div>
              {% else %}
              <div class="tab-block position-relative">
                <div class="tab-image">
                  <picture>
  <source media="(min-width:650px)" srcset="{{ block.settings.image | image_url }}">
  <source media="(min-width:320px)" srcset="{{ block.settings.mobile_image | image_url }}">
  <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image | image_url }}" class="w-100 h-auto" width="300" height="250">
</picture>
                </div>
                <div class="tab-block-content mt-2">
                  <h3 class="font-lausanne fw-400 heading-3">{{ block.settings.heading }}</h3>
                  <p class="fw-200 font-lausanne">{{ block.settings.content }}</p>
                </div>
               
                <div class="tab-block-blend">
                  <input type="checkbox" id="{{ block.id }}">
                  <div class="">
                    <label for="{{ block.id }}" class="d-flex open-tab-blend-popup justify-content-between font-lausanne fw-400">BLEND DETAILS <img src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/green-plus.svg?v=1722600268"  width="15" height="15" alt="icon"></label> 
                    
                  </div>
                  <div class="tab-blend-popup-wrapper">
                    <label for="{{ block.id }}" class="tab-popup-overlay close-tab-blend-popup"></label>
                    <div class="tab-blend-popup">
                      <label class="tab-close-blend-popup close-tab-blend-popup d-block text-right px-2 pt-2" for="{{ block.id }}">
                        <img src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/close.png?v=1736092528" width="32" height="32" alt="close">
                      </label>
                      <div class="overflow-auto">
                      <div class="tab-block-content">
                        <h3 class="font-lausanne fw-400 heading-3">{{ block.settings.heading }}</h3>
                        <p class="fw-200 font-lausanne">{{ block.settings.content }}</p>
                      </div>
                      <div class="tab-image">
                        <img src="{{ block.settings.mobile_image | image_url }}" class="w-100 h-auto" width="300" height="250" alt="image">
                      </div>
                      <div class="tab-blend-details">
                        <h3 class="font-lausanne fw-400">Blend Details</h3>
                        <div>{{ block.settings.blend }}</div>
                      </div>
                      </div>
                    </div>
                  </div>
                </div>
              
              </div>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>
<script>
document.querySelectorAll('.pf-tab').forEach(tab => {
    tab.addEventListener('click', function() {
        // Remove active class from all .pf-tab elements
        document.querySelectorAll('.pf-tab').forEach(tab => tab.classList.remove('active'));

        // Add active class to the clicked .pf-tab
        this.classList.add('active');

        // Remove active class from all target elements
        document.querySelectorAll('.pf-tab-content').forEach(el => el.classList.remove('active'));

        // Get the data-target value and use it as an ID
        const targetId = this.getAttribute('data-target');
        if (targetId) {
            const targetElement = document.getElementById(targetId);
            if (targetElement) {
                // Add active class to the target element
                targetElement.classList.add('active');
            }
        }
    });
});
// Add 'overflow-hidden' class to the body on click of '.open-tab-blend-popup'
document.querySelectorAll('.open-tab-blend-popup').forEach(button => {
    button.addEventListener('click', function() {
        document.body.classList.add('overflow-hidden');
    });
});

// Remove 'overflow-hidden' class from the body on click of '.close-tab-blend-popup'
document.querySelectorAll('.close-tab-blend-popup').forEach(button => {
    button.addEventListener('click', function() {
        document.body.classList.remove('overflow-hidden');
    });
});


// Add a click event listener to the specified elements
document.querySelectorAll('.gp-5-variant-li input.gp-219').forEach(inputElement => {
    inputElement.addEventListener('click', function() {
        // Get the value of "data-event-label" from the clicked element
        const dataEventLabel = this.getAttribute('data-event-label');

        if (dataEventLabel) {
            // Convert the value to lowercase
            const lowerCaseLabel = dataEventLabel.toLowerCase();

            // Find the corresponding ".pf-tab" element with a matching "data-label"
            const matchingTab = document.querySelector(`.pf-tab[data-label="${lowerCaseLabel}"]`);

            if (matchingTab) {
                // Trigger a click event on the matching ".pf-tab" element
                matchingTab.click();
            }
        }
    });
});

</script>


