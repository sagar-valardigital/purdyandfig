{% if section.settings.link-section%}
<script>
document.addEventListener("DOMContentLoaded", function () {
  var sourceElement = document.querySelector(".link-to-section");
  if (sourceElement) {
    var sourceId = sourceElement.id;
    var targetElements = document.querySelectorAll(".set-buybox-id");
    targetElements.forEach(function (el) {
      el.id = sourceId;
    });
  }
});
</script>
{% endif %}
{% assign product = section.settings.landingproduct %}
{% assign s_variant = product.selected_or_first_available_variant %}
<style>
  .new-product-gallery-wrapper .main-product-img:not(.slick-slide) img{
    display:none;
  }
  .new-product-gallery-wrapper .main-product-img:first-child img{
    display:block;
  }
  .new-product-gallery-wrapper-thumb .main-product-img:not(.slick-slide) img{
    display:none;
  }
  .product-block-4-wrapper{
    align-items:center;
  }
  .global-product-19-wrapper.py-80{
    padding-top:32px;
  }
  .variant-badge {
      position: absolute;
      right: 8.5px;
      top: -10px;
      border-radius: 4px;
      background: #708480;
      color: #fff;
      font-size: 12px;
      padding: 2px 6px;
  }
    .guarantee-text {
     font-size: 15.5px;
  }
  .choose-scent {
    font-size: 16px !important;
  }
  .new-product-gallery-wrapper-thumb{
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    max-width: 288px;
    width:80%;
  }
  .new-product-gallery-wrapper-thumb .main-product-img{
    padding:5px;
  }
  .new-product-gallery-wrapper-thumb .main-product-img img{
    border-radius:4px;
    border:2px solid transparent;
  }
  .new-product-gallery-wrapper-thumb .main-product-img.slick-current img{
    border:2px solid #0F2D28;
  }
  .global-product-5.gp-5-ab .gp-5-price-points .gp-5-points li{
    background-image: url('https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Tick_0b247544-b277-4cf3-a15a-4f8678af62ac.png?v=1747833665');
  }
  .gp-5-price-points{
    box-shadow:none;
    background-color:transparent;
  }
  .gp-5-bottom{
      padding-top:15px !important;
    }
  @media (max-width: 768px) {
    .global-product-19-wrapper.py-80{
    padding-top:0px;
  }
     .choose-scent {
      font-size: 14px !important;
      font-weight: 200;
    }

    /* new css starts */
    .global-product-5.py-80 {
      padding-bottom: 20px;
    }
    .gp-5-bottom {
      padding-bottom: 0px !important;
    }

    .link-to-variant {
      font-family: "Lausanne";
    }
    li.gp-5-variant-li.value-sans {
      font-family: "Lausanne";
    }
    .gp-5-bottom{
      padding-top:0 !important;
    }
    /* new css ends */
  }
</style>
