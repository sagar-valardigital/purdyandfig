                  {{- settings.gloabalreviews }} verified 5-star reviews</span
                >
              </div>
            </div>
            <h2 class="heading-3 blue-text-3 value-bold mb-0 mt-0">
              {{ section.settings.heading }}
            </h2>
            {% if section.settings.mainsubheading != '' -%}
              <p class="font-lausanne fw-400 mt-2 mb-0 gp-5-subheading" style="font-weight:400;">{{ section.settings.mainsubheading }}</p>
            {%- endif %}
            
          </div>
          <form
            name="shopify-product-form"
            autocomplete="off"
            @submit.prevent="console.log('submitted')"
            x-ref="product_form_{{ section.index}}"
            enctype="multipart/form-data"
            accept-charset="UTF-8"
            id="product_form_{{ section.index}}"
            class="shopify-product-form"
            data-product-id="{{product.id}}"
            action="/cart/add"
          >
            <div class="gp-5-bottom">
              {% if section.settings.choosescent != '' -%}
                <p class="font-lausanne mt-2 mb-2 gp-5-subheading choose-scent">{{ section.settings.choosescent }}</p>
              {% endif %}
              <ul class="list-unstyle   var_{{ product.variants | size  }}  gp-5-variants ">
                {% assign checked = true %}
                {% for block in section.blocks %}
                  {% if block.type == 'variant' %}
                    {% assign product_v = block.settings.variantProduct %}
                    {% assign s_variant_v = product_v.selected_or_first_available_variant %}
                    {% assign sub_discount_price = s_variant_v.selling_plan_allocations[0].price_adjustments[0].price %}
                    {% assign sub_discount_percentage = product_v.price
                      | minus: sub_discount_price
                      | times: 100
                      | divided_by: product.price
                    %}

                    <li
                      data-title="{{block.settings.text_heading | downcase }}"
                      class="gp-5-variant-li font-lausanne {% if block.settings.outofstock %}disabled var-out-of-stock{% endif %}"
                      {{ product_v | json }}
                    >
                      {% if block.settings.variantBadge != blank %}
                        <span class="variant-badge">{{ block.settings.variantBadge }}</span>
                      {% endif %}
                      <input
                        autocomplete="off"
                        class="{{ section.settings.className }}"
                        data-planid="{{block.settings.sellingid}}"
                        data-name="{{block.settings.text_heading}}"
                        data-include="{{variant.metafields.metadata.includes}}"
                        value="{{block.settings.varaiantid }}"
                        data-subprice="{{ block.settings.sellPrice | money }}"
                        data-price="{{block.settings.delPrice |  money}}"
                        data-image="{{ block.settings.varImage | img_url : '100x'}}"
                        data-variantid="{{block.settings.varaiantid}}"
                        data-productid="{{product_v.id}}"
                        data-variantclass="variant_{{ block.settings.varCount }}"
                        data-discount="{{ block.settings.discount }}"
                        data-refillprice1="{{ section.settings.refillPrice }}"
                        data-refillprice2="{{ block.settings.refillPrice2 }}"
                        type="radio"
                        name="id_{{ section.id }}"
                        {% if block.settings.sellingid != blank %}
                          data-plantype="subscription"
                        {% else %}
                          data-plantype="oneoff"
                        {% endif %}
                        {% if block.settings.dataTrack %}
                          data-tracked="true"
                          data-page-url="{{ request.path }}"
                          data-target-url="{{ block.settings.targetUrl }}"
                          data-index="{{ block.settings.index }}"
                          data-funnel-stage="{{ block.settings.funnel_stage }}"
                          data-module="{{ block.settings.dataModule }}"
                          data-event-label="{{ block.settings.dataTitle }}"
                          data-event-value="{{ block.settings.eventValue }}"
                          data-item-id="{{ block.settings.sku }}"
                          data-option-index="{{ block.settings.optionIndex }}"
                          data-item-name="{{ product_v.title }}"
                          {% if block.settings.sellingid != blank %}
                            data-item-type="subscription"
                          {% else %}
                            data-item-type="PAYG"
                          {% endif %}
                        {% endif %}
                        data-section="id_{{ section.id }}"
                        id="id_{{ section.id }}_{{block.settings.text_heading | escape }}"
                        {% if product_v.available and checked %}
                          checked {% assign checked = false -%}
                        {% else %}

                        {% endif %}
                      >

                      <label
                        style="background-image:url({{block.settings.varImage | img_url : '100x'}})"
                        {% if product_v.available %}
                          class="font-lausanne var_bg_{{ block.settings.text_heading | handle }}"
                        {% else %}
                          class="disabled  font-lausanne var_bg_{{ block.settings.text_heading | handle }}"
                        {% endif %}
                        for="id_{{ section.id }}_{{block.settings.text_heading | escape}}"
                        data-include="{{variant.metafields.metadata.includes}}"
                        data-value="{{block.settings.text_heading}}"
                      >
                        {{- block.settings.text_heading -}}
                      </label>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>

              <div class="black-text mt-2 gp-5-price-points mb-3">
                <div class="d-flex justify-content-between font-lausanne gp-5-var">
                  <div class="gp-5-price">
                    <del style="color:#707279; font-size:16px;" class="gp-5-del-price">
                      {{ localization.country.currency.symbol }}
                      {{- section.settings.delPrice -}}</del
                    >&nbsp;<span style="color:#A94442; font-size:16px;" class="value-medium gp-5-sell-price">
                      {{ localization.country.currency.symbol }}
                      {{- section.settings.price -}}
                    </span>
                  </div>
                  <div style="color:#434448;">Subscribe & Save 50%</div>
                </div>
                {% if section.settings.tab_description_1 != blank %}
                <div
                  style="color:#11322C; font-weight:600; font-size: clamp(14px, 3vw, 16px); padding:0 0 16px 0;"
                  class="font-lausanne gp-5-var gp-5-var-ab link-to-variant variant_1 show"
                >
                  {{ section.settings.tab_description_1 }}
                </div>
                {% endif %}
                {% if section.settings.tab_description_2 %}
                <div
                  style="color:#11322C; font-weight:600; font-size: clamp(14px, 3vw, 16px);  padding:0 0 16px 0;"
                  class="font-lausanne gp-5-var gp-5-var-ab link-to-variant variant_2 "
                >
                  {{ section.settings.tab_description_2 }}
                </div>
                {% endif %}
                <ul class="gp-5-points text-left">
                  {% for block in section.blocks %}
                    {% if block.type == 'text' %}
                      <li class="font-lausanne gray-text fw-200 link-to-variant variant_{{ block.settings.listClass }} " style="font-weight:200 !important;;">
                        {{ block.settings.listItem }}
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>

              <input
                autocomplete="off"
                type="hidden"
                name="id"
                class="input_variant_id"
                value="{{ section.settings.varaiantid }}"
              >
              <input
                autocomplete="off"
                type="hidden"
                class="discout_input"
                name="discount"
                value="{{ section.settings.discount }}"
              >
              {% assign discount_titles = '' %}

              {% for item in cart.items %}
                {% for discount in item.discounts %}
                  {% if discount_titles != '' %}
                    {% assign discount_titles = discount_titles | append: ',' %}
                  {% endif %}
                  {% assign discount_titles = discount_titles | append: discount.title %}
                {% endfor %}
              {% endfor %}

              <input autocomplete="off" type="hidden" name="already_discount" value="{{ discount_titles }}">
              <input autocomplete="off" type="hidden" name="quantity" value="1">
              {% if section.settings.isSub %}
                <input
                  autocomplete="off"
                  type="checkbox"
                  name="purchase_type"
                  value="subscription"
                  checked
                  class="d-none"
                >
                <input
                  autocomplete="off"
                  class="input_selling_plan"
                  type="hidden"
                  name="selling_plan"
                  value="{{section.settings.sellingid}}"
                >
              {% endif %}

              <div class="text-left  g4-btn-wrapper m-auto">
                {% if section.settings.redirectLink %}
                  <a
                    class="btn w-100 blue-btn value-sans btn-loader checkout-starterkit-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                    href="{{ section.settings.redirectLink }}"
                  >
                    {% if section.settings.outOfStock %}
                      Out of Stock
                    {% else %}
                      {{ section.settings.btnText }}
                    {% endif -%}
                  </a>
                {% else %}
                  {% if section.settings.isCheckout %}
                    <span
                      x-on:click="Purdy.CheckoutLandingV2($refs.product_form_{{ section.index}}, event)"
                      class="btn w-100 blue-btn value-medium btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                      style="background-color:{{ section.settings.btn_bg }} !important";

                      data-add-to-cart="true"
                      data-page-url="{{ request.path }}"
                      data-target-url="{{ section.settings.targetUrl }}"
                      data-index="{{ section.settings.index }}"
                      data-funnel-stage="{{ section.settings.funnel_stage }}"
                      data-module="{{ section.settings.dataModule }}"
                      data-event-label="{{ section.settings.dataTitle }}"
                      data-event-value="{{ section.settings.eventValue }}"
                      data-item-id="{{ section.settings.sku }}"
                      data-option-index="{{ section.settings.optionIndex }}"
                      data-item-name="{{ product.title }}"
                      data-quantity="{{ section.settings.quantity }}"
                      data-price="{{ localization.country.currency.symbol }}{{ section.settings.price }}"
                      data-checkout="true"
                      {% if section.settings.sellingid != blank %}
                        data-item-type="subscription"
                      {% else %}
                        data-item-type="PAYG"
                      {% endif %}
                    >
                      {% if section.settings.outOfStock %}
                        Out of Stock
                      {% else %}
                        <span class="buy-text">{{ section.settings.btnText }}</span> |
                        <span class="deleted-price value-sans white-text gp-5-del-price">
                          {{ localization.country.currency.symbol }}{{- section.settings.delPrice -}}
                        </span>
                        <span class="value-medium white-text gp-5-sell-price">
                          {{- localization.country.currency.symbol -}}{{- section.settings.price }}
                        </span>
                      {% endif -%}
                    </span>
                  {% else %}
                    <span
                      class="btn w-100 theme-btn value-sans btn-loader checkout-starterkit-btn ga4-checkout-btn {% if section.settings.outOfStock %} bb-disable {% endif %}"
                      x-on:click="Purdy.AddToCart($refs.product_form, true, false, $event)"
                      {% if section.settings.dataTrack %}
                        data-add-to-cart="true"
                        data-page-url="{{ request.path }}"
                        data-target-url="{{ section.settings.targetUrl }}"
                        data-index="{{ section.index }}"
                        data-funnel-stage="{{ section.settings.funnel_stage }}"
                        data-module="{{ section.settings.dataModule }}"
                        data-event-label="{{ section.settings.dataTitle }}"
                        data-event-value="{{ section.settings.eventValue }}"
                        data-item-id="{{ section.settings.sku }}"
                        data-option-index="{{ section.settings.optionIndex }}"
                        data-item-name="{{ product.title }}"
                        data-quantity="{{ section.settings.quantity }}"
                        data-price="{{ localization.country.currency.symbol }}{{ section.settings.price }}"
                        {% if section.settings.sellingid != blank %}
                          data-item-type="subscription"
                        {% else %}
                          data-item-type="PAYG"
                        {% endif %}
                      {% endif %}
                    >
                      {% if section.settings.outOfStock %}
                        Out of Stock
                      {% else %}
                        {{ section.settings.btnText }}
                      {% endif -%}
                    </span>
                  {% endif %}
                {% endif -%}
                {% if section.settings.guaranteeText %}
                  <div
                    class="text-center fw-600 font-lausanne theme-text mt-2 guarantee-text"
                    style="font-size:12px; color: {{ section.settings.guaranteeTextColor }}"
                  >
                    {{ section.settings.guaranteeDescription }}
                  </div>
                {% endif %}
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
    function removeAutocomplete() {
    const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;

    if (isSafari || isIOS) {
      const form = document.getElementById('product_form_{{ section.index}}');

      if (form) {
        form.removeAttribute('autocomplete');

        const formElements = form.elements;

        for (let i = 0; i < formElements.length; i++) {
          formElements[i].removeAttribute('autocomplete');
        }
      }
    }
  }

  document.addEventListener('DOMContentLoaded', removeAutocomplete);

  document.querySelectorAll('.gp-5-variant-li input').forEach(function(input) {
    input.addEventListener('change', function() {
      var sectionId = this.getAttribute('data-section');
      var itemType = this.getAttribute('data-item-type');
      var button = document.querySelector('#' + sectionId + ' .ga4-checkout-btn');
      if (button) {
        button.setAttribute('data-item-type', itemType);
      }
    });
  });
</script>

