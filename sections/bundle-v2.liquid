<div class="bundle-v2-wrapper" style="background-color:#e3f3fe;">
  <div class="container bundle-section bundle-v2"  x-init="{bundleItems:JSON.parse(localStorage.getItem('bundleItems')) || []},updateBundleItems();"
   x-data="{
    bundleItems: JSON.parse(localStorage.getItem('bundleItems')) || [],
    updateBundleItems() {
      if(this.calculateTotalQuantity() > this.totalCount) {
         this.bundleItems = []
         this.saveToLocalStorage();
      }
      const currentTime = new Date().getTime();
      this.bundleItems.forEach(item => {
                console.log(item.timestamp);
      });
      const updatedItems = this.bundleItems.filter(item => (currentTime - item.timestamp) < (60 * 60 * 1000));
      this.bundleItems = updatedItems;
      this.saveToLocalStorage();
    },
    totalCount:{{ section.settings.pack_size }},
    isAddingToCart: false,
    boxData: null,
    boxIndex: 0,
    oneTimeItems: null,
    skioBABProductMapping: {
      // Linden & Lavendar
      43824862232803: 43989883125987,
    
      // Citronella & Niaouli Fly Away
      43824862134499: 43989883617507,
    
      // Geranium & Ylang Ylang
      43824861610211: 43989884076259,
    
      // Balancing Floral
      43824861446371: 43989885550819,
    
      // Grounding Vetiver
      43824861315299: 43989885845731,
    
      // Uplifting Citrus
      43824860659939: 43989886107875,
  
      // Patchouli & Cedarwood
      43960619598051: 43989897478371,
  
      // Juniper & Cardamom
      43982357463267: 44009976463587,
      
      // Lavender & Chamomile
      43982358741219: 44009976856803
    },
    addToBundle(productId, productTitle, quantity, price, image, compareprice, sku) {
          const newItem = {'id': productId, 'productTitle': productTitle, 'quantity': quantity, 'price':price, 'image':image, 'compareprice':compareprice, 'sku':sku,'timestamp':new Date().getTime()};
          const existingItem = this.bundleItems.find(item => item.id === productId);
       const totalQuantity = this.calculateTotalQuantity();
          if (existingItem) {
              if (totalQuantity+1 <= this.totalCount) {
                  existingItem.quantity += quantity;
                  this.saveToLocalStorage();
              } else {
              }
          } else {
              if (totalQuantity+1 <= this.totalCount) {
                  this.bundleItems.unshift(newItem);
                  this.saveToLocalStorage();
              } else {
              }
          }
      },
    getBundleBreakdown(){
      let breakdown = []
      this.bundleItems.forEach(item => {
                breakdown.unshift(item.quantity+'x'+item.sku);
      });
      return breakdown.join('+');
        
    },
      formatCurrency(amountPence) {
          const amountInCurrency = (amountPence / 100).toFixed(2); // Convert pence to currency
          return '£'+amountInCurrency;
      },
   removeFromBundle(index) {
              if (index >= 0 && index < this.bundleItems.length) {
                  const item = this.bundleItems[index];
                  if (item.quantity > 1) {
                      item.quantity -= 1;
                  } else {
                      this.bundleItems.splice(index, 1);
                  }
                  this.saveToLocalStorage();
              }
          },
    getItemQuantity(productId) {
              const item = this.bundleItems.find(item => item.id === productId);
              return item ? item.quantity : 0;
      },
    calculateTotalQuantity() {
              let totalQuantity = 0;
              this.bundleItems.forEach(item => {
                  totalQuantity += item.quantity;
              });
              return totalQuantity;
    },
  increaseQuantity(productId) {
              const index = this.bundleItems.findIndex(item => item.id === productId);
              if (index >= 0) {
                  const item = this.bundleItems[index];
                  const totalQuantity = this.calculateTotalQuantity();
                  if (totalQuantity + 1 <= this.totalCount) {
                      item.quantity += 1;
                  } else {
                      alert('The maximum total quantity for all items in the bundle is '+this.totalCount);
                  }
                  this.saveToLocalStorage();
              }
          },
  decreaseQuantity(productId) {
              const index = this.bundleItems.findIndex(item => item.id === productId);
              if (index >= 0) {
                  const item = this.bundleItems[index];
                  if (item.quantity > 1) {
                      item.quantity -= 1;
                  } else {
                      this.bundleItems.splice(index, 1);
                  }
                  this.saveToLocalStorage();
              }
   },
    saveToLocalStorage() {
          localStorage.setItem('bundleItems', JSON.stringify(this.bundleItems));
    },
    bundleToAddCount() {
      return this.totalCount - this.calculateTotalQuantity();
    },
    isItemAdded(productId) {
              return this.bundleItems.some(item => item.id === productId);
      },
    isbundleCompleted() {
      return this.calculateTotalQuantity() >= this.totalCount;
    },
   formatString(str) {
    // Replace hyphens with spaces
    var formattedStr = str.replace(/-/g, ' ');
  
   // Capitalize the first letter of each word
    formattedStr = formattedStr.replace(/\b\w/g, function(match) {
      return match.toUpperCase();
    });
  
    return formattedStr;
    },
    getScentsBreakdown() {
        let breakdown = []
      this.bundleItems.forEach(item => {
                breakdown.unshift(item.quantity+'x '+this.formatString(item.productTitle));
      });
      return breakdown.join(' + ');
    },
   async addBundleToCart(redirect=true) {
     var checkoutButtons = document.getElementsByClassName('checkout-button');
    for (var i = 0; i < checkoutButtons.length; i++) {
     console.log('removing loaders..');
      checkoutButtons[i].classList.add('loading');
    }
    this.isAddingToCart = true;
   var bundleItems = this.bundleItems;
   var lineItems = [];
  
    const bundleLineItems = await this.getBundleLineItems();
    const bundleOneTimeItems = await this.getOneTimeLineItems();
  
    lineItems.push(...bundleLineItems);
    lineItems.push(...bundleOneTimeItems);
  
    // TODO: Create a second BAB or add an additional size option to this page
    // if (this.calculateTotalQuantity() < 6) {
    //   lineItems.push({
    //     quantity: 1,
    //     id: 43836262056163,
    //     selling_plan: 3313041635,
    //     properties: { '_is_bundle': 'Yes', '_breakdown': this.getBundleBreakdown(), 'scents': this.getScentsBreakdown() }
    //   });
    // } else {
    //   lineItems.push({
    //     quantity: 1,
    //     id: 43920216621283,
    //     selling_plan: 3401253091,
    //     properties: { '_is_bundle': 'Yes', '_breakdown': this.getBundleBreakdown(), 'scents': this.getScentsBreakdown() }
    //   });
    // }
  
   fetch('/cart/add.js', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ items: lineItems })
    })
    .then((response) => {
      if (response.ok) {
     var checkoutButtons = document.getElementsByClassName('checkout-button');
    for (var i = 0; i < checkoutButtons.length; i++) {
     console.log('removing loaders..');
      checkoutButtons[i].classList.remove('loading');
    }
        console.log('Bundle added to cart');
        this.isAddingToCart = false;
        if(redirect) {
          window.location.href = '/checkout/';
        }
        else {
        window.dispatchEvent(new Event('toggle-cart', {'detail':response}));
        window.dispatchEvent(new Event('cart-updated', {'detail':response}));
        }
      } else {
        console.error('Failed to add bundle to cart:', response);
      }
      
      this.boxIndex++;
    })
    .catch(function(error) {
      console.error('Error adding bundle to cart:', error);
    });
  },
  async init() {
    Promise.all([this.getBox(), this.getBoxesInCart()])
    .then((responses) => {
      this.loading = false
    })
  },
  async getBox() {
    return new Promise((resolve, reject) => {
        fetch('https://api.skio.com/storefront-http/get-dynamic-box', {
          method: 'POST',
          body: JSON.stringify({
            'productPlatformId': '{{ boxProduct.id }}',
          })
        })
        .then((response) => response.json())
        .then((response) => {
          if(!response.ok) throw new Error('Failed to get box');
          const { DynamicBox } = response;
          this.boxData = DynamicBox;
          resolve();
        })
        .catch((error) => {
          console.error(error);
          reject(error);
        })
      });
    },
    getBoxSwap(products) {
      return products.reduce((obj, item) => {
        let newKey = this.skioBABProductMapping[item.id];
        if(!newKey) return obj;
        return Object.assign(obj, { [newKey]: item.quantity })
      }, {});
    },
    async getOneTimeLineItems() {
      if(!this.boxData.oneTimeUpsells?.length) return [];
  
      return this.boxData.oneTimeUpsells.map(item => {
        return {
          quantity: 1,
          id: item.productVariants[0].platformId.replace('gid://shopify/ProductVariant/', ''),
          properties: {
            _dynamicBoxIndex: this.boxIndex,
            'Build a Bundle': this.boxData.settings.header
          }
        };
      });
    },
    async getBundleLineItems() {
      return this.bundleItems.map((item, index) => {
        return {
          quantity: item.quantity,
          id: item.id,
          selling_plan: Number(Object.keys(this.boxData.sellingPlanGroup)[0].replace('gid://shopify/SellingPlan/', '')),
          properties: {
            _dynamicBoxIndex: this.boxIndex,
            _dynamicBoxId: this.boxData.boxId,
            'Build a Bundle': this.boxData.settings.header,
            ...(index == 0 && {
              _dynamicBoxSwapMapping: JSON.stringify(this.getBoxSwap(this.bundleItems))
            })
          }
        };
      });
    },
    async getBoxesInCart() {
      return new Promise((resolve, reject) => {
        fetch('/cart.js')
        .then((response) => response.json())
        .then((response) => {
          const indexes = response.items.map(item => item.properties._dynamicBoxIndex).sort();
          const newIndex = Math.max(...indexes) + 1;
          if(newIndex > this.boxIndex) {
            this.boxIndex = newIndex;
          }
          resolve();
        })
        .catch((error) => {
          reject(error)
        })
      });
    }
  }">
