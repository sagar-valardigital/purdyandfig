<style>
  .btn-christmas-btn{font-size:14px !important}
</style>
<div class="product-blocks-section py-80" x-data="{qty:1}" style="background-color:{{ section.settings.bg }}">
  <div class="container">
    <div class="section-header text-center">
      {% if section.settings.heading != blank %}
        <h2 class="heading-2 font-gtsuper">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="font-lausanne fw-300">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="reskin-product-blocks-wrapper rpb-slider-black-friday ">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        <div class="reskin-product-block">
          <div class="rpb-image position-relative">
            {% if block.settings.product_image %}
              <img
                src="{{ block.settings.product_image | img_url : 'master' }}"
                width="300"
                height="300"
                class="img-responsive h-auto"
              >
            {% else %}
              <img
                src="{{ product.featured_image | img_url : 'master' }}"
                width="300"
                height="300"
                class="img-responsive h-auto"
              >
            {% endif %}
            {% if block.settings.saving != blank %}
              <span class="saving-tag font-lausanne fw-400">{{ block.settings.saving }}</span>
            {%- endif %}
          </div>
          <div class="rpb-product-details">
            <h3 class="heading-3 font-lausanne fw-400" data-handle="{{ product.title | handle }}">
              {% if block.settings.title != blank %}
                {{ block.settings.title }}
              {% else %}
                {{ product.title }}
              {% endif %}
            </h3>
           {% if section.settings.reviews %}
            {% render 'okendo-reviews-product-rating-summary', product: product %}
            {% endif %}
            <div class="rpb-pricing">
              <span>{{ localization.country.currency.symbol }}{{ block.settings.price }}</span>
              <del>{{ localization.country.currency.symbol }}{{ block.settings.crossprice }}</del>
            </div>
            <div>
              <form
                name="shopify-product-form"
                autocomplete="off"
                @submit.prevent="console.log('submitted')"
                x-ref="product_form_{{ forloop.index}}"
                enctype="multipart/form-data"
                accept-charset="UTF-8"
                id="product_form_{{ forloop.index}}"
                class="shopify-product-form form_s1 link-to-variant variant_1 show"
                data-product-id="{{product.id}}"
                action="/cart/add"
              >
                <input
                  autocomplete="off"
                  type="hidden"
                  name="id"
                  class="input_variant_id_"
                  value="{{ block.settings.variant_id }}"
                >

                <input autocomplete="off" type="hidden" name="quantity" value="1">
                {% if block.settings.isSub %}
                  <input
                    autocomplete="off"
                    type="checkbox"
                    name="purchase_type"
                    value="subscription"
                    checked
                    class="d-none gp--buyoption-input"
                  >
                {% endif %}
                <input
                  autocomplete="off"
                  class="input_selling_plan_"
                  type="hidden"
                  name="selling_plan"
                  value="{{ block.settings.sealing_plan}}"
                >
                <input
                  autocomplete="off"
                  type="hidden"
                  class=""
                  name="discount"
                  value="{{ block.settings.discount }}"
                >
                <button
                        data-add-to-cart="true" data-page-url="{{ request.path }}"
                        data-target-url="{{ section.settings.targetUrl }}"
                        data-index="4"
                        data-funnel-stage="landing_page"
                        data-module="{{ section.settings.module }}"
                        data-event-label="add_to_cart"
                        data-event-value="add_to_cart"
                        data-item-id="{{ block.settings.sku }}"
                        data-item-name="{{ block.settings.title }}" data-quantity="1"
                        data-price="{{ localization.country.currency.symbol }}{{ block.settings.price }}"
                        data-item-type="{% if block.settings.sealing_plan != blank %}subscription{% else %}PAYG{% endif %}"
{% if section.settings.toast %}
                  x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_{{ forloop.index}}, false, false, $event)"
{% else %}
                  x-on:click="Purdy.AddToCartWithDiscount($refs.product_form_{{ forloop.index}}, true, false, $event)"
{% endif %}
                  class="btn btn-christmas-btn btn-loader green-btn"
                >
                  {{ block.settings.buttonLabel }}
                </button>
              </form>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
 {
   "name": "Product Blocks",
   "settings": [
     {
           "type": "checkbox",
           "id": "reviews",
           "label": "Show Reviews",
           "default": true
         },  
{
            "type": "checkbox",
            "id": "toast",
            "label": "Enable Toast",
            "default": false
        }, 
     {
           "type": "color",
           "id": "bg",
           "label": "Section Background Color"
         },
        {
           "type": "text",
           "id": "heading",
           "label": "Section Heading"
         },
        {
           "type": "text",
           "id": "subheading",
           "label": "Section Sub Heading"
         },
      {
           "type": "header",
           "content": "GA4"
         },
     {
           "type": "text",
           "id": "module",
           "label": "Section Module"
         },
   ],
   "blocks": [
     {
       "type": "product",
       "name": "Product",
       "settings": [
         {
           "type": "product",
           "id": "product",
           "label": "Choose Product"
         },
         {
           "type": "text",
           "id": "variant_id",
           "label": "Variant ID"
         },
         {
           "type": "text",
           "id": "sku",
           "label": "SKU"
         },
         {
           "type": "text",
           "id": "sealing_plan",
           "label": "Sealing Plan"
         },
         {
           "type": "text",
           "id": "discount",
           "label": "Discount Code"
         },
         {
           "type": "image_picker",
           "id": "product_image",
           "label": "Choose Product Image"
         },
         {
           "type": "checkbox",
           "id": "isSub",
           "label": "Product subscription enable"
         },
         {
           "type": "text",
           "id": "title",
           "label": "Product Title"
         },
         {
           "type": "text",
           "id": "saving",
           "label": "Product Saving %",
           "default": "Saving 20%"
         },
         {
           "type": "text",
           "id": "price",
           "label": "Product Price"
         },
         {
           "type": "text",
           "id": "crossprice",
           "label": "Product Cross Price"
         },
         {
           "type": "text",
           "id": "buttonLabel",
           "label": "Button Label",
           "default" : "ADD TO CART"
         }
       ]
     }
],
   "presets": [
   	{
   		"name": "Product Blocks"
   	}
   ]
 }
{% endschema %}
