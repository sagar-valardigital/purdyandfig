<div
  style="background-color:{{section.settings.background}};"
  class="{{ section.settings.className }} py-80 two-women-wrapper-2 two-women-wrapper-3"
>
  <div class="container">
    <div class="">
      <div class="text-center m-text-left">
        <h2 class="heading-2 blue-text value-bold mt-0 mb-3">
          {{ section.settings.main_heading }}
        </h2>
        {% if section.settings.sub_heading != blank %}
        <p class="value-sans gray-text mb-4 sub-heading">{{ section.settings.sub_heading }}</p>
          {% endif %}
      </div>
      <div class="d-flex justify-content-between two-women-info-wrapper">
        <div class="w-100 {% if section.settings.layout %} order-2 {%endif%}">
          <div class="two-women position-relative">
            {% if section.settings.image %}
              <img src="{{ section.settings.image | img_url: 'master' }}" class="w-100 h-100 mobile-hide" width="320" height="240" />
              <img src="{{ section.settings.image_mobile | img_url: 'master' }}" class="w-100 h-100 desktop-hide" width="343" height="215" />
            {% else %}
              <video
                id="video_{{ section.id }}"
                class=" w-100 h-100"
                width="320"
                height="180"
                playsinline
                loop
                muted
                poster="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/two_women_720p.jpg?v=1754546797"
              >
                <source src="https://cdn.shopify.com/videos/c/o/v/04ae416a893b4ec1bdbcb8c046fb60eb.mp4" type="video/mp4">
              </video>
              <div class="video-pp-icon">
                <img
                  src="{{ 'play-button.png' | asset_img_url }}"
                  data-target="video_{{ section.id }}"
                  class="intro-video-play"
                  alt="video"
                  width="50"
                  height="50"
                >
              </div>
            {% endif %}
          </div>
        </div>
        <div class="w-100 d-flex justify-content-center {% if section.settings.layout %} order-1 {%endif%} ">
          <div class="two-women-details h-100 w-100">
            <div class="">
              <h2 class="heading-2 m-text-left {{section.settings.textcolor}} {% if section.settings.heading-position%} {% else %}mobile-hide{% endif %}">
                {{ section.settings.heading }}
              </h2>
              <div class="normal-text {{section.settings.textcolor}} m-text-left two-women-details-container">
                {{ section.settings.details }}
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="manufactured">
        <div class="manufactured-inner">
          <h2 class="heading-2 blue-text value-bold mt-0 text-center d-flex align-items-center justify-content-center">
            <span> Manufactured in the UK &nbsp;</span>
            <img
              width="40"
              height="40"
              alt="gb"
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/GB.png?v=1699590423"
            >
          </h2>
          <p class="value-sans gray-text mt-4 m-text-left">
            <span class="value-medium"
              >{{ section.settings.man_details_1 }}</span
            >
            <br>
            <br>
            <span style="color:#434448 !important"
              >{{ section.settings.man_details_2 }}</span
            >
          </p>
        </div>
         {% if section.settings.addScrollBtn %}
    <div class="mt-4 desktop-hide">
      <span
        class="d-block text-center blue-starterkit-btn click-scroll m-auto"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >{{ section.settings.btnLabel }}</span
      >
    </div>
    {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
  .two-women-wrapper-3 .sub-heading {
    color: #434448;
    font-size: 18px;
    line-height: 28px;
    max-width: 800px;
    margin: auto;
    margin-bottom: 40px !important;
  }

  .two-women-wrapper-3 .two-women-details-container {
    line-height: 28px;
    flex-wrap: nowrap;
  }

  .two-women-wrapper-3 .two-women-info-wrapper {
    gap: 32px;
  }

  .two-women-wrapper-3 .manufactured {
    margin-top: 40px;
  }

  .two-women-wrapper-2 .two-women-details {
    padding: 32px;
  }
  
  @media (max-width: 768px) {
    .two-women-wrapper-3 {
      padding: 32px 0;
    }

    .two-women-wrapper-3 .sub-heading {
      font-size: 16px !important;
      line-height: 24px;
      margin-bottom: 16px !important;
    }

    .two-women-wrapper-3 .two-women-info-wrapper {
      gap: 8px;
      flex-wrap: wrap;
    }

    .two-women-wrapper-3 .two-women-details {
      margin-top: 0 !important;
      background: #fff;
      box-shadow: none;
      padding: 0 !important;
      font-size: 16px;
    }

    .two-women-wrapper-3 .two-women-details-container p {
      margin-bottom: 4px;
    }

    .two-women-wrapper-3 .two-women-details p {
      line-height: 24px !important;
    }

    .two-women-wrapper-3 .manufactured-inner .heading-2 span {
      line-height: 44px;
      letter-spacing: -0.72px;
    }
    .two-women-wrapper-3 .manufactured-inner .heading-2 {
      height: 80px !important;
    }
    .two-women-wrapper-3 .manufactured-inner .heading-2 + p {
        margin-top: 8px !important;
    }

    .two-women-wrapper-3 .manufactured-inner p {
        margin-bottom: 0px !important;
    }
  }
</style>

{% schema %}
  {
    "name": "Two Women 3",
    "settings": [
      {
          "type": "checkbox",
          "id": "addScrollBtn",
          "label": "Show Scroll to Btn",
          "default": false
        },
      {
        "type": "text",
        "id": "className",
        "label": "Add Section class Name"
      },
      {
        "type": "color",
        "id": "background",
        "label": "Select background color"
      },
      {
        "type": "checkbox",
        "id": "layout",
        "label": "Image on right"
      },
      {
        "type": "text",
        "id": "main_heading",
        "label": "Heading"
      },
      {
        "type": "html",
        "id": "sub_heading",
        "label": "Heading Sub text"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Add Image"
      },
      {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "Add Mobile Image"
      },
      {
        "type": "html",
        "id": "details",
        "label": "Detail Text"
      },
      {
        "type": "html",
        "id": "man_details_1",
        "label": "Manufacturing Details 1",
        "default": "We manufacture Purdy & Figg concentrates in the UK, where we are subject to stringent health regulations."
      },
      {
        "type": "html",
        "id": "man_details_2",
        "label": "Manufacturing Details 2",
        "default": "Every Purdy & Figg refill is produced and packaged at our factory in Hertfordshire, where our dedicated team keep our customers’ safety in mind every step of the way"
      },
      {
          "type": "text",
          "id": "btnLabel",
          "label": "Button Label",
          "default": "GET YOUR OFFER"
        },
      {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      }
     ,
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
        {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
    ],
    "presets": [
      {
        "name": "Two Women 3"
      }
    ]
  }
{% endschema %}
