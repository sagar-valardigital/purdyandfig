<style></style>
<div class="table-2 table-reskin" style="background-color:#fff;">
  <div class="container">
    <div class="table-heading text-center">
      <h2 class="heading-2 mt-0  font-gtsuper">{{ section.settings.heading }}</h2>
      <p class="subheading font-lausanne fw-400">{{ section.settings.subheading }}</p>
    </div>

    <div class="table-responsive mt-5 ">
      <table class="table product-details-table w-100 theme-text normal-text ">
        <thead>
          <tr>
            <th class="font-lausanne fw-500 gray-text text-left">Features</th>
            <th class="text-center">
              <img
                width="78px"
                height="32px"
                loading="lazy"
                class="table-logo"
                src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Logo.svg?v=1722248252"
                alt="logo"
              >
            </th>
            <th class="text-center font-lausanne fw-500">Method + Ecover</th>
            <th class="text-right font-lausanne fw-500">Flash + Zoflora</th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            {% assign icon1 = block.settings.pfIcon | img_url: '50x' %}
            {% assign icon2 = block.settings.methodIcon | img_url: '50x' %}
            {% assign icon3 = block.settings.flashIcon | img_url: '50x' %}
            <tr>
              <td class="font-lausanne fw-500 featured-name">{{ block.settings.featureName }}</td>
              <td class="text-center">
                <img width="32px" height="32px" loading="lazy" src="{{icon1}}" alt="{{ block.settings.pfIcon.alt }}">
              </td>
              <td class="text-center">
                <img width="32px" height="32px" loading="lazy" src="{{icon2}}" alt="{{ block.settings.methodIcon.alt }}">
              </td>
              <td class="text-center">
                <img width="32px" height="32px" loading="lazy" src="{{icon3}}" alt="{{ block.settings.flashIcon.alt }}">
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% if section.settings.addScrollBtn %}
    <div class="mt-lg-40">
      <span
        class="d-block text-center blue-starterkit-btn green-btn font-lausanne fw-400 click-scroll m-auto common-btn-width"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >GET YOUR OFFER</span
      >
    </div>
    {% endif %}
  </div>
</div>

{% schema %}
  {
    "name": "PF228 Table Reskin",
    "settings": [
      {
          "type": "checkbox",
          "id": "addScrollBtn",
          "label": "Show Scroll to Btn",
          "default": false
        },
      {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
      {
          "type": "text",
          "id": "subheading",
          "label": "Heading"
        },
      {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      }
     ,
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
    {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
    ],
    "blocks": [
      {
        "type": "text",
        "name": "Table row",
        "settings": [
          {
            "type": "text",
            "id": "featureName",
            "label": "Feature Name"
          },
          {
            "type": "image_picker",
            "id": "pfIcon",
            "label": "P&F Icon"
          },
          {
            "type": "image_picker",
            "id": "methodIcon",
            "label": "Method Icon"
          },
          {
            "type": "image_picker",
            "id": "flashIcon",
            "label": "Flash Icon"
          }

        ]
      }
	],
"presets": [
		{
			"name": "PF228 Table Reskin"
		}
	]
  }
{% endschema %}
