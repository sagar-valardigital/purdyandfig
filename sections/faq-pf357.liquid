<style>

.btn {
  font-size: 18px !important;
}

.blue-starterkit-btn {
    font-size: 18px !important;
}

.pf357-btn {
    font-size: 18px !important;
}

.faq-section-wrapper-2 .faq {
  border-top: 1px solid #9E9E9E;
}
  
.faq-section-wrapper-2 .faq:first-child {
  border-top: 0;
}

.faq-section-2-heading .heading-2 {
  padding-bottom:48px;
}

.faq-acc-2{
  margin:32px 0;
}

.faq-que-2.value-medium {
  font-weight: 400 !important;
}

.heading-2 {
  letter-spacing: 0px;
}
.faq-que-2:after {
  background-image: url(https://cdn.shopify.com/s/files/1/0360/1347/3931/files/green-plus.svg?v=1722600268);
}
.faq-acc[open] .faq-que-2:after {
  background-image: url(https://cdn.shopify.com/s/files/1/0360/1347/3931/files/green-minus.svg?v=1722600268);
}

.pf357-btn {
    width: 343px;
    padding: 12px 16px;
    border-radius: 4px;
    margin-top: 80px !important;
    color: {{ section.settings.btntextcolour }};
    background-color: {{ section.settings.btnBG }};
  }

.pf357-bottom-text {
    font-family: "Lausanne";
    color: #212121;
    font-size: 16px;
    font-weight: 200;
    line-height: 1.6 !important;
    text-align: center;
    max-width: 700px;
    margin: 80px auto 0;
}

.pf357-bottom-text span.line-break {
  display: block !important;
  font-family: "Lausanne" !important;
}


@media(max-width: 768px){
  
.pf357-bottom-text {
  margin: 32px auto 0;
  text-align: left;
  font-size: 16px;
}

.pf357-bottom-text span.line-break {
  display: inline !important;
}

.pf357-btn {
    width: 100%;
    margin-top: 32px !important;
  
}

  
</style>

{% if section.settings.enable %}
  <div
    class="faq-section-wrapper-2 {{ section.settings.class }}"
    style="background-color:{{ section.settings.color_bg }}"
  >
    <div class="container">
      <div class="faq-section-2-heading text-center">
        <h3 class="heading-2 font-value blue-text">{{ section.settings.heading }}</h3>
      </div>
      <div class="faqBlockWrapper">
        {% for block in section.blocks %}
          <div class="faq">
            <details
              class="faq-acc faq-acc-2"
              {% if block.settings.open %}
                open="true"
              {% endif %}
            >
              <summary class="faq-que-2 value-medium ">{{ block.settings['faq-question'] }}</summary>
              <p class="mt-2 ">{{ block.settings['faq-ans'] }}</p>
            </details>
          </div>
        {% endfor %}
      </div>
      {% if section.settings.addScrollBtn %}
    <div class="mt-4">
      <span
        class="d-block text-center pf357-btn click-scroll m-auto"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >GET YOUR OFFER</span
      >
    </div>
      <div class="pf357-bottom-text">
        {{ section.settings.bottommessage }}
      </div>
    {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
 {
    "name": "FAQ PF357",
    "class": "faq-section",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },	{
          "type": "color",
          "id": "color_bg",
          "label": "Background color",
          "default": "#fff"
        },
      {
          "type": "text",
          "id": "class",
          "label": "Section Class"
        },
{
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
      {
          "type": "checkbox",
          "id": "addScrollBtn",
          "label": "Show Scroll to Btn",
          "default": false
        },
      {
          "type": "color",
          "id": "btnBG",
          "label": "Button Background Colour",
    },
    {
          "type": "color",
          "id": "btntextcolour",
          "label": "Button Text Colour",
    },  
      {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      }
     ,
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
      {
          "type": "html",
          "id": "bottommessage",
          "label": "Additional message"
      },
    {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
	],
	"blocks": [
      {
        "type": "text",
        "name": "faq",
        "settings": [

{
            "type": "checkbox",
            "id": "open",
            "label": "Default Open",
            "default": false
          },
{
            "type": "text",
            "id": "faq-question",
            "label": "FAQ QUE"
          },
{
            "type": "richtext",
            "id": "faq-ans",
            "label": "FAQ ANS"
          }
        ]
      }
	],
	"presets": [
		{
			"name": "FAQ PF357"
		}
	]
  }
{% endschema %}
