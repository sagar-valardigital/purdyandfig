{% if section.settings.enable%}
<div class="clients-section {%if section.settings.bg %} white-bg {%endif%}">
      <div class="container">
          <div class="client-slider">
             {% for block in section.blocks %}
              <div class="client-logo text-center ">
                  <h2 class="heading-2 font-value">{{block.settings.heading}}</h2>
                  {%- assign imageURL = block.settings.desktopimage | img_url:"250x" -%}
                  <img loading="lazy" class="m-auto img-responsie mt-3" src="{{imageURL}}" alt="">
              </div>
             {%endfor%}
          </div>
      </div>
  </div>
{% endif %}
{% schema %}
  {
    "name": "Image Slider",
    "settings": [
	{
      "type": "checkbox",
      "id": "enable",
      "label": "Uncheck to hide the section",
      "default": true
    },
{
      "type": "checkbox",
      "id": "bg",
      "label": "White Background"
    }
	],
	"blocks": [
      {
        "type": "text",
        "name": "block",
        "settings": [ 
          {
            "type": "text",
            "id": "heading",
            "label": "Block Heading"
          },
		{
            "type": "image_picker",
            "id": "desktopimage",
            "label": "Block Image"
          }
        ]
      }
	],
	"presets": [
		{
			"name": "Image slider with heading"
		}
	]
  }
{% endschema %}


