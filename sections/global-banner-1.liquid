              <span class="total-reviews value-sans">6300+ Reviews</span>
            </div>
          </div>

          <form
            @submit.prevent="console.log('submitted')"
            x-ref="product_form"
            enctype="multipart/form-data"
            accept-charset="UTF-8"
            id="product_form_{{product.id}}"
            class="shopify-product-form"
            data-product-id="{{product.id}}"
            action="/cart/add"
          >
            <input type="hidden" name="id" value="{{ s_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            {% if section.settings.isSub %}
              <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
              <input
                type="hidden"
                name="selling_plan"
                value="{{s_variant.selling_plan_allocations.first.selling_plan.id}}"
              >
            {% endif %}
          </form>

          <div class=" mt-3">
            <a
              {% if section.settings.landingproduct != '' %}
                x-on:click="Purdy.PurdyCheckout($refs.product_form, '{{ section.settings.discount }}', $event)"

              {% else %}
                {% if section.settings.scrollto != '' %}data-target="{{ section.settings.scrollto }}" {% endif -%}
                {
              {% endif %}
              href="javascript:void(0);"

              class="btn w-100 btn-loader theme-btn value-sans checkout-lander-btn {% if section.settings.scrollto !='' %}click-scroll{% endif %} {% if section.settings.outOfStock %} bb-disable {% endif %}"
            >
              {%- if section.settings.outOfStock %}
                Out of Stock
              {% else %}
                {{ section.settings.btnText }}
              {% endif -%}</a
            ><br>
            {% if section.settings.ctaDetails != '' -%}
              <small class="theme-text"
                ><img src="{{ 'lander-check.png' | asset_img_url }}" style="width:20px; vertical-align:bottom;">&nbsp;
                {{ section.settings.ctaDetails }}
              </small>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
  <span
    class="arrow-bottom {% if section.settings.scrollto != '' %} click-scroll{% endif %}"
    {% if section.settings.scrollto != '' %}
      data-target="{{ section.settings.scrollto }}"
    {% endif %}
  ></span>
</div>

{% schema %}
{
  "name": "Global Banner 1",
  "settings": [
    {
      "type": "checkbox",
      "id": "outOfStock",
      "label": "Enable If product out Of Stock",
      "default": true
    },
    {
      "id": "className",
      "label": "Section Class",
      "type": "text"
    },
{
    "id": "isSub",
    "label": "Product subscription",
    "type": "checkbox",
    "default": false
  },
    {
      "id": "landingproduct",
      "label": "Choose the landing product",
      "type": "product"
    },
     {
    "type": "text",
    "id": "discount",
    "label": "Discount Code"
  },
    {
      "id": "desktopimage",
      "label": "Desktop Image",
      "type": "image_picker"
    },
	{
      "id": "mobileimage",
      "label": "Mobile Image",
      "type": "image_picker"
    },

	{
      "id": "title",
      "label": "Banner Title",
      "type": "html"
    },

	{
      "id": "subtext",
      "label": "Banner Sub Text",
      "type": "html"
    },
    {
      "id": "price",
      "label": "Price",
      "type": "text"
    },
    {
      "id": "delPrice",
      "label": "Compare Price",
      "type": "text"
    },
{
      "id": "btnText",
      "label": "Button Label",
      "type": "text",
	  "default" : "BUY NOW"
	},
{
  "id": "ctaDetails",
  "label":"Button Details Text",
  "type": "html"
},
    {
  "id": "scrollto",
  "label":"Scroll to ID",
  "type": "text",
      "default":"javascript:void(0);"
}
  ],

  "presets": [
		{
			"name": "Global Banner 1"
		}
	]
}
{% endschema %}
