<style>
  {%- assign DimageURL = section.settings.desktopimage | img_url:"2000x" -%}
  {%- assign MimageURL = section.settings.mobileimage | img_url:"768x" -%}
  .lander-banner-wrapper{
    height:calc(100vh - 150px);
  }
  @media(min-width:768px){
  .bath{{ section.id }}{background-image:url({{DimageURL}})}
  }
  @media(max-width:768px){
  .bath{{ section.id }}{background-image:url({{MimageURL}});}
    .lander-banner-wrapper{
    height:calc(100vh - 150px);
     background-position:center bottom;
  }
  }
  @media(min-height:800px)and (max-width: 768px){
    .lander-banner-wrapper{
      height:calc(100vh - 250px);
    }
  }
</style>
{% assign product = section.settings.landingproduct %}
{% assign s_variant = product.selected_or_first_available_variant %}
<div
  class="pt-5 position-relative lander-banner-wrapper bathroom-banner bath{{ section.id }} {{ section.settings.className }}"
  x-data="{qty:1}"
>
  <div class="">
    <div class="banner-inner-container">
      <div class="d-flex justify-content-between flex-wrap">
        <div class="lander-banner-details">
          <h2 class="heading-2 theme-text value-pro">{{ section.settings.title }}</h2>
          <div class="theme-text px-2">
            <h3 class="value-sans mt-4 bb-points">{{ section.settings.subtext }}</h3>
          </div>
          <div class="text-left">
            <div class="font-pier theme-text mt-0 mb-3 stars-img-review">
