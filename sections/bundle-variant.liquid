          "label": "Choose sub-heading color",
          "default": "#000000"
        },
    {
    "type": "select",
    "id": "heading_position",
    "label": "alignment your main heading",
    "options": [
      {
        "value": "left",
        "label": "Left"
      },
      {
        "value": "center",
        "label": "Center"
      },
      {
        "value": "right",
        "label": "Right"
      }
    ],
    "default": "left"
  },
    {
      "type":"number",
      "id":"pack_size",
      "label":"Input the pack size i.e 6",
      "default":3
    },
    {
          "type": "text",
          "id": "card_heading",
          "label": "Enter build bundle heading",
          "default": "Build Your Bundle"
        },
    {
          "type": "color",
          "id": "card_heading_color",
          "label": "Choose card header-content color",
          "default": "#ffffff"
        },
     {
        "type": "range",
        "id": "card_heading_font",
        "min":  20,
        "max":  38,
        "step":  1,
        "unit": "px" ,
        "label": "card heading font size",
        "default":  34
      },
    {
        "type": "range",
        "id": "card_padding",
        "min":  10,
        "max":  60,
        "step":  1,
