          "default": "Select your Scent"
        },
     {
        "type": "range",
        "id": "heading_font",
        "min":  20,
        "max":  38,
        "step":  1,
        "unit": "px" ,
        "label": "main heading font size",
        "default":  22
      },
    {
        "type": "range",
