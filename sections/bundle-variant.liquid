  changeBanner(pack_size) {
    if(pack_size == 3) {
      desktop_banner = document.querySelector('.desktop-banner');
      desktop_banner.setAttribute('src', desktop_banner.getAttribute('data-src-p1'));
      mobile_banner = document.querySelector('.mobile-banner');
