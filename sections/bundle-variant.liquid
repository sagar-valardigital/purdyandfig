        "step":  1,
        "unit": "px" ,
        "label": "section top bottom space",
        "default":  50
      },
    {
          "type": "text",
          "id": "freeProductTitle",
          "label": "Free Product Title"
        },
    {
          "type": "image_picker",
          "id": "freeProductImg",
          "label": "Free Product Image"
        },
      {
          "type": "product",
          "id": "cart_product",
          "label": "Choose product"
      },
    {
          "type": "product",
          "id": "box_product",
          "label": "Choose SKIO BOX product"
      },
    {
          "type": "product",
          "id": "box_product_3pack",
          "label": "Choose SKIO 3 BOX product"
      }
  ],
  "blocks": [
  {
  "type": "product",
  "name": "bundle item",
