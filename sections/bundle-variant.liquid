    }
    const currentTime = new Date().getTime();
    this.bundleItems.forEach(item => {
              console.log(item.timestamp);
    });
    const updatedItems = this.bundleItems.filter(item => (currentTime - item.timestamp) < (60 * 60 * 1000));
    this.bundleItems = updatedItems;
    this.saveToLocalStorage();
  },
  totalCount:{{ section.settings.pack_size }},
  isAddingToCart: false,
  boxData: null,
  boxIndex: 0,
  oneTimeItems: null,
  skioBABProductMapping: {
    // Linden & Lavendar
    43824862232803: 43989883125987,
  
    // Citronella & Niaouli Fly Away
    43824862134499: 43989883617507,
  
    // Geranium & Ylang Ylang
    43824861610211: 43989884076259,
  
    // Balancing Floral
