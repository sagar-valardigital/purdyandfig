      <button @click="addBundleToCart" class="w-100 green-btn value-sans btn-loader checkout-button" type="button" :class="{ 'loading': isAddingToCart }">ADD TO CART FOR 50% OFF</button>
      </template>
      <template x-if="calculateTotalQuantity()+1 == totalCount">
     <button class="w-100 value-sans" type="button">SELECT <span x-text="bundleToAddCount"></span> MORE SCENT & GET 50% OFF</button>
      </template>
      <template x-if="calculateTotalQuantity() < totalCount && calculateTotalQuantity()+1 != totalCount">
      <button class="w-100 value-sans" type="button">SELECT <span x-text="bundleToAddCount"></span> MORE SCENTS & GET 50% OFF</button>
      </template>
          </div>
        </div>
      </div>
    </div>
  </div>


<div class="bundle-sticky-bar w-100 py-2">
  <div class="container d-flex align-items-center justify-content-between">
    <div>
      <h3 class="m-0 value-pro"><span x-text="totalCount"></span>{{section.settings.sticky_atc_heading}}</h3>
      <p class="m-0 value-sans">Subscription</p>
    </div>
    <div class="d-flex align-items-center justify-content-end">
    <div class="me-4">
      <div class="d-flex">
     <template x-if="calculateTotalQuantity() == totalCount  &  totalCount < 6">
      <del class="px-2 value-sans blue-text" style="text-decoration: line-through;">{{ section.settings.cart_product.compare_at_price |  money }}</del>
     </template>
     <template x-if="calculateTotalQuantity() == totalCount &  totalCount >= 6">
          <del class="px-2 value-sans blue-text" style="text-decoration: line-through;">
                {{ section.settings.cart_product.compare_at_price | times:2 |  money }}
          </del>
     </template>
 <template x-if="calculateTotalQuantity() == totalCount  &  totalCount < 6">
          <h3 class="m-0 value-sans">{{ sub_discount_price | money }}</h3>
 </template>
 <template x-if="calculateTotalQuantity() == totalCount &  totalCount >= 6">
 <h3 class="m-0 value-sans">{{ sub_discount_price |times:2 | money }}</h3>
</template>

       <template x-if="calculateTotalQuantity() < totalCount">
<h3 class="m-0 value-sans">£0.00</h3> 
       </template>
</div>
      
      <p class="m-0 value-sans">Free Bottle for Life</p>
    </div>
      <template x-if="calculateTotalQuantity() == totalCount">
      <button @click="addBundleToCart" class="w-100 green-btn btn-loader value-sans checkout-button" type="button" :class="{ 'loading': isAddingToCart }">ADD TO CART FOR 50% OFF</button>
      </template>
      <template x-if="calculateTotalQuantity()+1 == totalCount">
              <button class="w-100 value-sans" type="button">SELECT <span x-text="bundleToAddCount"></span> MORE SCENT & GET 50% OFF</button>  
      </template>
      <template  x-if="calculateTotalQuantity() < totalCount  && calculateTotalQuantity()+1 != totalCount">
      <button class="w-100 value-sans" type="button">SELECT <span x-text="bundleToAddCount"></span> MORE SCENTS & GET 50% OFF</button>
      </template>
    </div>
  </div>
</div>
  <div class="blends-popup">
      <span class="overlay"></span>
      <div class="slides-numbers text-white" style="display: block;">
        <span class="active">1</span> of <span class="total"></span>
      </div>
      <div class="blend-popup-slider">
        {% for block in section.blocks %}
          {% if block.settings.nopopup %}
          {% else %}
            <div class="blend-popup-content item blend-popup-{{ forloop.index }} text-left theme-text {% if block.settings.nopopup %} {%  else %} blend-pop {%  endif %}">
              <div class="blend-popup-content-inner">
                <span class="close-blend-popup">&#10005;</span>
                <h3 class="heading-3 m-0">{{ block.settings.pop_heading }}</h3>
                <div class="m-0 mt-2">{{ block.settings.pop_detail }}</div>
                {% if block.settings.PoopupIconCode != '' %}
                  <hr>
                  <div class="blend-popup-blocks">
                    {{ block.settings.PoopupIconCode }}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
</div>
{% schema %}
{
  "name": "Bundle variant section",
  "settings": [
    {
      "type": "checkbox",
      "id": "redirect_checkout",
      "label": "Redirect to checkout",
      "default": true
    },
{
      "type": "checkbox",
      "id": "pack_change",
      "label": "Pack change option"
    },
    {
          "type": "text",
          "id": "sectionId",
          "label": "Section ID"
        },
        {
          "type": "text",
          "id": "sectionClass",
          "label": "Section Class"
        },
    {
          "type": "text",
          "id": "sticky_atc_heading",
