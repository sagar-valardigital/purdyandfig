<style>

.btn {
  font-size: 18px !important;
}

.blue-starterkit-btn {
    font-size: 18px !important;
}
  
.cleaning-power-section .heading-2 {
  color: #0A1E1A !important;
  font-size: 40px;
  font-weight: 400;
  text-align: center;
  letter-spacing: 0px;
  line-height: 1.25;
  
}

.cleaning-power-section p.subheading {
  color: #424242 !important;
  max-width: 665px;
  margin: 0 auto;
  font-size: 18px;
  font-weight: 200;
  text-align: center;
  line-height: 1.50;
}

.transformational-scents-slider {
  margin-top: 40px;
}
  
.scents-reskins .transformational-scents-slider .tss-block {
  padding: 0;
}
.tss-tag {
  font-size: 14px;
  font-weight: 400;
  border-radius: 4px;
  right: 16px;
  top: 16px;
  padding: 2px 4px;
  border: 1px solid #ffb2d2;
  background: #fff2f7;
  line-height: 128%;
  color: #212121;
}
  
.tss-details {
  font-size: 14px;
}

.tss-content-center {
  text-align: center;
}
  
@media (max-width: 768px) {

.cleaning-power-section .heading-2 {
  color: #0A1E1A !important;
  font-size: 32px;
  text-align: left;
  
}

.cleaning-power-section p.subheading {
  color: #424242 !important;
  font-size: 16px;
  text-align: left;
}

  
  .common-btn-width {
    width: 100%;
  }
}
.blue-starterkit-btn {
  font-size: 16px;
}


  
.tss-block .tss-details {
  line-height: 1.6 !important;
  margin: 0 !important;
}
  
.tss-mobile-stack {
  width: 100%;
  padding: 0 16px;
}

.tss-mobile-card {
  align-items: flex-start;
}

.tss-mobile-card:last-child {
  margin-bottom: 0 !important;
}
  
.cleaning-power-mobile-image {
  flex-shrink: 0;
  width: 130px;
  height: 130px;
  border-radius: 4px;
  overflow: hidden;
}

.cleaning-power-mobile-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.tss-mobile-content {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.tss-mobile-content .tss-heading {
  font-size: 16px;
  font-weight: 400;
  line-height: 1.5;
  margin-bottom: 4px !important;
  padding-top: 0;
  padding-bottom: 0;
  border-bottom: none;
  color: #212121;
}

.cleaning-power-section .tss-mobile-content .tss-details {
  font-size: 14px !important;
  color: #424242 !important;
  line-height: 1.5 !important;
  letter-spacing: 0.015em;
  margin-bottom: 12px;
  padding-top: 0;
  font-style: normal;
  font-weight: 200;
}

.tss-mobile-content .tss-mobile-tag {
    font-size: 14px;
    font-weight: 400;
    border-radius: 4px;
    padding: 2px 4px;
    border: 1px solid #ffb2d2 !important;
    background: #fff2f7 !important;
    line-height: 128%;
    color: #212121;
    display: inline-block;
    white-space: nowrap;
    width: auto;
    max-width: fit-content;
}

.cleaning-power-section .discoverBtmBtn {
  margin-top: 32px !important;
}

  @media (min-width: 769px) {
  .trans-scents-desktop {
    display: block;
  }
  .trans-scents-mobile {
    display: none;
  }
}
  
  @media (max-width: 768px) {
  .trans-scents-desktop {
    display: none;
  }
  .trans-scents-mobile {
    display: block;
  }
}

  
</style>


{% assign count = 0 %}
{% for block in section.blocks %}
  {% assign count = count | plus: 1 %}
{% endfor %}
<div id="{{ section.settings.sectionId }}">
  <div
    style="background-color:{{ section.settings.bgcolor }}"
    class="py-80 cleaning-power-section scents-reskins variant_{{ section.settings.linkVariant }} {{ section.settings.class }}"
  >
    <div class="container">
      <div
        {% if count < 2 %}
          class="d-flex align-items-center justify-content-between tss-one-block-wrapper"
        {% endif %}
      >
        <div class="tss-main-header">
          <h2 class="heading-2 text-center white-text font-gtsuper mt-0 " style="color: #0A1E1A !important;">{{ section.settings.heading }}</h2>
{% if section.settings.subtext != blank %}          
<p class="subheading normal-text font-lausanne fw-200 text-center">
            {{ section.settings.subtext }}
          </p>
  {% endif %}
        </div>
        <!-- DESKTOP VERSION -->
        <div class="mt-4 trans-scents-desktop">
          <div class="transformational-scents-slider {% if count > 2 %}tss-slider{% endif %}">
            {% for block in section.blocks %}
              <div class="tss-block">
                <div class="tss-image position-relative">
                  <picture>
                    {% assign image = block.settings.blockImage %}
                    {% assign mimage = block.settings.mBlockImage %}

                    <source media="(min-width:769px)" srcset="{{ image | img_url: 'master'}}">
                    <source media="(max-width:768px)" srcset="{{ mimage | img_url: 'master' }}">
                    <img
                      data-id="{{image.id}}"
                      class="img-responsive w-100 h-auto lazy"
                      src="{{ image | img_url: 'master'}}"
                      width="400"
                      height="300"
                      alt="{{ image.alt }}"
                    >
                  </picture>
                  {% if block.settings.tag != blank %}
                    <span class="tss-tag font-lausanne">{{ block.settings.tag }}</span>
                  {% endif %}
                </div>
                <div class="tss-content text-center">
                  <h3 class="tss-heading  font-lausanne fw-400">{{ block.settings.heading }}</h3>
                  <p class="tss-details black-text normal-text font-lausanne fw-200">{{ block.settings.details }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
        <!-- END: DESKTOP VERSION -->

        <!-- MOBILE VERSION (NEW STACKED) -->

<div class="mt-4 trans-scents-mobile">
  <div class="tss-mobile-stack">
    {% for block in section.blocks %}
      <div class="tss-mobile-card d-flex mb-4">
        <div class="cleaning-power-mobile-image">
          <picture>
            {% assign image = block.settings.blockImage %}
            {% assign mimage = block.settings.mBlockImage %}
            <source media="(min-width:769px)" srcset="{{ image | img_url: 'master'}}">
            <source media="(max-width:768px)" srcset="{{ mimage | img_url: 'master' }}">
            <img
              data-id="{{image.id}}"
              class="img-responsive w-100 h-auto lazy"
              src="{{ mimage | img_url: 'master'}}"
              width="120"
              height="120"
              alt="{{ image.alt }}"
            >
          </picture>
        </div>
        <div class="tss-mobile-content flex-grow-1 ps-3">
          <h3 class="tss-heading font-lausanne fw-400 mb-2">{{ block.settings.heading }}</h3>
          <p class="tss-details black-text normal-text font-lausanne fw-200 mb-2">{{ block.settings.details }}</p>
          {% if block.settings.tag != blank %}
            <div class="tss-mobile-tag font-lausanne">{{ block.settings.tag }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>


        <!-- END: MOBILE VERSION -->
      </div>
    </div>
           {% if section.settings.addScrollBtn %}
    <div class="discoverBtmBtn">
      <span
          class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto common-btn-width"
          style="background-color: {{ section.settings.btnBG }} !important"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >{{ section.settings.btnLabel }}</span
      >
    </div>
    {% endif %}
  </div>
</div>
{% schema %}
{
  "name": "Cleaning Power PF357",
  "settings": [
    {
      "type": "text",
      "id": "sectionId",
      "label": "Section ID"
    },
    {
      "type": "color",
      "id": "bgcolor",
      "label": "Background color"
    },
  {
      "type": "text",
      "id": "class",
      "label": "Section Class"
    },
    {
      "type": "text",
      "id": "linkVariant",
      "label": "Link variant number"
    },
  {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
     {
      "type": "text",
      "id": "subtext",
      "label": "Sub Heading"
    },
    {
          "type": "checkbox",
          "id": "addScrollBtn",
          "label": "Show Scroll to Btn",
          "default": false
    },
   {
          "type": "text",
          "id": "btnLabel",
          "label": "Button Label",
          "default": "GET YOUR OFFER"
    },
    {
          "type": "color",
          "id": "btnBG",
          "label": "Button Background Colour",
    },
    {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      }
     ,
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
       {
        "id": "dataTrack",
        "label":"Data Track",
        "type": "checkbox"
        },
        {
        "id": "targetUrl",
        "label":"Target Url",
        "type": "url"
        },
        {
        "id": "index",
        "label":"Index",
        "type": "number",
        "default" : 0
            },
            {
        "id": "funnel_stage",
        "label":"Funnel Stage",
        "type": "text",
         "default" : "landing_page"
            },
            {
        "id": "dataModule",
        "label":"Module",
        "type": "text",
         "default" : "announcement_bar"
            },
              {
        "id": "dataTitle",
        "label":"Event Label",
        "type": "text",
        "default": "get_your_offer"
            }
            ,
              {
        "id": "eventValue",
        "label":"Event Value",
        "type": "text",
        "default" : "shop_anchor"
            },
              {
        "id": "itemId",
        "label":"Item Id",
        "type": "text"
            }
            ,
              {
        "id": "optionIndex",
        "label":"Option Index",
        "type": "text"
            }
            ,
              {
        "id": "ItemName",
        "label":"Item Name",
        "type": "text"
            }
  ],
  "blocks": [
      {
        "type": "image",
        "name": "Scent block",
        "settings": [
          {
            "type": "image_picker",
            "id": "blockImage",
            "label": "Desktop Image"
          },
          {
            "type": "image_picker",
            "id": "mBlockImage",
            "label": "Mobile Image"
          },
          {
            "type": "text",
            "id": "tag",
            "label": "Tag"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "text",
            "id": "details",
            "label": "text"
          }
        ]
      }
	],
  "presets": [
    {
        "name": "Cleaning Power PF357"
    }
]
}
{% endschema %}
