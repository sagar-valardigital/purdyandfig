<div class="product-info pt-5 {{ section.settings.class }}">
  <div class="d-flex flex-wrap mx-0 px-0 align-items-center justify-content-between">
    <div class="w-50 d-flex align-items-center justify-content-center">
      <div class="col-12 col-md-10 col-lg-8">
        <div class="d-flex align-items-center mb-3 product-review {% if section.settings.scrollto !=''%}click-scroll{% endif %}" 
          {% if section.settings.scrollto !=''%} data-target="{{ section.settings.scrollto }}" {% endif %}>
          {% render 'review-icon', content: product %}
          <span class="ms-2 value-sans" style="color:{{ section.settings.content_color }};">
            {{- section.settings.reviewtitle -}}
          </span>
        </div>
        <h1 class="mb-3 value-pro" style="color:{{ section.settings.content_color }};">
          {{ section.settings.section_heading }}
        </h1>
        <h4 class="mb-3 value-sans" style="color:{{ section.settings.content_color }};">
          {{ section.settings.subheading }}
        </h4>
        <div class="mb-3">
          {% for block in section.blocks %}
            <div class="d-flex align-items-center product-blocks mb-1 value-sans">
              <span class="d-flex align-items-center me-2">{% render 'checkbox-circle-icon', content: product %}</span>
              <span style="color:{{ section.settings.content_color }};">{{ block.settings.title }}</span>
            </div>
          {% endfor %}
        </div>
        {% if section.settings.btnLink %}
<a href="{{section.settings.btnLink}}" class="buy-btn col-12 col-md-10 mb-2 value-sans d-inline-block text-center" >
          {{ section.settings.btnLabel }}
        </a>
        {% else %}
        <button class="buy-btn col-12 col-md-10 mb-2 value-sans click-scroll" data-target="{{ section.settings.scrollID }}">
          {{ section.settings.btnLabel }}
        </button>
          {% endif %}
        <div class="d-flex align-items-center justify-content-center col-12 col-md-10">
          <svg class="mx-1" width="18" height="12" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10.5 7C9.8053 7 9.215 6.757 8.729 6.271C8.243 5.785 8 5.19467 8 4.5C8 3.80533 8.243 3.215 8.729 2.729C9.215 2.243 9.8053 2 10.5 2C11.1947 2 11.785 2.243 12.271 2.729C12.757 3.215 13 3.80533 13 4.5C13 5.19467 12.757 5.785 12.271 6.271C11.785 6.757 11.1947 7 10.5 7ZM4.5 9C4.08333 9 3.72933 8.854 3.438 8.562C3.146 8.2707 3 7.9167 3 7.5V1.5C3 1.08333 3.146 0.72933 3.438 0.438C3.72933 0.146 4.08333 0 4.5 0H16.5C16.9167 0 17.2707 0.146 17.562 0.438C17.854 0.72933 18 1.08333 18 1.5V7.5C18 7.9167 17.854 8.2707 17.562 8.562C17.2707 8.854 16.9167 9 16.5 9H4.5ZM6 7.5H15C15 7.0833 15.146 6.7293 15.438 6.438C15.7293 6.146 16.0833 6 16.5 6V3C16.0833 3 15.7293 2.854 15.438 2.562C15.146 2.27067 15 1.91667 15 1.5H6C6 1.91667 5.854 2.27067 5.562 2.562C5.27067 2.854 4.91667 3 4.5 3V6C4.91667 6 5.27067 6.146 5.562 6.438C5.854 6.7293 6 7.0833 6 7.5ZM15.5 12H1.5C1.08333 12 0.72933 11.854 0.438 11.562C0.146 11.2707 0 10.9167 0 10.5V2H1.5V10.5H15.5V12Z" fill="#334FB4"/>
          </svg>
          <span class="mx-1 value-sans" style="color:{{ section.settings.content_color }};">Money Back Guarantee</span>
        </div>
      </div>
    </div>
    <div class="w-50"><img class="w-100 vertical-middle" src="{{ section.settings.image | img_url: "1900x" }}"></div>
  </div>
</div>
{% schema %}
  {
    "name": "Homepage Banner 3",
    "settings": [
      {
      "type": "text",
      "id": "scrollto",
      "label": "Scroll To Section"
    },
      {
      "type": "text",
      "id": "class",
      "label": "custom class to add"
    },
        {
          "type": "text",
          "id": "reviewtitle",
          "label": "Enter review title",
          "default": "product review text"
        },
        {
          "type": "text",
          "id": "section_heading",
          "label": "Enter section heading",
          "default": "your section heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Enter section sub-heading",
          "default": "your section sub-heading"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Choose product image"
        },
        {
          "type": "color",
          "id": "content_color",
          "label": "Choose content color",
          "default": "#334FB4"
        },
      {
          "type": "text",
          "id": "btnLabel",
          "label": "Button Label",
          "default": "Shop Now & SAVE 50%"
        },
      {
          "type": "text",
          "id": "scrollID",
          "label": "Scroll Section Id"
        },
      {
          "type": "url",
          "id": "btnLink",
          "label": "Button Link"
        }
    ],
    "max_blocks": 4,
    "blocks": [
    {
      "type": "product_benefits",
      "name": "product benefits",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Enter product benefit",
          "default": "your product benefit"
        }
      ]
    }
  ],
    "presets": [
  {
      "name" : "HomePage banner 3"
  }
]
  }
{% endschema %}
