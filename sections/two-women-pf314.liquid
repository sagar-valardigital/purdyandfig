<style>

    .two-women-wrapper-2 .text-400 {
    font-size: 24px;
    font-weight: 400;
    display: block;
    line-height: 1.5;
    margin-bottom: 12px
  }

  .two-women-wrapper-2 .text-200 {
    font-size: 18px;
    font-weight: 200;
    display: block;
    line-height: 1.5;
  }

  .text-block {
    display: block !important;
    margin-top: 16px !important;
  }

  .two-women-pf314 .manufactured .manufactured-inner .heading-2 span {
    color: #0C231F !important;
    font-weight: 600 !important;
  }
  
  /* Margin before GB badge */
  .gb-margin {
    margin-right: 32px;
  }

@media (max-width: 768px) {
  .two-women-wrapper-2 .text-400 {
    font-size: 16px !important;
    font-weight: 200 !important;
    display: inline !important;
  }

  .two-women-wrapper-2 .text-200 {
    font-size: 16px !important;
    font-weight: 200 !important;
    display: inline;
  }

  .mt-32 {
    margin-top: 32px !important;
  }
}
  
</style>

<div
  style="background-color:{{section.settings.background}};"
  class="{{ section.settings.className }} py-80 two-women-wrapper-2"
>
  <div class="container">
    <div class="">
      <div class="text-center m-text-left tworows">
        <h2 class="heading-2 value-bold mt-0 mb-3">
          {{ section.settings.main_heading }}
        </h2>
        {% if section.settings.sub_heading != blank %}
        <p class="font-lausanne gray-text mb-4">{{ section.settings.sub_heading }}</p>
          {% endif %}
      </div>
      <div class="d-flex flex-wrap justify-content-between two-women--inner-wrapper">
        <div class="w-50 {% if section.settings.layout %} order-2 {%endif%}">
          <div class="two-women position-relative">
            <video
              id="video_{{ section.id }}"
              class=" w-100 h-100 two-women-video"
              width="320"
              height="180"
              playsinline
              loop
              muted
              poster="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/two_women_720p.jpg?v=1754546797"
            >
              <source src="https://cdn.shopify.com/videos/c/o/v/04ae416a893b4ec1bdbcb8c046fb60eb.mp4" type="video/mp4">
            </video>
            <div class="video-pp-icon">
              <img
                src="{{ 'play-button.png' | asset_img_url }}"
                data-target="video_{{ section.id }}"
                class="intro-video-play"
                alt="video"
                width="50"
                height="50"
              >
            </div>
          </div>
        </div>
        <div class="w-50  d-flex justify-content-center mobile-hide {% if section.settings.layout %} order-1 {%endif%} ">
          <div class="two-women-details h-100 w-90">
            <div class="p-3">
              <h2 class="heading-2 m-text-left {{section.settings.textcolor}} {% if section.settings.heading-position%} {% else %}mobile-hide{% endif %}">
                {{ section.settings.heading }}
              </h2>
              <div class="normal-text font-lausanne {{section.settings.textcolor}} m-text-left">
                {{ section.settings.details }}
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="manufactured mt-5">
        <div class="manufactured-inner">
          <h2 class="heading-2 blue-text font-lausanne mt-0 text-center d-flex align-items-center justify-content-center">
            <span class="font-lausanne gb-margin" style="color:#0c231f !important;"> Manufactured in the UK</span>
            <img
              width="40"
              height="40"
              alt="gb"
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/GB.png?v=1699590423"
            >
          </h2>
          <p class="value-sans gray-text mt-4 m-text-left">
            <span class="font-lausanne fw-400" style="color:#212121"
              >{{ section.settings.man_details_1 }}</span
            >
            <span class="font-lausanne text-200 text-block" style="color:#212121 !important"
              >{{ section.settings.man_details_2 }}</span
            >
          </p>
        </div>
         {% if section.settings.addScrollBtn %}
    <div class="mt-4 mt-32">
      <span
        class="d-block text-center blue-starterkit-btn green-btn click-scroll m-auto common-btn-width"
        data-target="{{ section.settings.scrollto }}"
        data-top="{{ section.settings.top }}"
        {% if section.settings.button_bg %}
                      style="background-color:{{ section.settings.button_bg }} !important"
                      {% endif %}
        {% if section.settings.dataTrack %}
            {% render "ga4-events" %}
          {% endif %}
        >{{ section.settings.btnLabel }}</span
      >
    </div>
    {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Two Women PF314",
    "settings": [
      {
          "type": "checkbox",
          "id": "addScrollBtn",
          "label": "Show Scroll to Btn",
          "default": false
        },
      {
        "type": "text",
        "id": "className",
        "label": "Add Section class Name"
      },
      {
        "type": "color",
        "id": "background",
        "label": "Select background color"
      },
      {
        "type": "checkbox",
        "id": "layout",
        "label": "Image on right"
      },
      {
        "type": "html",
        "id": "main_heading",
        "label": "Heading"
      },
      {
        "type": "html",
        "id": "sub_heading",
        "label": "Heading Sub text"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Add Image"
      },
      {
        "type": "html",
        "id": "details",
        "label": "Detail Text"
      },
      {
        "type": "html",
        "id": "man_details_1",
        "label": "Manufacturing Details 1",
        "default": "We manufacture Purdy & Figg concentrates in the UK, where we are subject to stringent health regulations."
      },
      {
        "type": "html",
        "id": "man_details_2",
        "label": "Manufacturing Details 2",
        "default": "Every Purdy & Figg refill is produced and packaged at our factory in Hertfordshire, where our dedicated team keep our customers’ safety in mind every step of the way"
      },
      {
          "type": "text",
          "id": "btnLabel",
          "label": "Button Label",
          "default": "GET YOUR OFFER"
        },
         {
      "id": "button_bg",
      "label": "Button background color",
      "type": "color"
    },
      {
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      }
     ,
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
        {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
    ],
    "presets": [
      {
        "name": "Two Women PF314"
      }
    ]
  }
{% endschema %}
