{% assign product = section.settings.landingproduct %}
{% assign s_variant = product.selected_or_first_available_variant %}

<div
  class="annoucment-bar annoucment-bar-2 py-2 value-sans {{ section.settings.class }}"
  style="background-color:{{section.settings.bb-color}}"
  id="annoucment_bar_2"
  {% if section.settings.checkout %}
x-data="{qty:1}"
  {% endif %}
