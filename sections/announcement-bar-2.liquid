        </div>
      {% endif %}
      <div class="ann-bar-text-2">
        <p class="m-0 value-sans" style="color:{{section.settings.text-color}}; font-size:20px;">
          {{ section.settings.text }}
        </p>
      </div>
      <div>
        <form
              @submit.prevent="console.log('submitted')"
              x-ref="product_form_{{ section.index}}"
              enctype="multipart/form-data"
              accept-charset="UTF-8"
              id="product_form_{{ section.index}}"
              class="shopify-product-form"
              data-product-id="{{product.id}}"
              action="/cart/add"
            >
              <input type="hidden" name="id" class="input_variant_id" value="{{ section.settings.varaiantid }}">
              <input type="hidden" class="discout_input" name="discount" value="{{ section.settings.discount }}">
              <input type="hidden" name="quantity" value="1">
          {% if section.settings.sellingid != blank %}  
                <input type="checkbox" name="purchase_type" value="subscription" checked class="d-none">
             
          <input
                  class="input_selling_plan"
                  type="hidden"
                  name="selling_plan"
                  value="{{section.settings.sellingid}}"
                >
          {% endif %}
            </form>
        <span
          style="cursor:pointer;"
{% if section.settings.checkout %}{% else %}
          data-target="{{ section.settings.scrollto }}"
          {% endif %}
          data-top="{{ section.settings.top }}"
          class="announcement-btn-2 {% if section.settings.checkout %}{% else %}click-scroll{% endif %}"
          {% if section.settings.dataTrack %}
            {% render 'ga4-events' %}
          {% endif %}

          {% if section.settings.checkout %}
              x-on:click="Purdy.CheckoutLanding($refs.product_form_{{ section.index}}, event)"
          {% endif %}

        >
          {{ section.settings.annuText -}}
        </span>
      </div>
    </div>
  </div>
</div>
<div class="ann-bar-text-2 desktop-hide text-center bg-blue white-text py-1">
  <p class="m-0 value-sans">
    {{ section.settings.text }}
  </p>
</div>

{% schema %}
{
  "name": "Announcement bar 2",
  "class": "top-sticky annoucment_bar_2",
  "settings" : [
{
    "type": "checkbox",
    "id": "checkout",
    "label": "Enable Checkout",
    "default": false
  },
    {
    "type": "product",
    "id": "landingproduct",
    "label": "Choose product"
  },
    {
    "type": "text",
    "id": "discount",
    "label": "Discount code"
  },
    {
    "type": "text",
    "id": "varaiantid",
    "label": "Variant id"
  },
    {
    "type": "text",
    "id": "sellingid",
    "label": "Selling plan id"
  },
    {
    "type": "checkbox",
    "id": "logo",
    "label": "show logo",
    "default": true
  },
    {
    "type": "text",
    "id": "class",
    "label": "Add Class"
  },
      {
          "type": "text",
          "id": "text",
          "default": "Welcome to our store",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
      },
	  {
          "type": "color",
          "id": "bb-color",
          "default": "#CB3C8E",
          "label": "Background Colour"
      },
	  {
          "type": "color",
          "id": "text-color",
          "default": "#fff",
          "label": "text Colour"
      },{
          "type": "text",
          "id": "scrollto",
          "label": "Scroll to section id",
          "default": "javascript:void(0);"
      },{
          "type": "text",
          "id": "annuText",
          "label": "Link Text",
          "default": "Click Here"
      },
    {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
   {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }

  ],
  "presets": [
		{
			"name": "Announcement bar 2"
		}
	]

}
{% endschema %}
