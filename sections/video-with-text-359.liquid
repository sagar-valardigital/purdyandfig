<div class="{{ section.settings.className }}" style="background-color:{{section.settings.background}};">
  {% for block in section.blocks %}
  <div
    
    class="py-80 image-with-text image-with-text-2 video-with-text"
  >
    <div class="container">
      <div class="d-flex flex-wrap justify-content-between align-items-center">
        <div class="video-wrapper-inner-block {% if block.settings.layout %} order-2 {%endif%}">
          <div class="position-relative">
            {% if block.settings.image %}
              {% assign mImage = block.settings.image | img_url: '800x' %}
              <video class="w-100 h-100"  width="320" height="240" autoplay muted loop playsinline poster="{{ mImage }}">
                  <source src="{{ block.settings.video }}" type="video/mp4">
                </video>
               
            {% endif %}
          </div>
          {% if section.settings.showbtn %}
              <div class="text-center mt-3 desktop-hide">
                <span
                  {% if section.settings.dataTrack %}
                    {% render 'ga4-events' %}
                  {% endif %}
                  data-target="{{ section.settings.scrollto }}"
                   data-top="{{ section.settings.top }}"
                  class="btn click-scroll green-btn"
                  style="background: {{ section.settings.btnbgcolor }} !important; color: {{ section.settings.btntxtcolor }};font-size: 18px !important"
                >
                  {{- section.settings.btntext -}}
                </span>
              </div>
            {% endif %}
        </div>
        <div class="w-50 d-flex justify-content-start {% if block.settings.layout %} order-1 {%endif%} image-txt">
          <div class="pb-4">
            <h2 class="heading-2 font-gtsuper" style="color:{{section.settings.headingColor}} !important;">
              {{ block.settings.heading }}
            </h2>
            <div class="normal-text font-lausanne fw-200 " style="color:{{section.settings.textcolor}};">
              {{ block.settings.details }}
            </div>
            {% if section.settings.showbtn %}
              <div class=" mt-3 mobile-hide">
                <span
                  {% if section.settings.dataTrack %}
                    {% render 'ga4-events' %}
                  {% endif %}
                  data-target="{{ section.settings.scrollto }}"
                   data-top="{{ section.settings.top }}"
                  class="btn click-scroll green-btn"
                  style="background: {{ section.settings.btnbgcolor }} !important; color: {{ section.settings.btntxtcolor }};font-size: 18px !important"
                >
                  {{- section.settings.btntext -}}
                </span>
              </div>
            {% endif %}
           
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endfor %}
</div>

{% schema %}
  {
    "name": "Video With Text 359",
    "settings": [
      {
        "type": "text",
        "id": "className",
        "label": "Add Section class Name"
      },
      {
        "type": "color",
        "id": "headingColor",
         "label": "Select Heading color",
        "default": "#0A1E1A"
      },
      {
        "type": "color",
        "id": "textcolor",
        "label": "Select text color",
        "default": "#212121"
      },
      {
        "type": "color",
        "id": "background",
        "label": "Select background color",
        "default": "#ffffff"
      },
     {
         "type": "checkbox",
         "id": "showbtn",
         "label": "Show button",
         "default": false
     },
     {
         "type": "color",
         "id": "btnbgcolor",
         "label": "Button background"
     },
     {
         "type": "color",
         "id": "btntxtcolor",
         "label": "Button text color"
     },
     {
         "type": "html",
         "id": "btntext",
         "label": "Button label"
     },
     {
         "type": "text",
         "id": "scrollto",
         "label": "Scroll to"
     },
     {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
     {
      "id": "dataTrack",
      "label":"Data Track",
      "type": "checkbox"
      },
      {
      "id": "targetUrl",
      "label":"Target Url",
      "type": "url"
      },
      {
      "id": "index",
      "label":"Index",
      "type": "number",
      "default" : 0
          },
          {
      "id": "funnel_stage",
      "label":"Funnel Stage",
      "type": "text",
       "default" : "landing_page"
          },
          {
      "id": "dataModule",
      "label":"Module",
      "type": "text",
       "default" : "announcement_bar"
          },
            {
      "id": "dataTitle",
      "label":"Event Label",
      "type": "text",
      "default": "get_your_offer"
          }
          ,
            {
      "id": "eventValue",
      "label":"Event Value",
      "type": "text",
      "default" : "shop_anchor"
          },
            {
      "id": "itemId",
      "label":"Item Id",
      "type": "text"
          }
          ,
            {
      "id": "optionIndex",
      "label":"Option Index",
      "type": "text"
          }
          ,
            {
      "id": "ItemName",
      "label":"Item Name",
      "type": "text"
          }
	],
    "blocks": [
      {
        "type": "text",
        "name": "block",
        "settings": [
          {
            "type": "select",
            "id": "width",
            "label": "Select text area width",
            "options": [
              {
                "value": "w-90",
                "label": "90%"
              },
              {
                "value": "w-80",
                "label": "80%"
              },
              {
                "value": "w-70",
                "label": "70%"
              },
              {
                "value": "w-60",
                "label": "60%"
              }
            ],
            "default": "w-80"
          },
          {
            "type": "checkbox",
            "id": "layout",
            "label": "Image on right"
          },
          {
            "type": "html",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Poster"
          },
          {
            "type": "url",
            "id": "video",
            "label": "Video Link"
          },
          {
            "type": "html",
            "id": "details",
            "label": "Detail Text"
          },
         
          {
            "type": "header",
            "content": "GA4"
          },
          {
            "id": "dataTrack",
            "label":"Data Track",
            "type": "checkbox"
          },
          {
            "id": "targetUrl",
            "label":"Target Url",
            "type": "url"
          },
          {
            "id": "index",
            "label":"Index",
            "type": "number",
            "default" : 0
          },
          {
            "id": "funnel_stage",
            "label":"Funnel Stage",
            "type": "text",
            "default" : "landing_page"
          },
          {
            "id": "dataModule",
            "label":"Module",
            "type": "text",
            "default" : "announcement_bar"
          },
          {
            "id": "dataTitle",
            "label":"Event Label",
            "type": "text",
            "default": "get_your_offer"
          },
          {
            "id": "eventValue",
            "label":"Event Value",
            "type": "text",
            "default" : "shop_anchor"
          },
          {
            "id": "itemId",
            "label":"Item Id",
            "type": "text"
          },
          {
            "id": "optionIndex",
            "label":"Option Index",
            "type": "text"
          },
          {
            "id": "ItemName",
            "label":"Item Name",
            "type": "text"
          }
        ]
      }
    ],
	"presets": [
		{
			"name": "Video With Text 359"
		}
	]
  }
{% endschema %}
