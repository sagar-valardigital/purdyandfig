                <span class="total-reviews value-bold" style="color:#2D469E">4.9</span>
              </div>
              <div class="value-medium customers-reviews" style="color:#161718">{{ section.settings.review_count }} reviews</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Banner 5",
  "settings": [

    {
      "id": "className",
      "label": "Section Class",
      "type": "text"
    },

    {
      "id": "desktopimage",
      "label": "Desktop Image",
      "type": "image_picker"
    },
	{
      "id": "mobileimage",
      "label": "Mobile Image",
      "type": "image_picker"
    },

	{
      "id": "title",
      "label": "Banner Title",
      "type": "html"
    },

	{
      "id": "subtext",
      "label": "Banner Sub Text",
      "type": "html"
    },

{
      "id": "btnText",
      "label": "Button Label",
      "type": "text",
	  "default" : "BUY NOW"
	},
    {
      "id": "review_count",
      "label": "Number of reviews",
      "type": "text",
      "default": "7,000+"
    },
    {
      "id": "btn_subtext",
      "label": "Button Subtext",
      "type": "text"
    },
    {
  "id": "scrollto",
  "label":"Scroll to ID",
  "type": "text",
      "default":"javascript:void(0);"
},
    {
          "type": "text",
          "id": "top",
          "label": "On scroll top position",
          "default": "0"
      },
    {
    "type": "header",
    "content": "GA4"
  },
    {
"id": "dataTrack",
"label":"Data Track",
"type": "checkbox"
    },
    {
"id": "targetUrl",
"label":"Target Url",
"type": "url"
    },
    {
"id": "index",
"label":"Index",
"type": "number",
"default" : 0
    },
    {
"id": "funnel_stage",
"label":"Funnel Stage",
"type": "text",
 "default" : "landing_page"
    },
    {
"id": "dataModule",
"label":"Module",
"type": "text",
 "default" : "announcement_bar"
    },
      {
"id": "dataTitle",
"label":"Event Label",
"type": "text",
"default": "get_your_offer"
    }
    ,
      {
"id": "eventValue",
"label":"Event Value",
"type": "text",
"default" : "shop_anchor"
    },
      {
"id": "itemId",
"label":"Item Id",
"type": "text"
    }
    ,
      {
"id": "optionIndex",
"label":"Option Index",
"type": "text"
    }
    ,
      {
"id": "ItemName",
"label":"Item Name",
"type": "text"
    }
  ],
"blocks": [
      {
        "type": "text",
        "name": "Points",
        "settings": [
          {
            "type": "text",
            "id": "text",
            "label": "Points"
          }

        ]
      }
	],
  "presets": [
		{
			"name": "Banner 5"
		}
	]
}
{% endschema %}
