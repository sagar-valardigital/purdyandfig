<style>
  {%- assign DimageURL = section.settings.desktopimage | img_url:"1900x" -%}
  {%- assign MimageURL = section.settings.mobileimage | img_url:"768x" -%}
  {%- assign MMimageURL = section.settings.mobileimage | img_url:"500x" -%}
  .banner-3{{ section.id }} .banner-inner-container{padding:65px 15px;}
  .banner-3{
    height:656px;
  }
  .banner3-points ul{
    margin:0;
    padding:0;
    list-style:none;
  }
  .banner3-points li.banner3-point{
    background-image:url('https://cdn.shopify.com/s/files/1/0360/1347/3931/files/check-cricle.png?v=1710738687');
    background-repeat:no-repeat;
    padding:5px 0 3px 25px;
    background-size:17px 17px;
    background-position:left 6px;
    font-size:17px
  }
  @media(min-width:768px){
    
  .banner-3{{ section.id }}{background-image:url({{DimageURL}});
    background-size:cover;
    background-position:center;
    }
    .banner3-points li.banner3-point{font-size:15px;}

  }
    @media(max-width:768px){
    .banner-3{{ section.id }} .banner-inner-container{padding:0;}
  .banner-3{{ section.id }}{background-image:url({{MimageURL}});
    background-size:cover;background-position:top right;}
  }
    @media(max-width:560px){
                            .banner-3{{ section.id }}{
    height:680px !important;
  }
    .banner-3 .banner-2-btn{margin:10px 0 !important;}
    .banner-3 .heading-2{margin-bottom:0 !important;}
    }
     @media(max-width:400px){
  .banner-3{{ section.id }}{background-image:url({{MMimageURL}})}
  }
  .btn-subtext {
    text-align: center;
    font-family: "Value-Bold";
    font-size: 12px;
    font-weight: 700;
    line-height: 18px;
    margin-top: 8px;
  }
</style>

<div
  class="pt-5 position-relative banner-3 banner-3{{ section.id }} {{ section.settings.className }}"
>
  <div class="">
    <div class="banner-inner-container">
      <div class="d-flex justify-content-between flex-wrap">
        <div class="lander-banner-details white-bg">
          <h2 class="heading-2 value-bold" style="color:#2D469E">{{ section.settings.title }}</h2>
          <div class="white-text value-sans py-2">
            <h3 class="mt-0 value-medium sub-text" style="color:#434448">{{ section.settings.subtext }}</h3>
          </div>

          <div class="banner3-points">
            <ul>
              {% for block in section.blocks %}
                <li class="banner3-point value-sans">{{ block.settings.text }}</li>
              {% endfor %}
            </ul>
          </div>

          <div class=" mt-3 banner-2-btn mb-4">
            <a
              {% if section.settings.dataTrack %}
                {% render 'ga4-events' %}
              {% endif %}
              {% if section.settings.scrollto != '' %}
                data-target="{{ section.settings.scrollto }}"
                data-top="{{ section.settings.top }}"
              {% endif -%}

              href="javascript:void(0);"

              class="btn w-100 btn-loader blue-btn value-sans checkout-banner-btn {% if section.settings.scrollto !='' %}click-scroll{% endif %} {% if section.settings.outOfStock %} bb-disable {% endif %}"
              style="background-color:#2D469E"
            >
              {{ section.settings.btnText -}}</a
            ><br>
            {% if section.settings.btn_subtext != "" %}
              <div class="btn-subtext">
                {{ section.settings.btn_subtext }}
              </div>
            {% endif %}
          </div>
          <div class="d-grid banner-2-reviews">
            <div class="">
              <img
                width="160"
                height="50"
                class="img-responsive h-auto"
                src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/Avatars.png?v=1700115459"
                alt="person"
              >
            </div>
            <div class="text-left ms-2">
              <div class="font-pier theme-text mt-0 stars-img-review">
                <span class="star-img">
