<style>
#body .header-2 .main-menu-right{
    width:55px;
}
.header_tag{
    position:absolute;
    top:50%;
    left:50%;
    transform:translateX(-50%) translateY(-50%);
    padding:8px 10px;
    line-height:1.2;
    border-radius:20px;
    font-size:12px;
    display:inline-block;
    background-color:#C8393C;
    color:#fff;
}
@media(max-width:768px){
    .header_tag{
    position:absolute;
    width:calc(100% + 30px);
    top:auto;
    bottom:-30px;
    left:-15px;
    text-align:center;
    transform:translateX(0%) translateY(0%);
    padding:8px 10px;
    line-height:1.2;
    border-radius:0px;
    font-size:12px;
}
 .mobile-menu-top-wrapper .mobile-menus-wrapper .no-submenu a  {
    background-color: tranparent !important;
    }
}
</style>
<div class="position-relative pf-header-wrapper top-sticky annoucment_bar_2 sticky">
  <header
    class="header-2  header  bg-header"
    style="position:relative;"
  >
    <div class="container" x-data>
      <div class="d-flex justify-content-between align-items-center py-1 position-relative">
        {% if section.settings.header_tag != blank %}
            <span class="header_tag">
                {{ section.settings.header_tag }}
            </span>
          {% endif %}
        <div class="menu-toggle desktop-hide">
          <span
            {% if section.settings.toggle_dataTrack %}
              data-tracked="true"
              data-page-url="{{ request.path }}"
              data-target-url=""
              data-index="{{ section.settings.toggle_index }}"
              data-funnel-stage="{{ section.settings.toggle_funnel_stage }}"
              data-module="{{ section.settings.toggle_dataModule }}"
              data-event-label="{{ section.settings.toggle_dataTitle }}"
              data-event-value="{{ section.settings.toggle_eventValue }}"
              data-item-id=""
              data-option-index=""
              data-item-name=""
            {% endif %}
            class="toggle-icon"
          >
          </span>
        </div>

        <div class="logo-wrapper">
          <a
            href="{% if template.name == 'index' %}javascript:void(0);{% else %}{{ routes.root_url }}{% endif %}"
            class="header__heading-link link link--text d-block focus-inset"
          >
            <img
              class="w-100 d-block"
              src="https://cdn.shopify.com/s/files/1/0360/1347/3931/files/pf-new-logo.svg?v=1722508905"
              alt="logo"
            >
          </a>
        </div>
        <div class="main-menu-left mobile-hide ">
          
          <ul class="list-unstyle d-flex  justify-content-end align-items-center">
            {%- for link in section.settings.menu2.links -%}
              <li>
                <a
                  {% if section.settings.dataTrack %}
                    data-tracked="true"
                    data-page-url="{{ request.path }}"
                    data-target-url="{{link.url}}"
                    data-index="{{ section.settings.index }}"
                    data-funnel-stage="{{ section.settings.funnel_stage }}"
                    data-module="{{ section.settings.dataModule }}"
                    data-event-label="{{ link.title | escape}}"
                    data-event-value="{{ section.settings.eventValue }}"
                    data-item-id=""
                    data-option-index=""
                    data-item-name=""
                  {% endif %}
                  href="{{link.url}}"
                  class="menu-item menu_{{ link.title| handle }}"
                >
                  {% if template.suffix == 'pf513' and link.title == "Member Zone"  %}
                    Members Offers
                  {% else %}
                  {{- link.title | escape -}}
                  {% endif %}
                </a>
              </li>
            {% endfor %}
            {% if template.name != 'product'
              and template.name != 'collection'
              and template.name != 'list-collections'
            %}
              <li style="margin-left:20px;">
                <a
                  
                    href="{% if section.settings.top_product_link %} {{ section.settings.top_product_link }} {% else %} javascript:void(0) {% endif %}"
             
                  class="menu-item starter-kit-btn {% if section.settings.top_product_link == blank %}click-scroll{% endif %}"
                  {% if section.settings.dataTrack %}
                    data-tracked="true"
                    data-page-url="{{ request.path }}"
                    data-target-url="shop_anchor"
                    data-index="{{ section.settings.index }}"
                    data-funnel-stage="{{ section.settings.funnel_stage }}"
                    data-module="{{ section.settings.dataModule }}"
                    data-event-label="get_started"
                    data-event-value="shop_anchor"
                    data-item-id=""
                    data-option-index=""
                    data-item-name=""
                  {% endif %}
                  data-target="{{ section.settings.ctaScrollTo }}"
                >
                  {% if template.suffix == 'pf513' %}
                    Join Us
                  {% else %}
                  {{- section.settings.ctaText }}
                  {% endif %}
                  <span class="btn-arrow_" style="font-size:16px;">
                  <i class="fa-regular fa-arrow-right"></i>
                </span>
                </a>
              </li>
            {% endif %}
          </ul>
        </div>
        {% if section.settings['cart-login'] %}
          <div class="main-menu-right mobile-hide" x-data>
            {% assign globalloginicon = '<i class="fa-solid fa-user"></i>' %}
            {% assign globalcarticon = '<i class="fa-solid fa-cart-shopping"></i>' %}

            {% if settings.global_login_icon != blank %}
              {% assign globalloginicon = settings.global_login_icon %}
            {% endif %}
            {% if settings.global_cart_icon  != blank %}
                {% assign globalcarticon = settings.global_cart_icon  %}
            {% endif %}

            <ul class="list-unstyle d-flex justify-content-end">
              {% if section.settings.login %}
                <li>
                  {% if customer %}
                    <a href="/a/account/subscriptions" class="menu-item header-icon">
                      {{globalloginicon}}
                    </a>
                  {% else %}
                    <a href="/a/account/login" class="menu-item header-icon" id="customer_login_link">
                      {{globalloginicon}}
                    </a>
                  {% endif %}
                </li>
              {% endif %}
              {% if section.settings.cart %}
                <li @click="$dispatch('toggle-cart')">
                  <a class="menu-item cart-toggle position-relative header-icon">
                    {{globalcarticon }}
                    <span class="cart-item-count">
                      {%- if cart.item_count > 0 %}
                        {{ cart.item_count -}}
                      {%- endif -%}
                    </span></a
                  >
                </li>
              {% endif %}
            </ul>
          </div>
        {% endif %}

        <div class="cart-toggle desktop-hide" @click="$dispatch('toggle-cart')">
          {% if section.settings.cart %}
            <span class="cart-icon position-relative">
              {{globalcarticon }}
              <span class="cart-item-count">
                {%- if cart.item_count > 0 %}{{ cart.item_count }}{% endif -%}
              </span>
            </span>
          {% endif %}
        </div>
      </div>

      {% render 'mobile-menu-399' %}
    </div>
  </header>
</div>

{% schema %}
