    },
    {
      "id": "toggle_dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "toggle_dataTitle",
      "label": "Event Label",
      "type": "text",
      "default": "get_your_offer"
    },
    {
      "id": "toggle_eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    },
    {
      "type": "header",
      "content": "Menu GA4"
    },
    {
      "id": "dataTrack",
      "label": "Data Track",
      "type": "checkbox"
    },

    {
      "id": "index",
      "label": "Index",
      "type": "number",
      "default": 0
    },
    {
      "id": "funnel_stage",
      "label": "Funnel Stage",
      "type": "text",
      "default": "hp"
    },
    {
      "id": "dataModule",
      "label": "Module",
      "type": "text",
      "default": "announcement_bar"
    },
    {
      "id": "eventValue",
      "label": "Event Value",
      "type": "text",
      "default": "shop_anchor"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Starter Kit Menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag"
        },
        {
          "type": "color",
          "id": "tagColor",
          "label": "Tag Background"
        },
        {
          "type": "url",
          "id": "menulink",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "menuImage",
          "label": "Choose Image"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Header 399"
    }
  ]
