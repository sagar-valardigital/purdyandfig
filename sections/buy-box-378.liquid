                    <div class="main-product-img">
                      <video
                        class=" w-100 lazy"
                        poster="{{ block.settings.poster | image_url: width: 100 }}"
                        width="48"
                        height="48"
                        controls
                      >
                        <source src="{{ block.settings.videoURL }}" type="video/mp4">
                      </video>
                    </div>
                  {% else %}
                    <div class="main-product-img">
                      <picture class="position-relative">
                        <source media="(min-width:650px)" srcset="{{ image | image_url: width: 100 }}">
                        <source media="(max-width:650px)" srcset="{{ image | image_url: width: 100 }}">
                        <img
                          {% comment %}
                            {% if forloop.index == 1 %}
                              skip-lazy
                            {% else %}
                              loading="lazy"
                            {% endif %}
                          {% endcomment %}
                          data-id="{{image.id}}"
                          class="img-responsive w-100 h-auto lazy"
                          src="{{ image | image_url: width: 100 }}"
                          width="48"
                          height="48"
                          alt="{{ image.alt }}"
                        >
                        <div class="imglay"></div>
                      </picture>
                    </div>
                  {% endif %}
                {% endif %}
                {% assign mediacount = mediacount | plus: '1' %}
              {% endfor %}
            </div>
          </div>
