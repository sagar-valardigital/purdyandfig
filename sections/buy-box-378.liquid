<div
  class="{{ section.settings.className }} multi-step-product-section gp--product-wrapper py-80"
  id="id_{{ section.id }}"
  style="background-color:{{section.settings.background}};"
  x-data="{qty:1}"
>
  <div class="position-relative">
    <div
      class=" mb-4 container heading-2-wrapper {% if section.settings.before-mobile %}resetpadding{% endif %}"
      {% if section.settings['before-mobile'] %}
        style="display: block !important;"
      {% endif %}
    >
      {% if section.settings.sectionheading != '' %}
        <h2 style="color: #212121;" class="heading-2 font-gtsuper fw-400 mt-0 text-center {% if section.settings.before-mobile %}headingpadding{% endif %}">
          {{ section.settings.sectionheading }}
        </h2>
      {% endif %}
    </div>

    <div class="d-flex product-block-4-wrapper flex-wrap justify-content-between align-items-start container">
      <div class="w-50 gp--product-gallery" id="{{ section.settings.scrollId }}">
        <div class="position-relative step step-1 step-gallery">
          {% assign mediacount = 0 %}
          <div class="gp-19-gallery-block link-to-variant variant_1 show position-relative">
            <div class="product-gallery-341-1 new-product-gallery-wrapper">
              {% for block in section.blocks %}
                {% if block.type == 'productImage' %}
                  {% assign image = block.settings.image %}
                  {% assign mimage = block.settings.mimage %}
                  {% if block.settings.is_video %}
                    <div class="main-product-img">
                      <video
                        class=" w-100 lazy"
                        poster="{{ block.settings.poster | image_url: width: 800 }}"
                        width="520"
                        height="520"
                        controls
                      >
                        <source src="{{ block.settings.videoURL }}" type="video/mp4">
                      </video>
                    </div>
                  {% else %}
                    <div class="main-product-img ">
                      <picture>
                        <source media="(min-width:650px)" srcset="{{ image | image_url: width: 800 }}">
                        <source media="(max-width:650px)" srcset="{{ mimage | image_url: width: 800 }}">
                        <img
                          {% comment %}
                            {% if forloop.index == 1 %}
                              skip-lazy
                            {% else %}
                              loading="lazy"
                            {% endif %}
                          {% endcomment %}
                          data-id="{{image.id}}"
                          class="img-responsive w-100 h-auto lazy"
                          src="{{ image | image_url: width: 800 }}"
                          width="800"
                          height="700"
                          alt="{{ image.alt }}"
                        >
                      </picture>
                    </div>
                  {% endif %}
                {% endif %}
                {% assign mediacount = mediacount | plus: '1' %}
              {% endfor %}
            </div>
            <div class="product-gallery-thumb-341-1  new-product-gallery-wrapper-thumb">
              {% for block in section.blocks %}
                {% if block.type == 'productImage' %}
                  {% assign image = block.settings.image %}
                  {% assign mimage = block.settings.mimage %}
