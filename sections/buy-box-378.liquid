<style>
  .link-to-variant,.link-to-plan {
      height: 0;
      overflow: hidden;
      position: relative;
  }
  .link-to-variant.show,.link-to-plan.show {
      display: block !important;
      height: auto;
      margin-top: 4px;
      margin-bottom: 4px;
      overflow: visible;
  }
  .scent-tag{
      position:absolute;
      border:1px solid #eee;
      font-weight:400;
      font-size:12px;
      border-radius:4px;
      padding:2px 6px;
      line-height:1.2;
      right:10px;
      top:-10px;
      border-color:#708480;
      background-color:#708480;
      color:#fff;
  }
  .new-product-gallery-wrapper-thumb {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    max-width: 288px;
    width:100%;
  }
  .new-product-gallery-wrapper-thumb .main-product-img img {
    border-radius:4px;
    border:2px solid transparent;
  }
  .new-product-gallery-wrapper-thumb .main-product-img.slick-current img {
    border:2px solid #0F2D28;
  }
  .sub-price-block span {
    margin-right: 4px;
  }
  .checkout-starterkit-btn {
    gap: 4px;
  }
  .ammend-weight del {
    font-weight: 400 !important;
    color: #9E9E9E;
  }
  .sent-heading {
	  font-size: 16px;
  }
  .bestvaluelabel {
    display: flex;
    justify-content: space-between;
  }
  span.inrlabel, span.lpo {
    margin: 4px 0 5px 0px;
    font-size: 16px;
  }
  span.tagtop {
    display: flex;
    gap: 8px;
    height: 24px;
    justify-content: center;
    align-items: center;
    margin: 4px 0 5px 0px;
  }
  .bestvaluestag {
    background: #FBE27C;
    font-size: 12px;
    padding: 6px 4px;
    border-radius: 24px;
    letter-spacing: 0.4px;
    color: #000000 !important;
  }
  .label-bestValue {
    display: flex;
    gap: 10px;
    height: 24px;
    justify-content: center;
    align-items: center;
  }
  .label-bestValue span {
    padding: 8px;
    font-weight: 400;
    letter-spacing: 0.18px;
  }
  .nspadding {
    padding-top: 10px;
  }
  .bspadding:before {
    top: 45px !important;
  }
  #body .multi-step-product-section .resetpadding h2.heading-2 {
    color: #212121 !important;
  }
  .scent-tag {
    font-size: 11px;
  }
  .scent-header .sent-heading, .scent-header .scent-price {
    color: #11322C;
  }
  .impteller {
    color: #11322C;
  }
  .new-product-gallery-wrapper-thumb .main-product-img.slick-current .imglay {
    background-color: #00000040;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 8px;
    pointer-events: none;
  }
  .new-product-gallery-wrapper .slick-slide {
    height: 610px;
  }
  .new-product-gallery-wrapper .slick-slide img {
    width: 100%;
    height: 100% !important;
    max-height: 610px;
    object-fit: cover;
    object-position: center center;
  }
  .new-product-gallery-wrapper-thumb .slick-track {
    display: flex;
    justify-content: center;
    gap: 10px;
  }
  .new-product-gallery-wrapper-thumb .main-product-img {
    width: 48px !important;
  }

  .new-product-gallery-wrapper-thumb .slick-track {
    transform: none !important;
  }

  @media (min-width: 1040px) and (max-width: 1220px) {
    .new-product-gallery-wrapper .slick-slide {
      height: 517px;
    }
    .new-product-gallery-wrapper .slick-slide img {
      height: 100% !important;
      max-height: 517px;
    }
  }

  @media (min-width: 960px) and (max-width: 1040px) {
    .new-product-gallery-wrapper .slick-slide {
      height: 480px;
    }
    .new-product-gallery-wrapper .slick-slide img {
      height: 100% !important;
      max-height: 480px;
    }
  }

  @media (min-width: 865px) and (max-width: 960px) {
    .new-product-gallery-wrapper .slick-slide {
      height: 430px;
    }
    .new-product-gallery-wrapper .slick-slide img {
